# Supabase
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # Required for cron/expire-subscriptions

# LemonSqueezy — Payments & Checkout
# Per-plan checkout URLs (Settings → Store → Products → Share)
LEMONSQUEEZY_BASIC_URL=https://your-store.lemonsqueezy.com/checkout/buy/BASIC_VARIANT_ID
LEMONSQUEEZY_PRO_URL=https://your-store.lemonsqueezy.com/checkout/buy/PRO_VARIANT_ID
LEMONSQUEEZY_ELITE_URL=https://your-store.lemonsqueezy.com/checkout/buy/ELITE_VARIANT_ID

# Webhook signing secret (Settings → Webhooks → Signing Secret)
LEMONSQUEEZY_SECRET=your-webhook-signing-secret

# Customer Portal (Settings → API Keys)
LEMONSQUEEZY_API_KEY=your-api-key-here
LEMONSQUEEZY_STORE_ID=12345                           # numeric ID from Settings → Stores
LEMONSQUEEZY_STORE_SLUG=your-store-slug               # subdomain: your-store.lemonsqueezy.com

# Legacy — kept for backwards compatibility during migration
LEMON_SQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/...

# Web Push / VAPID (generate with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(JSON.stringify(k))")
PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_EMAIL=mailto:your@email.com

# Cron security
CRON_SECRET=your-cron-secret-here

# Resend Email Automation
RESEND_API_KEY=re_your_key_here
# From address — use onboarding@resend.dev for testing, or your verified domain for production
EMAIL_FROM=Keto Journey <onboarding@resend.dev>
# Your app's public URL (used in email links)
PUBLIC_APP_URL=https://your-app.vercel.app