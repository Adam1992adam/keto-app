# Supabase
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # Required for cron/expire-subscriptions

# Lemon Squeezy
LEMON_SQUEEZY_CHECKOUT_URL=https://new-keto-plan.lemonsqueezy.com/checkout/buy/...

# Web Push / VAPID (generate with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(JSON.stringify(k))")
PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_EMAIL=mailto:your@email.com

# Cron security
CRON_SECRET=your-cron-secret-here