---
// signup.astro
import CookieConsent from '../components/CookieConsent.astro';
const emailParam = Astro.url.searchParams.get('email');
const allowedEmail = emailParam ? emailParam.toLowerCase().trim() : '';
const SITE_URL = (import.meta.env.PUBLIC_APP_URL || 'https://ketojourney.fun').replace(/\/$/, '');
const CHECKOUT_BASIC = import.meta.env.LEMONSQUEEZY_BASIC_URL || '';
const CHECKOUT_PRO   = import.meta.env.LEMONSQUEEZY_PRO_URL   || '';
const CHECKOUT_ELITE = import.meta.env.LEMONSQUEEZY_ELITE_URL || '';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Create Account — Keto Journey</title>
  <meta name="robots" content="noindex, nofollow"/>
  <link rel="canonical" href={SITE_URL + '/signup'}/>
  <meta property="og:type"        content="website"/>
  <meta property="og:url"         content={SITE_URL + '/signup'}/>
  <meta property="og:site_name"   content="KetoJourney"/>
  <meta property="og:title"       content="Start Your Keto Journey Today"/>
  <meta property="og:description" content="Create your KetoJourney account and begin your personalized 30, 90, or 360-day keto transformation."/>
  <meta property="og:image"       content={SITE_URL + '/og-image.png'}/>
  <meta name="twitter:card"       content="summary_large_image"/>
  <meta name="twitter:title"      content="Start Your Keto Journey Today"/>
  <meta name="twitter:image"      content={SITE_URL + '/og-image.png'}/>
  <link rel="icon" type="image/png" sizes="32x32" href="/icon-72.png"/>
  <link rel="manifest" href="/manifest.webmanifest"/>
  <meta name="theme-color" content="#10b981"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,900;1,9..144,700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --dark:#07100a; --dark2:#0d1810; --card:#111d13;
      --border:rgba(16,185,129,.13); --border2:rgba(16,185,129,.28);
      --text:#e4efe4; --soft:#5a7a5a; --muted:#2a3e2a;
      --green:#10b981; --green2:#34d399; --red:#ef4444;
      --gold:#f59e0b; --blue:#3b82f6; --indigo:#6366f1;
    }
    *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
    html,body { height:100%; }
    body {
      font-family:'DM Sans',sans-serif;
      background:var(--dark); color:var(--text);
      display:grid; grid-template-columns:1fr 1fr;
      min-height:100vh;
    }

    /* ── LEFT PANEL ── */
    .panel-img { position:relative; overflow:hidden; }
    .panel-img-bg {
      position:absolute; inset:0;
      background:url('https://images.unsplash.com/photo-1490645935967-10de6ba17061?w=1200&q=85') center/cover no-repeat;
      transition:transform 10s ease;
    }
    .panel-img:hover .panel-img-bg { transform:scale(1.04); }
    .panel-img-overlay {
      position:absolute; inset:0;
      background:linear-gradient(160deg,rgba(7,16,10,.92) 0%,rgba(7,16,10,.45) 50%,rgba(16,185,129,.08) 100%);
    }
    .panel-content {
      position:relative; z-index:1; height:100%;
      display:flex; flex-direction:column; justify-content:space-between;
      padding:2.75rem;
    }
    .panel-logo {
      display:flex; align-items:center; gap:.55rem;
      font-family:'Fraunces',serif; font-weight:700; font-size:1.1rem;
      color:#fff; text-decoration:none;
    }
    .panel-logo span { color:var(--green); }

    .panel-eyebrow {
      display:inline-flex; align-items:center; gap:.4rem;
      background:rgba(16,185,129,.15); border:1px solid rgba(16,185,129,.32);
      border-radius:99px; padding:.3rem .9rem;
      font-size:.68rem; font-weight:800; color:var(--green);
      text-transform:uppercase; letter-spacing:.1em; margin-bottom:1rem;
    }
    .panel-title {
      font-family:'Fraunces',serif; font-size:2.65rem; font-weight:900;
      line-height:1.07; color:#fff; margin-bottom:1.4rem;
    }
    .panel-title em { font-style:italic; color:var(--green2); }

    /* ── STATS ROW ── */
    .panel-stats {
      display:flex; align-items:stretch; gap:0;
      background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1);
      border-radius:16px; backdrop-filter:blur(12px); overflow:hidden;
      margin-bottom:1.4rem;
    }
    .stat-item { flex:1; text-align:center; padding:.9rem .5rem; }
    .stat-num {
      font-family:'Fraunces',serif; font-size:1.35rem; font-weight:900;
      color:#fff; line-height:1;
    }
    .stat-label {
      font-size:.62rem; color:rgba(255,255,255,.45);
      text-transform:uppercase; letter-spacing:.07em; margin-top:.2rem;
    }
    .stat-sep { width:1px; background:rgba(255,255,255,.1); align-self:stretch; }

    /* ── PERKS ── */
    .panel-perks { display:flex; flex-direction:column; gap:.6rem; }
    .perk {
      display:flex; align-items:center; gap:.8rem;
      background:rgba(255,255,255,.06); backdrop-filter:blur(14px);
      border:1px solid rgba(255,255,255,.09); border-radius:13px;
      padding:.8rem 1rem; transition:border-color .2s;
    }
    .perk:hover { border-color:rgba(16,185,129,.25); }
    .perk-icon {
      width:34px; height:34px; border-radius:9px; flex-shrink:0;
      display:flex; align-items:center; justify-content:center; font-size:.95rem;
    }
    .perk-text { font-size:.8rem; font-weight:700; color:rgba(255,255,255,.88); }
    .perk-sub  { font-size:.67rem; color:rgba(255,255,255,.4); margin-top:.08rem; }

    /* ── TESTIMONIAL ── */
    .panel-testimonial {
      background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1);
      border-radius:16px; padding:1.1rem 1.25rem; backdrop-filter:blur(12px);
    }
    .testimonial-quote {
      font-size:.8rem; color:rgba(255,255,255,.78); line-height:1.65;
      margin-bottom:.8rem; font-style:italic;
    }
    .testimonial-quote::before { content:'"'; font-size:1.1rem; color:var(--green); margin-right:.1rem; }
    .testimonial-quote::after  { content:'"'; font-size:1.1rem; color:var(--green); margin-left:.1rem; }
    .testimonial-meta { display:flex; align-items:center; gap:.65rem; }
    .testimonial-avatar {
      width:32px; height:32px; border-radius:50%; flex-shrink:0;
      background:linear-gradient(135deg,#10b981,#059669);
      display:flex; align-items:center; justify-content:center;
      font-size:.7rem; font-weight:800; color:#fff;
    }
    .testimonial-name { font-size:.78rem; font-weight:700; color:rgba(255,255,255,.85); }
    .testimonial-plan { font-size:.62rem; color:rgba(255,255,255,.38); margin-top:.05rem; }
    .testimonial-stars { margin-left:auto; color:var(--gold); font-size:.8rem; letter-spacing:.05em; }

    /* ── RIGHT PANEL ── */
    .panel-form {
      display:flex; flex-direction:column;
      padding:3rem 3.5rem; background:var(--dark2); overflow-y:auto;
    }
    .form-inner { margin:auto 0; width:100%; }
    .form-top { margin-bottom:1.75rem; animation:fadeUp .5s ease both; }
    .form-back {
      display:inline-flex; align-items:center; gap:.4rem;
      font-size:.73rem; font-weight:700; color:var(--soft);
      text-decoration:none; margin-bottom:1.4rem; transition:color .2s;
    }
    .form-back:hover { color:var(--text); }
    .form-tag {
      display:inline-flex; align-items:center; gap:.4rem;
      background:rgba(16,185,129,.08); border:1px solid var(--border);
      border-radius:99px; padding:.28rem .8rem;
      font-size:.67rem; font-weight:800; color:var(--green);
      text-transform:uppercase; letter-spacing:.08em; margin-bottom:.85rem;
    }
    .form-title {
      font-family:'Fraunces',serif; font-size:2rem; font-weight:900;
      line-height:1.1; margin-bottom:.4rem;
    }
    .form-title em {
      font-style:italic;
      background:linear-gradient(135deg,var(--green),var(--green2));
      -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    }
    .form-sub { font-size:.8rem; color:var(--soft); }

    /* ── STEP INDICATOR ── */
    .steps {
      display:flex; align-items:center; gap:.5rem; margin-bottom:2rem;
      animation:fadeUp .4s .05s ease both;
    }
    .step-dot {
      width:30px; height:30px; border-radius:50%; flex-shrink:0;
      display:flex; align-items:center; justify-content:center;
      font-size:.7rem; font-weight:800;
      border:2px solid var(--border); color:var(--muted);
      transition:all .3s;
    }
    .step-dot.active { background:var(--green); border-color:var(--green); color:#fff; box-shadow:0 0 0 4px rgba(16,185,129,.18); }
    .step-dot.done   { background:rgba(16,185,129,.15); border-color:var(--green); color:var(--green); }
    .step-line { flex:1; height:2px; background:var(--border); border-radius:2px; transition:all .3s; }
    .step-line.done { background:var(--green); }
    .step-label { font-size:.65rem; color:var(--soft); white-space:nowrap; }

    /* ── STEP PANELS ── */
    .step-panel { display:none; }
    .step-panel.active { display:block; animation:fadeUp .35s ease both; }

    /* ── FIELDS ── */
    .field { margin-bottom:1.1rem; }
    .field-label {
      display:block; font-size:.73rem; font-weight:800;
      color:var(--soft); text-transform:uppercase; letter-spacing:.07em;
      margin-bottom:.45rem;
    }
    .field-wrap { position:relative; }
    .field-icon {
      position:absolute; left:.95rem; top:50%; transform:translateY(-50%);
      font-size:.85rem; pointer-events:none;
    }
    .field-input {
      width:100%; padding:.825rem 1rem .825rem 2.5rem;
      background:var(--card); border:1.5px solid var(--border);
      border-radius:12px; color:var(--text);
      font-family:'DM Sans',sans-serif; font-size:.875rem; font-weight:500;
      transition:all .22s; outline:none;
    }
    .field-input::placeholder { color:var(--muted); }
    .field-input:focus {
      border-color:var(--green); background:rgba(16,185,129,.04);
      box-shadow:0 0 0 4px rgba(16,185,129,.1);
    }
    .field-input.error   { border-color:var(--red); box-shadow:0 0 0 3px rgba(239,68,68,.1); }
    .field-input.success { border-color:var(--green); }
    .field-msg {
      font-size:.72rem; margin-top:.4rem;
      display:flex; align-items:center; gap:.35rem;
    }
    .field-msg.error   { color:#fca5a5; }
    .field-msg.success { color:var(--green2); }
    .field-pw-toggle {
      position:absolute; right:.875rem; top:50%; transform:translateY(-50%);
      background:none; border:none; cursor:pointer;
      color:var(--soft); font-size:.9rem; transition:color .2s; padding:.25rem;
    }
    .field-pw-toggle:hover { color:var(--text); }

    /* ── PASSWORD STRENGTH ── */
    .pw-strength { margin-top:.6rem; }
    .pw-bars { display:flex; gap:.3rem; margin-bottom:.3rem; }
    .pw-bar {
      flex:1; height:4px; border-radius:2px;
      background:var(--muted); transition:background .3s;
    }
    .pw-bar.w { background:var(--red); }
    .pw-bar.m { background:var(--gold); }
    .pw-bar.s { background:var(--green); }
    .pw-label { font-size:.68rem; color:var(--soft); }

    /* ── PLAN BADGE (step 2 confirmed) ── */
    .plan-box {
      background:linear-gradient(135deg,rgba(16,185,129,.08),rgba(52,211,153,.03));
      border:1.5px solid var(--border2); border-radius:16px;
      padding:1.1rem 1.4rem; margin-bottom:1.5rem;
      display:flex; align-items:center; gap:.875rem;
    }
    .pb-emoji { font-size:2rem; flex-shrink:0; }
    .pb-title { font-weight:800; font-size:.9rem; margin-bottom:.12rem; }
    .pb-meta  { font-size:.72rem; color:var(--soft); }
    .pb-badge {
      margin-left:auto; padding:.25rem .8rem; border-radius:99px;
      background:rgba(16,185,129,.12); border:1px solid var(--border2);
      font-size:.65rem; font-weight:800; color:var(--green); flex-shrink:0;
      display:flex; align-items:center; gap:.3rem;
    }

    /* ── LOADING ── */
    .loading-state { text-align:center; padding:2.5rem 1rem; }
    .spinner-lg {
      width:48px; height:48px; border-radius:50%;
      border:3px solid var(--border); border-top-color:var(--green);
      animation:spin .8s linear infinite; margin:0 auto 1.25rem;
    }
    .loading-title { font-family:'Fraunces',serif; font-size:1.15rem; font-weight:700; margin-bottom:.4rem; }
    .loading-sub   { font-size:.8rem; color:var(--soft); }
    @keyframes spin { to{transform:rotate(360deg);} }

    /* ── NO PURCHASE HEADER ── */
    .np-header { text-align:center; margin-bottom:1.35rem; }
    .np-stars {
      display:inline-flex; align-items:center; gap:.5rem;
      margin-bottom:.75rem;
    }
    .np-stars-text { color:var(--gold); font-size:.85rem; letter-spacing:.05em; }
    .np-stars-count {
      font-size:.72rem; color:var(--soft); font-weight:600;
      padding:.2rem .7rem; border-radius:99px;
      background:rgba(245,158,11,.08); border:1px solid rgba(245,158,11,.18);
    }
    .np-title {
      font-family:'Fraunces',serif; font-size:1.45rem; font-weight:900;
      margin-bottom:.4rem; line-height:1.1;
    }
    .np-sub { font-size:.77rem; color:var(--soft); line-height:1.6; max-width:330px; margin:0 auto; }

    /* ── PLAN PICKER (cards injected by JS) ── */
    .plan-picker { display:flex; flex-direction:column; gap:.85rem; margin-bottom:.5rem; }

    /* ── TRUST ROW ── */
    .np-trust {
      display:flex; align-items:center; justify-content:center;
      flex-wrap:wrap; gap:.5rem; margin:.9rem 0 1rem;
      font-size:.7rem; color:var(--soft);
    }
    .np-trust-item { display:flex; align-items:center; gap:.3rem; }
    .trust-sep { color:var(--muted); }

    /* ── STEP 1 TRUST ── */
    .s1-trust {
      display:flex; align-items:center; justify-content:center;
      gap:.6rem; flex-wrap:wrap; margin:.875rem 0 1.25rem;
      font-size:.7rem; color:var(--soft);
    }
    .s1-trust-dot { color:var(--muted); }

    /* ── EMPTY / ALREADY REGISTERED ── */
    .empty-state {
      text-align:center; padding:1.75rem;
      background:rgba(239,68,68,.05); border:1px solid rgba(239,68,68,.15);
      border-radius:16px; margin-bottom:1.25rem;
    }
    .empty-icon  { font-size:2.2rem; margin-bottom:.75rem; }
    .empty-title { font-family:'Fraunces',serif; font-size:1.1rem; font-weight:700; color:#fca5a5; margin-bottom:.4rem; }
    .empty-sub   { font-size:.8rem; color:var(--soft); line-height:1.6; margin-bottom:1.1rem; }

    /* ── SUCCESS ── */
    .success-state { text-align:center; padding:2rem 1rem; }
    .success-icon  { font-size:3.5rem; margin-bottom:.875rem; }
    .success-title { font-family:'Fraunces',serif; font-size:1.55rem; font-weight:900; color:var(--green); margin-bottom:.5rem; }
    .success-sub   { font-size:.85rem; color:var(--soft); line-height:1.6; margin-bottom:1.5rem; }
    .progress-bar { height:4px; background:var(--muted); border-radius:2px; overflow:hidden; }
    .progress-fill {
      height:100%; background:linear-gradient(90deg,var(--green),var(--green2));
      border-radius:2px; animation:progressGrow 2.2s ease forwards;
    }
    @keyframes progressGrow { from{width:0%;}to{width:100%;} }

    /* ── BUTTONS ── */
    .btn-submit {
      width:100%; padding:.95rem;
      background:linear-gradient(135deg,var(--green),var(--green2));
      border:none; border-radius:12px; color:#fff;
      font-family:'DM Sans',sans-serif; font-weight:800; font-size:.9rem;
      cursor:pointer; transition:all .25s;
      display:flex; align-items:center; justify-content:center; gap:.5rem;
      position:relative; overflow:hidden;
    }
    .btn-submit::before {
      content:''; position:absolute; inset:0;
      background:linear-gradient(90deg,transparent,rgba(255,255,255,.12),transparent);
      transform:translateX(-100%); transition:transform .5s;
    }
    .btn-submit:hover::before { transform:translateX(100%); }
    .btn-submit:hover { transform:translateY(-2px); box-shadow:0 10px 28px rgba(16,185,129,.38); }
    .btn-submit:disabled { opacity:.5; cursor:not-allowed; transform:none; }
    .btn-outline {
      width:100%; padding:.85rem;
      background:transparent; border:1.5px solid var(--border);
      border-radius:12px; color:var(--soft);
      font-family:'DM Sans',sans-serif; font-weight:700; font-size:.85rem;
      cursor:pointer; transition:all .22s; margin-top:.6rem;
    }
    .btn-outline:hover { border-color:var(--green); color:var(--green); }
    .btn-purchase {
      display:block; padding:.875rem;
      background:linear-gradient(135deg,#6366f1,#8b5cf6);
      border-radius:12px; color:#fff; text-align:center;
      font-weight:800; font-size:.875rem; text-decoration:none;
      box-shadow:0 4px 16px rgba(99,102,241,.3); transition:all .22s;
    }
    .btn-purchase:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(99,102,241,.4); }

    /* ── INLINE SPINNER ── */
    .btn-spin {
      display:none; width:16px; height:16px; border-radius:50%;
      border:2px solid rgba(255,255,255,.3); border-top-color:#fff;
      animation:spin .7s linear infinite;
    }

    /* ── DIVIDER ── */
    .divider { display:flex; align-items:center; gap:.875rem; margin:1.1rem 0 .9rem; }
    .div-line { flex:1; height:1px; background:var(--border); }
    .div-text { font-size:.68rem; font-weight:700; color:var(--muted); white-space:nowrap; }

    /* ── LOGIN LINK ── */
    .login-prompt { text-align:center; font-size:.8rem; color:var(--soft); }
    .login-prompt a { color:var(--green); font-weight:800; text-decoration:none; }
    .login-prompt a:hover { text-decoration:underline; }

    @keyframes fadeUp { from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);} }

    @media(max-width:900px) {
      body { grid-template-columns:1fr; }
      .panel-img { display:none; }
      .panel-form { padding:2.5rem 1.75rem; }
    }
  </style>
</head>
<body>

<!-- ══════════════════════════════════════════════
     LEFT PANEL
══════════════════════════════════════════════ -->
<div class="panel-img">
  <div class="panel-img-bg"></div>
  <div class="panel-img-overlay"></div>
  <div class="panel-content">

    <a href="/" class="panel-logo">🥑 Keto<span>Journey</span></a>

    <div class="panel-middle">
      <div class="panel-eyebrow">🚀 Start today</div>
      <h2 class="panel-title">Your body<br/>can do <em>more</em><br/>than you think</h2>

      <!-- Stats row -->
      <div class="panel-stats">
        <div class="stat-item">
          <div class="stat-num">2,400+</div>
          <div class="stat-label">Members</div>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
          <div class="stat-num">4.9 ★</div>
          <div class="stat-label">Rating</div>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
          <div class="stat-num">87+</div>
          <div class="stat-label">Recipes</div>
        </div>
      </div>

      <!-- Perks -->
      <div class="panel-perks">
        {[
          { icon:'📅', g:'linear-gradient(135deg,#10b981,#059669)', g2:'rgba(16,185,129,.22)', title:'30-day structured plan', sub:'Every meal planned for you' },
          { icon:'🍽️', g:'linear-gradient(135deg,#f59e0b,#d97706)', g2:'rgba(245,158,11,.22)', title:'87 delicious keto recipes', sub:'All under 20g net carbs' },
          { icon:'🛡️', g:'linear-gradient(135deg,#3b82f6,#2563eb)', g2:'rgba(59,130,246,.22)', title:'30-day money-back guarantee', sub:'Zero risk, full results' },
        ].map(p => (
          <div class="perk">
            <div class="perk-icon" style={`background:${p.g};box-shadow:0 4px 10px ${p.g2};`}>{p.icon}</div>
            <div>
              <div class="perk-text">{p.title}</div>
              <div class="perk-sub">{p.sub}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Testimonial -->
    <div class="panel-testimonial">
      <div class="testimonial-quote">Lost 18 lbs in my first 30 days. The structured meal plans made keto genuinely easy to follow.</div>
      <div class="testimonial-meta">
        <div class="testimonial-avatar">SM</div>
        <div>
          <div class="testimonial-name">Sarah M.</div>
          <div class="testimonial-plan">Basic Plan · Verified Member</div>
        </div>
        <div class="testimonial-stars">★★★★★</div>
      </div>
    </div>

  </div>
</div>


<!-- ══════════════════════════════════════════════
     RIGHT PANEL
══════════════════════════════════════════════ -->
<div class="panel-form">
<div class="form-inner">

  <!-- Referral bonus banner -->
  <div id="refBanner" style="display:none;align-items:center;gap:.75rem;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:14px;padding:.875rem 1.1rem;margin-bottom:1.5rem;">
    <span style="font-size:1.25rem;">🎁</span>
    <div>
      <div style="font-weight:800;font-size:.85rem;color:#34d399;">You've been invited!</div>
      <div style="font-size:.78rem;color:#5a7a5a;margin-top:.1rem;">You'll receive a <strong style="color:#10b981;">+50 XP</strong> welcome bonus when you complete signup.</div>
    </div>
  </div>

  <div class="form-top">
    <a href="/login" class="form-back">← Back to login</a>
    <div class="form-tag">🎉 Create Account</div>
    <h1 class="form-title">Start your<br/><em>transformation</em></h1>
    <p class="form-sub">Verify your purchase, then set up your account</p>
  </div>

  <!-- STEP INDICATOR -->
  <div class="steps">
    <div class="step-dot active" id="stepDot1">1</div>
    <div class="step-line" id="stepLine1"></div>
    <div class="step-dot" id="stepDot2">2</div>
    <div class="step-line" id="stepLine2"></div>
    <div class="step-dot" id="stepDot3">3</div>
  </div>

  <!-- ──────────────────────────────────────
       STEP 1: VERIFY EMAIL
  ────────────────────────────────────── -->
  <div class="step-panel active" id="panel1">
    <div class="field">
      <label class="field-label">Purchase Email</label>
      <div class="field-wrap">
        <span class="field-icon">✉️</span>
        <input type="email" id="emailInput" class="field-input"
          placeholder="Email you used when purchasing"/>
      </div>
      <div class="field-msg error" id="emailError" style="display:none;">
        ⚠️ Please enter a valid email address
      </div>
    </div>

    <button type="button" class="btn-submit" id="verifyBtn">
      <div class="btn-spin" id="verifySpin"></div>
      <span id="verifyTxt">Verify Purchase →</span>
    </button>

    <!-- Trust signals -->
    <div class="s1-trust">
      <span class="s1-trust-item">🔒 Secure</span>
      <span class="s1-trust-dot">·</span>
      <span class="s1-trust-item">✓ 30-day guarantee</span>
      <span class="s1-trust-dot">·</span>
      <span class="s1-trust-item">⚡ Instant access</span>
    </div>

    <div class="divider">
      <div class="div-line"></div>
      <div class="div-text">Already have an account?</div>
      <div class="div-line"></div>
    </div>
    <div class="login-prompt"><a href="/login">Log in instead →</a></div>
  </div>

  <!-- ──────────────────────────────────────
       LOADING
  ────────────────────────────────────── -->
  <div class="step-panel" id="panelLoading">
    <div class="loading-state">
      <div class="spinner-lg"></div>
      <div class="loading-title">Verifying your purchase…</div>
      <div class="loading-sub">Checking your order — this takes just a second</div>
    </div>
  </div>

  <!-- ──────────────────────────────────────
       NO PURCHASE — PLAN PICKER
  ────────────────────────────────────── -->
  <div class="step-panel" id="panelNoPurchase">

    <div class="np-header">
      <div class="np-stars">
        <span class="np-stars-text">★★★★★</span>
        <span class="np-stars-count">Trusted by 2,400+ members</span>
      </div>
      <div class="np-title">Choose your plan</div>
      <p class="np-sub">Pick a plan below — you'll be brought back here after checkout to finish setup</p>
    </div>

    <!-- Cards injected by JS -->
    <div class="plan-picker" id="planPickerCards"></div>

    <!-- Trust row -->
    <div class="np-trust">
      <span class="np-trust-item">🔒 Secure checkout</span>
      <span class="trust-sep">·</span>
      <span class="np-trust-item">✓ 30-day guarantee</span>
      <span class="trust-sep">·</span>
      <span class="np-trust-item">⚡ Instant access</span>
    </div>

    <button type="button" class="btn-outline" onclick="resetToStep1()">← Try a different email</button>
  </div>

  <!-- ──────────────────────────────────────
       ALREADY REGISTERED
  ────────────────────────────────────── -->
  <div class="step-panel" id="panelAlready">
    <div class="empty-state" style="background:rgba(16,185,129,.06);border-color:rgba(16,185,129,.25);">
      <div class="empty-icon">✅</div>
      <div class="empty-title" style="color:#34d399;">Account already active</div>
      <div class="empty-sub" style="margin-bottom:.75rem;">This email already has a Keto Journey account.</div>
      <div class="empty-sub" style="background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.18);border-radius:10px;padding:.65rem .9rem;margin-bottom:1.25rem;font-size:.8rem;line-height:1.6;text-align:left;">
        If you just upgraded your plan — your account has already been updated and <strong style="color:#e4efe4;">all your data is safe</strong>. Log in to continue with your new plan.
      </div>
      <a href="/login" class="btn-purchase" style="background:linear-gradient(135deg,#10b981,#34d399);box-shadow:0 4px 16px rgba(16,185,129,.3);">Log In to Your Account →</a>
    </div>
    <button type="button" class="btn-outline" onclick="resetToStep1()">← Try a different email</button>
  </div>

  <!-- ──────────────────────────────────────
       STEP 2: CREATE ACCOUNT
  ────────────────────────────────────── -->
  <div class="step-panel" id="panel2">
    <div class="plan-box" id="planBox">
      <div class="pb-emoji" id="planEmoji">🥑</div>
      <div>
        <div class="pb-title" id="planTitle">Loading plan…</div>
        <div class="pb-meta"  id="planMeta">Verifying…</div>
      </div>
      <div class="pb-badge">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
        Verified
      </div>
    </div>

    <div class="field">
      <label class="field-label">Full Name</label>
      <div class="field-wrap">
        <span class="field-icon">👤</span>
        <input type="text" id="fullName" class="field-input" placeholder="Enter your full name"/>
      </div>
      <div class="field-msg error" id="nameError" style="display:none;">⚠️ Please enter your name</div>
    </div>

    <div class="field">
      <label class="field-label">Password</label>
      <div class="field-wrap">
        <span class="field-icon">🔒</span>
        <input type="password" id="password" class="field-input" placeholder="Choose a strong password"/>
        <button type="button" class="field-pw-toggle" id="pw1Toggle">👁️</button>
      </div>
      <div class="pw-strength" id="pwStrength">
        <div class="pw-bars">
          <div class="pw-bar" id="bar1"></div>
          <div class="pw-bar" id="bar2"></div>
          <div class="pw-bar" id="bar3"></div>
          <div class="pw-bar" id="bar4"></div>
        </div>
        <div class="pw-label" id="pwLabel">Enter a password</div>
      </div>
      <div class="field-msg error" id="passwordError" style="display:none;">⚠️ Password must be at least 6 characters</div>
    </div>

    <div class="field" style="margin-bottom:1.5rem;">
      <label class="field-label">Confirm Password</label>
      <div class="field-wrap">
        <span class="field-icon">🔒</span>
        <input type="password" id="confirmPassword" class="field-input" placeholder="Confirm your password"/>
        <button type="button" class="field-pw-toggle" id="pw2Toggle">👁️</button>
      </div>
      <div class="field-msg error" id="confirmError" style="display:none;">⚠️ Passwords don't match</div>
    </div>

    <button type="button" class="btn-submit" id="createBtn">
      <div class="btn-spin" id="createSpin"></div>
      <span id="createTxt">Create My Account 🚀</span>
    </button>
    <p style="font-size:.7rem;color:#4d7055;text-align:center;margin-top:.75rem;line-height:1.6;">
      By creating an account you agree to our
      <a href="/terms" target="_blank" style="color:#10b981;">Terms of Service</a>
      and <a href="/privacy-policy" target="_blank" style="color:#10b981;">Privacy Policy</a>.
    </p>
    <div class="field-msg error" id="formError" style="display:none;margin-top:.75rem;justify-content:center;"></div>
  </div>

  <!-- ──────────────────────────────────────
       STEP 3: SUCCESS
  ────────────────────────────────────── -->
  <div class="step-panel" id="panel3">
    <div class="success-state">
      <div class="success-icon">🎉</div>
      <div class="success-title">Welcome to Keto Journey!</div>
      <div class="success-sub">
        Your account is ready. Redirecting you to your personal dashboard…
      </div>
      <div class="progress-bar"><div class="progress-fill"></div></div>
    </div>
  </div>

</div><!-- /form-inner -->
</div><!-- /panel-form -->


<script is:inline define:vars={{ allowedEmail, CHECKOUT_BASIC, CHECKOUT_PRO, CHECKOUT_ELITE }}>
  var purchaseData = null;
  var verifiedEmail = '';

  // ── Step management ──────────────────────────────────
  function goToPanel(id) {
    document.querySelectorAll('.step-panel').forEach(function(p) { p.classList.remove('active'); });
    var el = document.getElementById(id);
    if (el) el.classList.add('active');
  }

  function updateStepUI(step) {
    for (var i = 1; i <= 3; i++) {
      var dot = document.getElementById('stepDot' + i);
      if (!dot) continue;
      dot.classList.remove('active', 'done');
      if (i < step) dot.classList.add('done');
      else if (i === step) dot.classList.add('active');
    }
    for (var j = 1; j <= 2; j++) {
      var line = document.getElementById('stepLine' + j);
      if (!line) continue;
      if (j < step) line.classList.add('done');
      else line.classList.remove('done');
    }
  }

  function resetToStep1() {
    updateStepUI(1);
    goToPanel('panel1');
    document.getElementById('emailInput').value = '';
    purchaseData = null;
    verifiedEmail = '';
  }

  // ── Password strength ────────────────────────────────
  var pwField = document.getElementById('password');
  if (pwField) {
    pwField.addEventListener('input', function() {
      var val = pwField.value;
      var strength = getStrength(val);
      var bars = ['bar1','bar2','bar3','bar4'].map(function(id) { return document.getElementById(id); });
      var label = document.getElementById('pwLabel');
      var cls = strength <= 1 ? 'w' : strength <= 2 ? 'm' : 's';
      bars.forEach(function(b, i) {
        if (!b) return;
        b.className = 'pw-bar';
        if (i < strength) b.classList.add(cls);
      });
      var labels = ['', 'Too weak', 'Fair', 'Good', 'Strong 💪'];
      if (label) label.textContent = val ? (labels[strength] || 'Strong 💪') : 'Enter a password';
    });
  }

  function getStrength(pw) {
    var s = 0;
    if (pw.length >= 6) s++;
    if (pw.length >= 10) s++;
    if (/[A-Z]/.test(pw) || /[0-9]/.test(pw)) s++;
    if (/[!@#$%^&*]/.test(pw)) s++;
    return Math.min(s, 4);
  }

  // ── Password toggles ─────────────────────────────────
  [['password','pw1Toggle'],['confirmPassword','pw2Toggle']].forEach(function(pair) {
    var f = document.getElementById(pair[0]);
    var b = document.getElementById(pair[1]);
    if (f && b) {
      b.addEventListener('click', function() {
        var isText = f.type === 'text';
        f.type = isText ? 'password' : 'text';
        b.textContent = isText ? '👁️' : '🙈';
      });
    }
  });

  // ── Build checkout URL ───────────────────────────────
  function buildCheckoutUrl(base, email) {
    if (!base) return '/#pricing';
    var sep = base.includes('?') ? '&' : '?';
    return base + sep + 'checkout%5Bemail%5D=' + encodeURIComponent(email);
  }

  // ── Plan picker ──────────────────────────────────────
  function showPlanPicker(email) {
    var plans = [
      {
        icon: '🥑',
        iconBg: 'rgba(16,185,129,.15)',
        badge: null,
        name: 'Basic',
        sub: '30-Day Kickstart',
        price: '$29',
        perDay: '$0.97/day',
        feats: ['30 structured keto days', '30+ curated recipes', 'Daily check-ins & streaks', 'Progress tracking', 'Weekly shopping lists'],
        cta: 'Get Started with Basic',
        cardBg: 'rgba(10,18,11,.97)',
        borderColor: 'rgba(16,185,129,.22)',
        shadow: 'none',
        priceColor: '#34d399',
        ctaBg: 'rgba(16,185,129,.1)',
        ctaBorder: 'rgba(16,185,129,.28)',
        ctaColor: '#34d399',
        ctaShadow: '',
        checkColor: '#34d399',
        featured: false,
        url: buildCheckoutUrl(CHECKOUT_BASIC, email),
      },
      {
        icon: '⚡',
        iconBg: 'rgba(99,102,241,.2)',
        badge: '⭐ Most Popular',
        badgeBg: 'linear-gradient(135deg,#10b981,#059669)',
        badgeColor: '#fff',
        name: 'Pro',
        sub: '90-Day Transformation',
        price: '$69',
        perDay: 'Just $0.77/day',
        feats: ['87+ premium recipes', 'Advanced analytics', 'Fasting timer & tracker', 'Weekly reports', 'Meal swap engine', 'Body measurements'],
        cta: 'Start Pro — Best Choice',
        cardBg: 'linear-gradient(150deg,rgba(16,185,129,.13) 0%,rgba(10,18,11,.98) 55%)',
        borderColor: '#10b981',
        shadow: '0 0 50px rgba(16,185,129,.16), inset 0 1px 0 rgba(52,211,153,.15)',
        priceColor: '#10b981',
        ctaBg: 'linear-gradient(135deg,#10b981,#34d399)',
        ctaBorder: 'transparent',
        ctaColor: '#fff',
        ctaShadow: '0 6px 22px rgba(16,185,129,.45)',
        checkColor: '#10b981',
        featured: true,
        url: buildCheckoutUrl(CHECKOUT_PRO, email),
      },
      {
        icon: '👑',
        iconBg: 'rgba(245,158,11,.18)',
        badge: '👑 Best Value',
        badgeBg: 'linear-gradient(135deg,#f59e0b,#d97706)',
        badgeColor: '#fff',
        name: 'Elite',
        sub: '360-Day Lifestyle',
        price: '$149',
        perDay: 'Just $0.41/day',
        feats: ['Everything in Pro', 'AI Keto Coach 24/7', 'Priority support', 'Lifetime updates', '360 structured days'],
        cta: 'Start Elite Plan',
        cardBg: 'rgba(10,18,11,.97)',
        borderColor: 'rgba(245,158,11,.3)',
        shadow: 'none',
        priceColor: '#f59e0b',
        ctaBg: 'linear-gradient(135deg,#f59e0b,#d97706)',
        ctaBorder: 'transparent',
        ctaColor: '#fff',
        ctaShadow: '0 6px 22px rgba(245,158,11,.38)',
        checkColor: '#f59e0b',
        featured: false,
        url: buildCheckoutUrl(CHECKOUT_ELITE, email),
      },
    ];

    var checkSvgTpl = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="COLOR" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>';
    var arrowSvg = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="flex-shrink:0;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';

    var container = document.getElementById('planPickerCards');
    container.innerHTML = plans.map(function(p) {
      var checkSvg = checkSvgTpl.replace('COLOR', p.checkColor);

      var badgeHtml = p.badge
        ? '<div style="display:inline-flex;align-items:center;gap:.3rem;background:' + p.badgeBg + ';color:' + p.badgeColor + ';font-size:.6rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;padding:.3rem .9rem;border-radius:99px;margin-bottom:.85rem;">' + p.badge + '</div>'
        : '<div style="height:.6rem;margin-bottom:.85rem;"></div>';

      var featsHtml = p.feats.map(function(f) {
        return '<li style="display:flex;align-items:flex-start;gap:.5rem;font-size:.78rem;color:rgba(220,235,220,.78);line-height:1.45;">' + checkSvg + '<span>' + f + '</span></li>';
      }).join('');

      var perDayHtml = p.perDay
        ? '<div style="display:flex;align-items:center;justify-content:center;gap:.3rem;margin-bottom:.85rem;font-size:.68rem;color:#5a7a5a;font-weight:600;">'
          + '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5"><path d="M12 2v20M2 12h20"/></svg>'
          + p.perDay + '</div>'
        : '';

      var ctaBoxShadow = p.ctaShadow ? ';box-shadow:' + p.ctaShadow : '';

      return '<a href="' + p.url + '" '
        + 'style="display:block;position:relative;border-radius:20px;padding:1.4rem 1.5rem;'
        + 'border:1.5px solid ' + p.borderColor + ';background:' + p.cardBg + ';'
        + 'box-shadow:' + p.shadow + ';text-decoration:none;color:#dfeedd;'
        + 'transition:transform .22s,box-shadow .22s;" '
        + 'onmouseover="this.style.transform=\'translateY(-3px)\'" '
        + 'onmouseout="this.style.transform=\'none\'">'

        // Badge row (always present, empty spacer if no badge)
        + badgeHtml

        // Header: icon + name | price
        + '<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.1rem;">'
        +   '<div style="display:flex;align-items:center;gap:.75rem;">'
        +     '<div style="width:44px;height:44px;border-radius:12px;background:' + p.iconBg + ';display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">' + p.icon + '</div>'
        +     '<div>'
        +       '<div style="font-weight:900;font-size:1rem;line-height:1.2;color:#e8f0e8;">' + p.name + '</div>'
        +       '<div style="font-size:.7rem;color:#5a7a5a;margin-top:.1rem;">' + p.sub + '</div>'
        +     '</div>'
        +   '</div>'
        +   '<div style="text-align:right;flex-shrink:0;padding-left:.5rem;">'
        +     '<div style="font-size:2.1rem;font-weight:900;color:' + p.priceColor + ';line-height:1;font-family:Georgia,serif;">' + p.price + '</div>'
        +     '<div style="font-size:.58rem;color:#5a7a5a;margin-top:.12rem;text-transform:uppercase;letter-spacing:.05em;">one-time</div>'
        +   '</div>'
        + '</div>'

        // Divider
        + '<div style="height:1px;background:rgba(255,255,255,.07);margin-bottom:1rem;"></div>'

        // Features list
        + '<ul style="list-style:none;display:flex;flex-direction:column;gap:.45rem;margin-bottom:.9rem;padding:0;">'
        + featsHtml
        + '</ul>'

        // Per-day cost
        + perDayHtml

        // CTA button
        + '<div style="display:flex;align-items:center;justify-content:center;gap:.45rem;padding:.875rem;border-radius:12px;background:' + p.ctaBg + ';border:1.5px solid ' + p.ctaBorder + ';color:' + p.ctaColor + ';font-size:.875rem;font-weight:800;letter-spacing:.01em' + ctaBoxShadow + ';">'
        +   '<span>' + p.cta + '</span>'
        +   arrowSvg
        + '</div>'

        + '</a>';
    }).join('');

    goToPanel('panelNoPurchase');
  }

  // ── Verify purchase ──────────────────────────────────
  async function startVerification() {
    var email = document.getElementById('emailInput').value.trim().toLowerCase();
    var emailErr = document.getElementById('emailError');

    if (!email || !email.includes('@')) {
      emailErr.style.display = 'flex'; return;
    }
    emailErr.style.display = 'none';

    var btn  = document.getElementById('verifyBtn');
    var spin = document.getElementById('verifySpin');
    var txt  = document.getElementById('verifyTxt');
    btn.disabled = true;
    spin.style.display = 'block';
    txt.textContent = 'Verifying…';

    goToPanel('panelLoading');

    try {
      var res = await fetch('/api/lemonsqueezy/verify-purchase', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email }),
      });
      var result = await res.json();

      if (result.reason === 'already_registered') {
        goToPanel('panelAlready'); return;
      }

      if (!result.success || !result.canSignup) {
        showPlanPicker(email); return;
      }

      // Success — populate plan box
      purchaseData  = result.purchase;
      verifiedEmail = email;

      var plans = {
        'basic_30':  { emoji:'🥑', name:'Basic Plan',  meta:'30-day access · $29 one-time' },
        'pro_6':     { emoji:'⚡', name:'Pro Plan',    meta:'90-day access · $69 one-time' },
        'elite_12':  { emoji:'👑', name:'Elite Plan',  meta:'360-day access · $149 one-time' },
      };
      var plan = plans[purchaseData.tier] || { emoji:'🥑', name: purchaseData.tier, meta: '' };
      document.getElementById('planEmoji').textContent = plan.emoji;
      document.getElementById('planTitle').textContent = plan.name;
      document.getElementById('planMeta').textContent  = plan.meta;

      updateStepUI(2);
      goToPanel('panel2');

    } catch(e) {
      showPlanPicker(email);
    } finally {
      btn.disabled = false;
      spin.style.display = 'none';
      txt.textContent = 'Verify Purchase →';
    }
  }

  // ── Create account ───────────────────────────────────
  async function handleCreate() {
    if (!purchaseData) return;

    ['nameError','passwordError','confirmError','formError'].forEach(function(id) {
      document.getElementById(id).style.display = 'none';
    });

    var fullName = document.getElementById('fullName').value.trim();
    var password = document.getElementById('password').value;
    var confirm  = document.getElementById('confirmPassword').value;
    var err = false;

    if (!fullName)           { document.getElementById('nameError').style.display = 'flex';     err = true; }
    if (password.length < 6) { document.getElementById('passwordError').style.display = 'flex'; err = true; }
    if (password !== confirm) { document.getElementById('confirmError').style.display = 'flex'; err = true; }
    if (err) return;

    var btn  = document.getElementById('createBtn');
    var spin = document.getElementById('createSpin');
    var txt  = document.getElementById('createTxt');
    btn.disabled = true;
    spin.style.display = 'block';
    txt.textContent = 'Creating account…';

    try {
      var refCode = localStorage.getItem('keto_ref') || '';

      var res = await fetch('/api/auth/signup-purchase', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email:         verifiedEmail,
          password:      password,
          fullName:      fullName,
          tier:          purchaseData.tier,
          startDate:     purchaseData.start_date,
          endDate:       purchaseData.end_date,
          saleId:         purchaseData.sale_id,
          ls_order_id:    purchaseData.ls_order_id    || '',
          ls_customer_id: purchaseData.ls_customer_id || '',
          referral_code:  refCode || undefined,
        }),
      });
      var result = await res.json();
      if (!res.ok) throw new Error(result.error || 'Signup failed');

      localStorage.removeItem('keto_ref');

      updateStepUI(3);
      goToPanel('panel3');
      setTimeout(function() { window.location.href = '/dashboard'; }, 2200);

    } catch(e) {
      var errEl = document.getElementById('formError');
      errEl.textContent = '⚠️ ' + e.message;
      errEl.style.display = 'flex';
      btn.disabled = false;
      spin.style.display = 'none';
      txt.textContent = 'Create My Account 🚀';
    }
  }

  // ── Referral code capture ────────────────────────────
  (function() {
    var params = new URLSearchParams(window.location.search);
    var ref = params.get('ref');
    if (ref && ref.length >= 6) {
      localStorage.setItem('keto_ref', ref.toUpperCase());
      var banner = document.getElementById('refBanner');
      if (banner) banner.style.display = 'flex';
    }
  })();

  // ── Wire events ──────────────────────────────────────
  window.addEventListener('DOMContentLoaded', function() {
    document.getElementById('verifyBtn').addEventListener('click', startVerification);
    document.getElementById('emailInput').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') startVerification();
    });
    document.getElementById('createBtn').addEventListener('click', handleCreate);

    if (allowedEmail) {
      document.getElementById('emailInput').value = allowedEmail;
      startVerification();
    }
  });

  window.resetToStep1 = resetToStep1;
