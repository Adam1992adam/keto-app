---
// src/pages/terms.astro — Terms of Service
import CookieConsent from '../components/CookieConsent.astro';
const lastUpdated = 'April 8, 2026';
const SITE_URL = (import.meta.env.PUBLIC_APP_URL || 'https://ketojourney.app').replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Terms of Service · KetoJourney</title>
  <meta name="description" content="Read the Terms of Service for KetoJourney. Understand your rights, subscription terms, refund policy, and acceptable use guidelines."/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href={SITE_URL + '/terms'}/>
  <meta property="og:type"        content="website"/>
  <meta property="og:url"         content={SITE_URL + '/terms'}/>
  <meta property="og:site_name"   content="KetoJourney"/>
  <meta property="og:title"       content="Terms of Service · KetoJourney"/>
  <meta property="og:description" content="Read the Terms of Service for KetoJourney. Understand your rights, subscription terms, refund policy, and acceptable use guidelines."/>
  <meta property="og:image"       content={SITE_URL + '/og-image.png'}/>
  <meta name="twitter:card"       content="summary"/>
  <meta name="twitter:title"      content="Terms of Service · KetoJourney"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/icon-72.png"/>
  <meta name="theme-color" content="#10b981"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;1,9..144,900&family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #060d09; --card: #0d1a0f; --border: rgba(16,185,129,.12);
      --text: #dfeedd; --soft: #4d7055; --green: #10b981; --green2: #34d399;
      --gold: #f59e0b;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); line-height:1.7; }
    a { color:var(--green); text-decoration:none; }
    a:hover { text-decoration:underline; }

    .nav { display:flex; align-items:center; justify-content:space-between; padding:1rem 2rem; border-bottom:1px solid var(--border); }
    .nav-logo { font-family:'Fraunces',serif; font-weight:900; font-size:1.2rem; color:var(--green2); display:flex; align-items:center; gap:.5rem; }
    .nav-back { font-size:.83rem; font-weight:700; color:var(--soft); border:1px solid var(--border); padding:.4rem .9rem; border-radius:8px; transition:all .2s; }
    .nav-back:hover { color:var(--text); border-color:var(--green); text-decoration:none; }

    .page { max-width:760px; margin:0 auto; padding:3rem 1.5rem 5rem; }
    .page-label { font-size:.7rem; font-weight:800; letter-spacing:.12em; text-transform:uppercase; color:var(--green); margin-bottom:.75rem; }
    h1 { font-family:'Fraunces',serif; font-weight:900; font-size:clamp(2rem,4vw,2.8rem); line-height:1.1; margin-bottom:.5rem; }
    .meta { font-size:.78rem; color:var(--soft); margin-bottom:2.5rem; }

    /* TOC */
    .toc {
      background:var(--card); border:1px solid var(--border); border-radius:16px;
      padding:1.25rem 1.5rem; margin-bottom:2rem;
    }
    .toc-title { font-size:.72rem; font-weight:800; letter-spacing:.1em; text-transform:uppercase; color:var(--soft); margin-bottom:.75rem; }
    .toc ol { padding-left:1.25rem; display:grid; grid-template-columns:1fr 1fr; gap:.25rem .5rem; }
    .toc li { font-size:.82rem; }
    .toc a { color:var(--soft); }
    .toc a:hover { color:var(--green); }
    @media(max-width:520px){ .toc ol { grid-template-columns:1fr; } }

    .section { margin-bottom:2rem; padding:1.5rem; background:var(--card); border:1px solid var(--border); border-radius:16px; scroll-margin-top:1.5rem; }
    h2 { font-family:'Fraunces',serif; font-size:1.15rem; font-weight:700; color:var(--green2); margin-bottom:.75rem; }
    p { font-size:.9rem; color:rgba(223,238,221,.8); margin-bottom:.75rem; }
    p:last-child { margin-bottom:0; }
    ul, ol { padding-left:1.25rem; margin:.5rem 0 .75rem; }
    li { font-size:.9rem; color:rgba(223,238,221,.8); margin-bottom:.35rem; }
    strong { color:var(--text); font-weight:700; }

    .highlight {
      background:rgba(16,185,129,.07); border-left:3px solid var(--green);
      padding:.75rem 1rem; border-radius:0 8px 8px 0; margin:.75rem 0;
      font-size:.85rem; color:rgba(223,238,221,.9);
    }
    .warning {
      background:rgba(245,158,11,.07); border-left:3px solid var(--gold);
      padding:.75rem 1rem; border-radius:0 8px 8px 0; margin:.75rem 0;
      font-size:.85rem; color:rgba(223,238,221,.9);
    }

    .footer { text-align:center; padding:2rem; border-top:1px solid var(--border); font-size:.78rem; color:var(--soft); }
    .footer a { margin:0 .5rem; }
  </style>
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo">🥑 KetoJourney</a>
  <a href="/" class="nav-back">← Back to Home</a>
</nav>

<div class="page">
  <div class="page-label">Legal</div>
  <h1>Terms of Service</h1>
  <p class="meta">Last updated: {lastUpdated} &nbsp;·&nbsp; Effective immediately upon account creation</p>

  <!-- TABLE OF CONTENTS -->
  <div class="toc">
    <div class="toc-title">Contents</div>
    <ol>
      <li><a href="#acceptance">Acceptance of Terms</a></li>
      <li><a href="#services">Description of Services</a></li>
      <li><a href="#eligibility">Eligibility</a></li>
      <li><a href="#accounts">User Accounts</a></li>
      <li><a href="#payments">Payments & Plans</a></li>
      <li><a href="#refunds">Refund Policy</a></li>
      <li><a href="#conduct">Acceptable Use</a></li>
      <li><a href="#content">User Content</a></li>
      <li><a href="#health">Health Disclaimer</a></li>
      <li><a href="#ip">Intellectual Property</a></li>
      <li><a href="#liability">Limitation of Liability</a></li>
      <li><a href="#termination">Termination</a></li>
      <li><a href="#changes">Changes to Terms</a></li>
      <li><a href="#contact">Contact Us</a></li>
    </ol>
  </div>

  <!-- 1 -->
  <div class="section" id="acceptance">
    <h2>1. Acceptance of Terms</h2>
    <p>By creating an account, accessing, or using KetoJourney ("the Service", "the App"), you agree to be bound by these Terms of Service ("Terms"). If you do not agree to these Terms, do not use the Service.</p>
    <p>These Terms constitute a legally binding agreement between you ("User", "you") and KetoJourney ("we", "us", "our"). By using the Service you confirm that you have read, understood, and accepted these Terms in full.</p>
  </div>

  <!-- 2 -->
  <div class="section" id="services">
    <h2>2. Description of Services</h2>
    <p>KetoJourney is a structured keto diet coaching web application that provides:</p>
    <ul>
      <li>Personalized keto meal plans (30, 90, or 360-day structured programs)</li>
      <li>Daily task tracking, check-ins, and progress monitoring</li>
      <li>Recipe library with nutritional information</li>
      <li>Fasting timer, macro tracking, and body measurement tools</li>
      <li>Community features, achievements, and XP-based gamification</li>
      <li>AI Keto Coach (Elite plan only)</li>
      <li>Email coaching summaries and push notifications</li>
    </ul>
    <p>We reserve the right to modify, suspend, or discontinue any feature of the Service at any time with or without notice. We will not be liable to you or any third party for any such modification, suspension, or discontinuation.</p>
  </div>

  <!-- 3 -->
  <div class="section" id="eligibility">
    <h2>3. Eligibility</h2>
    <p>To use KetoJourney you must:</p>
    <ul>
      <li>Be at least <strong>18 years of age</strong> (or the age of majority in your jurisdiction)</li>
      <li>Have the legal capacity to enter into a binding agreement</li>
      <li>Not be prohibited from using the Service under applicable law</li>
    </ul>
    <p>By using the Service, you represent and warrant that you meet all eligibility requirements. We reserve the right to terminate accounts that do not meet these requirements.</p>
  </div>

  <!-- 4 -->
  <div class="section" id="accounts">
    <h2>4. User Accounts</h2>
    <p>When you create an account with us, you must provide accurate, complete, and current information. You are responsible for:</p>
    <ul>
      <li>Maintaining the confidentiality of your password</li>
      <li>All activity that occurs under your account</li>
      <li>Notifying us immediately of any unauthorized use at <a href="mailto:abdeba980@gmail.com">abdeba980@gmail.com</a></li>
    </ul>
    <p>You may not share your account with others, create multiple accounts, or use another person's account. We reserve the right to terminate accounts that violate these provisions.</p>
    <div class="highlight">You may request deletion of your account and all associated data at any time by emailing <a href="mailto:abdeba980@gmail.com">abdeba980@gmail.com</a>. We will process your request within 30 days in compliance with applicable privacy law.</div>
  </div>

  <!-- 5 -->
  <div class="section" id="payments">
    <h2>5. Payments & Plans</h2>
    <p>KetoJourney offers the following one-time payment plans:</p>
    <ul>
      <li><strong>Basic</strong> — $29.99 one-time · 30-day program</li>
      <li><strong>Pro</strong> — $69.00 one-time · 90-day program</li>
      <li><strong>Elite</strong> — $149.00 one-time · 360-day program</li>
    </ul>
    <p>All payments are processed securely through <strong>LemonSqueezy</strong>, our authorized payment processor. By completing a purchase you also agree to LemonSqueezy's <a href="https://www.lemonsqueezy.com/terms" target="_blank" rel="noopener">Terms of Service</a>.</p>
    <p>All prices are listed in <strong>USD</strong>. You are responsible for any applicable taxes or currency conversion fees charged by your bank or card issuer.</p>
    <div class="highlight">All plans are <strong>one-time payments</strong> — there are no recurring charges or hidden fees. Access is granted immediately upon successful payment confirmation.</div>
    <p>We reserve the right to change our pricing at any time. Changes will not affect already-purchased plans.</p>
  </div>

  <!-- 6 -->
  <div class="section" id="refunds">
    <h2>6. Refund Policy</h2>
    <p>We offer a <strong>30-day money-back guarantee</strong> on all plans. If you are not satisfied with the Service for any reason, you may request a full refund within 30 days of your purchase date.</p>
    <p>To request a refund:</p>
    <ol>
      <li>Email <a href="mailto:abdeba980@gmail.com">abdeba980@gmail.com</a> with the subject line "Refund Request"</li>
      <li>Include your registered email address and order confirmation number</li>
      <li>We will process your refund within <strong>5–10 business days</strong></li>
    </ol>
    <div class="warning">Refund requests submitted after 30 days of purchase are not eligible unless required by applicable consumer protection law in your jurisdiction.</div>
    <p>Refunds are issued to the original payment method. We do not offer partial refunds or credit for unused portions of a plan.</p>
  </div>

  <!-- 7 -->
  <div class="section" id="conduct">
    <h2>7. Acceptable Use</h2>
    <p>You agree not to use the Service to:</p>
    <ul>
      <li>Violate any applicable law or regulation</li>
      <li>Attempt to gain unauthorized access to our systems or other users' accounts</li>
      <li>Transmit spam, malware, or any harmful code</li>
      <li>Scrape, copy, or redistribute our content without permission</li>
      <li>Impersonate any person or entity</li>
      <li>Post content that is defamatory, obscene, or harassing in community features</li>
      <li>Use automated means to access the Service (bots, scrapers)</li>
      <li>Reverse-engineer or attempt to extract the source code of the Service</li>
    </ul>
    <p>Violation of this section may result in immediate account termination without refund.</p>
  </div>

  <!-- 8 -->
  <div class="section" id="content">
    <h2>8. User Content</h2>
    <p>You retain ownership of any content you submit to the Service (check-in notes, reflection entries, photos, community posts). By submitting content, you grant us a non-exclusive, worldwide, royalty-free license to store and display that content solely for the purpose of providing the Service to you.</p>
    <p>You represent and warrant that you own or have the necessary rights to all content you submit, and that such content does not infringe the rights of any third party.</p>
    <p>We do not sell your personal content to third parties. See our <a href="/privacy-policy">Privacy Policy</a> for details on how data is handled.</p>
  </div>

  <!-- 9 -->
  <div class="section" id="health">
    <h2>9. Health Disclaimer</h2>
    <div class="warning">KetoJourney provides nutritional information, meal plans, and wellness tracking tools for general informational purposes only. The Service is <strong>not a substitute for professional medical advice, diagnosis, or treatment.</strong></div>
    <p>Always seek the advice of your physician or qualified healthcare provider before starting any diet program, especially if you have a pre-existing medical condition such as diabetes, kidney disease, or cardiovascular disease.</p>
    <p>Never disregard professional medical advice or delay seeking it because of something you read in this application. If you experience adverse symptoms while following the program, stop immediately and consult a healthcare professional.</p>
    <p>See our full <a href="/disclaimer">Health Disclaimer</a> for more information.</p>
  </div>

  <!-- 10 -->
  <div class="section" id="ip">
    <h2>10. Intellectual Property</h2>
    <p>The Service and all of its original content (meal plans, recipes, design, code, text, graphics, logos) are the exclusive property of KetoJourney and are protected by applicable intellectual property laws.</p>
    <p>You are granted a limited, non-exclusive, non-transferable license to access and use the Service for your personal, non-commercial purposes. This license does not include the right to:</p>
    <ul>
      <li>Copy, modify, or distribute any content from the Service</li>
      <li>Create derivative works based on the Service</li>
      <li>Use our brand name or logo without prior written consent</li>
      <li>Resell or sublicense access to the Service</li>
    </ul>
  </div>

  <!-- 11 -->
  <div class="section" id="liability">
    <h2>11. Limitation of Liability</h2>
    <p>To the maximum extent permitted by applicable law, KetoJourney and its team shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising from:</p>
    <ul>
      <li>Your use of or inability to use the Service</li>
      <li>Any health outcomes resulting from following our meal plans or advice</li>
      <li>Unauthorized access to or alteration of your data</li>
      <li>Any interruption or cessation of the Service</li>
    </ul>
    <p>Our total aggregate liability to you for any claims arising out of or related to the Service shall not exceed the amount you paid us in the <strong>12 months preceding the claim</strong>.</p>
    <p>Some jurisdictions do not allow the exclusion of certain warranties or limitation of liability. In such jurisdictions, our liability is limited to the greatest extent permitted by law.</p>
  </div>

  <!-- 12 -->
  <div class="section" id="termination">
    <h2>12. Termination</h2>
    <p>We reserve the right to suspend or terminate your account at our sole discretion, without notice, for conduct that we determine violates these Terms or is harmful to other users, us, or third parties.</p>
    <p>You may terminate your account at any time by emailing <a href="mailto:abdeba980@gmail.com">abdeba980@gmail.com</a>. Upon termination:</p>
    <ul>
      <li>Your access to the Service will be revoked immediately</li>
      <li>Your personal data will be deleted within 30 days of your request</li>
      <li>No refund will be issued unless you are within the 30-day guarantee period</li>
    </ul>
    <p>Sections 9 (Health Disclaimer), 10 (Intellectual Property), and 11 (Limitation of Liability) survive termination.</p>
  </div>

  <!-- 13 -->
  <div class="section" id="changes">
    <h2>13. Changes to These Terms</h2>
    <p>We reserve the right to modify these Terms at any time. When we make material changes, we will:</p>
    <ul>
      <li>Update the "Last updated" date at the top of this page</li>
      <li>Send a notification to your registered email address</li>
      <li>Display an in-app notice for at least 7 days</li>
    </ul>
    <p>Your continued use of the Service after changes take effect constitutes acceptance of the new Terms. If you do not agree to the revised Terms, you must stop using the Service and may request a refund if within the eligible period.</p>
  </div>

  <!-- 14 -->
  <div class="section" id="contact">
    <h2>14. Contact Us</h2>
    <p>If you have any questions about these Terms, please contact us:</p>
    <ul>
      <li><strong>Email:</strong> <a href="mailto:abdeba980@gmail.com">abdeba980@gmail.com</a></li>
      <li><strong>Response time:</strong> Within 2–3 business days</li>
    </ul>
    <p>For refund requests, account deletion, or data inquiries, please use the same email with the relevant subject line.</p>
  </div>

</div>

<footer class="footer">
  &copy; {new Date().getFullYear()} KetoJourney. All rights reserved.
  &nbsp;·&nbsp;
  <a href="/privacy-policy">Privacy Policy</a>
  <a href="/disclaimer">Disclaimer</a>
  <a href="/">Home</a>
</footer>

<CookieConsent />
</body>
</html>
