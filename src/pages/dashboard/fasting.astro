---
// src/pages/dashboard/fasting.astro
import { getUserJourney } from '../../lib/supabase';
import { requireAuth } from '../../lib/auth';
import Sidebar from '../../components/Sidebar.astro';
import { getTranslator, normaliseLang } from '../../lib/i18n';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;
const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? 'Elite' : planType === 'pro_6' ? 'Pro' : 'Basic';
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);

const journey    = await getUserJourney(user.id, db);
const currentDay = journey?.current_day || 1;

const { data: onboarding } = await db
  .from('onboarding_data').select('fasting_protocol, goal').eq('user_id', user.id).maybeSingle();

const { data: activeSession } = await db
  .from('fasting_sessions').select('*').eq('user_id', user.id).is('ended_at', null)
  .order('started_at', { ascending: false }).limit(1).maybeSingle();

const { data: pastSessions } = await db
  .from('fasting_sessions').select('*').eq('user_id', user.id)
  .not('ended_at', 'is', null).order('started_at', { ascending: false }).limit(5);

const totalFasts     = pastSessions?.length || 0;
const completedFasts = pastSessions?.filter(s => s.completed).length || 0;
const avgFastHours   = pastSessions && pastSessions.length > 0
  ? (pastSessions.reduce((s, f) => s + (f.actual_hours || 0), 0) / pastSessions.length).toFixed(1)
  : '0';
const totalFastHours = pastSessions?.reduce((s, f) => s + (f.actual_hours || 0), 0) || 0;

const userName        = profile.full_name?.split(' ')[0] || 'there';
const defaultProtocol = onboarding?.fasting_protocol || '16_8';

const activeSessionData = activeSession ? {
  id: activeSession.id,
  started_at: activeSession.started_at,
  protocol: activeSession.protocol,
  target_hours: activeSession.target_hours,
} : null;

const historyRows = (pastSessions || []).map(s => {
  const started   = new Date(s.started_at);
  const dateStr   = started.toLocaleDateString('en', { weekday: 'short', month: 'short', day: 'numeric' });
  const timeStr   = started.toLocaleTimeString('en', { hour: '2-digit', minute: '2-digit' });
  const hrs       = s.actual_hours || 0;
  const target    = s.target_hours || 16;
  const pct       = Math.min(Math.round((hrs / target) * 100), 100);
  const protoName = s.protocol ? s.protocol.replace('_', ':') : '—';
  const done      = s.completed;
  const barColor  = pct >= 100 ? '#10b981' : pct >= 60 ? '#f59e0b' : '#ef4444';
  const checkClass= done ? 'done' : 'partial';
  const checkIcon = done ? '✓' : '~';
  return { dateStr, timeStr, hrs, target, pct, protoName, done, barColor, checkClass, checkIcon };
});
const hasHistory = historyRows.length > 0;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Fasting — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
  <script is:inline>(function(){var t=localStorage.getItem('keto-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
  <style>
    /* ── Rose Vital tokens ───────────────────────────────── */
    :root {
      --rv-bg:      #FAF6F1;
      --rv-card:    #FFFFFF;
      --rv-bg-alt:  #F2EDE5;
      --rv-ink:     #16110F;
      --rv-ink-soft:#4A4340;
      --rv-muted:   #8A8077;
      --rv-line:    #E5DED2;
      --rv-accent:  #FF5C7A;
      --rv-accent-2:#B6FF3C;
      --rv-accent-3:#FF914D;

      /* Timer-specific semantic colors (kept for JS stage system) */
      --bg:      var(--rv-bg);
      --card:    var(--rv-card);
      --card2:   var(--rv-bg-alt);
      --border:  var(--rv-line);
      --border2: #D4C9BD;
      --border3: #C0B5A9;
      --text:    var(--rv-ink);
      --soft:    var(--rv-muted);
      --muted:   var(--rv-bg-alt);
      --green:   #10b981;
      --green2:  #34d399;
      --gold:    #f59e0b;
      --amber:   #fbbf24;
      --gold2:   #fde68a;
      --red:     #ef4444;
      --blue:    #3b82f6;
      --orange:  #f97316;
      --purple:  #8b5cf6;
      --cyan:    #06b6d4;
    }
    [data-theme="dark"] {
      --rv-bg:      #0F0B09;
      --rv-card:    #1A1410;
      --rv-bg-alt:  #221C18;
      --rv-ink:     #F5F0EA;
      --rv-ink-soft:#B8AFA6;
      --rv-muted:   #6B6260;
      --rv-line:    #2E2520;
    }

    *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Geist', system-ui, sans-serif;
      background: var(--rv-bg);
      color: var(--rv-ink);
      min-height: 100vh;
    }

    /* ── Shell ───────────────────────────────────────────── */
    .rv-shell {
      display: grid;
      grid-template-columns: 232px 1fr;
      min-height: 100vh;
    }
    .rv-main { min-width: 0; overflow-x: hidden; }
    @media (max-width: 900px) {
      .rv-shell { grid-template-columns: 1fr; }
      .rv-main  { padding-bottom: 5.5rem; }
    }

    .rv-inner {
      max-width: 840px;
      margin: 0 auto;
      padding: 2.5rem 2rem 4rem;
    }
    @media (max-width: 640px) { .rv-inner { padding: 1.25rem 1rem 3rem; } }

    @keyframes fadeUp { from{opacity:0;transform:translateY(12px);} to{opacity:1;transform:translateY(0);} }
    @keyframes pulseDot { 0%,100%{opacity:1;transform:scale(1);} 50%{opacity:.5;transform:scale(1.4);} }
    @keyframes glowPulse { 0%,100%{box-shadow:0 0 0 0 rgba(255,92,122,.2);} 50%{box-shadow:0 0 0 10px rgba(255,92,122,0);} }
    @keyframes ringGlowPulse { 0%,100%{filter:drop-shadow(0 0 8px rgba(255,92,122,.3));} 50%{filter:drop-shadow(0 0 20px rgba(255,92,122,.55));} }
    @keyframes outerPulse { 0%,100%{opacity:.25;stroke-width:2;} 50%{opacity:.06;stroke-width:7;} }
    @keyframes spin { to{transform:rotate(360deg);} }
    @keyframes fadeIn { from{opacity:0;} to{opacity:1;} }
    @keyframes bounceIn { 0%{transform:scale(0);} 70%{transform:scale(1.1);} 100%{transform:scale(1);} }

    /* ── Page header ─────────────────────────────────────── */
    .rv-hd {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 2rem;
      animation: fadeUp .35s ease both;
    }
    .rv-hd-title {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 1.6rem; font-weight: 800; line-height: 1.1;
    }
    .rv-hd-sub {
      font-family: 'Geist Mono', monospace;
      font-size: .72rem; color: var(--rv-muted); margin-top: .2rem;
    }

    /* ── Timer hero ──────────────────────────────────────── */
    .timer-hero {
      text-align: center;
      padding: 2.5rem 2rem 2.25rem;
      background: var(--rv-card);
      border: 1px solid var(--rv-line);
      border-radius: 24px;
      margin-bottom: 1.5rem;
      position: relative; overflow: hidden;
      animation: fadeUp .45s ease both;
      transition: background .5s, border-color .5s, box-shadow .5s;
    }
    .timer-hero.is-active {
      border-color: rgba(255,92,122,.3);
      box-shadow: 0 0 60px rgba(255,92,122,.08), 0 20px 60px rgba(22,17,15,.06);
    }
    .timer-hero::before {
      content:''; position:absolute; inset:0;
      background: radial-gradient(ellipse 80% 55% at 50% -5%, rgba(255,92,122,.04), transparent);
      pointer-events: none;
    }

    /* Active badge */
    .active-badge {
      display: none; align-items: center; gap: .5rem;
      background: rgba(255,92,122,.08);
      border: 1px solid rgba(255,92,122,.2);
      border-radius: 99px;
      padding: .3rem .9rem;
      font-family: 'Geist Mono', monospace;
      font-size: .65rem; font-weight: 700;
      color: var(--rv-accent);
      margin: 0 auto 1.25rem; width: fit-content;
      animation: glowPulse 2.5s ease-in-out infinite;
    }
    .timer-hero.is-active .active-badge { display: flex; }
    .active-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--rv-accent);
      animation: pulseDot 1.2s ease-in-out infinite;
    }

    /* Stage pill */
    .stage-pill {
      display: inline-flex; align-items: center; gap: .45rem;
      border-radius: 99px; padding: .3rem .9rem;
      font-family: 'Geist Mono', monospace;
      font-size: .65rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .08em;
      margin-bottom: 1.5rem;
      border: 1px solid currentColor;
      transition: all .5s;
    }
    .stage-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; animation: pulseDot 1.5s ease-in-out infinite; }

    /* SVG Ring — 240×240 */
    .ring-wrap {
      position: relative; width: 220px; height: 220px;
      margin: 0 auto 1.25rem;
    }
    .ring-svg { width: 100%; height: 100%; transform: rotate(-90deg); }
    .ring-track { fill: none; stroke: var(--rv-line); stroke-width: 10; }
    .ring-progress {
      fill: none; stroke-width: 10; stroke-linecap: round;
      stroke-dasharray: 659.73;
      stroke-dashoffset: 659.73;
      transition: stroke-dashoffset .6s ease, stroke 1s ease;
    }
    .ring-glow {
      fill: none; stroke-width: 22; stroke-linecap: round;
      opacity: .15; filter: blur(10px);
      stroke-dasharray: 659.73; stroke-dashoffset: 659.73;
      transition: stroke-dashoffset .6s ease, stroke 1s ease;
    }
    .ring-outer-pulse {
      fill: none; stroke: var(--rv-accent); stroke-width: 2;
      opacity: 0; stroke-dasharray: 722; stroke-dashoffset: 0;
    }
    .timer-hero.is-active .ring-wrap {
      animation: ringGlowPulse 2.8s ease-in-out infinite;
    }
    .timer-hero.is-active .ring-outer-pulse {
      opacity: .2; animation: outerPulse 2.8s ease-in-out infinite;
    }
    .ring-center {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      text-align: center; pointer-events: none;
    }
    .timer-display {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 2.6rem; font-weight: 800; line-height: 1;
      letter-spacing: -.02em; transition: color .5s;
    }
    .timer-of {
      font-family: 'Geist Mono', monospace;
      font-size: .68rem; font-weight: 500;
      color: var(--rv-muted); margin-top: .3rem;
    }
    .timer-pct {
      font-family: 'Geist Mono', monospace;
      font-size: .72rem; font-weight: 600;
      color: var(--rv-muted); margin-top: .15rem;
    }

    .stage-status {
      font-size: .86rem; color: var(--rv-muted);
      line-height: 1.6; max-width: 400px;
      margin: 0 auto .5rem; transition: all .5s; min-height: 2.5rem;
    }
    .stage-status strong { color: var(--rv-ink); }

    /* 4-stage burn strip */
    .burn-strip {
      display: none; gap: .5rem;
      margin: .75rem auto 1.5rem; max-width: 520px;
    }
    .timer-hero.is-active .burn-strip { display: flex; }
    .burn-stage {
      flex: 1; border-radius: 11px; padding: .55rem .4rem;
      text-align: center;
      background: var(--rv-bg-alt);
      border: 1.5px solid transparent;
      transition: all .4s; position: relative; overflow: hidden;
    }
    .burn-stage.bs-active {
      background: rgba(255,92,122,.06);
      border-color: rgba(255,92,122,.25);
    }
    .burn-stage.bs-done {
      background: var(--rv-bg-alt);
      border-color: var(--rv-line);
      opacity: .6;
    }
    .burn-stage::after {
      content:''; position: absolute; bottom: 0; left: 0; right: 0;
      height: 2px; background: transparent; border-radius: 2px;
      transition: background .4s;
    }
    .burn-stage.bs-active::after { background: var(--rv-accent); }
    .burn-stage.bs-done::after { background: var(--rv-line); }
    .bs-emoji { font-size: .95rem; line-height: 1; display: block; margin-bottom: .2rem; }
    .bs-name {
      font-family: 'Geist Mono', monospace;
      font-size: .58rem; font-weight: 700;
      color: var(--rv-muted); line-height: 1.3;
      transition: color .4s;
    }
    .burn-stage.bs-active .bs-name { color: var(--rv-accent); }

    /* Start time picker */
    .start-picker {
      display: flex; align-items: center; gap: .75rem;
      flex-wrap: wrap; padding: .75rem 0;
      justify-content: center; margin-bottom: .5rem;
    }
    .sp-label {
      font-family: 'Geist Mono', monospace;
      font-size: .65rem; font-weight: 600; color: var(--rv-muted);
    }
    .sp-btns { display: flex; gap: .4rem; flex-wrap: wrap; justify-content: center; }
    .sp-btn {
      padding: .3rem .75rem; border-radius: 99px;
      background: var(--rv-bg-alt); border: 1.5px solid var(--rv-line);
      font-family: 'Geist Mono', monospace;
      font-size: .65rem; font-weight: 700;
      color: var(--rv-muted); cursor: pointer; transition: all .2s;
    }
    .sp-btn:hover { border-color: var(--rv-ink-soft); color: var(--rv-ink); }
    .sp-btn.active {
      background: var(--rv-ink); color: var(--rv-bg);
      border-color: var(--rv-ink);
    }
    .sp-time-input {
      background: var(--rv-bg-alt); border: 1.5px solid var(--rv-line);
      border-radius: 9px; padding: .3rem .65rem;
      color: var(--rv-ink);
      font-family: 'Geist Mono', monospace;
      font-size: .72rem; outline: none; transition: all .2s; cursor: pointer;
    }
    .sp-time-input:focus { border-color: var(--rv-ink); }

    /* Action buttons */
    .timer-actions {
      display: flex; gap: .75rem;
      justify-content: center; flex-wrap: wrap; margin-top: 1.5rem;
    }
    .btn-start {
      display: flex; align-items: center; gap: .55rem;
      padding: .9rem 2.5rem; border-radius: 13px;
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-weight: 800; font-size: .95rem;
      border: none; cursor: pointer;
      background: var(--rv-ink); color: var(--rv-bg);
      transition: all .25s;
    }
    .btn-start:hover { opacity: .85; transform: translateY(-2px); }
    .btn-end {
      display: flex; align-items: center; gap: .5rem;
      padding: .9rem 1.5rem; border-radius: 13px;
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-weight: 700; font-size: .88rem;
      border: 1.5px solid rgba(239,68,68,.3); cursor: pointer;
      background: rgba(239,68,68,.06); color: #ef4444;
      transition: all .22s;
    }
    .btn-end:hover { background: rgba(239,68,68,.12); border-color: #ef4444; }
    .btn-ghost {
      display: flex; align-items: center; gap: .5rem;
      padding: .9rem 1.25rem; border-radius: 13px;
      font-family: 'Geist', system-ui, sans-serif;
      font-weight: 600; font-size: .84rem;
      border: 1.5px solid var(--rv-line); cursor: pointer;
      background: transparent; color: var(--rv-muted);
      transition: all .2s;
    }
    .btn-ghost:hover { border-color: var(--rv-ink-soft); color: var(--rv-ink); }

    /* ── Section label ───────────────────────────────────── */
    .rv-sec-lbl {
      font-family: 'Geist Mono', monospace;
      font-size: .65rem; font-weight: 700;
      color: var(--rv-muted); letter-spacing: .1em;
      text-transform: uppercase;
      display: flex; align-items: center; gap: .5rem;
      margin-bottom: 1rem;
    }
    .rv-sec-lbl::after { content:''; flex:1; height:1px; background:var(--rv-line); }

    /* ── Protocol cards ──────────────────────────────────── */
    .protocol-section {
      background: var(--rv-card); border: 1px solid var(--rv-line);
      border-radius: 20px; padding: 1.5rem;
      margin-bottom: 1.5rem;
      animation: fadeUp .4s .08s ease both;
      transition: opacity .4s;
    }
    .protocol-grid {
      display: grid; grid-template-columns: repeat(2,1fr); gap: .75rem;
    }
    .proto-card {
      background: var(--rv-bg-alt); border: 2px solid var(--rv-line);
      border-radius: 14px; padding: 1.2rem 1.1rem 1rem;
      cursor: pointer; transition: all .25s; user-select: none;
      position: relative; overflow: hidden;
      display: flex; flex-direction: column; gap: .25rem;
    }
    .proto-card::before {
      content:''; position:absolute; top:0; left:0; right:0;
      height:3px; opacity:0; transition:opacity .3s;
      border-radius:14px 14px 0 0;
    }
    .proto-card:hover {
      border-color: var(--rv-ink-soft);
      transform: translateY(-2px);
    }
    .proto-card.active {
      border-color: var(--rv-ink);
      background: var(--rv-card);
    }
    .proto-card.active::before {
      opacity: 1;
      background: var(--rv-ink);
    }
    .proto-diff-badge {
      position: absolute; top: .6rem; right: .65rem;
      border-radius: 99px; padding: .15rem .55rem;
      font-family: 'Geist Mono', monospace;
      font-size: .58rem; font-weight: 700;
      letter-spacing: .04em;
      border: 1px solid currentColor;
    }
    .proto-diff-badge.easy   { color: #10b981; background: rgba(16,185,129,.08); }
    .proto-diff-badge.medium { color: #f59e0b; background: rgba(245,158,11,.08); }
    .proto-diff-badge.hard   { color: var(--rv-accent); background: rgba(255,92,122,.08); }
    .proto-diff-badge.extreme{ color: #8b5cf6; background: rgba(139,92,246,.08); }
    .proto-header { display: flex; align-items: center; gap: .55rem; margin-bottom: .1rem; }
    .proto-icon { font-size: 1.25rem; line-height: 1; }
    .proto-name {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 1.05rem; font-weight: 800;
      transition: color .2s;
    }
    .proto-window {
      font-family: 'Geist Mono', monospace;
      font-size: .65rem; font-weight: 600; color: var(--rv-muted);
    }
    .proto-desc {
      font-size: .72rem; color: var(--rv-muted); line-height: 1.5; margin-top: .2rem;
    }
    .proto-start-wrap { margin-top: 1.25rem; text-align: center; }

    /* ── Fasting stages science ──────────────────────────── */
    .stages-section {
      background: var(--rv-card); border: 1px solid var(--rv-line);
      border-radius: 20px; overflow: hidden;
      margin-bottom: 1.5rem;
      animation: fadeUp .4s .12s ease both;
    }
    .stages-head {
      display: flex; align-items: center; gap: .75rem;
      padding: 1.1rem 1.5rem; border-bottom: 1px solid var(--rv-line);
    }
    .sh-icon {
      width: 36px; height: 36px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; font-size: .95rem;
    }
    .sh-title {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: .95rem; font-weight: 700;
    }
    .stage-item {
      display: flex; align-items: flex-start; gap: 1rem;
      padding: 1rem 1.5rem; border-bottom: 1px solid var(--rv-line);
      transition: all .25s; position: relative;
    }
    .stage-item:last-child { border-bottom: none; }
    .stage-item.current { background: rgba(255,92,122,.03); }
    .stage-item.past { opacity: .5; }
    .stage-icon-wrap {
      width: 40px; height: 40px; border-radius: 11px;
      flex-shrink: 0; display: flex; align-items: center; justify-content: center;
      font-size: 1rem; border: 2px solid transparent; transition: all .4s;
    }
    .stage-time {
      font-family: 'Geist Mono', monospace;
      font-size: .72rem; font-weight: 700; color: var(--rv-muted);
      flex-shrink: 0; min-width: 32px; margin-top: .3rem;
    }
    .stage-content { flex: 1; }
    .stage-name {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-weight: 700; font-size: .88rem; margin-bottom: .15rem;
      transition: color .3s;
    }
    .stage-desc { font-size: .74rem; color: var(--rv-muted); line-height: 1.55; }
    .stage-current-badge {
      display: inline-flex; align-items: center; gap: .3rem;
      background: rgba(255,92,122,.08); border: 1px solid rgba(255,92,122,.2);
      border-radius: 6px; padding: .15rem .5rem;
      font-family: 'Geist Mono', monospace;
      font-size: .6rem; font-weight: 700;
      color: var(--rv-accent); margin-top: .3rem;
    }
    .stage-connector {
      position: absolute;
      left: calc(1.5rem + 20px); top: calc(40px + 1rem);
      width: 2px; height: calc(100% - 40px - 1rem + .5rem);
      background: var(--rv-line);
    }

    /* ── Stats row ───────────────────────────────────────── */
    .stats-row {
      display: grid; grid-template-columns: repeat(4,1fr); gap: 1rem;
      margin-bottom: 1.5rem;
      animation: fadeUp .4s .16s ease both;
    }
    .stat-card {
      background: var(--rv-card); border: 1px solid var(--rv-line);
      border-radius: 14px; padding: 1.1rem; text-align: center;
      transition: all .2s;
    }
    .stat-card:hover { border-color: var(--rv-ink-soft); transform: translateY(-2px); }
    .sc-icon { font-size: 1.25rem; margin-bottom: .4rem; }
    .sc-val {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 1.6rem; font-weight: 800;
      line-height: 1; margin-bottom: .2rem;
    }
    .sc-lbl {
      font-family: 'Geist Mono', monospace;
      font-size: .6rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: .07em; color: var(--rv-muted);
    }

    /* ── History ─────────────────────────────────────────── */
    .history-section {
      background: var(--rv-card); border: 1px solid var(--rv-line);
      border-radius: 20px; overflow: hidden;
      animation: fadeUp .4s .2s ease both;
      margin-bottom: 1.5rem;
    }
    .hist-item {
      display: flex; align-items: center; gap: 1rem;
      padding: 1rem 1.5rem; border-bottom: 1px solid var(--rv-line);
      transition: background .15s;
    }
    .hist-item:last-child { border-bottom: none; }
    .hist-item:hover { background: var(--rv-bg-alt); }
    .hist-proto {
      width: 50px; height: 50px; border-radius: 11px;
      flex-shrink: 0; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      background: var(--rv-bg-alt); border: 1px solid var(--rv-line);
    }
    .hist-proto-name {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: .8rem; font-weight: 800; color: var(--rv-ink); line-height: 1;
    }
    .hist-proto-sub {
      font-family: 'Geist Mono', monospace;
      font-size: .55rem; font-weight: 600; color: var(--rv-muted);
    }
    .hist-info { flex: 1; min-width: 0; }
    .hist-date { font-weight: 700; font-size: .85rem; margin-bottom: .15rem; }
    .hist-dur {
      font-family: 'Geist Mono', monospace;
      font-size: .68rem; color: var(--rv-muted); margin-bottom: .4rem;
    }
    .hist-bar-wrap { display: flex; align-items: center; gap: .5rem; }
    .hist-bar-track { flex: 1; height: 5px; background: var(--rv-bg-alt); border-radius: 99px; overflow: hidden; }
    .hist-bar-fill  { height: 100%; border-radius: 99px; transition: width .6s ease; }
    .hist-bar-pct {
      font-family: 'Geist Mono', monospace;
      font-size: .62rem; font-weight: 700; min-width: 30px; text-align: right;
    }
    .hist-check {
      width: 30px; height: 30px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: .88rem; font-weight: 800; flex-shrink: 0;
    }
    .hist-check.done    { background: rgba(16,185,129,.1); color: #10b981; border: 1.5px solid rgba(16,185,129,.2); }
    .hist-check.partial { background: rgba(245,158,11,.1); color: #f59e0b; border: 1.5px solid rgba(245,158,11,.2); }

    /* ── Science panels ──────────────────────────────────── */
    .science-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
      margin-bottom: 1.5rem;
      animation: fadeUp .4s .24s ease both;
    }
    .sci-card {
      background: var(--rv-card); border: 1px solid var(--rv-line);
      border-radius: 16px; padding: 1.25rem; transition: all .2s;
    }
    .sci-card:hover { border-color: var(--rv-ink-soft); }
    .sci-icon { font-size: 1.4rem; margin-bottom: .55rem; }
    .sci-title {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-weight: 700; font-size: .9rem; margin-bottom: .4rem;
    }
    .sci-text { font-size: .76rem; color: var(--rv-muted); line-height: 1.6; }
    .sci-text strong { color: var(--rv-ink); }

    /* ── Toast ───────────────────────────────────────────── */
    .toast {
      position: fixed; top: 1.25rem; right: 1.5rem; z-index: 9999;
      padding: .7rem 1.1rem; border-radius: 10px;
      font-family: 'Geist Mono', monospace;
      font-weight: 600; font-size: .72rem;
      box-shadow: 0 10px 30px rgba(0,0,0,.12);
      transform: translateX(120px); opacity: 0;
      pointer-events: none; transition: all .3s;
    }
    .toast.show { transform: translateX(0); opacity: 1; }
    .toast-s, .toast-g { background: var(--rv-ink); color: var(--rv-bg); }
    .toast-e { background: #ef4444; color: #fff; }

    /* ── Complete overlay ────────────────────────────────── */
    .complete-overlay {
      display: none; position: fixed; inset: 0; z-index: 9999;
      background: rgba(250,246,241,.97);
      backdrop-filter: blur(20px);
      flex-direction: column; align-items: center;
      justify-content: center; text-align: center; padding: 2rem;
    }
    [data-theme="dark"] .complete-overlay { background: rgba(15,11,9,.97); }
    .complete-overlay.show { display: flex; animation: fadeIn .5s ease both; }
    .co-ring { position: relative; width: 140px; height: 140px; margin: 0 auto 1.5rem; }
    .co-ring svg { transform: rotate(-90deg); }
    .co-ring-label { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 2.5rem; }
    .co-title {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 2.2rem; font-weight: 800; margin-bottom: .6rem;
      animation: bounceIn .6s ease both;
    }
    .co-title em {
      font-style: italic;
      color: var(--rv-accent);
    }
    .co-stats { display: flex; gap: .75rem; justify-content: center; margin: 1.25rem 0; flex-wrap: wrap; }
    .co-stat {
      padding: .65rem 1.1rem;
      background: var(--rv-bg-alt); border: 1px solid var(--rv-line);
      border-radius: 12px; text-align: center;
    }
    .co-stat-val {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 1.5rem; font-weight: 800; color: var(--rv-accent);
    }
    .co-stat-lbl {
      font-family: 'Geist Mono', monospace;
      font-size: .6rem; font-weight: 600; color: var(--rv-muted);
      text-transform: uppercase; letter-spacing: .07em;
    }
    .co-btns { display: flex; gap: .65rem; flex-wrap: wrap; justify-content: center; margin-top: 1.25rem; }
    .co-btn-primary {
      display: inline-flex; align-items: center; gap: .5rem;
      padding: .8rem 1.5rem; border-radius: 11px;
      background: var(--rv-ink); color: var(--rv-bg);
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-weight: 800; font-size: .88rem;
      text-decoration: none; transition: opacity .2s;
    }
    .co-btn-primary:hover { opacity: .85; }
    .co-btn-ghost {
      display: inline-flex; align-items: center; gap: .5rem;
      padding: .8rem 1.5rem; border-radius: 11px;
      background: var(--rv-bg-alt); border: 1.5px solid var(--rv-line);
      color: var(--rv-ink-soft);
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-weight: 700; font-size: .88rem;
      cursor: pointer; transition: all .2s;
    }
    .co-btn-ghost:hover { border-color: var(--rv-ink-soft); }

    @media (max-width: 700px) {
      .protocol-grid { grid-template-columns: 1fr 1fr; }
      .stats-row     { grid-template-columns: 1fr 1fr; }
      .science-grid  { grid-template-columns: 1fr; }
      .timer-display { font-size: 2.1rem; }
      .ring-wrap     { width: 190px; height: 190px; }
    }
    @media (max-width: 480px) {
      .burn-strip { flex-wrap: wrap; }
      .burn-stage { flex: 0 0 calc(50% - .25rem); }
    }
  </style>
</head>
<body>

<div class="rv-shell">
  <Sidebar userName={userName} planType={planType} tierLabel={tierLabel} currentDay={currentDay} activePage="fasting" />

  <div class="rv-main">
    <div class="rv-inner">

      <!-- HEADER -->
      <div class="rv-hd">
        <div>
          <div class="rv-hd-title">Fasting Timer</div>
          <div class="rv-hd-sub">{activeSession ? 'Fast in progress' : 'Choose a protocol and start'}</div>
        </div>
      </div>

      <!-- TIMER HERO -->
      <div class="timer-hero" id="timerHero">
        <div class="active-badge">
          <span class="active-dot"></span>
          <span>FASTING ACTIVE</span>
        </div>

        <div class="stage-pill" id="stagePill" style="color:var(--rv-muted);background:var(--rv-bg-alt);border-color:var(--rv-line);">
          <span class="stage-dot"></span>
          <span id="stagePillText">Ready to fast</span>
        </div>

        <div class="ring-wrap" id="ringWrap">
          <svg class="ring-svg" viewBox="0 0 240 240" aria-hidden="true">
            <circle class="ring-outer-pulse" cx="120" cy="120" r="113"/>
            <circle class="ring-track" cx="120" cy="120" r="105"/>
            <circle class="ring-glow"     id="ringGlow"     cx="120" cy="120" r="105" stroke="var(--rv-muted)"/>
            <circle class="ring-progress" id="ringProgress" cx="120" cy="120" r="105" stroke="var(--rv-accent)"/>
          </svg>
          <div class="ring-center">
            <div class="timer-display" id="timerDisplay" style="color:var(--rv-muted);">00:00:00</div>
            <div class="timer-of" id="timerOf">Start your fast</div>
            <div class="timer-pct" id="timerPct"></div>
          </div>
        </div>

        <p class="stage-status" id="stageStatus">
          Choose your fasting protocol below, then tap <strong>Start Fast</strong> to begin.
        </p>

        <div class="burn-strip" id="burnStrip">
          <div class="burn-stage" id="bs0" data-min="0" data-max="4">
            <span class="bs-emoji">⏱️</span>
            <span class="bs-name">Glycogen<br>Depleting</span>
          </div>
          <div class="burn-stage" id="bs1" data-min="4" data-max="8">
            <span class="bs-emoji">🔥</span>
            <span class="bs-name">Fat Burning<br>Begins</span>
          </div>
          <div class="burn-stage" id="bs2" data-min="8" data-max="16">
            <span class="bs-emoji">⚡</span>
            <span class="bs-name">Deep<br>Fat Burn</span>
          </div>
          <div class="burn-stage" id="bs3" data-min="16" data-max="999">
            <span class="bs-emoji">🧬</span>
            <span class="bs-name">Autophagy<br>Zone</span>
          </div>
        </div>

        <div class="start-picker" id="startPicker">
          <span class="sp-label">Fast started:</span>
          <div class="sp-btns">
            <button class="sp-btn active" data-offset="0" onclick="setStartOffset(this,0)">Now</button>
            <button class="sp-btn" data-offset="1"  onclick="setStartOffset(this,1)">1h ago</button>
            <button class="sp-btn" data-offset="2"  onclick="setStartOffset(this,2)">2h ago</button>
            <button class="sp-btn" data-offset="4"  onclick="setStartOffset(this,4)">4h ago</button>
            <button class="sp-btn" data-offset="8"  onclick="setStartOffset(this,8)">8h ago</button>
          </div>
          <input type="time" class="sp-time-input" id="customStartTime" title="Custom start time"/>
        </div>

        <div class="timer-actions">
          <button class="btn-start" id="startBtn" onclick="startFast()">
            ▶ Start Fast
          </button>
          <button class="btn-end" id="endBtn" style="display:none;" onclick="endFast()">
            ■ End Fast
          </button>
          <button class="btn-ghost" id="resetBtn" style="display:none;" onclick="resetFast()">
            ↺ Reset
          </button>
        </div>
      </div>

      <!-- PROTOCOL CARDS -->
      <div class="protocol-section" id="protocolSection">
        <div class="rv-sec-lbl">Choose Your Protocol</div>
        <div class="protocol-grid">
          {[
            { val:'16_8', hours:16, icon:'⏰', name:'16:8', window:'Fast 16h · Eat in 8h window', desc:'The most popular keto fasting protocol. Effective for fat loss and easy to maintain long-term.', diff:'Easy', diffClass:'easy' },
            { val:'18_6', hours:18, icon:'🔥', name:'18:6', window:'Fast 18h · Eat in 6h window', desc:'Faster ketosis and deeper fat oxidation. A natural step up from 16:8 once adapted.', diff:'Medium', diffClass:'medium' },
            { val:'20_4', hours:20, icon:'💪', name:'20:4', window:'Fast 20h · Eat in 4h window', desc:'Extended fat-burning window with strong autophagy benefits. Best for experienced fasters.', diff:'Hard', diffClass:'hard' },
            { val:'omad', hours:23, icon:'⚡', name:'OMAD 23:1', window:'Fast 23h · One meal a day', desc:'Maximum metabolic impact. One eating window per day. Elite-level discipline required.', diff:'Extreme', diffClass:'extreme' },
          ].map(p => (
            <div class={`proto-card${p.val === defaultProtocol ? ' active' : ''}`}
              data-protocol={p.val} data-hours={p.hours} onclick="selectProtocol(this)">
              <div class={`proto-diff-badge ${p.diffClass}`}>{p.diff}</div>
              <div class="proto-header">
                <span class="proto-icon">{p.icon}</span>
                <span class="proto-name">{p.name}</span>
              </div>
              <div class="proto-window">{p.window}</div>
              <div class="proto-desc">{p.desc}</div>
            </div>
          ))}
        </div>
        <div class="proto-start-wrap">
          <button class="btn-start" onclick="startFast()">▶ Start Fast</button>
        </div>
      </div>

      <!-- FASTING STAGES SCIENCE -->
      <div class="stages-section">
        <div class="stages-head">
          <div class="sh-icon" style="background:rgba(255,92,122,.1);">📈</div>
          <div class="sh-title">What Happens to Your Body</div>
        </div>
        {[
          { h:0,  color:'#6b7280', icon:'🍽️', name:'Fed State',          desc:'Insulin is elevated. Your body is digesting nutrients from your last meal. Fat burning is minimal.',                                              key:'fed'       },
          { h:4,  color:'#10b981', icon:'📉', name:'Insulin Drops',       desc:'Blood sugar normalizes. Insulin falls. Your body begins transitioning from glucose to fat as its primary fuel source.',                           key:'insulin'   },
          { h:8,  color:'#3b82f6', icon:'⚡', name:'Glycogen Depletion',  desc:'Liver glycogen (stored carbs) starts running out. Your body is forced to find alternative fuel — enter: fat burning.',                           key:'glycogen'  },
          { h:12, color:'#f59e0b', icon:'🔥', name:'Fat Burning Begins',  desc:'Ketone production begins. Free fatty acids are released from fat cells. You enter a mild ketogenic state.',                                     key:'burning'   },
          { h:16, color:'#f97316', icon:'🔆', name:'Ketosis Deepens',     desc:'Full metabolic shift to fat. Brain switches to ketones for fuel. Mental clarity improves. This is the keto sweet spot.',                        key:'ketosis'   },
          { h:18, color:'#ef4444', icon:'🧹', name:'Autophagy Activates', desc:'Your cells begin cleaning house — breaking down damaged proteins and cellular waste. Anti-aging effects begin. This is powerful.',               key:'autophagy' },
          { h:24, color:'#8b5cf6', icon:'🌌', name:'Deep Autophagy',      desc:'Maximum cellular repair mode. Growth hormone spikes by up to 2000%. Stem cell regeneration increases. The deep healing zone.',                   key:'deep'      },
        ].map((stage, idx) => (
          <div class="stage-item" id={`stage-${stage.key}`} style="position:relative;">
            {idx < 6 && <div class="stage-connector"></div>}
            <div class="stage-icon-wrap" id={`sicon-${stage.key}`} style={`background:${stage.color}15;border-color:${stage.color}25;`}>
              {stage.icon}
            </div>
            <div class="stage-time" style={`color:${stage.color};`}>{stage.h}h</div>
            <div class="stage-content">
              <div class="stage-name" id={`sname-${stage.key}`}>{stage.name}</div>
              <div class="stage-desc">{stage.desc}</div>
              <div class="stage-current-badge" id={`sbadge-${stage.key}`} style="display:none;">
                <span>●</span> You are here
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- STATS -->
      <div class="stats-row">
        <div class="stat-card">
          <div class="sc-icon">🔥</div>
          <div class="sc-val" style="color:var(--rv-accent-3);">{totalFasts}</div>
          <div class="sc-lbl">Total Fasts</div>
        </div>
        <div class="stat-card">
          <div class="sc-icon">✅</div>
          <div class="sc-val" style="color:#10b981;">{completedFasts}</div>
          <div class="sc-lbl">Completed</div>
        </div>
        <div class="stat-card">
          <div class="sc-icon">⏱️</div>
          <div class="sc-val" style="color:var(--rv-blue, #4E80EE);">{avgFastHours}h</div>
          <div class="sc-lbl">Avg Duration</div>
        </div>
        <div class="stat-card">
          <div class="sc-icon">⚡</div>
          <div class="sc-val" style="color:#8b5cf6;">{Math.round(totalFastHours)}h</div>
          <div class="sc-lbl">Total Hours</div>
        </div>
      </div>

      <!-- HISTORY -->
      {hasHistory && (
        <div class="history-section">
          <div class="stages-head">
            <div class="sh-icon" style="background:rgba(139,92,246,.1);">📅</div>
            <div class="sh-title">Recent Sessions</div>
          </div>
          {historyRows.map(row => (
            <div class="hist-item">
              <div class="hist-proto">
                <div class="hist-proto-name">{row.protoName}</div>
                <div class="hist-proto-sub">fast</div>
              </div>
              <div class="hist-info">
                <div class="hist-date">{row.dateStr} at {row.timeStr}</div>
                <div class="hist-dur">{row.hrs > 0 ? row.hrs.toFixed(1) + 'h of ' + row.target + 'h target' : 'In progress'}</div>
                <div class="hist-bar-wrap">
                  <div class="hist-bar-track">
                    <div class="hist-bar-fill" style={`width:${row.pct}%;background:${row.barColor};`}></div>
                  </div>
                  <span class="hist-bar-pct" style={`color:${row.barColor};`}>{row.pct}%</span>
                </div>
              </div>
              <div class={`hist-check ${row.checkClass}`}>{row.checkIcon}</div>
            </div>
          ))}
        </div>
      )}

      <!-- SCIENCE PANELS -->
      <div class="science-grid">
        <div class="sci-card">
          <div class="sci-icon">🧠</div>
          <div class="sci-title">Fasting + Keto = Supercharged</div>
          <div class="sci-text">Combining intermittent fasting with a keto diet creates a <strong>dual metabolic advantage</strong>. Keto primes your body to burn fat, while fasting depletes glycogen stores faster — meaning you reach deep ketosis in hours, not days.</div>
        </div>
        <div class="sci-card">
          <div class="sci-icon">📈</div>
          <div class="sci-title">Why 16+ Hours Matters</div>
          <div class="sci-text">The most significant metabolic benefits — <strong>autophagy, growth hormone release, and deep fat oxidation</strong> — only kick in after 16 hours. The first 12 hours are just clearing the runway. Push past 16h for the real magic.</div>
        </div>
        <div class="sci-card">
          <div class="sci-icon">💧</div>
          <div class="sci-title">What to Consume While Fasting</div>
          <div class="sci-text"><strong>Water, black coffee, plain tea, and electrolytes</strong> are fasting-safe. Salt + potassium + magnesium prevent energy crashes. Avoid anything with calories or sweeteners.</div>
        </div>
        <div class="sci-card">
          <div class="sci-icon">⚠️</div>
          <div class="sci-title">When to Break Your Fast</div>
          <div class="sci-text"><strong>Extreme dizziness, heart palpitations, or fainting</strong> are signals to eat. Break your fast with something small — a few nuts or an egg. These symptoms usually mean electrolyte imbalance, not weakness.</div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- COMPLETE OVERLAY -->
<div class="complete-overlay" id="completeOverlay">
  <div class="co-ring">
    <svg width="140" height="140" viewBox="0 0 140 140">
      <circle cx="70" cy="70" r="60" fill="none" stroke="var(--rv-line)" stroke-width="8"/>
      <circle cx="70" cy="70" r="60" fill="none" stroke="var(--rv-accent)" stroke-width="8" stroke-linecap="round" stroke-dasharray="377" stroke-dashoffset="0"/>
    </svg>
    <div class="co-ring-label">🏆</div>
  </div>
  <h2 class="co-title">Fast <em>complete!</em></h2>
  <p style="color:var(--rv-muted);font-size:.88rem;max-width:360px;line-height:1.6;margin-bottom:1rem;" id="coMessage">You crushed it. Your body just unlocked deep fat-burning mode.</p>
  <div class="co-stats">
    <div class="co-stat"><div class="co-stat-val" id="coHours">—</div><div class="co-stat-lbl">Hours Fasted</div></div>
    <div class="co-stat"><div class="co-stat-val" id="coStage">—</div><div class="co-stat-lbl">Stage Reached</div></div>
    <div class="co-stat"><div class="co-stat-val" id="coXP">+50</div><div class="co-stat-lbl">XP Earned</div></div>
  </div>
  <div class="co-btns">
    <a href="/dashboard" class="co-btn-primary">← Back to Dashboard</a>
    <button onclick="newFast()" class="co-btn-ghost">▶ Fast Again</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script is:inline define:vars={{ defaultProtocol, activeSessionData, userName }}>
var STAGES = [
  { key:'fed',       h:0,  color:'#6b7280', name:'Fed State',          emoji:'🍽️' },
  { key:'insulin',   h:4,  color:'#10b981', name:'Insulin Drops',      emoji:'📉' },
  { key:'glycogen',  h:8,  color:'#3b82f6', name:'Glycogen Depletion', emoji:'⚡' },
  { key:'burning',   h:12, color:'#f59e0b', name:'Fat Burning',        emoji:'🔥' },
  { key:'ketosis',   h:16, color:'#f97316', name:'Deep Ketosis',       emoji:'🔆' },
  { key:'autophagy', h:18, color:'#ef4444', name:'Autophagy',          emoji:'🧹' },
  { key:'deep',      h:24, color:'#8b5cf6', name:'Deep Autophagy',     emoji:'🌌' },
];
var BURN_STAGES = [
  { id:'bs0', min:0,  max:4   },
  { id:'bs1', min:4,  max:8   },
  { id:'bs2', min:8,  max:16  },
  { id:'bs3', min:16, max:999 },
];
var RING_CIRC = 2 * Math.PI * 105;

var state = {
  active: false, startTime: null,
  targetHours: 16, protocol: defaultProtocol || '16_8',
  startOffset: 0, sessionId: null,
};
window.fastTimer = null;

if (activeSessionData) {
  state.active      = true;
  state.startTime   = new Date(activeSessionData.started_at);
  state.targetHours = activeSessionData.target_hours || 16;
  state.protocol    = activeSessionData.protocol || '16_8';
  state.sessionId   = activeSessionData.id;
  selectProtocol(document.querySelector('[data-protocol="' + state.protocol + '"]'), false);
  showRunningUI();
  startTicking();
}

function selectProtocol(el, updateState) {
  if (!el) return;
  if (typeof updateState === 'undefined') updateState = true;
  document.querySelectorAll('.proto-card').forEach(function(c){ c.classList.remove('active'); });
  el.classList.add('active');
  if (updateState) {
    state.protocol    = el.dataset.protocol;
    state.targetHours = parseInt(el.dataset.hours) || 16;
    var ofEl = document.getElementById('timerOf');
    if (ofEl && !state.active) ofEl.textContent = 'of ' + state.targetHours + ' hours';
  }
}
window.selectProtocol = selectProtocol;

function setStartOffset(el, hours) {
  document.querySelectorAll('.sp-btn').forEach(function(b){ b.classList.remove('active'); });
  el.classList.add('active');
  state.startOffset = hours;
  var d = new Date(); d.setHours(d.getHours() - hours);
  document.getElementById('customStartTime').value =
    d.getHours().toString().padStart(2,'0') + ':' + d.getMinutes().toString().padStart(2,'0');
}
window.setStartOffset = setStartOffset;

document.getElementById('customStartTime').addEventListener('change', function() {
  var parts = this.value.split(':').map(Number);
  var now = new Date(); var start = new Date();
  start.setHours(parts[0], parts[1], 0, 0);
  if (start > now) start.setDate(start.getDate() - 1);
  state.startOffset = (now - start) / 3600000;
  document.querySelectorAll('.sp-btn').forEach(function(b){ b.classList.remove('active'); });
});

var initNow = new Date();
document.getElementById('customStartTime').value =
  initNow.getHours().toString().padStart(2,'0') + ':' + initNow.getMinutes().toString().padStart(2,'0');

function startFast() {
  var offsetMs = state.startOffset * 3600000;
  state.startTime = new Date(Date.now() - offsetMs);
  state.active = true;
  fetch('/api/fasting/start', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ protocol: state.protocol, target_hours: state.targetHours, started_at: state.startTime.toISOString() }),
  }).then(function(res){ return res.json(); }).then(function(data){ if (data.id) state.sessionId = data.id; }).catch(function(){});
  showRunningUI(); startTicking();
  showToast('Fast started! Stay strong, ' + userName + '.', 's');
}
window.startFast = startFast;

function endFast() {
  if (!state.active) return;
  clearInterval(window.fastTimer); window.fastTimer = null;
  var elapsed = getElapsedHours();
  var completed = elapsed >= state.targetHours;
  fetch('/api/fasting/end', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ session_id: state.sessionId, ended_at: new Date().toISOString(), actual_hours: elapsed, completed: completed }),
  }).catch(function(){});
  var stage = getCurrentStage(elapsed);
  document.getElementById('coHours').textContent = elapsed.toFixed(1) + 'h';
  document.getElementById('coStage').textContent = stage.emoji + ' ' + stage.name;
  var xp = completed ? 50 + Math.round(elapsed * 2) : 20;
  document.getElementById('coXP').textContent = '+' + xp;
  document.getElementById('coMessage').textContent = completed
    ? 'You hit your ' + state.targetHours + 'h goal! Your body reached ' + stage.name + '. Incredible.'
    : elapsed.toFixed(1) + 'h is still a win. Every fast builds your metabolic flexibility.';
  document.getElementById('completeOverlay').classList.add('show');
  resetState();
}
window.endFast = endFast;

function resetFast() {
  if (state.active && !confirm('Reset your current fast?')) return;
  clearInterval(window.fastTimer); window.fastTimer = null;
  resetState(); showIdleUI(); showToast('Timer reset.', 's');
}
window.resetFast = resetFast;

function newFast() {
  document.getElementById('completeOverlay').classList.remove('show');
  resetState(); showIdleUI();
}
window.newFast = newFast;

function resetState() {
  state.active = false; state.startTime = null;
  state.sessionId = null; state.startOffset = 0;
}

function startTicking() { clearInterval(window.fastTimer); tick(); window.fastTimer = setInterval(tick, 1000); }
function getElapsedHours() { return state.startTime ? (Date.now() - state.startTime.getTime()) / 3600000 : 0; }
function getCurrentStage(hours) {
  var current = STAGES[0];
  for (var i = 0; i < STAGES.length; i++) { if (hours >= STAGES[i].h) current = STAGES[i]; else break; }
  return current;
}

function tick() {
  if (!state.startTime) return;
  var elapsed = getElapsedHours(); var target = state.targetHours;
  var pct = Math.min(elapsed / target, 1); var stage = getCurrentStage(elapsed);
  var dispH = Math.floor(elapsed);
  var dispM = Math.floor((elapsed % 1) * 60);
  var dispS = Math.floor(((elapsed * 60) % 1) * 60);
  document.getElementById('timerDisplay').textContent =
    dispH.toString().padStart(2,'0') + ':' + dispM.toString().padStart(2,'0') + ':' + dispS.toString().padStart(2,'0');
  document.getElementById('timerDisplay').style.color = stage.color;
  var ofEl = document.getElementById('timerOf');
  ofEl.textContent = elapsed >= target ? 'Goal reached! 🎉' : 'of ' + target + ' hours';
  document.getElementById('timerPct').textContent = Math.round(pct * 100) + '% complete';
  var offset = RING_CIRC * (1 - pct);
  document.getElementById('ringProgress').style.strokeDashoffset = offset;
  document.getElementById('ringProgress').style.stroke = stage.color;
  document.getElementById('ringGlow').style.strokeDashoffset = offset;
  document.getElementById('ringGlow').style.stroke = stage.color;
  document.getElementById('stagePill').style.color = stage.color;
  document.getElementById('stagePill').style.background = stage.color + '15';
  document.getElementById('stagePill').style.borderColor = stage.color + '40';
  document.getElementById('stagePillText').textContent = stage.emoji + ' ' + stage.name;
  var nextStage = null;
  for (var i = 0; i < STAGES.length; i++) { if (STAGES[i].h > elapsed) { nextStage = STAGES[i]; break; } }
  if (nextStage) {
    var hoursLeft = nextStage.h - elapsed; var minsLeft = Math.round(hoursLeft * 60);
    var untilMsg = minsLeft > 60
      ? '<strong>' + Math.floor(hoursLeft) + 'h ' + (minsLeft % 60) + 'm</strong> until <strong>' + nextStage.emoji + ' ' + nextStage.name + '</strong>.'
      : 'Only <strong>' + minsLeft + ' minutes</strong> until <strong>' + nextStage.emoji + ' ' + nextStage.name + '</strong>!';
    document.getElementById('stageStatus').innerHTML = 'You\'re in <strong style="color:' + stage.color + '">' + stage.name + '</strong>. ' + untilMsg;
  } else {
    document.getElementById('stageStatus').innerHTML = '🌌 <strong>Deep Autophagy</strong> — Maximum cellular repair is happening right now.';
  }
  for (var j = 0; j < STAGES.length; j++) {
    var s = STAGES[j];
    var item = document.getElementById('stage-' + s.key);
    var icon = document.getElementById('sicon-' + s.key);
    var badge= document.getElementById('sbadge-' + s.key);
    if (!item) continue;
    item.classList.remove('current', 'past');
    if (s.key === stage.key) {
      item.classList.add('current');
      icon.style.borderColor = s.color;
      icon.style.boxShadow = '0 0 0 4px ' + s.color + '18, 0 4px 12px ' + s.color + '35';
      badge.style.display = 'inline-flex';
    } else if (elapsed >= s.h) {
      item.classList.add('past');
      icon.style.borderColor = s.color + '60';
      badge.style.display = 'none';
    } else {
      icon.style.borderColor = 'transparent';
      icon.style.boxShadow = 'none';
      badge.style.display = 'none';
    }
  }
  for (var k = 0; k < BURN_STAGES.length; k++) {
    var bs = BURN_STAGES[k]; var bsEl = document.getElementById(bs.id);
    if (!bsEl) continue;
    bsEl.classList.remove('bs-active', 'bs-done');
    if (elapsed >= bs.min && elapsed < bs.max) bsEl.classList.add('bs-active');
    else if (elapsed >= bs.max) bsEl.classList.add('bs-done');
  }
  if (pct >= 1 && !document.getElementById('completeOverlay').classList.contains('show')) {
    showToast('🏆 You hit your fasting goal!', 'g');
  }
}

function showRunningUI() {
  document.getElementById('timerHero').classList.add('is-active');
  document.getElementById('startBtn').style.display = 'none';
  document.getElementById('endBtn').style.display = 'flex';
  document.getElementById('resetBtn').style.display = 'flex';
  document.getElementById('startPicker').style.display = 'none';
  document.getElementById('protocolSection').style.opacity = '.4';
  document.getElementById('protocolSection').style.pointerEvents = 'none';
  document.getElementById('burnStrip').style.display = 'flex';
}

function showIdleUI() {
  document.getElementById('timerHero').classList.remove('is-active');
  document.getElementById('startBtn').style.display = 'flex';
  document.getElementById('endBtn').style.display = 'none';
  document.getElementById('resetBtn').style.display = 'none';
  document.getElementById('startPicker').style.display = 'flex';
  document.getElementById('burnStrip').style.display = 'none';
  document.getElementById('timerDisplay').textContent = '00:00:00';
  document.getElementById('timerDisplay').style.color = 'var(--rv-muted)';
  document.getElementById('timerOf').textContent = 'of ' + state.targetHours + ' hours';
  document.getElementById('timerPct').textContent = '';
  document.getElementById('stagePillText').textContent = 'Ready to fast';
  document.getElementById('stagePill').style.color = 'var(--rv-muted)';
  document.getElementById('stagePill').style.background = 'var(--rv-bg-alt)';
  document.getElementById('stagePill').style.borderColor = 'var(--rv-line)';
  document.getElementById('stageStatus').innerHTML = 'Choose your protocol below, then tap <strong>Start Fast</strong> to begin.';
  document.getElementById('ringProgress').style.strokeDashoffset = RING_CIRC;
  document.getElementById('ringGlow').style.strokeDashoffset = RING_CIRC;
  document.getElementById('ringProgress').style.stroke = 'var(--rv-accent)';
  document.getElementById('ringGlow').style.stroke = 'var(--rv-accent)';
  document.getElementById('protocolSection').style.opacity = '1';
  document.getElementById('protocolSection').style.pointerEvents = 'auto';
  for (var i = 0; i < STAGES.length; i++) {
    var item = document.getElementById('stage-' + STAGES[i].key);
    var icon = document.getElementById('sicon-' + STAGES[i].key);
    var bdg  = document.getElementById('sbadge-' + STAGES[i].key);
    if (item) item.classList.remove('current', 'past');
    if (icon) { icon.style.borderColor = 'transparent'; icon.style.boxShadow = 'none'; }
    if (bdg)  bdg.style.display = 'none';
  }
  for (var j = 0; j < BURN_STAGES.length; j++) {
    var bsEl = document.getElementById(BURN_STAGES[j].id);
    if (bsEl) bsEl.classList.remove('bs-active', 'bs-done');
  }
}

function showToast(msg, type) {
  var t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast toast-' + (type || 's') + ' show';
  setTimeout(function(){ t.classList.remove('show'); }, 3500);
}

document.getElementById('ringProgress').style.strokeDashoffset = RING_CIRC;
document.getElementById('ringGlow').style.strokeDashoffset = RING_CIRC;
document.getElementById('timerOf').textContent = 'of ' + state.targetHours + ' hours';
document.getElementById('burnStrip').style.display = 'none';

window.addEventListener('beforeunload', function(){ clearInterval(window.fastTimer); window.fastTimer = null; });
document.addEventListener('visibilitychange', function(){
  if (document.hidden) { clearInterval(window.fastTimer); window.fastTimer = null; }
  else if (state.active) startTicking();
});
</script>
</body>
</html>
