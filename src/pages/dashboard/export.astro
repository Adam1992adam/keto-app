---
import { requireAuth } from '../../lib/auth';
import { getUserJourney } from '../../lib/supabase';
import DashNav from '../../components/DashNav.astro';
import Download from 'lucide-astro/Download';
import FileText from 'lucide-astro/FileText';
import BarChart3 from 'lucide-astro/BarChart3';
import Calendar from 'lucide-astro/Calendar';
import CheckCircle from 'lucide-astro/CheckCircle';
import Share2 from 'lucide-astro/Share2';
import Info from 'lucide-astro/Info';
import TrendingUp from 'lucide-astro/TrendingUp';
import Utensils from 'lucide-astro/Utensils';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? '👑 Elite' : planType === 'pro_6' ? '⚡ Pro' : '🥑 Basic';
const userName  = profile.full_name?.split(' ')[0] || 'there';

const journey    = await getUserJourney(user.id, db);
const currentDay = journey?.current_day || 1;

const imperial = (profile.preferred_units || 'imperial') === 'imperial';
const wUnit = imperial ? 'lbs' : 'kg';
const mUnit = imperial ? 'in'  : 'cm';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Export Data — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&display=swap" rel="stylesheet"/>
  <script is:inline>
    (function(){ var t = localStorage.getItem('keto-theme') || 'dark'; document.documentElement.setAttribute('data-theme', t); })();
  </script>
  <style>
    /* ── Design tokens ── */
    :root {
      --bg:      #060d09;
      --card:    #0d1a0f;
      --card2:   #111f13;
      --border:  rgba(16,185,129,.1);
      --border2: rgba(16,185,129,.22);
      --text:    #dfeedd;
      --soft:    #4d7055;
      --muted:   #233328;
      --green:   #10b981;
      --green2:  #34d399;
      --gold:    #f59e0b;
      --purple:  #8b5cf6;
      --blue:    #3b82f6;
      --red:     #ef4444;
      --nav-h:   64px;
    }
    [data-theme="light"] {
      --bg:      #eef5ee;
      --card:    #ffffff;
      --card2:   #f5faf5;
      --border:  rgba(0,0,0,.07);
      --border2: rgba(16,185,129,.3);
      --text:    #071807;
      --soft:    #3a6040;
      --muted:   #b8cfb8;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Layout ── */
    .page {
      max-width: 820px;
      margin: 0 auto;
      padding: calc(var(--nav-h) + 2rem) 1.5rem 6rem;
    }

    /* ── Page header ── */
    .page-header {
      margin-bottom: 2.5rem;
      animation: fadeUp .5s ease both;
    }
    .page-header h1 {
      font-family: 'Fraunces', serif;
      font-size: 2rem;
      font-weight: 900;
      color: var(--text);
      margin-bottom: .4rem;
    }
    .page-header h1 span { color: var(--green); }
    .page-header p {
      color: var(--soft);
      font-size: .95rem;
      max-width: 520px;
      line-height: 1.6;
    }

    /* ── Cards grid ── */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1.25rem;
    }

    /* ── Export card ── */
    .export-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 1.6rem 1.5rem 1.4rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      transition: transform .2s, border-color .2s, box-shadow .2s;
      animation: fadeUp .5s ease both;
    }
    .export-card:hover {
      transform: translateY(-3px);
      border-color: var(--border2);
      box-shadow: 0 8px 30px rgba(16,185,129,.07);
    }
    .export-card:nth-child(1) { animation-delay: .05s; }
    .export-card:nth-child(2) { animation-delay: .10s; }
    .export-card:nth-child(3) { animation-delay: .15s; }
    .export-card:nth-child(4) { animation-delay: .20s; }

    /* Card icon row */
    .card-icon-row {
      display: flex;
      align-items: center;
      gap: .75rem;
    }
    .card-icon {
      width: 46px;
      height: 46px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      flex-shrink: 0;
    }
    .icon-green  { background: rgba(16,185,129,.12); }
    .icon-blue   { background: rgba(59,130,246,.12); }
    .icon-purple { background: rgba(139,92,246,.12); }
    .icon-gold   { background: rgba(245,158,11,.12); }

    .card-title {
      font-weight: 800;
      font-size: 1.05rem;
      color: var(--text);
    }
    .card-subtitle {
      font-size: .75rem;
      color: var(--soft);
      margin-top: .1rem;
    }

    /* Description */
    .card-desc {
      font-size: .85rem;
      color: var(--soft);
      line-height: 1.6;
      flex: 1;
    }

    /* Column pills */
    .card-columns {
      display: flex;
      flex-wrap: wrap;
      gap: .35rem;
    }
    .col-pill {
      font-size: .68rem;
      font-weight: 700;
      padding: .2rem .55rem;
      border-radius: 99px;
      background: var(--card2);
      border: 1px solid var(--border);
      color: var(--soft);
      white-space: nowrap;
    }

    /* Download button */
    .btn-download {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .5rem;
      width: 100%;
      padding: .75rem 1.25rem;
      border-radius: 12px;
      border: 1px solid var(--border2);
      background: rgba(16,185,129,.08);
      color: var(--green);
      font-weight: 700;
      font-size: .88rem;
      cursor: pointer;
      transition: background .2s, transform .15s, box-shadow .2s;
      font-family: inherit;
    }
    .btn-download:hover {
      background: rgba(16,185,129,.16);
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(16,185,129,.12);
    }
    .btn-download:active { transform: scale(.98); }
    .btn-download.loading {
      opacity: .7;
      cursor: not-allowed;
      pointer-events: none;
    }
    .btn-download.loading::after {
      content: '';
      width: 14px;
      height: 14px;
      border: 2px solid var(--green);
      border-top-color: transparent;
      border-radius: 50%;
      animation: spin .7s linear infinite;
    }

    /* Info banner */
    .info-banner {
      margin-top: 2.5rem;
      padding: 1rem 1.25rem;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      display: flex;
      align-items: flex-start;
      gap: .75rem;
      font-size: .85rem;
      color: var(--soft);
      line-height: 1.6;
      animation: fadeUp .5s .25s ease both;
    }
    .info-banner-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: .05rem; }

    /* Toast */
    #export-toast {
      position: fixed;
      bottom: 5.5rem;
      left: 50%;
      transform: translateX(-50%) translateY(20px);
      background: var(--card2);
      border: 1px solid var(--border2);
      border-radius: 12px;
      padding: .65rem 1.2rem;
      font-size: .85rem;
      font-weight: 600;
      color: var(--green);
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s, transform .25s;
      z-index: 9999;
      white-space: nowrap;
    }
    #export-toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    #export-toast.error { color: var(--red); border-color: rgba(239,68,68,.3); }

    /* Animations */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    @media (max-width: 600px) {
      .page { padding-left: 1rem; padding-right: 1rem; }
      .cards-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<DashNav
  userId={user.id}
  userName={userName}
  tierLabel={tierLabel}
  planType={planType}
  activePage="profile"
/>

<main class="page">

  <!-- ── Page header ── -->
  <div class="page-header">
    <h1>Export <span>Your Data</span></h1>
    <p>Download your personal keto journey data as CSV files. Open them in Excel, Google Sheets, or any spreadsheet app.</p>
  </div>

  <!-- ── Export cards ── -->
  <div class="cards-grid">

    <!-- Weight Log -->
    <div class="export-card">
      <div class="card-icon-row">
        <div class="card-icon icon-green"><TrendingUp size={20} /></div>
        <div>
          <div class="card-title">Weight Log</div>
          <div class="card-subtitle">All your weigh-in records</div>
        </div>
      </div>
      <p class="card-desc">
        Every weight entry you've logged throughout your journey, sorted by date from oldest to newest.
      </p>
      <div class="card-columns">
        <span class="col-pill">Date</span>
        <span class="col-pill">Weight ({wUnit})</span>
      </div>
      <button class="btn-download" onclick="window.downloadExport('weight', this)">
        <Download size={15} style="vertical-align:middle;margin-right:.3rem;" /> Download CSV
      </button>
    </div>

    <!-- Daily Check-ins -->
    <div class="export-card">
      <div class="card-icon-row">
        <div class="card-icon icon-blue"><FileText size={20} /></div>
        <div>
          <div class="card-title">Daily Check-ins</div>
          <div class="card-subtitle">Energy, mood, symptoms & habits</div>
        </div>
      </div>
      <p class="card-desc">
        Your daily check-in history including energy levels, mood, hydration, symptoms like headaches or cravings, and whether you followed your meals.
      </p>
      <div class="card-columns">
        <span class="col-pill">Date</span>
        <span class="col-pill">Energy</span>
        <span class="col-pill">Mood</span>
        <span class="col-pill">Hunger</span>
        <span class="col-pill">Water</span>
        <span class="col-pill">Headache</span>
        <span class="col-pill">Fatigue</span>
        <span class="col-pill">Cravings</span>
        <span class="col-pill">XP Earned</span>
        <span class="col-pill">Note</span>
      </div>
      <button class="btn-download" onclick="window.downloadExport('checkins', this)">
        <Download size={15} style="vertical-align:middle;margin-right:.3rem;" /> Download CSV
      </button>
    </div>

    <!-- Food Log -->
    <div class="export-card">
      <div class="card-icon-row">
        <div class="card-icon icon-purple"><Utensils size={20} /></div>
        <div>
          <div class="card-title">Food Log</div>
          <div class="card-subtitle">Everything you've eaten</div>
        </div>
      </div>
      <p class="card-desc">
        Your complete food diary with full macro breakdown for every logged meal. Great for analysing your nutrition patterns over time.
      </p>
      <div class="card-columns">
        <span class="col-pill">Date</span>
        <span class="col-pill">Food Name</span>
        <span class="col-pill">Meal Type</span>
        <span class="col-pill">Calories</span>
        <span class="col-pill">Protein (g)</span>
        <span class="col-pill">Carbs (g)</span>
        <span class="col-pill">Fat (g)</span>
        <span class="col-pill">Serving</span>
      </div>
      <button class="btn-download" onclick="window.downloadExport('food', this)">
        <Download size={15} style="vertical-align:middle;margin-right:.3rem;" /> Download CSV
      </button>
    </div>

    <!-- Body Measurements -->
    <div class="export-card">
      <div class="card-icon-row">
        <div class="card-icon icon-gold"><BarChart3 size={20} /></div>
        <div>
          <div class="card-title">Body Measurements</div>
          <div class="card-subtitle">Neck, waist, hips & more</div>
        </div>
      </div>
      <p class="card-desc">
        All your body measurement snapshots over time. Track inches lost across six key measurement sites from the day you started.
      </p>
      <div class="card-columns">
        <span class="col-pill">Date</span>
        <span class="col-pill">Neck ({mUnit})</span>
        <span class="col-pill">Waist ({mUnit})</span>
        <span class="col-pill">Hips ({mUnit})</span>
        <span class="col-pill">Chest ({mUnit})</span>
        <span class="col-pill">Arm ({mUnit})</span>
        <span class="col-pill">Thigh ({mUnit})</span>
        <span class="col-pill">Notes</span>
      </div>
      <button class="btn-download" onclick="window.downloadExport('measurements', this)">
        <Download size={15} style="vertical-align:middle;margin-right:.3rem;" /> Download CSV
      </button>
    </div>

  </div>

  <!-- ── Info banner ── -->
  <div class="info-banner">
    <span class="info-banner-icon"><Info size={18} /></span>
    <span>
      CSV files open in Excel, Google Sheets, Numbers, or any text editor.
      Your data belongs to you — exported files contain only your personal records and are never shared.
    </span>
  </div>

</main>

<!-- Toast notification -->
<div id="export-toast"></div>

<script is:inline>
(function () {
  /* ── Show a brief toast message ── */
  function showToast(msg, isError) {
    var toast = document.getElementById('export-toast');
    if (!toast) return;
    toast.textContent = msg;
    toast.className = isError ? 'error show' : 'show';
    setTimeout(function () { toast.className = isError ? 'error' : ''; }, 3000);
  }

  /* ── Trigger a CSV download from a Blob ── */
  function triggerDownload(blob, filename) {
    var url = URL.createObjectURL(blob);
    var a   = document.createElement('a');
    a.href  = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    setTimeout(function () {
      URL.revokeObjectURL(url);
      document.body.removeChild(a);
    }, 500);
  }

  /* ── Filename map ── */
  var filenames = {
    weight:       'keto-weight.csv',
    checkins:     'keto-checkins.csv',
    food:         'keto-food-log.csv',
    measurements: 'keto-measurements.csv',
  };

  /* ── Main download handler — assigned to window so onclick can reach it ── */
  window.downloadExport = function (type, btn) {
    if (!type || !filenames[type]) return;

    /* Show loading state */
    var originalHtml = btn.innerHTML;
    btn.classList.add('loading');
    btn.innerHTML = 'Preparing…';

    fetch('/api/export/' + type, { credentials: 'include' })
      .then(function (res) {
        if (!res.ok) {
          return res.json().then(function (err) {
            throw new Error(err.error || 'Export failed');
          });
        }
        return res.blob();
      })
      .then(function (blob) {
        triggerDownload(blob, filenames[type]);
        showToast('Download started!', false);
      })
      .catch(function (err) {
        showToast(err.message || 'Export failed. Please try again.', true);
      })
      .finally(function () {
        btn.classList.remove('loading');
        btn.innerHTML = originalHtml;
      });
  };
})();
</script>

</body>
</html>
