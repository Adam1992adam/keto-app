  </style>

  <script is:inline define:vars={{ userName, planType, myProgressData }}>
  (function() {
    // ── State ────────────────────────────────────────────────────────
    var state    = { cat: 'all', page: 1, hasMore: false };
    var postMode = 'text';
    var pendingImgBase64 = null;
    var pendingImgType   = null;
    var myInitial        = userName.charAt(0).toUpperCase();
    var avatarColors     = ['#10b981','#3b82f6','#8b5cf6','#f59e0b','#ef4444','#06b6d4'];

    // ── Helpers ──────────────────────────────────────────────────────
    function colorFor(name) {
      var code = 0;
      for (var i = 0; i < (name||'').length; i++) code += name.charCodeAt(i);
      return avatarColors[code % avatarColors.length];
    }
    function timeAgo(d) {
      var diff = Math.floor((Date.now() - new Date(d).getTime()) / 1000);
      if (diff < 60)     return 'just now';
      if (diff < 3600)   return Math.floor(diff / 60)   + 'm';
      if (diff < 86400)  return Math.floor(diff / 3600)  + 'h';
      if (diff < 604800) return Math.floor(diff / 86400) + 'd';
      return new Date(d).toLocaleDateString('en', { month: 'short', day: 'numeric' });
    }
    function esc(s) {
      return String(s)
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function showToast(msg) {
      var t = document.getElementById('comToast');
      t.textContent = '✓ ' + msg;
      t.style.display = 'flex';
      setTimeout(function() { t.style.display = 'none'; }, 3000);
    }

    // ── Render post ──────────────────────────────────────────────────
    function renderPost(p) {
      var col    = colorFor(p.author_name || 'M');
      var isLong = p.post_type === 'text' && (p.content || '').length > 450;
      var myLike = p.my_reactions && p.my_reactions.indexOf('like') !== -1;
      var myFire = p.my_reactions && p.my_reactions.indexOf('fire') !== -1;
      var myClap = p.my_reactions && p.my_reactions.indexOf('clap') !== -1;

      var el = document.createElement('article');
      el.className = 'com-post';
      el.dataset.id = p.id;

      var html = '';

      // Pinned bar
      if (p.is_pinned) html += '<div class="com-pinned-bar">📌 Pinned post</div>';

      // Header
      html += '<div class="com-post-head">';
      html += '<div class="com-av" style="background:linear-gradient(135deg,' + col + ',rgba(52,211,153,.65))">' + esc((p.author_name || 'M').charAt(0).toUpperCase()) + '</div>';
      html += '<div class="com-post-meta">';
      html += '<div class="com-post-author">' + esc(p.author_name || 'Member');
      if (p.author_tier === 'elite_12') html += ' <span class="com-tier-elite">👑 Elite</span>';
      else if (p.author_tier === 'pro_6') html += ' <span class="com-tier-pro">⚡ Pro</span>';
      html += ' <span class="com-cat-tag ' + esc(p.category) + '">' + esc(p.category) + '</span>';
      html += '</div>';
      html += '<div class="com-post-time">' + timeAgo(p.created_at) + '</div>';
      html += '</div>';
      html += '<div class="com-post-menu">';
      html += '<button class="com-menu-btn" onclick="toggleMenu(this)">···</button>';
      html += '<div class="com-dropdown">';
      if (p.is_own) {
        html += '<div class="com-drop-item danger" onclick="deletePost(\'' + esc(p.id) + '\')">🗑 Delete</div>';
      } else {
        html += '<div class="com-drop-item warn" onclick="openReportModal(\'post\',\'' + esc(p.id) + '\')">🚩 Report</div>';
      }
      html += '<div class="com-drop-item" onclick="copyPostLink(\'' + esc(p.id) + '\')">🔗 Copy link</div>';
      html += '</div></div>';
      html += '</div>'; // post-head end

      // Photo image (above body)
      if (p.post_type === 'photo' && p.image_url) {
        html += '<div class="com-post-img-wrap"><img class="com-post-img" src="' + esc(p.image_url) + '" alt="Post photo" loading="lazy" data-lightbox="' + esc(p.image_url) + '" /></div>';
      }

      // Body text / caption
      var textContent = (p.content || '').trim();
      if (textContent) {
        html += '<div class="com-post-body">';
        var paras = textContent.split(/\n\n+/);
        var rendered = paras.map(function(para) {
          var lines = para.split('\n');
          return '<p>' + lines.map(esc).join('<br>') + '</p>';
        }).join('');
        if (isLong) {
          html += '<div class="com-post-text collapsed" id="pt-' + esc(p.id) + '">' + rendered + '</div>';
          html += '<button class="com-see-more" onclick="expandPost(\'' + esc(p.id) + '\',this)">See more</button>';
        } else {
          html += '<div class="com-post-text">' + rendered + '</div>';
        }
        html += '</div>';
      }

      // Progress card (below body)
      if (p.post_type === 'progress' && p.result_data) {
        var rd = (typeof p.result_data === 'string') ? JSON.parse(p.result_data) : p.result_data;
        html += '<div class="com-progress-card">';
        html += '<div class="com-progress-card-label">📊 Progress Update</div>';
        html += '<div class="com-pc-row">';
        if (rd.streak !== undefined) html += '<div class="com-pc-stat"><div class="com-pc-val">' + esc(String(rd.streak)) + '</div><div class="com-pc-lbl">Day Streak 🔥</div></div>';
        if (rd.day    !== undefined) html += '<div class="com-pc-stat"><div class="com-pc-val">' + esc(String(rd.day))    + '</div><div class="com-pc-lbl">Journey Day</div></div>';
        if (rd.level  !== undefined) html += '<div class="com-pc-stat"><div class="com-pc-val">' + esc(String(rd.level))  + '</div><div class="com-pc-lbl">Level ⭐</div></div>';
        if (rd.weightLost && rd.weightLost > 0) {
          html += '<div class="com-pc-stat"><div class="com-pc-val">' + esc(String(rd.weightLost)) + '</div><div class="com-pc-lbl">' + esc(rd.unit || 'kg') + ' lost ⚖️</div></div>';
        }
        html += '</div></div>';
      }

      // Reaction counts
      var hasCounts = (p.like_count||0) + (p.fire_count||0) + (p.clap_count||0) > 0 || (p.comment_count||0) > 0;
      if (hasCounts) {
        html += '<div class="com-reaction-counts">';
        if ((p.like_count||0) > 0) html += '<span class="com-rc-item">❤️ <span id="lc-' + esc(p.id) + '">' + (p.like_count||0) + '</span></span>';
        if ((p.fire_count||0) > 0) html += '<span class="com-rc-item">🔥 <span id="fc-' + esc(p.id) + '">' + (p.fire_count||0) + '</span></span>';
        if ((p.clap_count||0) > 0) html += '<span class="com-rc-item">👏 <span id="cc-' + esc(p.id) + '">' + (p.clap_count||0) + '</span></span>';
        if ((p.comment_count||0) > 0) html += '<span class="com-rc-item" style="margin-left:auto">💬 ' + (p.comment_count||0) + '</span>';
        html += '</div>';
      }

      // Actions
      html += '<div class="com-post-actions">';
      html += '<button class="com-react' + (myLike ? ' active-like':'') + '" onclick="react(\'' + esc(p.id) + '\',\'like\',this)">❤️ Like</button>';
      html += '<button class="com-react' + (myFire ? ' active-fire':'') + '" onclick="react(\'' + esc(p.id) + '\',\'fire\',this)">🔥 Fire</button>';
      html += '<button class="com-react' + (myClap ? ' active-clap':'') + '" onclick="react(\'' + esc(p.id) + '\',\'clap\',this)">👏 Clap</button>';
      html += '<button class="com-react" onclick="toggleComments(\'' + esc(p.id) + '\',this)">💬 Comment</button>';
      html += '</div>';

      // Comments panel
      html += '<div class="com-comments" id="cmts-' + esc(p.id) + '">';
      html += '<div class="com-comment-input-row">';
      html += '<div class="com-comment-av" style="background:linear-gradient(135deg,' + colorFor(userName) + ',rgba(52,211,153,.55))">' + myInitial + '</div>';
      html += '<textarea class="com-comment-input" placeholder="Write a comment…" rows="1" id="ci-' + esc(p.id) + '"></textarea>';
      html += '<button class="com-comment-send" id="cs-' + esc(p.id) + '">';
      html += '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>';
      html += '</button></div>';
      html += '<div class="com-comments-inner" id="cl-' + esc(p.id) + '"></div>';
      html += '</div>';

      el.innerHTML = html;
      return el;
    }

    // ── Render comment ───────────────────────────────────────────────
    function renderComment(c) {
      var col = colorFor(c.author_name || 'M');
      var el  = document.createElement('div');
      el.className = 'com-comment';
      if (c.id) el.dataset.cid = c.id;
      var actions = '';
      if (c.is_own) {
        actions = '<button class="com-comment-action" onclick="deleteComment(\'' + esc(c.id||'') + '\',this)">Delete</button>';
      } else if (c.id) {
        actions = '<button class="com-comment-action" onclick="openReportModal(\'comment\',\'' + esc(c.id) + '\')">Report</button>';
      }
      el.innerHTML =
        '<div class="com-comment-av" style="background:linear-gradient(135deg,' + col + ',rgba(52,211,153,.55))">' + esc((c.author_name||'M').charAt(0).toUpperCase()) + '</div>' +
        '<div class="com-comment-bubble">' +
          '<div class="com-comment-author">' + esc(c.author_name || 'Member') + (actions ? ' <span class="com-comment-actions">' + actions + '</span>' : '') + '</div>' +
          '<div class="com-comment-text">' + esc(c.content) + '</div>' +
          '<div class="com-comment-time">' + timeAgo(c.created_at) + '</div>' +
        '</div>';
      return el;
    }

    // ── Load posts ───────────────────────────────────────────────────
    function loadPosts(append) {
      var feed = document.getElementById('postsList');
      if (!append) feed.innerHTML = '<div class="com-loading"><div class="com-spinner"></div></div>';
      fetch('/api/community/posts?category=' + state.cat + '&page=' + state.page)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!append) feed.innerHTML = '';
          var posts = data.posts || [];
          if (!posts.length && !append) {
            feed.innerHTML = '<div class="com-empty"><div class="com-empty-icon">🌿</div><div class="com-empty-title">No posts yet</div><div class="com-empty-sub">Be the first to share something!</div></div>';
          }
          posts.forEach(function(p) { feed.appendChild(renderPost(p)); });
          state.hasMore = data.has_more;
          document.getElementById('loadMoreBtn').style.display = state.hasMore ? '' : 'none';
        })
        .catch(function() {
          if (!append) feed.innerHTML = '<div class="com-empty"><div class="com-empty-icon">⚠️</div><div class="com-empty-title">Failed to load posts</div><div class="com-empty-sub">Please refresh the page.</div></div>';
        });
    }

    // ── Category ─────────────────────────────────────────────────────
    function setCategory(cat) {
      state.cat = cat;
      state.page = 1;
      document.querySelectorAll('.com-tab, .com-cat-pill').forEach(function(b) {
        b.classList.toggle('active', b.dataset.cat === cat);
      });
      loadPosts(false);
    }
    document.getElementById('sidebarCats').addEventListener('click', function(e) {
      var b = e.target.closest('.com-cat-pill');
      if (b) setCategory(b.dataset.cat);
    });
    document.getElementById('comMobileCats').addEventListener('click', function(e) {
      var b = e.target.closest('.com-tab');
      if (b) setCategory(b.dataset.cat);
    });
    document.getElementById('loadMoreBtn').addEventListener('click', function() {
      state.page++;
      loadPosts(true);
    });

    // ── Reactions ────────────────────────────────────────────────────
    window.react = function(postId, type, btn) {
      fetch('/api/community/posts/' + postId + '/react', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reaction_type: type }),
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.error) return;
        btn.classList.toggle('active-' + type, data.action === 'added');
        var map = { like: 'lc', fire: 'fc', clap: 'cc' };
        var el  = document.getElementById(map[type] + '-' + postId);
        if (el) {
          var cur = parseInt(el.textContent) || 0;
          el.textContent = data.action === 'added' ? cur + 1 : Math.max(0, cur - 1);
        }
      });
    };

    // ── Comments ─────────────────────────────────────────────────────
    window.toggleComments = function(postId, btn) {
      var panel = document.getElementById('cmts-' + postId);
      var open  = !panel.classList.contains('open');
      panel.classList.toggle('open', open);
      btn.classList.toggle('active-comment', open);
      if (open) {
        loadComments(postId);
        setTimeout(function() {
          var inp = document.getElementById('ci-' + postId);
          if (inp) inp.focus();
        }, 150);
      }
    };
    function loadComments(postId) {
      var list = document.getElementById('cl-' + postId);
      if (!list || list.dataset.loaded === 'true') return;
      list.innerHTML = '<div style="text-align:center;padding:.5rem;color:var(--soft);font-size:.78rem">Loading…</div>';
      fetch('/api/community/posts/' + postId + '/comments')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          list.innerHTML = '';
          list.dataset.loaded = 'true';
          (data.comments || []).forEach(function(c) { list.appendChild(renderComment(c)); });
        });
    }
    window.sendComment = function(postId) {
      var inp = document.getElementById('ci-' + postId);
      var btn = document.getElementById('cs-' + postId);
      var txt = inp ? inp.value.trim() : '';
      if (!txt) return;
      btn.disabled = true;
      fetch('/api/community/posts/' + postId + '/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: txt }),
      }).then(function(r) { return r.json(); }).then(function(data) {
        btn.disabled = false;
        if (data.error) return;
        inp.value = '';
        var list = document.getElementById('cl-' + postId);
        if (list) {
          list.dataset.loaded = 'true';
          var newC = { author_name: userName, content: txt, created_at: new Date().toISOString(), is_own: true };
          list.appendChild(renderComment(newC));
          list.lastElementChild.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      });
    };
    document.getElementById('postsList').addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey && e.target.classList.contains('com-comment-input')) {
        e.preventDefault();
        window.sendComment(e.target.id.replace('ci-', ''));
      }
    });

    // Lightbox via event delegation on image clicks
    document.getElementById('postsList').addEventListener('click', function(e) {
      var img = e.target.closest('[data-lightbox]');
      if (img) openLightbox(img.dataset.lightbox);
    });

    // ── Lightbox ─────────────────────────────────────────────────────
    window.openLightbox = function(url) {
      var lb  = document.getElementById('lightboxOverlay');
      var img = document.getElementById('lightboxImg');
      img.src = url;
      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
    };
    window.closeLightbox = function() {
      var lb = document.getElementById('lightboxOverlay');
      lb.classList.remove('open');
      document.getElementById('lightboxImg').src = '';
      document.body.style.overflow = '';
    };

    // ── Post modal ───────────────────────────────────────────────────
    var modal = document.getElementById('postModal');

    function switchMode(mode) {
      postMode = mode;
      document.querySelectorAll('.com-mode-tab').forEach(function(t) {
        t.classList.toggle('active', t.dataset.mode === mode);
      });
      document.getElementById('modeText').style.display     = mode === 'text'     ? '' : 'none';
      document.getElementById('modePhoto').style.display    = mode === 'photo'    ? '' : 'none';
      document.getElementById('modeProgress').style.display = mode === 'progress' ? '' : 'none';
      if (mode === 'progress') fillProgressPreview();
      if (mode === 'text' && document.getElementById('postCategory').value === 'recipes') {
        var ta = document.getElementById('postContent');
        if (!ta.value.trim()) {
          ta.value = 'Recipe name:\n\nIngredients:\n- \n\nInstructions:\n1. \n\nMacros: X cal | Xg protein | Xg fat | Xg carbs';
          document.getElementById('charCount').textContent = ta.value.length + ' / 2000';
        }
      }
    }

    function fillProgressPreview() {
      var pd = myProgressData;
      document.getElementById('ppStreak').textContent = pd.streak;
      document.getElementById('ppDay').textContent    = pd.day;
      document.getElementById('ppLevel').textContent  = pd.level;
      if (pd.weightLost > 0) {
        document.getElementById('ppWeight').textContent  = pd.weightLost;
        document.getElementById('ppWeightLbl').textContent = pd.unit + ' lost ⚖️';
        document.getElementById('ppWeightWrap').style.display = '';
      }
    }

    function openModal(mode) {
      modal.classList.add('open');
      switchMode(mode || 'text');
      if ((mode || 'text') === 'text') document.getElementById('postContent').focus();
    }

    function closeModal() {
      modal.classList.remove('open');
      pendingImgBase64 = null;
      pendingImgType   = null;
      document.getElementById('photoPreviewWrap').style.display = 'none';
      document.getElementById('photoDropzone').style.display    = '';
      document.getElementById('photoCaption').value   = '';
      document.getElementById('progressCaption').value = '';
      document.getElementById('postError').textContent = '';
      document.getElementById('photoUploadError').textContent = '';
      document.getElementById('photoFileInput').value = '';
    }

    document.getElementById('openPostBtn').addEventListener('click', function() { openModal('text'); });
    document.getElementById('comWriteBtn').addEventListener('click', function() { openModal('text'); });
    document.getElementById('quickPhotoBtn').addEventListener('click', function() { openModal('photo'); });
    document.getElementById('quickProgressBtn').addEventListener('click', function() { openModal('progress'); });
    document.getElementById('sidebarProgressBtn').addEventListener('click', function() { openModal('progress'); });
    document.getElementById('closeModal').addEventListener('click', closeModal);
    document.getElementById('cancelPost').addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

    document.getElementById('postModeTabs').addEventListener('click', function(e) {
      var t = e.target.closest('.com-mode-tab');
      if (t) switchMode(t.dataset.mode);
    });

    document.getElementById('postCategory').addEventListener('change', function() {
      if (postMode === 'text' && this.value === 'recipes') {
        var ta = document.getElementById('postContent');
        if (!ta.value.trim()) {
          ta.value = 'Recipe name:\n\nIngredients:\n- \n\nInstructions:\n1. \n\nMacros: X cal | Xg protein | Xg fat | Xg carbs';
          document.getElementById('charCount').textContent = ta.value.length + ' / 2000';
        }
      }
    });

    document.getElementById('postContent').addEventListener('input', function() {
      document.getElementById('charCount').textContent = this.value.length + ' / 2000';
    });

    // Photo file input
    document.getElementById('photoPickBtn').addEventListener('click', function() {
      document.getElementById('photoFileInput').click();
    });
    document.getElementById('photoFileInput').addEventListener('change', function(e) {
      var file = e.target.files && e.target.files[0];
      var errEl = document.getElementById('photoUploadError');
      if (!file) return;
      if (file.size > 2 * 1024 * 1024) { errEl.textContent = 'Image too large — max 2 MB'; return; }
      var allowed = ['image/jpeg', 'image/png', 'image/webp'];
      if (allowed.indexOf(file.type) === -1) { errEl.textContent = 'Only JPEG, PNG, WebP allowed'; return; }
      errEl.textContent = '';
      var reader = new FileReader();
      reader.onload = function(ev) {
        var dataUrl = ev.target.result;
        var comma   = dataUrl.indexOf(',');
        pendingImgBase64 = dataUrl.slice(comma + 1);
        pendingImgType   = file.type;
        document.getElementById('photoPreviewImg').src     = dataUrl;
        document.getElementById('photoPreviewWrap').style.display = '';
        document.getElementById('photoDropzone').style.display    = 'none';
      };
      reader.readAsDataURL(file);
    });
    document.getElementById('photoRemoveBtn').addEventListener('click', function() {
      pendingImgBase64 = null; pendingImgType = null;
      document.getElementById('photoPreviewWrap').style.display = 'none';
      document.getElementById('photoDropzone').style.display    = '';
      document.getElementById('photoFileInput').value = '';
    });

    // Submit post
    document.getElementById('submitPost').addEventListener('click', function() {
      var errEl    = document.getElementById('postError');
      var btn      = document.getElementById('submitPost');
      var category = document.getElementById('postCategory').value;
      errEl.textContent = '';

      var content, postType, imgUrl, resultData;

      if (postMode === 'text') {
        content    = document.getElementById('postContent').value.trim();
        postType   = 'text'; imgUrl = null; resultData = null;
        if (content.length < 3) { errEl.textContent = 'Post too short.'; return; }

      } else if (postMode === 'photo') {
        if (!pendingImgBase64) {
          document.getElementById('photoUploadError').textContent = 'Please choose a photo first.';
          return;
        }
        content = document.getElementById('photoCaption').value.trim();
        postType = 'photo'; imgUrl = null; resultData = null;

      } else {
        content    = document.getElementById('progressCaption').value.trim();
        postType   = 'progress'; imgUrl = null;
        resultData = {
          day: myProgressData.day, streak: myProgressData.streak,
          level: myProgressData.level, xp: myProgressData.xp,
          weightLost: myProgressData.weightLost, unit: myProgressData.unit,
        };
      }

      btn.disabled = true;
      btn.textContent = postType === 'photo' ? 'Uploading…' : 'Posting…';

      function doPost(resolvedUrl) {
        fetch('/api/community/posts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            content: content, category: category,
            post_type: postType, image_url: resolvedUrl || null,
            result_data: resultData || null,
          }),
        }).then(function(r) { return r.json(); }).then(function(data) {
          btn.disabled = false; btn.textContent = 'Post';
          if (data.error) { errEl.textContent = data.error; return; }
          closeModal();
          document.getElementById('postContent').value = '';
          document.getElementById('charCount').textContent = '0 / 2000';
          state.page = 1;
          loadPosts(false);
          showToast('Post shared with the community!');
        }).catch(function() {
          btn.disabled = false; btn.textContent = 'Post';
          errEl.textContent = 'Network error. Try again.';
        });
      }

      if (postType === 'photo') {
        fetch('/api/community/upload-photo', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ imageBase64: pendingImgBase64, imageType: pendingImgType }),
        }).then(function(r) { return r.json(); }).then(function(data) {
          if (data.error) {
            btn.disabled = false; btn.textContent = 'Post';
            document.getElementById('photoUploadError').textContent = data.error;
            return;
          }
          btn.textContent = 'Posting…';
          doPost(data.url);
        }).catch(function() {
          btn.disabled = false; btn.textContent = 'Post';
          document.getElementById('photoUploadError').textContent = 'Upload failed. Try again.';
        });
      } else {
        doPost(null);
      }
    });

    // ── Misc actions ─────────────────────────────────────────────────
    window.toggleMenu = function(btn) {
      var dd = btn.nextElementSibling;
      var wasOpen = dd.classList.contains('open');
      document.querySelectorAll('.com-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
      if (!wasOpen) dd.classList.add('open');
    };
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.com-post-menu')) {
        document.querySelectorAll('.com-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
      }
    });

    window.deletePost = function(postId) {
      if (!confirm('Delete this post?')) return;
      fetch('/api/community/posts/' + postId + '/delete', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.error) return;
          var card = document.querySelector('[data-id="' + postId + '"]');
          if (card) { card.style.opacity = '0'; card.style.transform = 'scale(.96)'; card.style.transition = 'all .2s'; setTimeout(function() { card.remove(); }, 200); }
        });
    };

    window.deleteComment = function(commentId, btn) {
      if (!commentId || !confirm('Delete this comment?')) return;
      fetch('/api/community/comments/' + commentId + '/delete', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.error) return;
          var el = document.querySelector('[data-cid="' + commentId + '"]');
          if (el) el.remove();
        });
    };

    window.expandPost = function(postId, btn) {
      var textEl = document.getElementById('pt-' + postId);
      if (textEl) { textEl.classList.remove('collapsed'); btn.remove(); }
    };

    window.copyPostLink = function(postId) {
      if (navigator.clipboard) navigator.clipboard.writeText(window.location.origin + '/dashboard/community#' + postId);
      document.querySelectorAll('.com-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
      showToast('Link copied!');
    };

    // ── Report modal ─────────────────────────────────────────────────
    var reportModal  = document.getElementById('reportModal');
    var reportTarget = { type: null, id: null };

    window.openReportModal = function(type, id) {
      reportTarget.type = type; reportTarget.id = id;
      document.getElementById('reportError').textContent = '';
      document.getElementById('reportReason').value = 'spam';
      reportModal.classList.add('open');
      document.querySelectorAll('.com-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
    };
    document.getElementById('closeReportModal').addEventListener('click', function() { reportModal.classList.remove('open'); });
    reportModal.addEventListener('click', function(e) { if (e.target === reportModal) reportModal.classList.remove('open'); });
    document.getElementById('submitReport').addEventListener('click', function() {
      var reason = document.getElementById('reportReason').value;
      var errEl  = document.getElementById('reportError');
      var btn    = document.getElementById('submitReport');
      errEl.textContent = '';
      if (!reportTarget.id) return;
      var url = reportTarget.type === 'post'
        ? '/api/community/posts/'    + reportTarget.id + '/report'
        : '/api/community/comments/' + reportTarget.id + '/report';
      btn.disabled = true; btn.textContent = 'Submitting…';
      fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason: reason }),
      }).then(function(r) { return r.json(); }).then(function(data) {
        btn.disabled = false; btn.textContent = 'Submit Report';
        if (data.error) { errEl.textContent = data.error; return; }
        reportModal.classList.remove('open');
        showToast('Report submitted — thank you!');
      }).catch(function() {
        btn.disabled = false; btn.textContent = 'Submit Report';
        errEl.textContent = 'Network error.';
      });
    });

    // Escape key closes modals / lightbox
    document.addEventListener('keydown', function(e) {
      if (e.key !== 'Escape') return;
      closeLightbox();
      closeModal();
      reportModal.classList.remove('open');
    });

    // ── Init ─────────────────────────────────────────────────────────
    loadPosts(false);
  })();
  </script>
</body>
</html>
