---
// src/pages/dashboard/community.astro — Elite-only community (Facebook-group style)
import { requireAuth } from '../../lib/auth';
import DashNav from '../../components/DashNav.astro';
import Users from 'lucide-astro/Users';
import MessageCircle from 'lucide-astro/MessageCircle';
import Heart from 'lucide-astro/Heart';
import ThumbsUp from 'lucide-astro/ThumbsUp';
import Share2 from 'lucide-astro/Share2';
import Lock from 'lucide-astro/Lock';
import Calendar from 'lucide-astro/Calendar';
import Trophy from 'lucide-astro/Trophy';
import TrendingUp from 'lucide-astro/TrendingUp';
import Flame from 'lucide-astro/Flame';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

if (profile.subscription_tier !== 'elite_12') {
  return Astro.redirect('/dashboard/upgrade');
}

const planType  = profile.subscription_tier;
const userName  = profile.full_name || 'Member';
const tierLabel = '👑 Elite';

// Member count for the group header
const { count: memberCount } = await db
  .from('profiles')
  .select('id', { count: 'exact', head: true })
  .eq('subscription_tier', 'elite_12');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Community · Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <DashNav userId={user.id} userName={userName} tierLabel={tierLabel} planType={planType} activePage="community" />

  <!-- GROUP COVER BANNER -->
  <div id="comCover">
    <div id="comCoverBg"></div>
    <div id="comCoverContent">
      <div id="comGroupIcon"><Users size={32} /></div>
      <div id="comGroupInfo">
        <h1 id="comGroupName">Elite Keto <em>Community</em></h1>
        <p id="comGroupDesc">Private group · {memberCount || 0} Elite members · Share your journey, recipes &amp; wins</p>
        <div id="comGroupMeta">
          <span class="com-badge"><Lock size={12} style="display:inline;vertical-align:middle;" /> Elite members only</span>
          <span class="com-badge"><Calendar size={12} style="display:inline;vertical-align:middle;" /> 365-day journey</span>
          <span class="com-badge"><Users size={12} style="display:inline;vertical-align:middle;" /> Global community</span>
        </div>
      </div>
      <button id="openPostBtn" class="com-post-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Create Post
      </button>
    </div>
  </div>

  <!-- MAIN LAYOUT -->
  <div id="comLayout">

    <!-- LEFT SIDEBAR -->
    <aside id="comSidebar">
      <div class="com-side-card">
        <div class="com-side-title">About this group</div>
        <p class="com-side-body">A private space for Elite Keto Journey members to share progress, recipes, tips and motivation on the 12-month program.</p>
        <div class="com-side-stat"><span><Trophy size={14} /></span><span>{memberCount || 0} members</span></div>
        <div class="com-side-stat"><span><Lock size={14} /></span><span>Private · Elite only</span></div>
        <div class="com-side-stat"><span><Users size={14} /></span><span>12-month program</span></div>
      </div>
      <div class="com-side-card">
        <div class="com-side-title">Categories</div>
        <div id="sidebarCats">
          <button class="com-cat-pill active" data-cat="all">All Posts</button>
          <button class="com-cat-pill" data-cat="progress"><TrendingUp size={12} style="display:inline;vertical-align:middle;" /> Progress</button>
          <button class="com-cat-pill" data-cat="recipes">Recipes</button>
          <button class="com-cat-pill" data-cat="tips">Tips</button>
          <button class="com-cat-pill" data-cat="motivation"><Flame size={12} style="display:inline;vertical-align:middle;" /> Motivation</button>
          <button class="com-cat-pill" data-cat="general"><MessageCircle size={12} style="display:inline;vertical-align:middle;" /> General</button>
        </div>
      </div>
    </aside>

    <!-- FEED -->
    <main id="comFeed">
      <!-- Write post shortcut -->
      <div id="comWriteBar">
        <div id="comWriteAvatar">{userName.charAt(0).toUpperCase()}</div>
        <button id="comWriteBtn">What's on your mind, {userName.split(' ')[0]}?</button>
      </div>

      <!-- Category tabs (mobile) -->
      <div id="comMobileCats">
        <button class="com-tab active" data-cat="all">All</button>
        <button class="com-tab" data-cat="progress">Progress</button>
        <button class="com-tab" data-cat="recipes">Recipes</button>
        <button class="com-tab" data-cat="tips">Tips</button>
        <button class="com-tab" data-cat="motivation">Motivation</button>
        <button class="com-tab" data-cat="general">General</button>
      </div>

      <!-- Posts list -->
      <div id="postsList">
        <div class="com-loading"><div class="com-spinner"></div></div>
      </div>
      <button id="loadMoreBtn" style="display:none">Load more</button>
    </main>
  </div>

  <!-- CREATE POST MODAL -->
  <div id="postModal" class="com-modal-overlay">
    <div class="com-modal">
      <div class="com-modal-head">
        <h2>Create Post</h2>
        <button id="closeModal" class="com-modal-close">&times;</button>
      </div>
      <div class="com-modal-author">
        <div class="com-av com-av-lg">{userName.charAt(0).toUpperCase()}</div>
        <div>
          <div class="com-author-name">{userName}</div>
          <select id="postCategory" class="com-cat-select">
            <option value="general">💬 General</option>
            <option value="progress">📈 Progress Update</option>
            <option value="recipes">🍳 Recipe Share</option>
            <option value="tips">💡 Tips &amp; Tricks</option>
            <option value="motivation">🔥 Motivation</option>
          </select>
        </div>
      </div>
      <textarea id="postContent" class="com-textarea" placeholder="Share your progress, a recipe, tip or win..."></textarea>
      <div class="com-char-row">
        <span id="postError" class="com-err"></span>
        <span id="charCount">0 / 2000</span>
      </div>
      <div class="com-modal-footer">
        <button id="cancelPost" class="com-btn-ghost">Cancel</button>
        <button id="submitPost" class="com-btn-primary">Post</button>
      </div>
    </div>
  </div>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #060d09; --card: #0d1a0f; --card2: #111f13;
      --border: rgba(16,185,129,.1); --border2: rgba(16,185,129,.22);
      --text: #dfeedd; --soft: #4d7055; --muted: #233328;
      --green: #10b981; --green2: #34d399;
      --gold: #f59e0b; --purple: #8b5cf6; --blue: #3b82f6; --red: #ef4444;
      --nav-h: 64px;
    }
    body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; }

    /* ── COVER BANNER ── */
    #comCover {
      position: relative; margin-top: var(--nav-h);
      background: linear-gradient(135deg, #051209 0%, #082e12 50%, #051209 100%);
      border-bottom: 1px solid var(--border2);
      overflow: hidden;
    }
    #comCoverBg {
      position: absolute; inset: 0; opacity: .4;
      background: radial-gradient(ellipse at 30% 50%, rgba(16,185,129,.18) 0%, transparent 60%),
                  radial-gradient(ellipse at 80% 20%, rgba(52,211,153,.1) 0%, transparent 50%);
    }
    #comCoverContent {
      position: relative; max-width: 1100px; margin: 0 auto;
      padding: 2rem 1.5rem 1.5rem;
      display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap;
    }
    #comGroupIcon {
      width: 72px; height: 72px; border-radius: 16px; flex-shrink: 0;
      background: linear-gradient(135deg, rgba(16,185,129,.25), rgba(52,211,153,.1));
      border: 2px solid rgba(16,185,129,.4);
      display: flex; align-items: center; justify-content: center; font-size: 2.2rem;
    }
    #comGroupInfo { flex: 1; min-width: 200px; }
    #comGroupName {
      font-family: 'Fraunces', serif; font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 700; color: var(--text); margin-bottom: .3rem;
    }
    #comGroupName em { font-style: italic; color: var(--green2); }
    #comGroupDesc { font-size: .83rem; color: var(--soft); margin-bottom: .6rem; }
    #comGroupMeta { display: flex; gap: .5rem; flex-wrap: wrap; }
    .com-badge {
      font-size: .7rem; font-weight: 700; padding: .22rem .65rem; border-radius: 99px;
      background: rgba(16,185,129,.1); border: 1px solid rgba(16,185,129,.2); color: var(--green2);
    }
    .com-post-btn {
      display: flex; align-items: center; gap: .5rem;
      padding: .65rem 1.4rem; border-radius: 12px;
      background: var(--green); color: #fff; border: none;
      font-weight: 700; font-size: .88rem; cursor: pointer;
      transition: opacity .2s, transform .15s; flex-shrink: 0;
    }
    .com-post-btn:hover { opacity: .88; transform: translateY(-1px); }

    /* ── LAYOUT ── */
    #comLayout {
      max-width: 1100px; margin: 0 auto; padding: 1.5rem 1.5rem 5rem;
      display: grid; grid-template-columns: 280px 1fr; gap: 1.5rem;
    }
    @media (max-width: 900px) { #comLayout { grid-template-columns: 1fr; } }
    @media (max-width: 640px) { #comLayout { padding: 1rem .75rem 5rem; } }

    /* ── SIDEBAR ── */
    #comSidebar { display: flex; flex-direction: column; gap: 1rem; }
    @media (max-width: 900px) { #comSidebar { display: none; } }
    .com-side-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 16px; padding: 1.1rem 1.15rem;
    }
    .com-side-title { font-weight: 800; font-size: .82rem; color: var(--text); margin-bottom: .75rem; text-transform: uppercase; letter-spacing: .05em; }
    .com-side-body { font-size: .8rem; color: var(--soft); line-height: 1.6; margin-bottom: .75rem; }
    .com-side-stat { display: flex; align-items: center; gap: .5rem; font-size: .8rem; color: var(--soft); margin-bottom: .4rem; }
    .com-cat-pill {
      display: block; width: 100%; text-align: left;
      padding: .45rem .65rem; border-radius: 9px; border: none;
      background: transparent; color: var(--soft); font-size: .82rem; font-weight: 600;
      cursor: pointer; transition: all .15s; margin-bottom: .2rem;
    }
    .com-cat-pill:hover { background: rgba(16,185,129,.08); color: var(--text); }
    .com-cat-pill.active { background: rgba(16,185,129,.12); color: var(--green2); font-weight: 700; }

    /* ── FEED ── */
    #comFeed { display: flex; flex-direction: column; gap: 1rem; min-width: 0; }

    /* Write bar */
    #comWriteBar {
      display: flex; align-items: center; gap: .75rem;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 16px; padding: .85rem 1rem;
    }
    #comWriteAvatar {
      width: 42px; height: 42px; border-radius: 50%; flex-shrink: 0;
      background: linear-gradient(135deg, var(--green), var(--green2));
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 1rem; color: #fff;
    }
    #comWriteBtn {
      flex: 1; text-align: left; background: var(--card2);
      border: 1px solid var(--border); border-radius: 99px;
      padding: .55rem 1rem; color: var(--soft); font-size: .88rem;
      cursor: pointer; transition: border-color .2s;
    }
    #comWriteBtn:hover { border-color: var(--green); color: var(--text); }

    /* Mobile category tabs */
    #comMobileCats {
      display: none; gap: .4rem; overflow-x: auto; padding-bottom: .25rem;
      scrollbar-width: none;
    }
    #comMobileCats::-webkit-scrollbar { display: none; }
    @media (max-width: 900px) { #comMobileCats { display: flex; } }
    .com-tab {
      padding: .38rem .85rem; border-radius: 99px; border: 1px solid var(--border);
      background: transparent; color: var(--soft); font-size: .78rem; font-weight: 600;
      cursor: pointer; white-space: nowrap; transition: all .15s; flex-shrink: 0;
    }
    .com-tab:hover { border-color: var(--border2); color: var(--text); }
    .com-tab.active { background: rgba(16,185,129,.12); color: var(--green2); border-color: var(--green); }

    /* ── POST CARD ── */
    .com-post {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 18px; overflow: hidden;
      transition: border-color .2s, box-shadow .2s;
      animation: comFadeUp .3s ease both;
    }
    .com-post:hover { border-color: var(--border2); box-shadow: 0 4px 20px rgba(0,0,0,.2); }
    @keyframes comFadeUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }

    .com-post-head {
      display: flex; align-items: center; gap: .75rem;
      padding: 1rem 1.1rem .7rem;
    }
    .com-av {
      width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: .95rem; color: #fff;
    }
    .com-av-lg { width: 46px; height: 46px; font-size: 1.1rem; }
    .com-post-meta { flex: 1; min-width: 0; }
    .com-post-author { font-weight: 700; font-size: .9rem; color: var(--text); display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }
    .com-tier-badge { font-size: .6rem; font-weight: 800; padding: .1rem .4rem; border-radius: 99px; background: linear-gradient(135deg,#7c3aed,#9333ea); color: #fff; }
    .com-cat-tag { font-size: .65rem; font-weight: 700; padding: .12rem .4rem; border-radius: 6px; text-transform: capitalize; }
    .com-cat-tag.progress   { background: rgba(59,130,246,.15); color: #60a5fa; }
    .com-cat-tag.recipes    { background: rgba(16,185,129,.15); color: var(--green2); }
    .com-cat-tag.tips       { background: rgba(245,158,11,.15); color: var(--gold); }
    .com-cat-tag.motivation { background: rgba(139,92,246,.15); color: #a78bfa; }
    .com-cat-tag.general    { background: rgba(77,112,85,.15); color: var(--soft); }
    .com-post-time { font-size: .75rem; color: var(--soft); margin-top: .1rem; }
    .com-post-menu { margin-left: auto; position: relative; }
    .com-menu-btn { background: none; border: none; color: var(--soft); cursor: pointer; padding: .3rem .5rem; border-radius: 8px; font-size: 1.1rem; line-height: 1; transition: all .15s; }
    .com-menu-btn:hover { background: var(--card2); color: var(--text); }
    .com-dropdown { position: absolute; right: 0; top: 100%; background: var(--card2); border: 1px solid var(--border2); border-radius: 12px; min-width: 130px; z-index: 50; box-shadow: 0 8px 24px rgba(0,0,0,.4); display: none; }
    .com-dropdown.open { display: block; }
    .com-drop-item { display: flex; align-items: center; gap: .5rem; padding: .6rem .85rem; font-size: .82rem; font-weight: 600; color: var(--soft); cursor: pointer; transition: all .15s; border-radius: 10px; margin: .2rem; }
    .com-drop-item:hover { background: rgba(255,255,255,.05); color: var(--text); }
    .com-drop-item.danger { color: var(--red); }
    .com-drop-item.danger:hover { background: rgba(239,68,68,.08); }

    /* Pinned indicator */
    .com-pinned-bar { display: flex; align-items: center; gap: .4rem; padding: .35rem 1.1rem; background: rgba(245,158,11,.06); border-bottom: 1px solid rgba(245,158,11,.12); font-size: .72rem; font-weight: 700; color: var(--gold); }

    /* Post body */
    .com-post-body { padding: 0 1.1rem .9rem; }
    .com-post-text { font-size: .93rem; line-height: 1.68; color: var(--text); white-space: pre-wrap; word-break: break-word; }
    .com-post-text.collapsed { display: -webkit-box; -webkit-line-clamp: 5; -webkit-box-orient: vertical; overflow: hidden; }
    .com-see-more { font-size: .8rem; font-weight: 700; color: var(--green); background: none; border: none; cursor: pointer; padding: .2rem 0; margin-top: .25rem; display: block; }

    /* Reaction bar */
    .com-reaction-counts { display: flex; gap: .75rem; padding: .4rem 1.1rem; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); font-size: .78rem; color: var(--soft); }
    .com-rc-item { display: flex; align-items: center; gap: .2rem; }

    .com-post-actions { display: flex; padding: .3rem .7rem; gap: .2rem; }
    .com-react {
      flex: 1; display: flex; align-items: center; justify-content: center; gap: .4rem;
      padding: .5rem .4rem; border-radius: 10px; border: none; background: transparent;
      color: var(--soft); font-size: .82rem; font-weight: 700; cursor: pointer;
      transition: all .15s;
    }
    .com-react:hover { background: var(--card2); color: var(--text); }
    .com-react.active-like   { color: var(--red); background: rgba(239,68,68,.07); }
    .com-react.active-fire   { color: var(--gold); background: rgba(245,158,11,.07); }
    .com-react.active-clap   { color: var(--green2); background: rgba(52,211,153,.07); }
    .com-react.active-comment { color: var(--blue); background: rgba(59,130,246,.07); }

    /* Comments section */
    .com-comments { border-top: 1px solid var(--border); background: var(--card2); display: none; }
    .com-comments.open { display: block; }
    .com-comments-inner { padding: .75rem 1rem; display: flex; flex-direction: column; gap: .65rem; }
    .com-comment { display: flex; gap: .6rem; }
    .com-comment-av { width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: .75rem; color: #fff; }
    .com-comment-bubble { flex: 1; background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: .5rem .75rem; }
    .com-comment-author { font-size: .78rem; font-weight: 700; color: var(--green2); margin-bottom: .15rem; }
    .com-comment-text { font-size: .83rem; color: var(--text); line-height: 1.5; }
    .com-comment-time { font-size: .68rem; color: var(--soft); margin-top: .2rem; }
    .com-comment-input-row { display: flex; gap: .5rem; align-items: flex-end; padding: 0 1rem .75rem; }
    .com-comment-input {
      flex: 1; background: var(--card); border: 1px solid var(--border);
      border-radius: 20px; padding: .55rem 1rem; color: var(--text);
      font-size: .83rem; font-family: inherit; resize: none; line-height: 1.4;
      min-height: 38px; max-height: 120px; transition: border-color .2s;
    }
    .com-comment-input:focus { outline: none; border-color: var(--green); }
    .com-comment-send {
      width: 36px; height: 36px; border-radius: 50%; background: var(--green);
      border: none; color: #fff; cursor: pointer; display: flex; align-items: center;
      justify-content: center; flex-shrink: 0; transition: opacity .2s;
    }
    .com-comment-send:hover { opacity: .85; }
    .com-comment-send:disabled { opacity: .5; cursor: not-allowed; }

    /* ── LOADING / EMPTY ── */
    .com-loading { display: flex; justify-content: center; padding: 3rem; }
    .com-spinner { width: 32px; height: 32px; border: 3px solid var(--border); border-top-color: var(--green); border-radius: 50%; animation: spin .7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .com-empty { text-align: center; padding: 4rem 1rem; }
    .com-empty-icon { font-size: 3rem; margin-bottom: 1rem; }
    .com-empty-title { font-family: 'Fraunces', serif; font-size: 1.1rem; font-weight: 700; margin-bottom: .4rem; }
    .com-empty-sub { font-size: .83rem; color: var(--soft); }
    #loadMoreBtn {
      width: 100%; padding: .8rem; background: transparent;
      border: 1px dashed var(--border2); border-radius: 14px;
      color: var(--soft); font-size: .85rem; cursor: pointer; transition: all .2s;
    }
    #loadMoreBtn:hover { color: var(--text); border-color: var(--green); background: rgba(16,185,129,.05); }

    /* ── MODAL ── */
    .com-modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,.75); backdrop-filter: blur(6px);
      z-index: 1000; display: flex; align-items: center; justify-content: center;
      padding: 1rem; opacity: 0; pointer-events: none; transition: opacity .2s;
    }
    .com-modal-overlay.open { opacity: 1; pointer-events: auto; }
    .com-modal {
      background: var(--card); border: 1px solid var(--border2); border-radius: 20px;
      width: 100%; max-width: 560px; max-height: 92vh; overflow-y: auto;
      transform: translateY(16px); transition: transform .25s;
    }
    .com-modal-overlay.open .com-modal { transform: translateY(0); }
    .com-modal-head { display: flex; align-items: center; justify-content: space-between; padding: 1.1rem 1.25rem; border-bottom: 1px solid var(--border); }
    .com-modal-head h2 { font-family: 'Fraunces', serif; font-size: 1.1rem; font-weight: 700; }
    .com-modal-close { background: none; border: none; color: var(--soft); font-size: 1.5rem; cursor: pointer; line-height: 1; padding: .1rem .4rem; border-radius: 6px; }
    .com-modal-close:hover { color: var(--text); background: var(--card2); }
    .com-modal-author { display: flex; align-items: center; gap: .75rem; padding: 1rem 1.25rem .75rem; }
    .com-author-name { font-weight: 700; font-size: .9rem; margin-bottom: .3rem; }
    .com-cat-select { background: var(--card2); border: 1px solid var(--border); border-radius: 99px; padding: .28rem .75rem; color: var(--soft); font-size: .78rem; cursor: pointer; }
    .com-textarea { width: 100%; min-height: 130px; background: transparent; border: none; padding: .5rem 1.25rem; color: var(--text); font-family: inherit; font-size: .95rem; line-height: 1.65; resize: none; }
    .com-textarea:focus { outline: none; }
    .com-textarea::placeholder { color: var(--soft); }
    .com-char-row { display: flex; justify-content: space-between; align-items: center; padding: .4rem 1.25rem; font-size: .75rem; color: var(--soft); border-top: 1px solid var(--border); }
    .com-err { color: var(--red); font-weight: 600; }
    .com-modal-footer { display: flex; justify-content: flex-end; gap: .75rem; padding: .85rem 1.25rem; }
    .com-btn-ghost { padding: .6rem 1.1rem; background: transparent; border: 1px solid var(--border2); color: var(--soft); border-radius: 10px; font-size: .85rem; cursor: pointer; font-family: inherit; }
    .com-btn-primary { padding: .6rem 1.5rem; background: var(--green); color: #fff; border: none; border-radius: 10px; font-weight: 700; font-size: .85rem; cursor: pointer; font-family: inherit; transition: opacity .2s; }
    .com-btn-primary:hover { opacity: .88; }
    .com-btn-primary:disabled { opacity: .5; cursor: not-allowed; }

    /* Report / comment actions */
    .com-drop-item.warn { color: #f97316; }
    .com-drop-item.warn:hover { background: rgba(249,115,22,.08); }
    .com-comment-actions { display: inline-flex; gap: .3rem; margin-left: .4rem; }
    .com-comment-action { background: none; border: none; font-size: .7rem; color: var(--soft); cursor: pointer; padding: .1rem .35rem; border-radius: 4px; font-family: inherit; transition: color .15s; }
    .com-comment-action:hover { color: var(--red); }
  </style>

  <!-- REPORT MODAL -->
  <div id="reportModal" class="com-modal-overlay">
    <div class="com-modal" style="max-width:420px">
      <div class="com-modal-head">
        <h2>Report Content</h2>
        <button id="closeReportModal" class="com-modal-close">&times;</button>
      </div>
      <div style="padding:1.25rem">
        <p style="font-size:.85rem;color:var(--soft);margin-bottom:1rem;line-height:1.5">
          Help keep our community safe. Select a reason and our moderators will review this content.
        </p>
        <label style="font-size:.78rem;font-weight:700;color:var(--soft);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem">Reason</label>
        <select id="reportReason" style="width:100%;background:var(--card2);border:1px solid var(--border2);border-radius:10px;padding:.6rem .9rem;color:var(--text);font-size:.88rem;font-family:inherit;cursor:pointer">
          <option value="spam">Spam or self-promotion</option>
          <option value="harassment">Harassment or bullying</option>
          <option value="inappropriate">Inappropriate content</option>
          <option value="misinformation">Health misinformation</option>
          <option value="other">Other</option>
        </select>
        <div style="margin-top:.75rem;min-height:1.2rem">
          <span id="reportError" style="font-size:.78rem;color:var(--red);font-weight:600"></span>
        </div>
      </div>
      <div class="com-modal-footer">
        <button id="closeReportModal2" class="com-btn-ghost" onclick="document.getElementById('reportModal').classList.remove('open')">Cancel</button>
        <button id="submitReport" class="com-btn-primary" style="background:var(--red)">Submit Report</button>
      </div>
    </div>
  </div>

  <!-- REPORT TOAST -->
  <div id="reportToast" style="display:none;position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:#1a2e1f;border:1px solid rgba(16,185,129,.3);color:var(--green2);padding:.65rem 1.3rem;border-radius:999px;font-size:.83rem;font-weight:600;z-index:2000;align-items:center;gap:.5rem;box-shadow:0 4px 20px rgba(0,0,0,.4)">
    ✓ Report submitted — our moderators will review it
  </div>

  <script is:inline define:vars={{ userName, planType }}>
  (function() {
    // ── State ──────────────────────────────────────────────────────
    var state = { cat: 'all', page: 1, hasMore: false };
    var myInitial = userName.charAt(0).toUpperCase();
    var avatarColors = ['#10b981','#3b82f6','#8b5cf6','#f59e0b','#ef4444','#06b6d4'];

    function colorFor(name) {
      var code = 0;
      for (var i = 0; i < name.length; i++) code += name.charCodeAt(i);
      return avatarColors[code % avatarColors.length];
    }

    function timeAgo(d) {
      var diff = Math.floor((Date.now() - new Date(d).getTime()) / 1000);
      if (diff < 60)   return 'just now';
      if (diff < 3600) return Math.floor(diff/60) + 'm';
      if (diff < 86400)return Math.floor(diff/3600) + 'h';
      if (diff < 604800) return Math.floor(diff/86400) + 'd';
      return new Date(d).toLocaleDateString('en', { month:'short', day:'numeric' });
    }

    function esc(s) {
      return String(s)
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Render post card ──────────────────────────────────────────
    function renderPost(p) {
      var col = colorFor(p.author_name || 'M');
      var isLong = (p.content || '').length > 400;
      var myLike = p.my_reactions && p.my_reactions.indexOf('like')  !== -1;
      var myFire = p.my_reactions && p.my_reactions.indexOf('fire')  !== -1;
      var myClap = p.my_reactions && p.my_reactions.indexOf('clap')  !== -1;

      var el = document.createElement('article');
      el.className = 'com-post';
      el.dataset.id = p.id;

      var html = '';

      // Pinned bar
      if (p.is_pinned) {
        html += '<div class="com-pinned-bar">📌 Pinned post</div>';
      }

      // Header
      html += '<div class="com-post-head">';
      html += '<div class="com-av" style="background:linear-gradient(135deg,' + col + ',rgba(52,211,153,.7))">' + esc((p.author_name||'M').charAt(0).toUpperCase()) + '</div>';
      html += '<div class="com-post-meta">';
      html += '<div class="com-post-author">';
      html += esc(p.author_name || 'Member');
      html += ' <span class="com-tier-badge">👑 Elite</span>';
      html += ' <span class="com-cat-tag ' + esc(p.category) + '">' + esc(p.category) + '</span>';
      html += '</div>';
      html += '<div class="com-post-time">' + timeAgo(p.created_at) + '</div>';
      html += '</div>';
      // Menu
      html += '<div class="com-post-menu">';
      html += '<button class="com-menu-btn" onclick="toggleMenu(this)">···</button>';
      html += '<div class="com-dropdown">';
      if (p.is_own) {
        html += '<div class="com-drop-item danger" onclick="deletePost(\'' + esc(p.id) + '\', this)">🗑 Delete</div>';
      } else {
        html += '<div class="com-drop-item warn" onclick="openReportModal(\'post\',\'' + esc(p.id) + '\')">🚩 Report</div>';
      }
      html += '<div class="com-drop-item" onclick="copyLink(\'' + esc(p.id) + '\')">🔗 Copy link</div>';
      html += '</div>';
      html += '</div>';
      html += '</div>'; // post-head

      // Body
      html += '<div class="com-post-body">';
      if (isLong) {
        html += '<div class="com-post-text collapsed" id="pt-' + esc(p.id) + '">' + esc(p.content) + '</div>';
        html += '<button class="com-see-more" onclick="expandPost(\'' + esc(p.id) + '\', this)">See more</button>';
      } else {
        html += '<div class="com-post-text">' + esc(p.content) + '</div>';
      }
      html += '</div>';

      // Reaction counts (only show if > 0)
      var hasCounts = (p.like_count||0) + (p.fire_count||0) + (p.clap_count||0) > 0 || (p.comment_count||0) > 0;
      if (hasCounts) {
        html += '<div class="com-reaction-counts">';
        if ((p.like_count||0) > 0) html += '<span class="com-rc-item">❤️ <span id="lc-' + esc(p.id) + '">' + (p.like_count||0) + '</span></span>';
        if ((p.fire_count||0) > 0) html += '<span class="com-rc-item">🔥 <span id="fc-' + esc(p.id) + '">' + (p.fire_count||0) + '</span></span>';
        if ((p.clap_count||0) > 0) html += '<span class="com-rc-item">👏 <span id="cc-' + esc(p.id) + '">' + (p.clap_count||0) + '</span></span>';
        if ((p.comment_count||0) > 0) html += '<span class="com-rc-item" style="margin-left:auto">💬 ' + (p.comment_count||0) + ' comment' + ((p.comment_count||0) !== 1 ? 's':'') + '</span>';
        html += '</div>';
      }

      // Action bar
      html += '<div class="com-post-actions">';
      html += '<button class="com-react' + (myLike ? ' active-like':'') + '" data-type="like" onclick="react(\'' + esc(p.id) + '\',\'like\',this)">❤️ Like</button>';
      html += '<button class="com-react' + (myFire ? ' active-fire':'') + '" data-type="fire" onclick="react(\'' + esc(p.id) + '\',\'fire\',this)">🔥 Fire</button>';
      html += '<button class="com-react' + (myClap ? ' active-clap':'') + '" data-type="clap" onclick="react(\'' + esc(p.id) + '\',\'clap\',this)">👏 Clap</button>';
      html += '<button class="com-react" onclick="toggleComments(\'' + esc(p.id) + '\',this)">💬 Comment</button>';
      html += '</div>';

      // Comments panel (lazy loaded)
      html += '<div class="com-comments" id="cmts-' + esc(p.id) + '">';
      html += '<div class="com-comment-input-row">';
      html += '<div class="com-comment-av" style="background:linear-gradient(135deg,' + colorFor(userName) + ',rgba(52,211,153,.6))">' + myInitial + '</div>';
      html += '<textarea class="com-comment-input" placeholder="Write a comment..." rows="1" id="ci-' + esc(p.id) + '"></textarea>';
      html += '<button class="com-comment-send" onclick="sendComment(\'' + esc(p.id) + '\')" id="cs-' + esc(p.id) + '">';
      html += '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>';
      html += '</button>';
      html += '</div>';
      html += '<div class="com-comments-inner" id="cl-' + esc(p.id) + '"></div>';
      html += '</div>';

      el.innerHTML = html;
      return el;
    }

    // ── Load posts ─────────────────────────────────────────────────
    function loadPosts(append) {
      var feed = document.getElementById('postsList');
      if (!append) feed.innerHTML = '<div class="com-loading"><div class="com-spinner"></div></div>';

      fetch('/api/community/posts?category=' + state.cat + '&page=' + state.page)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!append) feed.innerHTML = '';
          var posts = data.posts || [];
          if (!posts.length && !append) {
            feed.innerHTML = '<div class="com-empty"><div class="com-empty-icon">🌿</div><div class="com-empty-title">No posts yet</div><div class="com-empty-sub">Be the first to share something with the community!</div></div>';
          }
          posts.forEach(function(p) { feed.appendChild(renderPost(p)); });
          state.hasMore = data.has_more;
          document.getElementById('loadMoreBtn').style.display = state.hasMore ? '' : 'none';
        }).catch(function() {
          if (!append) feed.innerHTML = '<div class="com-empty"><div class="com-empty-icon">⚠️</div><div class="com-empty-title">Failed to load posts</div><div class="com-empty-sub">Please refresh the page.</div></div>';
        });
    }

    // ── Category switching ─────────────────────────────────────────
    function setCategory(cat) {
      state.cat = cat;
      state.page = 1;
      // Update all tab/pill UI
      document.querySelectorAll('.com-tab, .com-cat-pill').forEach(function(b) {
        b.classList.toggle('active', b.dataset.cat === cat);
      });
      loadPosts(false);
    }

    document.getElementById('sidebarCats').addEventListener('click', function(e) {
      var b = e.target.closest('.com-cat-pill');
      if (b) setCategory(b.dataset.cat);
    });
    document.getElementById('comMobileCats').addEventListener('click', function(e) {
      var b = e.target.closest('.com-tab');
      if (b) setCategory(b.dataset.cat);
    });

    document.getElementById('loadMoreBtn').addEventListener('click', function() {
      state.page++;
      loadPosts(true);
    });

    // ── Reactions ─────────────────────────────────────────────────
    window.react = function(postId, type, btn) {
      fetch('/api/community/posts/' + postId + '/react', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reaction_type: type }),
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.error) return;
        var activeClass = 'active-' + type;
        var added = data.action === 'added';
        btn.classList.toggle(activeClass, added);
        // Update count display in reaction bar
        var fieldMap = { like: 'lc', fire: 'fc', clap: 'cc' };
        var countEl = document.getElementById(fieldMap[type] + '-' + postId);
        if (countEl) {
          var cur = parseInt(countEl.textContent) || 0;
          countEl.textContent = added ? cur + 1 : Math.max(0, cur - 1);
          // Show/hide reaction counts bar based on totals
        }
      });
    };

    // ── Comments ──────────────────────────────────────────────────
    window.toggleComments = function(postId, btn) {
      var panel = document.getElementById('cmts-' + postId);
      var isOpen = panel.classList.contains('open');
      panel.classList.toggle('open', !isOpen);
      btn.classList.toggle('active-comment', !isOpen);
      if (!isOpen) {
        loadComments(postId);
        setTimeout(function() {
          var inp = document.getElementById('ci-' + postId);
          if (inp) inp.focus();
        }, 150);
      }
    };

    function loadComments(postId) {
      var list = document.getElementById('cl-' + postId);
      if (!list || list.dataset.loaded === 'true') return;
      list.innerHTML = '<div style="text-align:center;padding:.5rem;color:var(--soft);font-size:.78rem">Loading…</div>';
      fetch('/api/community/posts/' + postId + '/comments')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          list.innerHTML = '';
          list.dataset.loaded = 'true';
          (data.comments || []).forEach(function(c) { list.appendChild(renderComment(c)); });
        });
    }

    function renderComment(c) {
      var col = colorFor(c.author_name || 'M');
      var el = document.createElement('div');
      el.className = 'com-comment';
      if (c.id) el.dataset.cid = c.id;
      var actions = '';
      if (c.is_own) {
        actions = '<button class="com-comment-action" onclick="deleteComment(\'' + esc(c.id||'') + '\',this)">Delete</button>';
      } else if (c.id) {
        actions = '<button class="com-comment-action" onclick="openReportModal(\'comment\',\'' + esc(c.id) + '\')">Report</button>';
      }
      el.innerHTML =
        '<div class="com-comment-av" style="background:linear-gradient(135deg,' + col + ',rgba(52,211,153,.6))">' + esc((c.author_name||'M').charAt(0).toUpperCase()) + '</div>' +
        '<div class="com-comment-bubble">' +
          '<div class="com-comment-author">' + esc(c.author_name || 'Member') + (actions ? ' <span class="com-comment-actions">' + actions + '</span>' : '') + '</div>' +
          '<div class="com-comment-text">' + esc(c.content) + '</div>' +
          '<div class="com-comment-time">' + timeAgo(c.created_at) + '</div>' +
        '</div>';
      return el;
    }

    window.sendComment = function(postId) {
      var inp = document.getElementById('ci-' + postId);
      var btn = document.getElementById('cs-' + postId);
      var text = inp ? inp.value.trim() : '';
      if (!text) return;
      btn.disabled = true;
      fetch('/api/community/posts/' + postId + '/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: text }),
      }).then(function(r) { return r.json(); }).then(function(data) {
        btn.disabled = false;
        if (data.error) return;
        inp.value = '';
        var list = document.getElementById('cl-' + postId);
        if (list) {
          list.dataset.loaded = 'true';
          var newC = { author_name: userName, content: text, created_at: new Date().toISOString() };
          list.appendChild(renderComment(newC));
          // Scroll to new comment
          list.lastElementChild.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
        // Update comment count
        var card = document.querySelector('[data-id="' + postId + '"]');
        if (card) {
          var cBtn = card.querySelector('.com-react:last-child');
          // Increment comment count in reaction bar if present
          var existing = card.querySelector('.com-reaction-counts');
          // Simple approach: update button text isn't trivial here; let full reload handle accurate count
        }
      });
    };

    // Enter to submit comment (Shift+Enter for newline)
    document.getElementById('postsList').addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey && e.target.classList.contains('com-comment-input')) {
        e.preventDefault();
        var postId = e.target.id.replace('ci-', '');
        window.sendComment(postId);
      }
    });

    // ── Post creation ─────────────────────────────────────────────
    var modal = document.getElementById('postModal');
    function openModal() { modal.classList.add('open'); document.getElementById('postContent').focus(); }
    function closeModal() { modal.classList.remove('open'); }

    document.getElementById('openPostBtn').addEventListener('click', openModal);
    document.getElementById('comWriteBtn').addEventListener('click', openModal);
    document.getElementById('closeModal').addEventListener('click', closeModal);
    document.getElementById('cancelPost').addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

    var contentEl = document.getElementById('postContent');
    contentEl.addEventListener('input', function() {
      document.getElementById('charCount').textContent = contentEl.value.length + ' / 2000';
    });

    document.getElementById('submitPost').addEventListener('click', function() {
      var content = contentEl.value.trim();
      var category = document.getElementById('postCategory').value;
      var errEl = document.getElementById('postError');
      errEl.textContent = '';
      if (content.length < 3) { errEl.textContent = 'Post too short.'; return; }
      var btn = document.getElementById('submitPost');
      btn.disabled = true; btn.textContent = 'Posting…';
      fetch('/api/community/posts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: content, category: category }),
      }).then(function(r) { return r.json(); }).then(function(data) {
        btn.disabled = false; btn.textContent = 'Post';
        if (data.error) { errEl.textContent = data.error; return; }
        closeModal();
        contentEl.value = '';
        document.getElementById('charCount').textContent = '0 / 2000';
        state.page = 1;
        loadPosts(false);
      }).catch(function() {
        btn.disabled = false; btn.textContent = 'Post';
        errEl.textContent = 'Network error.';
      });
    });

    // ── Misc actions ──────────────────────────────────────────────
    window.toggleMenu = function(btn) {
      var dd = btn.nextElementSibling;
      var wasOpen = dd.classList.contains('open');
      // Close all other dropdowns first
      document.querySelectorAll('.com-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
      if (!wasOpen) dd.classList.add('open');
    };
    // Close menus on outside click
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.com-post-menu')) {
        document.querySelectorAll('.com-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
      }
    });

    window.deletePost = function(postId, el) {
      if (!confirm('Delete this post?')) return;
      fetch('/api/community/posts/' + postId + '/delete', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.error) return;
          var card = document.querySelector('[data-id="' + postId + '"]');
          if (card) card.remove();
        });
    };

    window.deleteComment = function(commentId, btn) {
      if (!commentId || !confirm('Delete this comment?')) return;
      fetch('/api/community/comments/' + commentId + '/delete', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.error) return;
          var el = document.querySelector('[data-cid="' + commentId + '"]');
          if (el) el.remove();
        });
    };

    // ── Report modal ──────────────────────────────────────────────
    var reportModal    = document.getElementById('reportModal');
    var reportTarget   = { type: null, id: null };

    window.openReportModal = function(type, id) {
      reportTarget.type = type;
      reportTarget.id   = id;
      document.getElementById('reportError').textContent = '';
      document.getElementById('reportReason').value = 'spam';
      reportModal.classList.add('open');
      document.querySelectorAll('.com-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
    };

    document.getElementById('closeReportModal').addEventListener('click', function() {
      reportModal.classList.remove('open');
    });
    reportModal.addEventListener('click', function(e) {
      if (e.target === reportModal) reportModal.classList.remove('open');
    });

    document.getElementById('submitReport').addEventListener('click', function() {
      var reason = document.getElementById('reportReason').value;
      var errEl  = document.getElementById('reportError');
      var btn    = document.getElementById('submitReport');
      errEl.textContent = '';
      if (!reportTarget.id) return;

      var url = reportTarget.type === 'post'
        ? '/api/community/posts/'    + reportTarget.id + '/report'
        : '/api/community/comments/' + reportTarget.id + '/report';

      btn.disabled = true; btn.textContent = 'Submitting…';
      fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason: reason }),
      }).then(function(r) { return r.json(); }).then(function(data) {
        btn.disabled = false; btn.textContent = 'Submit Report';
        if (data.error) { errEl.textContent = data.error; return; }
        reportModal.classList.remove('open');
        // Brief toast
        var toast = document.getElementById('reportToast');
        if (toast) { toast.style.display = 'flex'; setTimeout(function() { toast.style.display = 'none'; }, 3000); }
      }).catch(function() {
        btn.disabled = false; btn.textContent = 'Submit Report';
        errEl.textContent = 'Network error.';
      });
    });

    window.expandPost = function(postId, btn) {
      var textEl = document.getElementById('pt-' + postId);
      if (textEl) { textEl.classList.remove('collapsed'); btn.remove(); }
    };

    window.copyLink = function(postId) {
      navigator.clipboard && navigator.clipboard.writeText(window.location.origin + '/dashboard/community#' + postId);
      document.querySelectorAll('.com-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
    };

    // ── Init ──────────────────────────────────────────────────────
    loadPosts(false);
  })();
  </script>
</body>
</html>
