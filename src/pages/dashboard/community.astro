---
// src/pages/dashboard/community.astro — Pro & Elite community (Facebook-group style)
import { requireAuth } from '../../lib/auth';
import DashNav from '../../components/DashNav.astro';
import { getTranslator, normaliseLang } from '../../lib/i18n';
import Users from 'lucide-astro/Users';
import Lock from 'lucide-astro/Lock';
import Calendar from 'lucide-astro/Calendar';
import Trophy from 'lucide-astro/Trophy';
import TrendingUp from 'lucide-astro/TrendingUp';
import Flame from 'lucide-astro/Flame';
import MessageCircle from 'lucide-astro/MessageCircle';
import ImageIcon from 'lucide-astro/Image';
import BarChart2 from 'lucide-astro/BarChart2';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

if (profile.subscription_tier === 'basic_30' || !profile.subscription_tier) {
  return Astro.redirect('/dashboard/upgrade');
}

const planType  = profile.subscription_tier;
const userName  = profile.full_name || 'Member';
const tierLabel = planType === 'elite_12' ? 'Elite' : 'Pro';
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);

// Parallel data fetch
const [memberRes, journeyRes, weightRes, onboardingRes] = await Promise.allSettled([
  db.from('profiles').select('id', { count: 'exact', head: true }).in('subscription_tier', ['pro_6', 'elite_12']),
  db.from('user_journey').select('current_day,streak_days,total_xp,level').eq('user_id', user.id).maybeSingle(),
  db.from('weight_logs').select('weight').eq('user_id', user.id).order('logged_date', { ascending: false }).limit(1).maybeSingle(),
  db.from('onboarding_data').select('current_weight').eq('user_id', user.id).maybeSingle(),
]);

const memberCount    = memberRes.status    === 'fulfilled' ? (memberRes.value?.count    ?? 0) : 0;
const journey        = journeyRes.status   === 'fulfilled' ? (journeyRes.value?.data    ?? null) : null;
const latestWtRow    = weightRes.status    === 'fulfilled' ? (weightRes.value?.data     ?? null) : null;
const onboarding     = onboardingRes.status === 'fulfilled' ? (onboardingRes.value?.data ?? null) : null;

const startWtKg      = onboarding?.current_weight || profile.weight_kg || 0;
const latestWtKg     = latestWtRow?.weight || startWtKg;
const weightLostKg   = Math.max(0, Math.round((startWtKg - latestWtKg) * 10) / 10);

const myProgressData = {
  day:        journey?.current_day  || 1,
  streak:     journey?.streak_days  || 0,
  level:      journey?.level        || 1,
  xp:         journey?.total_xp     || 0,
  weightLost: weightLostKg,
  unit:       'kg',
};

const showWeightLost = weightLostKg > 0;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Community · Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <DashNav userId={user.id} userName={userName} tierLabel={tierLabel} planType={planType} activePage="community" />

  <!-- GROUP COVER BANNER -->
  <div id="comCover">
    <div id="comCoverBg"></div>
    <div id="comCoverContent">
      <div id="comGroupIcon"><Users size={32} /></div>
      <div id="comGroupInfo">
        <h1 id="comGroupName">Keto <em>Community</em></h1>
        <p id="comGroupDesc">Private group · {memberCount} Pro &amp; Elite members · Share your journey, recipes &amp; wins</p>
        <div id="comGroupMeta">
          <span class="com-badge"><Lock size={12} style="display:inline;vertical-align:middle;" /> Pro &amp; Elite only</span>
          <span class="com-badge"><Calendar size={12} style="display:inline;vertical-align:middle;" /> 365-day journey</span>
          <span class="com-badge"><Users size={12} style="display:inline;vertical-align:middle;" /> Global community</span>
        </div>
      </div>
      <button id="openPostBtn" class="com-post-btn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Create Post
      </button>
    </div>
  </div>

  <!-- MAIN LAYOUT -->
  <div id="comLayout">

    <!-- LEFT SIDEBAR -->
    <aside id="comSidebar">
      <div class="com-side-card">
        <div class="com-side-title">About this group</div>
        <p class="com-side-body">A private space for Pro &amp; Elite Keto Journey members to share progress, recipes, tips and motivation.</p>
        <div class="com-side-stat"><span><Trophy size={14} /></span><span>{memberCount} members</span></div>
        <div class="com-side-stat"><span><Lock size={14} /></span><span>Private · Pro &amp; Elite</span></div>
        <div class="com-side-stat"><span><Users size={14} /></span><span>12-month program</span></div>
      </div>

      <div class="com-side-card">
        <div class="com-side-title">Your Stats</div>
        <div class="com-side-stat com-stat-hi"><span>🔥</span><span><strong>{myProgressData.streak}</strong> day streak</span></div>
        <div class="com-side-stat com-stat-hi"><span>📅</span><span>Day <strong>{myProgressData.day}</strong> of journey</span></div>
        <div class="com-side-stat com-stat-hi"><span>⭐</span><span>Level <strong>{myProgressData.level}</strong> · {myProgressData.xp} XP</span></div>
        {showWeightLost && (
          <div class="com-side-stat com-stat-hi"><span>⚖️</span><span><strong>{myProgressData.weightLost} {myProgressData.unit}</strong> lost</span></div>
        )}
        <button class="com-share-progress-btn" id="sidebarProgressBtn">
          <BarChart2 size={13} style="display:inline;vertical-align:middle;" /> Share my progress
        </button>
      </div>

      <div class="com-side-card">
        <div class="com-side-title">Categories</div>
        <div id="sidebarCats">
          <button class="com-cat-pill active" data-cat="all">All Posts</button>
          <button class="com-cat-pill" data-cat="progress"><TrendingUp size={12} style="display:inline;vertical-align:middle;" /> Progress</button>
          <button class="com-cat-pill" data-cat="recipes">🍳 Recipes</button>
          <button class="com-cat-pill" data-cat="tips">💡 Tips</button>
          <button class="com-cat-pill" data-cat="motivation"><Flame size={12} style="display:inline;vertical-align:middle;" /> Motivation</button>
          <button class="com-cat-pill" data-cat="general"><MessageCircle size={12} style="display:inline;vertical-align:middle;" /> General</button>
        </div>
      </div>

      <div class="com-side-card">
        <div class="com-side-title">Community Rules</div>
        <ol class="com-rules-list">
          <li>Be kind and supportive</li>
          <li>No spam or self-promotion</li>
          <li>Share accurate health info</li>
          <li>Respect everyone's journey</li>
          <li>No personal attacks</li>
        </ol>
      </div>
    </aside>

    <!-- FEED -->
    <main id="comFeed">
      <!-- Write bar -->
      <div id="comWriteBar">
        <div id="comWriteAvatar">{userName.charAt(0).toUpperCase()}</div>
        <button id="comWriteBtn" class="com-write-placeholder">What's on your mind, {userName.split(' ')[0]}?</button>
        <div id="comWriteActions">
          <button class="com-write-action" id="quickPhotoBtn"><ImageIcon size={14} style="display:inline;vertical-align:middle;" /> Photo</button>
          <button class="com-write-action" id="quickProgressBtn"><BarChart2 size={14} style="display:inline;vertical-align:middle;" /> Progress</button>
        </div>
      </div>

      <!-- Category tabs (mobile) -->
      <div id="comMobileCats">
        <button class="com-tab active" data-cat="all">All</button>
        <button class="com-tab" data-cat="progress">Progress</button>
        <button class="com-tab" data-cat="recipes">Recipes</button>
        <button class="com-tab" data-cat="tips">Tips</button>
        <button class="com-tab" data-cat="motivation">Motivation</button>
        <button class="com-tab" data-cat="general">General</button>
      </div>

      <!-- Posts list -->
      <div id="postsList">
        <div class="com-loading"><div class="com-spinner"></div></div>
      </div>
      <button id="loadMoreBtn" style="display:none">Load more posts</button>
    </main>
  </div>

  <!-- ═══════════════ CREATE POST MODAL ═══════════════ -->
  <div id="postModal" class="com-modal-overlay">
    <div class="com-modal">
      <div class="com-modal-head">
        <h2>Create Post</h2>
        <button id="closeModal" class="com-modal-close">&times;</button>
      </div>
      <div class="com-modal-author">
        <div class="com-av com-av-lg">{userName.charAt(0).toUpperCase()}</div>
        <div>
          <div class="com-author-name">{userName}</div>
          <select id="postCategory" class="com-cat-select">
            <option value="general">💬 General</option>
            <option value="progress">📈 Progress Update</option>
            <option value="recipes">🍳 Recipe Share</option>
            <option value="tips">💡 Tips &amp; Tricks</option>
            <option value="motivation">🔥 Motivation</option>
          </select>
        </div>
      </div>

      <!-- Mode tabs -->
      <div id="postModeTabs">
        <button class="com-mode-tab active" data-mode="text">✏️ Text</button>
        <button class="com-mode-tab" data-mode="photo">📷 Photo</button>
        <button class="com-mode-tab" data-mode="progress">📊 My Progress</button>
      </div>

      <!-- TEXT mode -->
      <div id="modeText" class="com-mode-panel">
        <textarea id="postContent" class="com-textarea" placeholder="Share your progress, a recipe, tip or win…"></textarea>
      </div>

      <!-- PHOTO mode -->
      <div id="modePhoto" class="com-mode-panel" style="display:none">
        <div id="photoDropzone">
          <input type="file" id="photoFileInput" accept="image/jpeg,image/png,image/webp" style="display:none" />
          <button id="photoPickBtn" class="com-photo-pick">📷 Choose a photo</button>
          <p class="com-photo-hint">JPEG · PNG · WebP · max 2 MB</p>
        </div>
        <div id="photoPreviewWrap" style="display:none">
          <img id="photoPreviewImg" src="" alt="Preview" class="com-photo-preview" />
          <button id="photoRemoveBtn" class="com-photo-remove">✕ Remove</button>
        </div>
        <textarea id="photoCaption" class="com-textarea" style="min-height:72px;border-top:1px solid var(--border)" placeholder="Add a caption (optional)…"></textarea>
        <p id="photoUploadError" class="com-err" style="padding:.25rem 1.25rem .5rem"></p>
      </div>

      <!-- PROGRESS mode -->
      <div id="modeProgress" class="com-mode-panel" style="display:none">
        <div class="com-progress-preview" id="progressPreviewCard">
          <div class="com-progress-preview-label">📊 Your Progress</div>
          <div class="com-pp-grid">
            <div class="com-pp-stat"><div class="com-pp-val" id="ppStreak">0</div><div class="com-pp-lbl">Day Streak 🔥</div></div>
            <div class="com-pp-stat"><div class="com-pp-val" id="ppDay">1</div><div class="com-pp-lbl">Journey Day</div></div>
            <div class="com-pp-stat"><div class="com-pp-val" id="ppLevel">1</div><div class="com-pp-lbl">Level ⭐</div></div>
            <div class="com-pp-stat" id="ppWeightWrap" style="display:none">
              <div class="com-pp-val" id="ppWeight">0</div>
              <div class="com-pp-lbl" id="ppWeightLbl">kg lost ⚖️</div>
            </div>
          </div>
        </div>
        <textarea id="progressCaption" class="com-textarea" style="min-height:72px;border-top:1px solid var(--border)" placeholder="Add a message (optional)…"></textarea>
      </div>

      <div class="com-char-row">
        <span id="postError" class="com-err"></span>
        <span id="charCount">0 / 2000</span>
      </div>
      <div class="com-modal-footer">
        <button id="cancelPost" class="com-btn-ghost">Cancel</button>
        <button id="submitPost" class="com-btn-primary">Post</button>
      </div>
    </div>
  </div>

  <!-- ═══════════════ REPORT MODAL ═══════════════ -->
  <div id="reportModal" class="com-modal-overlay">
    <div class="com-modal" style="max-width:420px">
      <div class="com-modal-head">
        <h2>Report Content</h2>
        <button id="closeReportModal" class="com-modal-close">&times;</button>
      </div>
      <div style="padding:1.25rem">
        <p style="font-size:.85rem;color:var(--soft);margin-bottom:1rem;line-height:1.5">Help keep our community safe. Select a reason and our moderators will review this content.</p>
        <label style="font-size:.78rem;font-weight:700;color:var(--soft);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem">Reason</label>
        <select id="reportReason" style="width:100%;background:var(--card2);border:1px solid var(--border2);border-radius:10px;padding:.6rem .9rem;color:var(--text);font-size:.88rem;font-family:inherit;cursor:pointer">
          <option value="spam">Spam or self-promotion</option>
          <option value="harassment">Harassment or bullying</option>
          <option value="inappropriate">Inappropriate content</option>
          <option value="misinformation">Health misinformation</option>
          <option value="other">Other</option>
        </select>
        <div style="margin-top:.75rem;min-height:1.2rem"><span id="reportError" style="font-size:.78rem;color:var(--red);font-weight:600"></span></div>
      </div>
      <div class="com-modal-footer">
        <button id="closeReportModal2" class="com-btn-ghost" onclick="document.getElementById('reportModal').classList.remove('open')">Cancel</button>
        <button id="submitReport" class="com-btn-primary" style="background:var(--red)">Submit Report</button>
      </div>
    </div>
  </div>

  <!-- ═══════════════ LIGHTBOX ═══════════════ -->
  <div id="lightboxOverlay" onclick="closeLightbox()">
    <button id="lightboxClose" onclick="closeLightbox()">&times;</button>
    <img id="lightboxImg" src="" alt="" />
  </div>

  <!-- TOAST -->
  <div id="comToast"></div>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #060d09; --card: #0d1a0f; --card2: #111f13;
      --border: rgba(16,185,129,.1); --border2: rgba(16,185,129,.22);
      --text: #dfeedd; --soft: #4d7055; --muted: #233328;
      --green: #10b981; --green2: #34d399;
      --gold: #f59e0b; --purple: #8b5cf6; --blue: #3b82f6; --red: #ef4444;
      --nav-h: 64px;
    }
    body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; }

    /* ── COVER BANNER ─────────────────────────────────────────────── */
    #comCover {
      position: relative; margin-top: var(--nav-h);
      background: linear-gradient(135deg, #051209 0%, #082e12 50%, #051209 100%);
      border-bottom: 1px solid var(--border2); overflow: hidden;
    }
    #comCoverBg {
      position: absolute; inset: 0; opacity: .45;
      background:
        radial-gradient(ellipse at 25% 50%, rgba(16,185,129,.18) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 20%, rgba(52,211,153,.1) 0%, transparent 50%),
        repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(16,185,129,.03) 40px),
        repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(16,185,129,.03) 40px);
    }
    #comCoverContent {
      position: relative; max-width: 1100px; margin: 0 auto;
      padding: 2rem 1.5rem 1.5rem;
      display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap;
    }
    #comGroupIcon {
      width: 76px; height: 76px; border-radius: 18px; flex-shrink: 0;
      background: linear-gradient(135deg, rgba(16,185,129,.3), rgba(52,211,153,.12));
      border: 2px solid rgba(16,185,129,.45);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 0 28px rgba(16,185,129,.15);
    }
    #comGroupInfo { flex: 1; min-width: 200px; }
    #comGroupName {
      font-family: 'Fraunces', serif; font-size: clamp(1.5rem, 3vw, 2.1rem);
      font-weight: 700; color: var(--text); margin-bottom: .3rem;
    }
    #comGroupName em { font-style: italic; color: var(--green2); }
    #comGroupDesc { font-size: .84rem; color: var(--soft); margin-bottom: .65rem; }
    #comGroupMeta { display: flex; gap: .5rem; flex-wrap: wrap; }
    .com-badge {
      font-size: .7rem; font-weight: 700; padding: .22rem .65rem; border-radius: 99px;
      background: rgba(16,185,129,.1); border: 1px solid rgba(16,185,129,.2); color: var(--green2);
    }
    .com-post-btn {
      display: flex; align-items: center; gap: .5rem; flex-shrink: 0;
      padding: .7rem 1.5rem; border-radius: 12px;
      background: var(--green); color: #fff; border: none;
      font-weight: 700; font-size: .88rem; cursor: pointer;
      transition: opacity .2s, transform .15s; box-shadow: 0 4px 16px rgba(16,185,129,.3);
    }
    .com-post-btn:hover { opacity: .88; transform: translateY(-2px); }

    /* ── LAYOUT ─────────────────────────────────────────────────── */
    #comLayout {
      max-width: 1100px; margin: 0 auto; padding: 1.5rem 1.5rem 5rem;
      display: grid; grid-template-columns: 285px 1fr; gap: 1.5rem;
    }
    @media (max-width: 900px)  { #comLayout { grid-template-columns: 1fr; } }
    @media (max-width: 640px)  { #comLayout { padding: 1rem .75rem 5rem; } }

    /* ── SIDEBAR ─────────────────────────────────────────────────── */
    #comSidebar { display: flex; flex-direction: column; gap: 1rem; }
    @media (max-width: 900px) { #comSidebar { display: none; } }
    .com-side-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 16px; padding: 1.1rem 1.15rem;
    }
    .com-side-title {
      font-weight: 800; font-size: .78rem; color: var(--soft);
      margin-bottom: .75rem; text-transform: uppercase; letter-spacing: .06em;
    }
    .com-side-body { font-size: .8rem; color: var(--soft); line-height: 1.6; margin-bottom: .75rem; }
    .com-side-stat { display: flex; align-items: center; gap: .5rem; font-size: .82rem; color: var(--soft); margin-bottom: .45rem; }
    .com-stat-hi strong { color: var(--green2); }
    .com-share-progress-btn {
      width: 100%; margin-top: .6rem; padding: .5rem;
      background: rgba(16,185,129,.08); border: 1px solid rgba(16,185,129,.2);
      color: var(--green2); border-radius: 10px; font-size: .8rem; font-weight: 700;
      cursor: pointer; font-family: inherit; transition: all .15s;
    }
    .com-share-progress-btn:hover { background: rgba(16,185,129,.14); border-color: var(--green); }
    .com-cat-pill {
      display: block; width: 100%; text-align: left;
      padding: .45rem .65rem; border-radius: 9px; border: none;
      background: transparent; color: var(--soft); font-size: .82rem; font-weight: 600;
      cursor: pointer; transition: all .15s; margin-bottom: .2rem; font-family: inherit;
    }
    .com-cat-pill:hover  { background: rgba(16,185,129,.07); color: var(--text); }
    .com-cat-pill.active { background: rgba(16,185,129,.12); color: var(--green2); font-weight: 700; }
    .com-rules-list { padding-left: 1.1rem; display: flex; flex-direction: column; gap: .4rem; }
    .com-rules-list li { font-size: .79rem; color: var(--soft); line-height: 1.45; }

    /* ── FEED ────────────────────────────────────────────────────── */
    #comFeed { display: flex; flex-direction: column; gap: 1rem; min-width: 0; }

    /* Write bar */
    #comWriteBar {
      display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 16px; padding: .85rem 1rem;
    }
    #comWriteAvatar {
      width: 42px; height: 42px; border-radius: 50%; flex-shrink: 0;
      background: linear-gradient(135deg, var(--green), var(--green2));
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 1rem; color: #fff;
    }
    .com-write-placeholder {
      flex: 1; min-width: 120px; text-align: left; background: var(--card2);
      border: 1px solid var(--border); border-radius: 99px;
      padding: .55rem 1rem; color: var(--soft); font-size: .88rem; font-family: inherit;
      cursor: pointer; transition: border-color .2s;
    }
    .com-write-placeholder:hover { border-color: var(--green); color: var(--text); }
    #comWriteActions { display: flex; gap: .4rem; margin-left: auto; }
    .com-write-action {
      display: flex; align-items: center; gap: .3rem;
      padding: .4rem .75rem; border-radius: 99px; border: 1px solid var(--border);
      background: transparent; color: var(--soft); font-size: .78rem; font-weight: 700;
      cursor: pointer; white-space: nowrap; transition: all .15s; font-family: inherit;
    }
    .com-write-action:hover { border-color: var(--green); color: var(--green2); background: rgba(16,185,129,.07); }
    @media (max-width: 480px) { #comWriteActions { display: none; } }

    /* Mobile category tabs */
    #comMobileCats {
      display: none; gap: .4rem; overflow-x: auto; padding-bottom: .25rem; scrollbar-width: none;
    }
    #comMobileCats::-webkit-scrollbar { display: none; }
    @media (max-width: 900px) { #comMobileCats { display: flex; } }
    .com-tab {
      padding: .38rem .85rem; border-radius: 99px; border: 1px solid var(--border);
      background: transparent; color: var(--soft); font-size: .78rem; font-weight: 600;
      cursor: pointer; white-space: nowrap; transition: all .15s; flex-shrink: 0; font-family: inherit;
    }
    .com-tab:hover  { border-color: var(--border2); color: var(--text); }
    .com-tab.active { background: rgba(16,185,129,.12); color: var(--green2); border-color: var(--green); }

    /* ── POST CARD ───────────────────────────────────────────────── */
    .com-post {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 20px; overflow: hidden;
      transition: border-color .2s, box-shadow .2s;
      animation: comFadeUp .3s ease both;
    }
    .com-post:hover { border-color: var(--border2); box-shadow: 0 6px 24px rgba(0,0,0,.22); }
    @keyframes comFadeUp { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:none; } }

    .com-post-head {
      display: flex; align-items: center; gap: .75rem;
      padding: 1rem 1.1rem .75rem;
    }
    .com-av {
      width: 42px; height: 42px; border-radius: 50%; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: .95rem; color: #fff;
    }
    .com-av-lg { width: 46px; height: 46px; font-size: 1.05rem; }
    .com-post-meta { flex: 1; min-width: 0; }
    .com-post-author { font-weight: 700; font-size: .9rem; color: var(--text); display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }
