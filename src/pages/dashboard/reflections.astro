---
import { requireAuth } from '../../lib/auth';
import DashNav from '../../components/DashNav.astro';
import BookOpen from 'lucide-astro/BookOpen';
import Heart from 'lucide-astro/Heart';
import Star from 'lucide-astro/Star';
import Edit3 from 'lucide-astro/Edit3';
import Calendar from 'lucide-astro/Calendar';
import Droplets from 'lucide-astro/Droplets';
import CheckCircle from 'lucide-astro/CheckCircle';
import X from 'lucide-astro/X';
import Zap from 'lucide-astro/Zap';
import Moon from 'lucide-astro/Moon';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? '👑 Elite' : planType === 'pro_6' ? '⚡ Pro' : '🥑 Basic';
const userName  = profile.full_name?.split(' ')[0] || 'Friend';

const { data: reflections } = await db
  .from('daily_reflections')
  .select('*')
  .eq('user_id', user.id)
  .order('reflection_date', { ascending: false })
  .limit(30);

const thirtyAgo = new Date(Date.now() - 29 * 86400000).toISOString().split('T')[0];

const { data: checkins } = await db
  .from('daily_checkins')
  .select('checkin_date, energy_level, mood_level, water_glasses, followed_meals, note, sleep_hours, sleep_quality')
  .eq('user_id', user.id)
  .gte('checkin_date', thirtyAgo)
  .order('checkin_date', { ascending: false });

// Build a unified list keyed by date
const reflMap = new Map();
(reflections || []).forEach((r) => { reflMap.set(r.reflection_date, r); });

const checkinMap = new Map();
(checkins || []).forEach((c) => { checkinMap.set(c.checkin_date, c); });

// Merge all dates (newest first)
const allDates = Array.from(new Set([
  ...(reflections || []).map((r) => r.reflection_date),
  ...(checkins    || []).map((c) => c.checkin_date),
])).sort((a, b) => (a < b ? 1 : -1));

const hasData = allDates.length > 0;

// 7-day averages
const last7Checkins = (checkins || []).slice(0, 7);
const avg7Energy = last7Checkins.length
  ? (last7Checkins.reduce((s, c) => s + (c.energy_level || 3), 0) / last7Checkins.length).toFixed(1)
  : null;
const avg7Mood = last7Checkins.length
  ? (last7Checkins.reduce((s, c) => s + (c.mood_level || 3), 0) / last7Checkins.length).toFixed(1)
  : null;
const avg7Water = last7Checkins.length
  ? (last7Checkins.reduce((s, c) => s + (c.water_glasses || 0), 0) / last7Checkins.length).toFixed(1)
  : null;
const avg7Meals = last7Checkins.length
  ? Math.round((last7Checkins.filter((c) => c.followed_meals).length / last7Checkins.length) * 100)
  : null;

// Pre-compute mood emojis to avoid inline ternaries with numbers
const moodEmojis = ['', '😔', '😐', '😊', '😄', '🤩'];
const energyMax = 5;

// Format date helper (server-side)
function formatDate(dateStr) {
  if (!dateStr) return '';
  const d = new Date(dateStr + 'T12:00:00');
  return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });
}

// Pre-build display entries
const entries = allDates.map((date) => {
  const refl   = reflMap.get(date);
  const checkin = checkinMap.get(date);
  const energy  = refl?.energy_level || checkin?.energy_level || 0;
  const mood    = refl?.mood_level   || checkin?.mood_level   || 0;
  const water   = checkin?.water_glasses || 0;
  const mealOk  = checkin?.followed_meals;
  const note    = refl?.note || checkin?.note || '';
  const highlights  = refl?.highlights   || '';
  const challenges  = refl?.challenges   || '';
  const sleepH  = checkin?.sleep_hours   || 0;
  const sleepQ  = checkin?.sleep_quality || 0;
  const moodEmoji = moodEmojis[mood] || '';
  const energyStars = energy > 0 ? '⭐'.repeat(energy) + '☆'.repeat(Math.max(0, energyMax - energy)) : '';

  return { date, dateLabel: formatDate(date), energy, mood, water, mealOk, note, highlights, challenges, sleepH, sleepQ, moodEmoji, energyStars };
});

// Summary bar energy/mood percentages (out of 5)
const energyPct = avg7Energy ? Math.round((parseFloat(avg7Energy) / 5) * 100) : 0;
const moodPct   = avg7Mood   ? Math.round((parseFloat(avg7Mood)   / 5) * 100) : 0;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Daily Reflections — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg, #060d09);
      color: var(--text, #dfeedd);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
    }

    .page-wrap {
      max-width: 780px;
      margin: 0 auto;
      padding: 32px 20px 80px;
    }

    /* ── Header ── */
    .page-header {
      margin-bottom: 28px;
      animation: fadeUp .5s ease both;
    }
    .page-header h1 {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 700;
      color: var(--text, #dfeedd);
    }
    .page-header .subtitle {
      margin-top: 6px;
      font-size: .9rem;
      color: var(--soft, #4d7055);
    }

    /* ── Summary bar ── */
    .summary-bar {
      background: var(--card, #0d1a0f);
      border: 1px solid var(--border, rgba(16,185,129,.1));
      border-radius: 18px;
      padding: 20px 24px;
      margin-bottom: 32px;
      animation: fadeUp .5s .05s ease both;
    }
    .summary-bar h3 {
      font-size: .8rem;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--soft, #4d7055);
      margin-bottom: 16px;
    }
    .summary-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
    @media (max-width: 540px) { .summary-stats { grid-template-columns: repeat(2, 1fr); } }

    .stat-item { display: flex; flex-direction: column; gap: 6px; }
    .stat-label { font-size: .75rem; color: var(--soft, #4d7055); }
    .stat-value {
      font-size: 1.25rem;
      font-weight: 700;
      font-family: 'Fraunces', serif;
      color: var(--text, #dfeedd);
    }
    .stat-bar-wrap {
      height: 4px;
      background: var(--muted, #233328);
      border-radius: 4px;
      overflow: hidden;
    }
    .stat-bar-fill {
      height: 100%;
      border-radius: 4px;
      background: var(--green, #10b981);
      transition: width .6s ease;
    }
    .stat-bar-fill.mood   { background: var(--gold, #f59e0b); }
    .stat-bar-fill.water  { background: var(--blue, #3b82f6); }
    .stat-bar-fill.meals  { background: var(--purple, #8b5cf6); }

    /* ── Timeline ── */
    .timeline {
      position: relative;
      padding-left: 28px;
    }
    .timeline::before {
      content: '';
      position: absolute;
      left: 9px;
      top: 8px;
      bottom: 8px;
      width: 2px;
      background: linear-gradient(to bottom, var(--green, #10b981), transparent);
      opacity: .35;
    }

    .timeline-entry {
      position: relative;
      margin-bottom: 24px;
      animation: fadeUp .5s ease both;
    }
    .timeline-dot {
      position: absolute;
      left: -24px;
      top: 18px;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--green, #10b981);
      border: 2px solid var(--bg, #060d09);
      box-shadow: 0 0 8px rgba(16,185,129,.4);
    }

    .entry-card {
      background: var(--card, #0d1a0f);
      border: 1px solid var(--border, rgba(16,185,129,.1));
      border-radius: 16px;
      padding: 18px 20px;
      transition: border-color .25s, box-shadow .25s;
    }
    .entry-card:hover {
      border-color: var(--border2, rgba(16,185,129,.22));
      box-shadow: 0 6px 24px rgba(16,185,129,.08);
    }

    .entry-date {
      font-family: 'Fraunces', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--green2, #34d399);
      margin-bottom: 12px;
    }

    .entry-vitals {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-bottom: 12px;
    }
    .vital-item {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: .82rem;
    }
    .vital-label { color: var(--soft, #4d7055); }
    .vital-value { color: var(--text, #dfeedd); font-weight: 600; }
    .vital-stars { font-size: .8rem; letter-spacing: -.05em; }

    .badge-ok  { color: var(--green, #10b981); }
    .badge-no  { color: var(--red, #ef4444); }

    .entry-divider {
      height: 1px;
      background: var(--border, rgba(16,185,129,.08));
      margin: 12px 0;
    }

    .entry-note {
      background: var(--card2, #111f13);
      border-left: 3px solid var(--green, #10b981);
      border-radius: 0 8px 8px 0;
      padding: 10px 14px;
      font-size: .88rem;
      color: var(--text, #dfeedd);
      line-height: 1.6;
      font-style: italic;
    }

    .entry-extras {
      margin-top: 10px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .extra-chip {
      background: var(--card2, #111f13);
      border: 1px solid var(--border, rgba(16,185,129,.08));
      border-radius: 20px;
      padding: 4px 10px;
      font-size: .75rem;
      color: var(--soft, #4d7055);
    }
    .extra-chip strong { color: var(--text, #dfeedd); }

    /* ── Empty state ── */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      animation: fadeUp .5s ease both;
    }
    .empty-icon { font-size: 3.5rem; margin-bottom: 16px; }
    .empty-state h2 {
      font-family: 'Fraunces', serif;
      font-size: 1.4rem;
      color: var(--text, #dfeedd);
      margin-bottom: 8px;
    }
    .empty-state p { color: var(--soft, #4d7055); margin-bottom: 24px; }
    .btn-checkin {
      display: inline-block;
      background: var(--green, #10b981);
      color: #fff;
      text-decoration: none;
      padding: 11px 24px;
      border-radius: 12px;
      font-weight: 600;
      font-size: .9rem;
      transition: background .2s, transform .2s;
    }
    .btn-checkin:hover { background: var(--green2, #34d399); transform: translateY(-2px); }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <DashNav
    userId={user.id}
    userName={userName}
    tierLabel={tierLabel}
    planType={planType}
    activePage="reflections"
  />

  <div class="page-wrap">
    <div class="page-header">
      <h1><BookOpen size={28} style="display:inline;vertical-align:middle;" /> Daily Reflections</h1>
      {hasData && (
        <p class="subtitle">Your last 30 days of check-ins and reflections</p>
      )}
    </div>

    {!hasData ? (
      <div class="empty-state">
        <div class="empty-icon"><BookOpen size={48} color="var(--soft)" /></div>
        <h2>Nothing logged yet</h2>
        <p>Complete your first daily check-in to start your reflection history.</p>
        <a href="/dashboard/checkin" class="btn-checkin">Start Check-in</a>
      </div>
    ) : (
      <>
        {last7Checkins.length > 0 && (
          <div class="summary-bar">
            <h3>7-day averages</h3>
            <div class="summary-stats">
              <div class="stat-item">
                <span class="stat-label">Energy</span>
                <span class="stat-value">{avg7Energy} / 5</span>
                <div class="stat-bar-wrap">
                  <div class="stat-bar-fill" style={`width:${energyPct}%`}></div>
                </div>
              </div>
              <div class="stat-item">
                <span class="stat-label">Mood</span>
                <span class="stat-value">{avg7Mood} / 5</span>
                <div class="stat-bar-wrap">
                  <div class="stat-bar-fill mood" style={`width:${moodPct}%`}></div>
                </div>
              </div>
              <div class="stat-item">
                <span class="stat-label">Water (glasses)</span>
                <span class="stat-value">{avg7Water}</span>
                <div class="stat-bar-wrap">
                  <div class="stat-bar-fill water" style={`width:${Math.min(100, Math.round((parseFloat(avg7Water || '0') / 10) * 100))}%`}></div>
                </div>
              </div>
              <div class="stat-item">
                <span class="stat-label">Meal adherence</span>
                <span class="stat-value">{avg7Meals}%</span>
                <div class="stat-bar-wrap">
                  <div class="stat-bar-fill meals" style={`width:${avg7Meals}%`}></div>
                </div>
              </div>
            </div>
          </div>
        )}

        <div class="timeline">
          {entries.map((entry, idx) => {
            const delay = (0.06 + idx * 0.05).toFixed(2);
            return (
              <div class="timeline-entry" style={`animation-delay:${delay}s`}>
                <div class="timeline-dot"></div>
                <div class="entry-card">
                  <div class="entry-date">{entry.dateLabel}</div>

                  <div class="entry-vitals">
                    {entry.energy > 0 && (
                      <div class="vital-item">
                        <span class="vital-label">Energy</span>
                        <span class="vital-stars">{entry.energyStars}</span>
                      </div>
                    )}
                    {entry.mood > 0 && (
                      <div class="vital-item">
                        <span class="vital-label">Mood</span>
                        <span class="vital-value">{entry.moodEmoji}</span>
                      </div>
                    )}
                    {entry.water > 0 && (
                      <div class="vital-item">
                        <span class="vital-label">Water</span>
                        <span class="vital-value"><Droplets size={13} style="display:inline;vertical-align:middle;" /> {entry.water}</span>
                      </div>
                    )}
                    <div class="vital-item">
                      <span class="vital-label">Meals</span>
                      {entry.mealOk ? (
                        <span class="vital-value badge-ok"><CheckCircle size={13} style="display:inline;vertical-align:middle;" /> Followed</span>
                      ) : (
                        <span class="vital-value badge-no"><X size={13} style="display:inline;vertical-align:middle;" /> Skipped</span>
                      )}
                    </div>
                    {entry.sleepH > 0 && (
                      <div class="vital-item">
                        <span class="vital-label">Sleep</span>
                        <span class="vital-value"><Moon size={13} style="display:inline;vertical-align:middle;" /> {entry.sleepH}h</span>
                      </div>
                    )}
                  </div>

                  {(entry.note || entry.highlights || entry.challenges) && (
                    <div class="entry-divider"></div>
                  )}

                  {entry.note && (
                    <div class="entry-note">"{entry.note}"</div>
                  )}

                  {(entry.highlights || entry.challenges) && (
                    <div class="entry-extras">
                      {entry.highlights && (
                        <span class="extra-chip"><Star size={12} style="display:inline;vertical-align:middle;" /> <strong>Win:</strong> {entry.highlights}</span>
                      )}
                      {entry.challenges && (
                        <span class="extra-chip"><Zap size={12} style="display:inline;vertical-align:middle;" /> <strong>Challenge:</strong> {entry.challenges}</span>
                      )}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </>
    )}
  </div>

  <!-- ── Add Reflection FAB ── -->
  <button class="fab" onclick="openReflModal()" title="Add today's reflection">＋ Reflect</button>

  <!-- ── Reflection Modal ── -->
  <div id="reflModal" style="display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);overflow-y:auto;padding:1.5rem;" onclick="closeReflModal(event)">
    <div style="background:var(--card,#0d1a0f);border:1px solid var(--border2,rgba(16,185,129,.22));border-radius:24px;max-width:500px;margin:3rem auto;padding:2rem;" onclick="event.stopPropagation()">
      <h2 style="font-family:'Fraunces',serif;font-size:1.4rem;margin-bottom:1.5rem;"><BookOpen size={20} style="display:inline;vertical-align:middle;" /> Today's Reflection</h2>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.25rem;">
        <div>
          <label style="display:block;font-size:.78rem;color:var(--soft);margin-bottom:.4rem;text-transform:uppercase;letter-spacing:.06em;">Energy (1–5)</label>
          <input id="rf_energy" type="number" min="1" max="5" placeholder="3" style="width:100%;background:var(--card2,#111f13);border:1px solid var(--border);border-radius:10px;padding:.6rem .9rem;color:var(--text);font-size:.95rem;" />
        </div>
        <div>
          <label style="display:block;font-size:.78rem;color:var(--soft);margin-bottom:.4rem;text-transform:uppercase;letter-spacing:.06em;">Mood (1–5)</label>
          <input id="rf_mood" type="number" min="1" max="5" placeholder="3" style="width:100%;background:var(--card2,#111f13);border:1px solid var(--border);border-radius:10px;padding:.6rem .9rem;color:var(--text);font-size:.95rem;" />
        </div>
      </div>

      <div style="margin-bottom:1.25rem;">
        <label style="display:block;font-size:.78rem;color:var(--soft);margin-bottom:.4rem;text-transform:uppercase;letter-spacing:.06em;">Notes</label>
        <textarea id="rf_notes" rows="3" placeholder="How was your day on keto?" style="width:100%;background:var(--card2,#111f13);border:1px solid var(--border);border-radius:10px;padding:.7rem .9rem;color:var(--text);font-size:.9rem;resize:vertical;font-family:inherit;"></textarea>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;">
        <div>
          <label style="display:block;font-size:.78rem;color:var(--soft);margin-bottom:.4rem;text-transform:uppercase;letter-spacing:.06em;">Win / Highlight</label>
          <input id="rf_highlights" type="text" placeholder="Something that went well…" style="width:100%;background:var(--card2,#111f13);border:1px solid var(--border);border-radius:10px;padding:.6rem .9rem;color:var(--text);font-size:.9rem;" />
        </div>
        <div>
          <label style="display:block;font-size:.78rem;color:var(--soft);margin-bottom:.4rem;text-transform:uppercase;letter-spacing:.06em;">Challenge</label>
          <input id="rf_challenges" type="text" placeholder="Something difficult…" style="width:100%;background:var(--card2,#111f13);border:1px solid var(--border);border-radius:10px;padding:.6rem .9rem;color:var(--text);font-size:.9rem;" />
        </div>
      </div>

      <div id="rf_error" style="display:none;color:#ef4444;font-size:.85rem;margin-bottom:1rem;"></div>

      <div style="display:flex;gap:.75rem;">
        <button onclick="saveReflection()" style="flex:1;background:var(--green,#10b981);color:#fff;border:none;border-radius:12px;padding:.8rem;font-size:.95rem;font-weight:600;cursor:pointer;">Save Reflection +15 XP</button>
        <button onclick="closeReflModal()" style="background:var(--card2,#111f13);border:1px solid var(--border);color:var(--soft);border-radius:12px;padding:.8rem 1.2rem;cursor:pointer;">Cancel</button>
      </div>
    </div>
  </div>

  <style>
    .fab {
      position: fixed; bottom: 5.5rem; right: 1.25rem; z-index: 300;
      background: var(--green, #10b981); color: #fff;
      border: none; border-radius: 50px; padding: .7rem 1.3rem;
      font-size: .9rem; font-weight: 700; cursor: pointer;
      box-shadow: 0 4px 20px rgba(16,185,129,.4);
      transition: transform .2s, box-shadow .2s;
    }
    .fab:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(16,185,129,.5); }
    @media (min-width: 900px) { .fab { bottom: 2rem; } }
  </style>

  <script is:inline>
    function openReflModal() {
      document.getElementById('reflModal').style.display = 'block';
      document.getElementById('rf_error').style.display = 'none';
    }
    function closeReflModal(e) {
      if (!e || e.target === document.getElementById('reflModal')) {
        document.getElementById('reflModal').style.display = 'none';
      }
    }
    function saveReflection() {
      var energy     = parseInt(document.getElementById('rf_energy').value) || null;
      var mood       = parseInt(document.getElementById('rf_mood').value) || null;
      var notes      = document.getElementById('rf_notes').value.trim() || null;
      var highlights = document.getElementById('rf_highlights').value.trim() || null;
      var challenges = document.getElementById('rf_challenges').value.trim() || null;
      var errEl      = document.getElementById('rf_error');

      if (energy && (energy < 1 || energy > 5)) { errEl.textContent = 'Energy must be 1–5'; errEl.style.display='block'; return; }
      if (mood   && (mood   < 1 || mood   > 5)) { errEl.textContent = 'Mood must be 1–5';   errEl.style.display='block'; return; }
      if (!energy && !mood && !notes && !highlights && !challenges) {
        errEl.textContent = 'Please fill in at least one field.'; errEl.style.display='block'; return;
      }

      fetch('/api/reflection/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          energy_level:    energy,
          mood_level:      mood,
          notes:           notes,
          highlights:      highlights,
          challenges:      challenges,
          client_date:     new Date().toLocaleDateString('en-CA'),
        }),
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) { errEl.textContent = data.error; errEl.style.display='block'; return; }
        document.getElementById('reflModal').style.display = 'none';
        window.location.reload();
      })
      .catch(function() { errEl.textContent = 'Failed to save. Please try again.'; errEl.style.display='block'; });
    }
  </script>
</body>
</html>
