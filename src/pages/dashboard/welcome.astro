---
import { requireAuth } from '../../lib/auth';
import { getMaxJourneyDays } from '../../lib/supabase';
import { getTranslator, normaliseLang } from '../../lib/i18n';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

// Fetch onboarding data for personalization
let onboarding = null as any;
try {
  const { data } = await db.from('onboarding_data').select('*').eq('user_id', user.id).maybeSingle();
  onboarding = data;
} catch (e) {
  console.error('[Welcome] DB error:', e);
  return new Response(
    `<!DOCTYPE html><html><head><title>Temporarily Unavailable</title><meta http-equiv="refresh" content="15;url=/dashboard/welcome"></head><body style="background:#FAF6F1;color:#1A110D;font-family:'Bricolage Grotesque',system-ui,sans-serif;display:flex;align-items:center;justify-content:center;height:100vh;margin:0;flex-direction:column;gap:1.2rem;text-align:center;padding:2rem"><h2 style="font-size:1.6rem;margin:0;color:#FF5C7A">Keto Journey</h2><p style="font-size:1.1rem;margin:0">Page temporarily unavailable</p><p style="color:#7A5C52;margin:0;font-size:.9rem">Retrying automatically in 15 seconds…</p><a href="/dashboard/welcome" style="color:#FF5C7A;font-size:.9rem;margin-top:.5rem">Retry now</a></body></html>`,
    { status: 503, headers: { 'Content-Type': 'text/html' } }
  );
}

// If no onboarding, send to onboarding
if (!onboarding) return Astro.redirect('/dashboard/onboarding');

const planType  = profile.subscription_tier || 'basic_30';
const maxDays   = getMaxJourneyDays(planType);
const tierLabel = planType === 'elite_12' ? 'Elite' : planType === 'pro_6' ? 'Pro' : 'Basic';
const tierColor = planType === 'elite_12' ? '#f59e0b' : planType === 'pro_6' ? '#6366f1' : '#10b981';
const firstName = profile.full_name?.split(' ')[0] || 'there';
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);

const goalLabels: Record<string, string> = {
  lose_weight: 'Lose weight',
  lose_fast:   'Lose weight fast',
  maintain:    'Maintain weight',
  build_muscle:'Build muscle',
  energy:      'Boost energy',
  health:      'Improve health',
};
const goalLabel = goalLabels[onboarding.goal] || 'Reach your goal';

const macroCalories = Math.round(
  onboarding.current_weight && onboarding.height_cm && onboarding.age
    ? (() => {
        const bmr = onboarding.gender === 'female'
          ? 10 * onboarding.current_weight + 6.25 * onboarding.height_cm - 5 * onboarding.age - 161
          : 10 * onboarding.current_weight + 6.25 * onboarding.height_cm - 5 * onboarding.age + 5;
        const mult: Record<string,number> = { sedentary:1.2, light:1.375, moderate:1.55, very:1.725, extreme:1.9, active:1.725, very_active:1.9 };
        const tdee = bmr * (mult[onboarding.activity_level] || 1.55);
        const cal = onboarding.goal === 'lose_weight' ? tdee - 500
          : onboarding.goal === 'lose_fast' ? tdee - 750
          : onboarding.goal === 'build_muscle' ? tdee + 200 : tdee - 300;
        return Math.max(1200, cal);
      })()
    : 1800
);
const proteinG = Math.round((macroCalories * 0.25) / 4);
const fatG     = Math.round((macroCalories * 0.70) / 9);
const carbG    = Math.round((macroCalories * 0.05) / 4);

// Weight goal timeline (in lbs for display)
const startWeightKg  = onboarding?.current_weight || 0;
const targetWeightKg = onboarding?.target_weight  || 0;
const weightDiffKg   = startWeightKg - targetWeightKg;
const weightDiffLbs  = weightDiffKg > 0 ? Math.round(weightDiffKg * 2.20462 * 10) / 10 : 0;
const startWeightLbs = startWeightKg ? Math.round(startWeightKg * 2.20462 * 10) / 10 : null;
const targetWeightLbs= targetWeightKg ? Math.round(targetWeightKg * 2.20462 * 10) / 10 : null;
const ketoRateLbs    = 1.1; // conservative keto fat loss rate lbs/week
const weeksToGoal    = weightDiffLbs > 0 ? Math.ceil(weightDiffLbs / ketoRateLbs) : null;
const goalDateStr    = weeksToGoal
  ? new Date(Date.now() + weeksToGoal * 7 * 86400000).toLocaleDateString('en', { month: 'long', year: 'numeric' })
  : null;
const hasWeightGoal  = weightDiffLbs > 0 && startWeightLbs && targetWeightLbs;

// Milestone weeks (show 4 milestones evenly spaced to goal)
const ms1Wk  = weeksToGoal ? Math.round(weeksToGoal * 0.25) : null;
const ms2Wk  = weeksToGoal ? Math.round(weeksToGoal * 0.50) : null;
const ms3Wk  = weeksToGoal ? Math.round(weeksToGoal * 0.75) : null;
const ms1Lbs = ms1Wk  ? Math.round(((startWeightLbs || 0) - ms1Wk  * ketoRateLbs) * 10) / 10 : null;
const ms2Lbs = ms2Wk  ? Math.round(((startWeightLbs || 0) - ms2Wk  * ketoRateLbs) * 10) / 10 : null;
const ms3Lbs = ms3Wk  ? Math.round(((startWeightLbs || 0) - ms3Wk  * ketoRateLbs) * 10) / 10 : null;

// Fasting protocol label
const fastingLabels: Record<string, string> = {
  '16_8': '16:8 (16h fast / 8h eating window)',
  '18_6': '18:6 (18h fast / 6h eating window)',
  'omad':  'OMAD (one meal a day)',
  'none':  '',
};
const fastingLabel = fastingLabels[onboarding?.fasting_protocol || ''] || '';

// Dietary restrictions
const dietLabels: Record<string, string> = {
  gluten_free:'Gluten-free', dairy_free:'Dairy-free', vegetarian:'Vegetarian',
  vegan:'Vegan', no_pork:'No pork', no_seafood:'No seafood', nut_free:'Nut-free',
};
const dietRestrictions = (onboarding?.dietary_restrictions || [])
  .filter((d: string) => d !== 'none' && dietLabels[d])
  .map((d: string) => dietLabels[d]);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{t('welcome.title')} — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:#FAF6F1; --card:#FFFFFF; --card2:#F2EDE5;
      --border:rgba(255,90,122,.12); --border2:rgba(255,90,122,.28);
      --text:#1A110D; --soft:#7A5C52; --muted:#C8B5AD;
      --green:#10b981; --green2:#34d399; --gold:#f59e0b;
      --purple:#8b5cf6; --blue:#3b82f6; --rv-accent:#FF5C7A;
    }
    *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
    html { background:var(--bg); }
    body {
      font-family:'Bricolage Grotesque',system-ui,sans-serif; color:var(--text);
      min-height:100vh; display:flex; align-items:center; justify-content:center;
      padding:2rem 1rem;
      background:radial-gradient(ellipse 80% 60% at 50% -10%, rgba(255,90,122,.06) 0%, transparent 70%);
    }

    .wrap { width:100%; max-width:640px; }

    /* ── header ── */
    .hdr { text-align:center; margin-bottom:2.5rem; }
    .hdr-badge {
      display:inline-flex; align-items:center; gap:.5rem;
      background:rgba(16,185,129,.1); border:1px solid var(--border2);
      border-radius:99px; padding:.35rem 1rem;
      font-size:.72rem; font-weight:800; color:var(--green);
      text-transform:uppercase; letter-spacing:.09em;
      margin-bottom:1.25rem; animation:fadeUp .4s ease both;
    }
    .hdr-check {
      width:80px; height:80px; border-radius:50%;
      background:linear-gradient(135deg,var(--green),var(--green2));
      display:flex; align-items:center; justify-content:center;
      margin:0 auto 1.5rem;
      box-shadow:0 0 0 16px rgba(16,185,129,.08), 0 0 0 32px rgba(16,185,129,.04);
      animation:popIn .6s cubic-bezier(.34,1.56,.64,1) .2s both;
    }
    .hdr-check svg { width:36px; height:36px; stroke:#fff; stroke-width:2.5; fill:none; }
    .hdr h1 {
      font-size:2.4rem; font-weight:900;
      line-height:1.08; margin-bottom:.6rem;
      animation:fadeUp .5s .3s ease both;
    }
    .hdr h1 em { font-style:italic; color:var(--green); }
    .hdr p { color:var(--soft); font-size:.95rem; line-height:1.6; animation:fadeUp .5s .4s ease both; }

    /* ── plan summary card ── */
    .plan-card {
      background:var(--card); border:1px solid var(--border2);
      border-radius:20px; padding:1.5rem 1.75rem;
      margin-bottom:1.25rem;
      animation:fadeUp .5s .5s ease both;
    }
    .plan-card-header {
      display:flex; align-items:center; justify-content:space-between;
      margin-bottom:1.25rem;
    }
    .plan-label { font-size:.7rem; font-weight:800; color:var(--soft); text-transform:uppercase; letter-spacing:.08em; }
    .plan-name { font-size:1.3rem; font-weight:900; margin-top:.15rem; }
    .plan-badge {
      padding:.35rem .9rem; border-radius:99px;
      font-size:.72rem; font-weight:800; text-transform:uppercase; letter-spacing:.07em;
    }
    .plan-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; }
    .ps { text-align:center; }
    .ps-val { font-size:1.6rem; font-weight:900; line-height:1; }
    .ps-lbl { font-size:.65rem; font-weight:700; color:var(--soft); text-transform:uppercase; letter-spacing:.06em; margin-top:.25rem; }

    /* ── macro card ── */
    .macro-card {
      background:var(--card); border:1px solid var(--border);
      border-radius:20px; padding:1.5rem 1.75rem;
      margin-bottom:1.25rem;
      animation:fadeUp .5s .6s ease both;
    }
    .section-title {
      font-size:.72rem; font-weight:800; color:var(--soft);
      text-transform:uppercase; letter-spacing:.09em; margin-bottom:1rem;
      display:flex; align-items:center; gap:.5rem;
    }
    .section-title svg { width:14px; height:14px; stroke:currentColor; stroke-width:2; fill:none; }
    .macro-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:.75rem; }
    .macro-item { text-align:center; }
    .macro-ring {
      width:56px; height:56px; margin:0 auto .5rem;
    }
    .macro-val { font-size:1.1rem; font-weight:900; line-height:1; }
    .macro-unit { font-size:.65rem; color:var(--soft); }
    .macro-lbl { font-size:.65rem; font-weight:700; color:var(--soft); text-transform:uppercase; letter-spacing:.05em; margin-top:.2rem; }

    /* ── steps card ── */
    .steps-card {
      background:var(--card); border:1px solid var(--border);
      border-radius:20px; padding:1.5rem 1.75rem;
      margin-bottom:1.75rem;
      animation:fadeUp .5s .7s ease both;
    }
    .step-list { display:flex; flex-direction:column; gap:.9rem; }
    .step {
      display:flex; align-items:flex-start; gap:1rem;
      padding:.875rem 1rem; border-radius:14px;
      background:var(--card2); border:1px solid var(--border);
      transition:border-color .2s;
    }
    .step:hover { border-color:var(--border2); }
    .step-num {
      width:32px; height:32px; border-radius:10px; flex-shrink:0;
      background:linear-gradient(135deg,var(--green),var(--green2));
      display:flex; align-items:center; justify-content:center;
      font-size:.78rem; font-weight:900; color:#fff;
    }
    .step-body { flex:1; min-width:0; }
    .step-title { font-weight:700; font-size:.875rem; margin-bottom:.2rem; }
    .step-desc  { font-size:.78rem; color:var(--soft); line-height:1.5; }

    /* ── CTA ── */
    .cta-wrap { animation:fadeUp .5s .8s ease both; }
    .btn-main {
      display:flex; align-items:center; justify-content:center; gap:.6rem;
      width:100%; padding:1.1rem;
      background:linear-gradient(135deg,var(--green),var(--green2));
      border:none; border-radius:16px; color:#fff;
      font-weight:800; font-size:1rem;
      cursor:pointer; text-decoration:none;
      transition:all .25s; position:relative; overflow:hidden;
    }
    .btn-main::before {
      content:''; position:absolute; inset:0;
      background:linear-gradient(90deg,transparent,rgba(255,255,255,.12),transparent);
      transform:translateX(-100%); transition:transform .5s;
    }
    .btn-main:hover::before { transform:translateX(100%); }
    .btn-main:hover { transform:translateY(-2px); box-shadow:0 12px 32px rgba(16,185,129,.4); }
    .btn-main svg { width:20px; height:20px; stroke:#fff; stroke-width:2.5; fill:none; }

    @keyframes fadeUp { from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);} }
    @keyframes popIn  { from{opacity:0;transform:scale(.5);}to{opacity:1;transform:scale(1);} }

    @media(max-width:500px) {
      .macro-grid { grid-template-columns:repeat(2,1fr); }
      .plan-stats  { grid-template-columns:repeat(3,1fr); gap:.5rem; }
    }
  </style>
</head>
<body>
<div class="wrap">

  <!-- Header -->
  <div class="hdr">
    <div class="hdr-badge">
      <svg viewBox="0 0 24 24" style="width:12px;height:12px;stroke:currentColor;stroke-width:2.5;fill:none"><polyline points="20 6 9 17 4 12"/></svg>
      Setup complete
    </div>
    <div class="hdr-check">
      <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <h1>Your plan is<br/><em>ready, {firstName}!</em></h1>
    <p>Everything is set up. Here's what we built for you based on your goals.</p>
  </div>

  <!-- Plan summary -->
  <div class="plan-card">
    <div class="plan-card-header">
      <div>
        <div class="plan-label">Your plan</div>
        <div class="plan-name">{maxDays}-Day Keto Journey</div>
      </div>
      <div class="plan-badge" style={`background:${tierColor}20;border:1px solid ${tierColor}40;color:${tierColor}`}>
        {tierLabel}
      </div>
    </div>
    <div class="plan-stats">
      <div class="ps">
        <div class="ps-val" style="color:var(--green)">{maxDays}</div>
        <div class="ps-lbl">Days total</div>
      </div>
      <div class="ps">
        <div class="ps-val" style="color:var(--gold)">{goalLabel.split(' ')[0]}</div>
        <div class="ps-lbl">Goal</div>
      </div>
      <div class="ps">
        <div class="ps-val" style="color:var(--purple)">{macroCalories}</div>
        <div class="ps-lbl">Daily kcal</div>
      </div>
    </div>
  </div>

  <!-- Macro targets -->
  <div class="macro-card">
    <div class="section-title">
      <svg viewBox="0 0 24 24"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
      Your daily macro targets
    </div>
    <div class="macro-grid">
      <div class="macro-item">
        <svg class="macro-ring" viewBox="0 0 56 56">
          <circle cx="28" cy="28" r="22" fill="none" stroke="rgba(16,185,129,.1)" stroke-width="5"/>
          <circle cx="28" cy="28" r="22" fill="none" stroke="#10b981" stroke-width="5"
            stroke-dasharray="138.2" stroke-dashoffset="0" stroke-linecap="round"
            transform="rotate(-90 28 28)"/>
        </svg>
        <div class="macro-val">{macroCalories}</div>
        <div class="macro-unit">kcal</div>
        <div class="macro-lbl">Calories</div>
      </div>
      <div class="macro-item">
        <svg class="macro-ring" viewBox="0 0 56 56">
          <circle cx="28" cy="28" r="22" fill="none" stroke="rgba(99,102,241,.1)" stroke-width="5"/>
          <circle cx="28" cy="28" r="22" fill="none" stroke="#6366f1" stroke-width="5"
            stroke-dasharray="138.2" stroke-dashoffset="34.5" stroke-linecap="round"
            transform="rotate(-90 28 28)"/>
        </svg>
        <div class="macro-val" style="color:#6366f1">{proteinG}g</div>
        <div class="macro-unit">25%</div>
        <div class="macro-lbl">Protein</div>
      </div>
      <div class="macro-item">
        <svg class="macro-ring" viewBox="0 0 56 56">
          <circle cx="28" cy="28" r="22" fill="none" stroke="rgba(245,158,11,.1)" stroke-width="5"/>
          <circle cx="28" cy="28" r="22" fill="none" stroke="#f59e0b" stroke-width="5"
            stroke-dasharray="138.2" stroke-dashoffset="41.5" stroke-linecap="round"
            transform="rotate(-90 28 28)"/>
        </svg>
        <div class="macro-val" style="color:var(--gold)">{fatG}g</div>
        <div class="macro-unit">70%</div>
        <div class="macro-lbl">Fat</div>
      </div>
      <div class="macro-item">
        <svg class="macro-ring" viewBox="0 0 56 56">
          <circle cx="28" cy="28" r="22" fill="none" stroke="rgba(239,68,68,.1)" stroke-width="5"/>
          <circle cx="28" cy="28" r="22" fill="none" stroke="#ef4444" stroke-width="5"
            stroke-dasharray="138.2" stroke-dashoffset="131.3" stroke-linecap="round"
            transform="rotate(-90 28 28)"/>
        </svg>
        <div class="macro-val" style="color:#ef4444">{carbG}g</div>
        <div class="macro-unit">5%</div>
        <div class="macro-lbl">Net carbs</div>
      </div>
    </div>
  </div>

  <!-- Weight Goal Timeline (only shown when user has a weight loss goal) -->
  {hasWeightGoal && (
    <div class="macro-card" style="animation-delay:.65s;">
      <div class="section-title">
        <svg viewBox="0 0 24 24"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
        Your weight goal timeline
      </div>
      <!-- Start → Goal bar -->
      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:.6rem;">
        <div style="text-align:center;">
          <div style="font-size:1.5rem;font-weight:900;color:var(--soft);">{startWeightLbs}<span style="font-size:.7rem;margin-left:.2rem;">lbs</span></div>
          <div style="font-size:.62rem;font-weight:700;color:var(--soft);text-transform:uppercase;letter-spacing:.06em;margin-top:.1rem;">Start</div>
        </div>
        <div style="text-align:center;">
          <div style="font-size:.75rem;font-weight:800;color:var(--soft);">–{weightDiffLbs} lbs</div>
          <div style="font-size:.65rem;color:var(--soft);">in ~{weeksToGoal} weeks</div>
        </div>
        <div style="text-align:center;">
          <div style="font-size:1.5rem;font-weight:900;color:var(--green);">{targetWeightLbs}<span style="font-size:.7rem;margin-left:.2rem;">lbs</span></div>
          <div style="font-size:.62rem;font-weight:700;color:var(--green);text-transform:uppercase;letter-spacing:.06em;margin-top:.1rem;">Goal 🎯</div>
        </div>
      </div>
      <!-- Milestone track -->
      <div style="position:relative;height:6px;background:rgba(16,185,129,.1);border-radius:99px;margin:1rem 0 2rem;">
        <div style="position:absolute;left:0;top:0;height:100%;width:0%;background:linear-gradient(90deg,var(--green),var(--green2));border-radius:99px;"></div>
        <!-- 25% marker -->
        {ms1Wk && (
          <div style="position:absolute;top:50%;left:25%;transform:translate(-50%,-50%);">
            <div style="width:10px;height:10px;border-radius:50%;background:var(--card);border:2px solid var(--green);"></div>
            <div style="position:absolute;top:14px;left:50%;transform:translateX(-50%);white-space:nowrap;text-align:center;">
              <div style="font-size:.62rem;font-weight:800;color:var(--green);">Wk {ms1Wk}</div>
              <div style="font-size:.6rem;color:var(--soft);">{ms1Lbs} lbs</div>
            </div>
          </div>
        )}
        <!-- 50% marker -->
        {ms2Wk && (
          <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);">
            <div style="width:10px;height:10px;border-radius:50%;background:var(--card);border:2px solid var(--green);"></div>
            <div style="position:absolute;top:14px;left:50%;transform:translateX(-50%);white-space:nowrap;text-align:center;">
              <div style="font-size:.62rem;font-weight:800;color:var(--green);">Wk {ms2Wk}</div>
              <div style="font-size:.6rem;color:var(--soft);">{ms2Lbs} lbs</div>
            </div>
          </div>
        )}
        <!-- 75% marker -->
        {ms3Wk && (
          <div style="position:absolute;top:50%;left:75%;transform:translate(-50%,-50%);">
            <div style="width:10px;height:10px;border-radius:50%;background:var(--card);border:2px solid var(--green);"></div>
            <div style="position:absolute;top:14px;left:50%;transform:translateX(-50%);white-space:nowrap;text-align:center;">
              <div style="font-size:.62rem;font-weight:800;color:var(--green);">Wk {ms3Wk}</div>
              <div style="font-size:.6rem;color:var(--soft);">{ms3Lbs} lbs</div>
            </div>
          </div>
        )}
        <!-- Goal marker -->
        <div style="position:absolute;top:50%;left:100%;transform:translate(-50%,-50%);">
          <div style="width:12px;height:12px;border-radius:50%;background:var(--green);border:2px solid var(--green2);box-shadow:0 0 6px rgba(16,185,129,.5);"></div>
        </div>
      </div>
      {goalDateStr && (
        <div style="background:rgba(16,185,129,.07);border:1px solid var(--border2);border-radius:10px;padding:.6rem .9rem;display:flex;align-items:center;gap:.65rem;margin-top:.5rem;">
          <span style="font-size:1.1rem;">🗓️</span>
          <div>
            <div style="font-size:.78rem;font-weight:800;color:var(--green);">Estimated goal: {goalDateStr}</div>
            <div style="font-size:.68rem;color:var(--soft);margin-top:.1rem;">At ~{ketoRateLbs} lbs/week keto loss rate · Stay consistent!</div>
          </div>
        </div>
      )}
    </div>
  )}

  <!-- Personalized extras (fasting + dietary) -->
  {(fastingLabel || dietRestrictions.length > 0) && (
    <div class="macro-card" style="animation-delay:.68s;">
      <div class="section-title">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        Your personal preferences
      </div>
      <div style="display:flex;flex-direction:column;gap:.6rem;">
        {fastingLabel && (
          <div style="display:flex;align-items:center;gap:.75rem;background:rgba(59,130,246,.06);border:1px solid rgba(59,130,246,.15);border-radius:11px;padding:.65rem .9rem;">
            <span style="font-size:1.1rem;">⏱️</span>
            <div>
              <div style="font-size:.78rem;font-weight:800;color:#3b82f6;">Fasting Protocol</div>
              <div style="font-size:.71rem;color:var(--soft);margin-top:.1rem;">{fastingLabel}</div>
            </div>
          </div>
        )}
        {dietRestrictions.length > 0 && (
          <div style="display:flex;align-items:center;gap:.75rem;background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.15);border-radius:11px;padding:.65rem .9rem;">
            <span style="font-size:1.1rem;">🍽️</span>
            <div>
              <div style="font-size:.78rem;font-weight:800;color:var(--gold);">Dietary Restrictions</div>
              <div style="font-size:.71rem;color:var(--soft);margin-top:.1rem;">{dietRestrictions.join(', ')}</div>
            </div>
          </div>
        )}
      </div>
    </div>
  )}

  <!-- Day 1 steps -->
  <div class="steps-card">
    <div class="section-title">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      What to do on Day 1
    </div>
    <div class="step-list">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-body">
          <div class="step-title">Complete your daily check-in</div>
          <div class="step-desc">Log your energy, mood, and water. Takes 60 seconds and keeps your streak alive.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-body">
          <div class="step-title">Review today's meals</div>
          <div class="step-desc">Your personalized meal plan is ready. Tap any recipe to see full instructions and macros.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-body">
          <div class="step-title">Log your starting weight</div>
          <div class="step-desc">Your progress charts start here. The more data points, the clearer your results will be.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <div class="step-body">
          <div class="step-title">Complete all 7 daily tasks</div>
          <div class="step-desc">Each task earns XP. Complete all 7 for a Perfect Day bonus and a streak point.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="cta-wrap">
    <a href="/dashboard" class="btn-main">
      <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Start Day 1 →
    </a>
  </div>

</div>
</body>
</html>
