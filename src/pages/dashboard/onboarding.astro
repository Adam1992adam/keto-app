---
// onboarding.astro
// Shown once after first login — before dashboard
import { supabase } from '../../lib/supabase';
import { requireAuth } from '../../lib/auth';
import Target from 'lucide-astro/Target';
import Zap from 'lucide-astro/Zap';
import Calendar from 'lucide-astro/Calendar';
import Bell from 'lucide-astro/Bell';
import BarChart2 from 'lucide-astro/BarChart2';
import CheckCircle from 'lucide-astro/CheckCircle';
import Flame from 'lucide-astro/Flame';
import Utensils from 'lucide-astro/Utensils';
import Droplets from 'lucide-astro/Droplets';
import TrendingDown from 'lucide-astro/TrendingDown';
import Sparkles from 'lucide-astro/Sparkles';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

// Check if already onboarded — use user-scoped client so RLS passes
const { data: existing } = await db
  .from('onboarding_data')
  .select('id')
  .eq('user_id', user.id)
  .maybeSingle();

if (existing) return Astro.redirect('/dashboard');

const userName = profile.full_name?.split(' ')[0] || 'there';
const tier = profile.subscription_tier || 'basic_30';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Set Up Your Journey — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;0,9..144,900;1,9..144,700;1,9..144,900&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&display=swap" rel="stylesheet"/>
  <style>
    /* ─── TOKENS ─── */
    :root {
      --bg:#070d0a; --surface:#0e1812; --card:#142010;
      --card2:#1a2a1a; --border:rgba(16,185,129,.13);
      --border2:rgba(16,185,129,.28); --border3:rgba(16,185,129,.45);
      --text:#e6f0e6; --soft:#6b8c6b; --muted:#2e4030;
      --green:#10b981; --green2:#34d399; --green3:#6ee7b7;
      --gold:#f59e0b; --red:#ef4444; --blue:#3b82f6;
      --purple:#8b5cf6; --cyan:#06b6d4; --orange:#f97316;
    }
    *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body {
      font-family:'DM Sans',sans-serif;
      background:var(--bg); color:var(--text);
      min-height:100vh; overflow-x:hidden;
      display:flex; flex-direction:column; align-items:center;
      justify-content:center; padding:1.5rem;
    }

    /* ─── ANIMATED BG ─── */
    .bg-wrap { position:fixed; inset:0; z-index:0; overflow:hidden; pointer-events:none; }
    .orb {
      position:absolute; border-radius:50%; filter:blur(120px);
      animation:drift ease-in-out infinite;
    }
    .o1 { width:600px;height:600px;background:rgba(16,185,129,.07);top:-150px;left:-150px;animation-duration:22s; }
    .o2 { width:500px;height:500px;background:rgba(6,182,212,.05);bottom:-100px;right:-100px;animation-duration:28s;animation-delay:-12s; }
    .o3 { width:350px;height:350px;background:rgba(245,158,11,.04);top:45%;left:45%;animation-duration:18s;animation-delay:-7s; }
    @keyframes drift {
      0%,100% { transform:translate(0,0) scale(1); }
      33% { transform:translate(40px,-50px) scale(1.06); }
      66% { transform:translate(-35px,45px) scale(.95); }
    }
    /* Grain */
    .grain { position:fixed;inset:0;z-index:1;pointer-events:none;opacity:.018;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    /* ─── SHELL ─── */
    .shell {
      position:relative; z-index:2;
      width:100%; max-width:760px;
    }

    /* ─── TOP BAR ─── */
    .top-bar {
      display:flex; align-items:center; justify-content:space-between;
      margin-bottom:2rem;
    }
    .logo {
      font-family:'Fraunces',serif; font-weight:700; font-size:1.1rem;
      color:var(--text); text-decoration:none; display:flex; align-items:center; gap:.5rem;
    }
    .logo span { color:var(--green); }
    .step-counter { font-size:.78rem; font-weight:700; color:var(--soft); }
    .step-counter strong { color:var(--green); }

    /* ─── PROGRESS BAR ─── */
    .progress-wrap { margin-bottom:2.5rem; }
    .progress-track {
      height:4px; background:var(--muted); border-radius:99px;
      overflow:hidden; margin-bottom:.75rem;
    }
    .progress-fill {
      height:100%;
      background:linear-gradient(90deg,var(--green),var(--green2),var(--cyan));
      border-radius:99px;
      transition:width .5s cubic-bezier(.4,0,.2,1);
      position:relative;
    }
    .progress-fill::after {
      content:'';
      position:absolute; right:0; top:50%; transform:translateY(-50%);
      width:10px; height:10px; border-radius:50%;
      background:var(--green2);
      box-shadow:0 0 8px var(--green);
    }
    .progress-dots {
      display:flex; align-items:center; justify-content:space-between;
    }
    .pdot {
      display:flex; flex-direction:column; align-items:center; gap:.3rem;
      cursor:pointer;
    }
    .pdot-circle {
      width:28px; height:28px; border-radius:50%;
      border:2px solid var(--muted);
      display:flex; align-items:center; justify-content:center;
      font-size:.72rem; font-weight:800; color:var(--muted);
      transition:all .3s;
    }
    .pdot.done .pdot-circle {
      background:rgba(16,185,129,.15); border-color:var(--green); color:var(--green);
    }
    .pdot.active .pdot-circle {
      background:var(--green); border-color:var(--green); color:#fff;
      box-shadow:0 0 0 4px rgba(16,185,129,.2);
    }
    .pdot-label {
      font-size:.62rem; font-weight:700; color:var(--muted);
      text-transform:uppercase; letter-spacing:.06em;
      transition:color .3s;
    }
    .pdot.active .pdot-label { color:var(--green); }
    .pdot.done .pdot-label { color:var(--soft); }

    /* ─── CARD ─── */
    .card {
      background:var(--card);
      border:1px solid var(--border);
      border-radius:24px;
      overflow:hidden;
      box-shadow:0 32px 80px rgba(0,0,0,.35), 0 0 0 1px rgba(16,185,129,.04);
    }
    .card-head {
      padding:2.5rem 2.5rem 0;
    }
    .step-badge {
      display:inline-flex; align-items:center; gap:.4rem;
      background:rgba(16,185,129,.1); border:1px solid var(--border2);
      border-radius:99px; padding:.3rem .9rem;
      font-size:.68rem; font-weight:800; color:var(--green);
      text-transform:uppercase; letter-spacing:.09em; margin-bottom:1rem;
    }
    .card-title {
      font-family:'Fraunces',serif;
      font-size:clamp(1.6rem,3vw,2.2rem);
      font-weight:900; line-height:1.1; margin-bottom:.5rem;
    }
    .card-title em {
      font-style:italic;
      background:linear-gradient(135deg,var(--green),var(--green2));
      -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    }
    .card-sub {
      font-size:.875rem; color:var(--soft); line-height:1.6; margin-bottom:1.75rem;
    }
    .card-body { padding:0 2.5rem 2rem; }
    .card-foot {
      padding:1.5rem 2.5rem 2.5rem;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      border-top:1px solid var(--border);
    }

    /* ─── STEP PANELS ─── */
    .step-panel { display:none; }
    .step-panel.active { display:block; animation:fadeUp .35s ease both; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);} }

    /* ─── OPTION GRIDS ─── */
    .opt-grid {
      display:grid; gap:.75rem;
    }
    .opt-grid-2 { grid-template-columns:1fr 1fr; }
    .opt-grid-3 { grid-template-columns:1fr 1fr 1fr; }
    .opt-grid-4 { grid-template-columns:repeat(4,1fr); }

    .opt-card {
      background:var(--card2); border:1.5px solid var(--border);
      border-radius:16px; padding:1.25rem 1rem;
      text-align:center; cursor:pointer;
      transition:all .22s;
      display:flex; flex-direction:column; align-items:center; gap:.5rem;
      user-select:none;
    }
    .opt-card:hover {
      border-color:rgba(16,185,129,.3); transform:translateY(-2px);
      background:rgba(16,185,129,.05);
    }
    .opt-card.selected {
      border-color:var(--green); background:rgba(16,185,129,.1);
      box-shadow:0 0 0 3px rgba(16,185,129,.15);
    }
    .opt-card.selected .opt-label { color:var(--green); }
    .opt-icon { font-size:1.75rem; line-height:1; }
    .opt-label { font-weight:800; font-size:.85rem; }
    .opt-desc { font-size:.7rem; color:var(--soft); line-height:1.4; }
    .opt-check {
      width:18px; height:18px; border-radius:50%;
      background:var(--green); display:flex; align-items:center; justify-content:center;
      font-size:.65rem; color:#fff; margin-top:.2rem;
      opacity:0; transition:opacity .2s;
    }
    .opt-card.selected .opt-check { opacity:1; }

    /* multi-select variant */
    .opt-card.multi { position:relative; }
    .opt-card.multi .opt-check { position:absolute; top:.6rem; right:.6rem; }

    /* ─── NUMBER INPUT ─── */
    .num-group {
      display:flex; align-items:center; gap:1.25rem;
      background:var(--card2); border:1.5px solid var(--border);
      border-radius:16px; padding:1rem 1.5rem;
      margin-bottom:1rem;
    }
    .num-icon { font-size:1.75rem; flex-shrink:0; }
    .num-label-wrap { flex:1; }
    .num-label { font-weight:800; font-size:.9rem; margin-bottom:.15rem; }
    .num-sublabel { font-size:.72rem; color:var(--soft); }
    .num-control { display:flex; align-items:center; gap:.75rem; flex-shrink:0; }
    .num-btn {
      width:36px; height:36px; border-radius:10px;
      background:var(--card); border:1.5px solid var(--border);
      color:var(--text); font-size:1.1rem; font-weight:700;
      cursor:pointer; transition:all .2s; display:flex; align-items:center; justify-content:center;
    }
    .num-btn:hover { border-color:var(--green); color:var(--green); }
    .num-val {
      font-family:'Fraunces',serif; font-size:1.4rem; font-weight:900;
      min-width:52px; text-align:center;
    }
    .num-unit { font-size:.72rem; color:var(--soft); text-align:center; margin-top:-.3rem; }

    /* ─── RANGE SLIDER ─── */
    .slider-wrap { margin-bottom:1.25rem; }
    .slider-head { display:flex; justify-content:space-between; margin-bottom:.5rem; }
    .slider-lbl { font-weight:800; font-size:.875rem; }
    .slider-val {
      font-family:'Fraunces',serif; font-size:1.1rem; font-weight:900; color:var(--green);
    }
    .slider-unit { font-size:.72rem; color:var(--soft); margin-left:.2rem; }
    input[type=range] {
      -webkit-appearance:none; width:100%; height:6px;
      background:var(--muted); border-radius:99px; outline:none;
      cursor:pointer;
    }
    input[type=range]::-webkit-slider-thumb {
      -webkit-appearance:none; width:22px; height:22px; border-radius:50%;
      background:linear-gradient(135deg,var(--green),var(--green2));
      box-shadow:0 0 0 4px rgba(16,185,129,.2), 0 2px 8px rgba(0,0,0,.3);
      cursor:pointer; transition:all .2s;
    }
    input[type=range]::-webkit-slider-thumb:hover { transform:scale(1.15); }
    .slider-marks {
      display:flex; justify-content:space-between;
      margin-top:.4rem; font-size:.68rem; color:var(--muted); font-weight:600;
    }

    /* ─── TEXT INPUT ─── */
    .text-input {
      width:100%; background:var(--card2); border:1.5px solid var(--border);
      border-radius:12px; padding:.825rem 1.1rem;
      color:var(--text); font-family:'DM Sans',sans-serif;
      font-size:.9rem; font-weight:500; outline:none;
      transition:all .22s;
    }
    .text-input::placeholder { color:var(--muted); }
    .text-input:focus {
      border-color:var(--green); background:rgba(16,185,129,.04);
      box-shadow:0 0 0 4px rgba(16,185,129,.1);
    }

    /* ─── TOGGLE ROW ─── */
    .toggle-row {
      display:flex; align-items:center; justify-content:space-between;
      background:var(--card2); border:1.5px solid var(--border);
      border-radius:14px; padding:1rem 1.25rem; margin-bottom:.75rem;
      transition:all .2s;
    }
    .toggle-row:hover { border-color:rgba(16,185,129,.2); }
    .tr-left { display:flex; align-items:center; gap:.875rem; }
    .tr-icon { font-size:1.3rem; }
    .tr-label { font-weight:800; font-size:.875rem; margin-bottom:.12rem; }
    .tr-sub { font-size:.72rem; color:var(--soft); }
    .tog {
      position:relative; width:46px; height:25px; flex-shrink:0;
      background:var(--muted); border-radius:99px;
      cursor:pointer; transition:background .3s;
      border:none; outline:none;
    }
    .tog.on { background:linear-gradient(135deg,var(--green),var(--green2)); }
    .tog-thumb {
      position:absolute; top:2.5px; left:2.5px;
      width:20px; height:20px; border-radius:50%;
      background:#fff; pointer-events:none;
      transition:transform .28s cubic-bezier(.4,0,.2,1);
      box-shadow:0 2px 6px rgba(0,0,0,.22);
    }
    .tog.on .tog-thumb { transform:translateX(21px); }

    /* ─── MACRO RESULT (Step 6) ─── */
    .macro-hero {
      text-align:center; padding:1.25rem 0 1.5rem;
    }
    .macro-ring-wrap {
      position:relative; width:140px; height:140px;
      margin:0 auto 1.25rem;
    }
    .macro-ring-svg { transform:rotate(-90deg); }
    .ring-track { fill:none; stroke:var(--muted); stroke-width:10; }
    .ring-fill {
      fill:none; stroke-width:10; stroke-linecap:round;
      stroke-dasharray:347; stroke-dashoffset:347;
      transition:stroke-dashoffset 1.2s cubic-bezier(.4,0,.2,1);
    }
    .ring-label {
      position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
      text-align:center;
    }
    .ring-cal { font-family:'Fraunces',serif; font-size:1.75rem; font-weight:900; color:var(--green); line-height:1; }
    .ring-unit { font-size:.65rem; font-weight:700; color:var(--soft); text-transform:uppercase; letter-spacing:.06em; }
    .macro-title { font-family:'Fraunces',serif; font-size:1.1rem; font-weight:700; margin-bottom:.25rem; }
    .macro-sub { font-size:.78rem; color:var(--soft); }

    .macro-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:.75rem; margin:1.25rem 0; }
    .macro-card {
      background:var(--card2); border:1.5px solid var(--border);
      border-radius:14px; padding:1rem; text-align:center;
      transition:all .25s;
    }
    .macro-card:hover { border-color:var(--border2); transform:translateY(-2px); }
    .mc-icon { font-size:1.3rem; margin-bottom:.4rem; }
    .mc-val { font-family:'Fraunces',serif; font-size:1.5rem; font-weight:900; line-height:1; margin-bottom:.2rem; }
    .mc-lbl { font-size:.68rem; font-weight:700; color:var(--soft); text-transform:uppercase; letter-spacing:.05em; }
    .mc-pct { font-size:.72rem; color:var(--soft); margin-top:.1rem; }

    .insights-grid { display:flex; flex-direction:column; gap:.65rem; }
    .insight {
      display:flex; align-items:center; gap:.875rem;
      background:var(--card2); border:1px solid var(--border);
      border-radius:12px; padding:.875rem 1.1rem;
      font-size:.82rem;
    }
    .ins-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
    .ins-text { line-height:1.5; }
    .ins-text strong { color:var(--text); }

    /* ─── BUTTONS ─── */
    .btn-next {
      display:flex; align-items:center; justify-content:center; gap:.5rem;
      padding:.875rem 2rem; border-radius:13px;
      font-family:'DM Sans',sans-serif; font-weight:800; font-size:.9rem;
      border:none; cursor:pointer; transition:all .25s;
      background:linear-gradient(135deg,var(--green),var(--green2));
      color:#fff; box-shadow:0 4px 16px rgba(16,185,129,.3);
      position:relative; overflow:hidden; min-width:140px;
    }
    .btn-next::before {
      content:''; position:absolute; inset:0;
      background:linear-gradient(90deg,transparent,rgba(255,255,255,.1),transparent);
      transform:translateX(-100%); transition:transform .5s;
    }
    .btn-next:hover::before { transform:translateX(100%); }
    .btn-next:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(16,185,129,.4); }
    .btn-next:disabled { opacity:.5; cursor:not-allowed; transform:none; }
    .btn-back {
      display:flex; align-items:center; gap:.4rem;
      padding:.875rem 1.4rem; border-radius:13px;
      font-family:'DM Sans',sans-serif; font-weight:700; font-size:.875rem;
      border:1.5px solid var(--border); background:transparent; color:var(--soft);
      cursor:pointer; transition:all .22s;
    }
    .btn-back:hover { border-color:var(--green); color:var(--green); }

    .btn-spin {
      display:none; width:16px; height:16px; border-radius:50%;
      border:2.5px solid rgba(255,255,255,.35); border-top-color:#fff;
      animation:spin .7s linear infinite; flex-shrink:0;
    }
    @keyframes spin { to{transform:rotate(360deg);} }

    /* ─── SECTION LABEL ─── */
    .sec-label {
      font-size:.72rem; font-weight:800; color:var(--soft);
      text-transform:uppercase; letter-spacing:.08em; margin-bottom:.75rem;
      display:flex; align-items:center; gap:.5rem;
    }
    .sec-label::after { content:''; flex:1; height:1px; background:var(--border); }

    /* ─── SKIP LINK ─── */
    .skip-link {
      text-align:center; margin-top:1rem;
      font-size:.75rem; color:var(--muted);
    }
    .skip-link a { color:var(--soft); text-decoration:none; transition:color .2s; }
    .skip-link a:hover { color:var(--text); }

    /* ─── SUCCESS OVERLAY ─── */
    .success-overlay {
      display:none; position:fixed; inset:0; z-index:9999;
      background:var(--bg); flex-direction:column;
      align-items:center; justify-content:center; text-align:center;
      padding:2rem;
    }
    .success-overlay.show { display:flex; animation:fadeIn .5s ease both; }
    @keyframes fadeIn { from{opacity:0;}to{opacity:1;} }
    .success-icon { font-size:5rem; margin-bottom:1.5rem; animation:bounceIn .6s ease; }
    @keyframes bounceIn {
      0%{transform:scale(0);}70%{transform:scale(1.15);}100%{transform:scale(1);}
    }
    .success-title {
      font-family:'Fraunces',serif; font-size:2.5rem; font-weight:900;
      margin-bottom:.75rem;
    }
    .success-title em {
      font-style:italic;
      background:linear-gradient(135deg,var(--green),var(--green2));
      -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    }
    .success-sub { font-size:1rem; color:var(--soft); max-width:380px; line-height:1.7; }
    .success-bar { width:320px; height:4px; background:var(--muted); border-radius:99px; margin-top:2rem; overflow:hidden; }
    .success-fill { height:100%; background:linear-gradient(90deg,var(--green),var(--green2)); border-radius:99px; width:0; transition:width 3s ease; }

    @media(max-width:640px) {
      body { padding:1rem; align-items:flex-start; }
      .card-head,.card-body,.card-foot { padding-left:1.5rem; padding-right:1.5rem; }
      .opt-grid-3,.opt-grid-4 { grid-template-columns:1fr 1fr; }
      .macro-grid { grid-template-columns:1fr 1fr 1fr; }
    }
  </style>
</head>
<body>

<div class="bg-wrap"><div class="orb o1"></div><div class="orb o2"></div><div class="orb o3"></div></div>
<div class="grain"></div>

<div class="shell">
  <!-- TOP BAR -->
  <div class="top-bar">
    <a href="/" class="logo">Keto<span>Journey</span></a>
    <div class="step-counter">Step <strong id="stepNum">1</strong> of 6</div>
  </div>

  <!-- PROGRESS -->
  <div class="progress-wrap">
    <div class="progress-track"><div class="progress-fill" id="progressFill" style="width:16.6%"></div></div>
    <div class="progress-dots">
      {[
        { n:1, label:'Goal' },
        { n:2, label:'Body' },
        { n:3, label:'Lifestyle' },
        { n:4, label:'Diet' },
        { n:5, label:'Fasting' },
        { n:6, label:'Your Plan' },
      ].map(s => (
        <div class={`pdot ${s.n === 1 ? 'active' : ''}`} id={`pdot${s.n}`}>
          <div class="pdot-circle">{s.n}</div>
          <div class="pdot-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- CARD -->
  <div class="card">

    <!-- ════════════════ STEP 1: GOAL ════════════════ -->
    <div class="step-panel active" id="step1">
      <div class="card-head">
        <div class="step-badge"><Target size={14} style="vertical-align:middle;margin-right:.3rem;" /> Step 1 · Goal</div>
        <h2 class="card-title">What's your main <em>goal</em>,<br/>{userName}?</h2>
        <p class="card-sub">This shapes your entire 30-day plan. Be honest — your results depend on it.</p>
      </div>
      <div class="card-body">
        <div class="opt-grid opt-grid-2">
          {[
            { val:'lose_weight',  icon:'⚖️', label:'Lose Weight',      desc:'Reduce body fat and reach a healthier weight' },
            { val:'lose_fast',    icon:'🔥', label:'Lose Fast',         desc:'Aggressive fat loss with strict keto + fasting' },
