<!-- ─── SCRIPT ─── -->
<script is:inline define:vars={{ userName, tier }}>

/* ══════════════ STATE ══════════════ */
const data = {
  goal:       null,
  age:        28,
  gender:     null,
  height:     67,   // stored in total inches; converted to cm on submit
  weight:     176,  // stored in lbs; converted to kg on submit
  target:     154,  // stored in lbs; converted to kg on submit
  activity:   null,
  diet:       [],
  cooktime:   null,
  fasting:    null,
  electrolytes: true,
  checkin:    true,
  report:     true,
  reminders:  true,
  // calculated
  tdee:       0,
  calories:   0,
  protein:    0,
  fat:        0,
  carbs:      0,
};

/* ══════════════ STEP NAVIGATION ══════════════ */
var currentStep = 1;
const TOTAL = 6;

function updateUI(step) {
  // Dots
  for (let i = 1; i <= TOTAL; i++) {
    const dot = document.getElementById(`pdot${i}`);
    dot.classList.remove('active','done');
    if (i < step) dot.classList.add('done');
    else if (i === step) dot.classList.add('active');
    // Update inner text
    dot.querySelector('.pdot-circle').textContent = i < step ? '✓' : i;
  }
  // Progress bar
  const pct = (step / TOTAL) * 100;
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('stepNum').textContent = step;

  // Panels
  document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('step' + step)?.classList.add('active');

  // Scroll to top
  window.scrollTo({ top:0, behavior:'smooth' });
}

function nextStep(from) {
  if (!validateStep(from)) return;
  syncData(from);
  currentStep = from + 1;
  if (currentStep === 6) calculateMacros();
  updateUI(currentStep);
}
function prevStep(from) {
  currentStep = from - 1;
  updateUI(currentStep);
}

/* ══════════════ VALIDATION ══════════════ */
function validateStep(step) {
  if (step === 1 && !data.goal)     { shake('step1'); return false; }
  if (step === 2 && !data.gender)   { shake('step2'); return false; }
  if (step === 3 && !data.activity) { shake('step3'); return false; }
  if (step === 4 && !data.cooktime) { shake('step4'); return false; }
  if (step === 5 && !data.fasting)  { shake('step5'); return false; }
  return true;
}
function shake(id) {
  const el = document.getElementById(id);
  el.style.animation = 'none';
  el.offsetHeight;
  el.style.animation = 'shake .4s ease';
}
// Add shake keyframe
const shakeStyle = document.createElement('style');
shakeStyle.textContent = '@keyframes shake{0%,100%{transform:translateX(0);}20%,60%{transform:translateX(-6px);}40%,80%{transform:translateX(6px);}}'
document.head.appendChild(shakeStyle);

/* ══════════════ SYNC DATA ══════════════ */
function syncData(step) {
  if (step === 2) {
    data.height = parseInt(document.getElementById('heightSlider').value);
    data.weight = parseInt(document.getElementById('weightSlider').value);
    data.target = parseInt(document.getElementById('targetSlider').value);
  }
  if (step === 5) {
    data.electrolytes = document.getElementById('tog-electrolytes').classList.contains('on');
    data.checkin      = document.getElementById('tog-checkin').classList.contains('on');
    data.report       = document.getElementById('tog-report').classList.contains('on');
    data.reminders    = document.getElementById('tog-reminders').classList.contains('on');
  }
}

/* ══════════════ SELECTION HELPERS ══════════════ */
function selectOpt(el, group) {
  document.querySelectorAll(`[data-group="${group}"]`).forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  data[group] = el.dataset.val;
}
function toggleMulti(el, group) {
  el.classList.toggle('selected');
  const val = el.dataset.val;
  if (val === 'none') {
    // deselect all others
    document.querySelectorAll(`[data-group="${group}"]`).forEach(c => {
      if (c !== el) c.classList.remove('selected');
    });
    data[group] = ['none'];
    return;
  }
  // deselect "none" if anything else selected
  document.querySelectorAll(`[data-group="${group}"][data-val="none"]`).forEach(c => c.classList.remove('selected'));
  data[group] = Array.from(document.querySelectorAll(`[data-group="${group}"].selected`)).map(c => c.dataset.val);
}

/* ══════════════ NUMBER ADJUST ══════════════ */
function adjust(field, delta) {
  const limits = { age:[10,100] };
  const [min,max] = limits[field] || [0,999];
  data[field] = Math.max(min, Math.min(max, data[field] + delta));
  document.getElementById(field + 'Val').textContent = data[field];
}

/* ══════════════ MACRO CALCULATOR ══════════════ */
function calculateMacros() {
  const { age, gender, height, weight, activity, goal } = data;

  // Convert imperial to metric for Mifflin-St Jeor (height in total inches, weight in lbs)
  var weightKg = weight / 2.20462;
  var heightCm = height * 2.54;

  // BMR (Mifflin-St Jeor, metric)
  let bmr;
  if (gender === 'male') {
    bmr = 10 * weightKg + 6.25 * heightCm - 5 * age + 5;
  } else {
    bmr = 10 * weightKg + 6.25 * heightCm - 5 * age - 161;
  }

  // TDEE multiplier
  const multipliers = { sedentary:1.2, light:1.375, moderate:1.55, very:1.725, extreme:1.9 };
  const tdee = bmr * (multipliers[activity] || 1.55);
  data.tdee = Math.round(tdee);

  // Calorie target based on goal
  let cal = tdee;
  if (goal === 'lose_weight') cal = tdee - 500;
  if (goal === 'lose_fast')   cal = tdee - 750;
  if (goal === 'build_muscle') cal = tdee + 200;
  if (goal === 'maintain')    cal = tdee;
  if (goal === 'energy')      cal = tdee - 200;
  if (goal === 'health')      cal = tdee - 300;
  cal = Math.max(1200, Math.round(cal));
  data.calories = cal;

  // Keto macro split (standard: 70% fat, 25% protein, 5% carbs)
  data.fat     = Math.round((cal * 0.70) / 9);
  data.protein = Math.round((cal * 0.25) / 4);
  data.carbs   = Math.round((cal * 0.05) / 4);

  // Update UI
  document.getElementById('ringCal').textContent = cal.toLocaleString();
  document.getElementById('mcProtein').textContent = data.protein + 'g';
  document.getElementById('mcFat').textContent     = data.fat + 'g';
  document.getElementById('mcCarbs').textContent   = data.carbs + 'g';
  document.getElementById('mcProteinPct').textContent = '25% of calories';
  document.getElementById('mcFatPct').textContent     = '70% of calories';
  document.getElementById('mcCarbsPct').textContent   = '5% of calories';

  // Animate ring
  const circumference = 2 * Math.PI * 55; // 345.6
  const filled = circumference * 0.78; // show 78% full
  setTimeout(() => {
    document.getElementById('ringFill').style.strokeDashoffset = circumference - filled;
  }, 200);

  // Title
  const diff = data.weight - data.target;
  const goalLabels = { lose_weight:'Weight Loss', lose_fast:'Aggressive Fat Loss', build_muscle:'Muscle Building', energy:'Energy Boost', health:'Health Optimization', maintain:'Maintenance' };
  document.getElementById('macroTitle').textContent = goalLabels[data.goal] || 'Keto Plan';
  document.getElementById('macroSub').textContent   = diff > 0 ? `Goal: lose ${diff} lbs · estimated ${Math.ceil(diff/1.1)} weeks` : 'Maintain and optimize your body';

  // Insights
  buildInsights();
}

function buildInsights() {
  const { goal, activity, fasting, weight, target, calories, gender } = data;
  const diff = weight - target;
  const weeksToGoal = diff > 0 ? Math.ceil(diff / 1.1) : null; // ~1.1 lbs/week on keto

  const items = [
    {
      color: '#10b981',
      text: `Your daily keto target is <strong>${data.calories.toLocaleString()} kcal</strong> — ${data.calories < 1600 ? 'aggressive cut' : data.calories < 2000 ? 'moderate deficit' : 'maintenance zone'} for your goal.`
    },
    {
      color: '#3b82f6',
      text: `Eat <strong>${data.protein}g protein/day</strong> to preserve muscle while burning fat. Aim for ${Math.round(data.protein / (gender === 'male' ? 3 : 2.5))} servings of meat or eggs.`
    },
    {
      color: '#f59e0b',
      text: `Keep net carbs under <strong>${data.carbs}g/day</strong> to stay in ketosis. Avoid bread, rice, sugar, and most fruits.`
    },
  ];

  if (fasting && fasting !== 'none') {
    const windows = { '16_8': '8-hour', '18_6': '6-hour', 'omad': '1-hour' };
    items.push({
      color: '#ef4444',
      text: `With <strong>${fasting.replace('_',':')}</strong> fasting, eat all your meals within your ${windows[fasting]} window. This can accelerate fat loss by 15-30%.`
    });
  }

  if (weeksToGoal) {
    items.push({
      color: '#8b5cf6',
      text: `At this rate, you can reach your target weight in approximately <strong>${weeksToGoal} weeks</strong>. Consistency is everything.`
    });
  }

  items.push({
    color: '#06b6d4',
    text: `Drink <strong>2.5–3.5L of water/day</strong> and supplement electrolytes in week 1 to prevent keto flu. This is the #1 reason people quit early.`
  });

  const grid = document.getElementById('insightsGrid');
  grid.innerHTML = items.map(i => `
    <div class="insight">
      <div class="ins-dot" style="background:${i.color};box-shadow:0 0 6px ${i.color}88;"></div>
      <div class="ins-text">${i.text}</div>
    </div>
  `).join('');
}

/* ══════════════ SAVE ══════════════ */
async function saveAndStart() {
  const btn = document.getElementById('next6');
  const spin = document.getElementById('saveSpin');
  const txt = document.getElementById('saveTxt');
  btn.disabled = true;
  spin.style.display = 'block';
  txt.textContent = 'Saving…';

  // Convert imperial → metric for storage (height: total inches → cm, weight: lbs → kg)
  const heightCmCalc    = Math.round(data.height * 2.54);
  const weightKgCalc    = Math.round((data.weight  / 2.20462) * 10) / 10;
  const targetKgCalc    = Math.round((data.target  / 2.20462) * 10) / 10;

  const payload = {
    goal:         data.goal,
    age:          data.age,
    gender:       data.gender,
    height_cm:    heightCmCalc,
    current_weight: weightKgCalc,
    target_weight: targetKgCalc,
    activity_level: data.activity,
    dietary_restrictions: data.diet,
    cook_time_pref: data.cooktime,
    fasting_protocol: data.fasting,
    feature_electrolytes: data.electrolytes,
    feature_checkin:      data.checkin,
    feature_report:       data.report,
    feature_reminders:    data.reminders,
    // Calculated macros
    tdee:         data.tdee,
    daily_calories: data.calories,
    protein_g:    data.protein,
    fat_g:        data.fat,
    carbs_g:      data.carbs,
  };

  try {
    const res = await fetch('/api/onboarding/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (!res.ok) throw new Error('Failed to save');

    // Show success overlay
    const overlay = document.getElementById('successOverlay');
    overlay.classList.add('show');
    setTimeout(() => {
      document.getElementById('successFill').style.width = '100%';
    }, 200);
    setTimeout(() => {
      window.location.href = data.redirect || '/dashboard/welcome';
    }, 3200);

  } catch (err) {
    btn.disabled = false;
    spin.style.display = 'none';
    txt.textContent = '🚀 Start My Journey';
    alert('Something went wrong. Please try again.');
  }
}

/* ══════════════ EXPOSE GLOBALS ══════════════ */
window.selectOpt   = selectOpt;
window.toggleMulti = toggleMulti;
window.adjust      = adjust;
window.nextStep    = nextStep;
window.prevStep    = prevStep;
window.saveAndStart= saveAndStart;

</script>
</body>
</html>