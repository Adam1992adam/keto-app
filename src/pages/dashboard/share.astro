---
// src/pages/dashboard/share.astro
import { supabase, getUserJourney, getMaxJourneyDays } from '../../lib/supabase';
import { requireAuth } from '../../lib/auth';
import DashNav from '../../components/DashNav.astro';
import Share2   from 'lucide-astro/Share2';
import Download from 'lucide-astro/Download';
import Sparkles from 'lucide-astro/Sparkles';
import Trophy   from 'lucide-astro/Trophy';
import Flame    from 'lucide-astro/Flame';
import Scale    from 'lucide-astro/Scale';
import Zap      from 'lucide-astro/Zap';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile } = auth;
const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? '👑 Elite' : planType === 'pro_6' ? '⚡ Pro' : '🥑 Basic';
const userName  = profile.full_name?.split(' ')[0] || 'Keto Warrior';

const journey = await getUserJourney(user.id);
if (!journey) return Astro.redirect('/dashboard');

const currentDay  = journey.current_day  || 1;
const totalXP     = journey.total_xp     || 0;
const xpLevel     = journey.level        || 1;
const streakDays  = journey.streak_days  || 0;
const maxDays     = getMaxJourneyDays(planType);
const journeyPct  = Math.min(100, Math.round((currentDay / maxDays) * 100));

// Weight data
const { data: weightLogs } = await supabase
  .from('weight_logs')
  .select('weight, logged_date')
  .eq('user_id', user.id)
  .order('logged_date', { ascending: true })
  .limit(30);

const { data: onboarding } = await supabase
  .from('onboarding_data')
  .select('current_weight, target_weight')
  .eq('user_id', user.id)
  .maybeSingle();

const startWeight  = onboarding?.current_weight || profile.weight_kg || 0;
const latestWeight = weightLogs?.[weightLogs.length - 1]?.weight || startWeight;
const weightLost   = Math.max(0, Math.round((startWeight - latestWeight) * 10) / 10);

// Milestone detection — which milestones has the user hit
const milestones = [7, 14, 21, 30, 60, 90, 180, 365];
const hitMilestones = milestones.filter(m => currentDay >= m);
const nextMilestone = milestones.find(m => currentDay < m) || maxDays;

// Card template suggestions
const hasMilestone = hitMilestones.length > 0;
const latestMilestone = hitMilestones[hitMilestones.length - 1] || currentDay;

// Closest milestone label
const milestoneLabel =
  latestMilestone >= 365 ? '365-Day Champion' :
  latestMilestone >= 180 ? '6-Month Hero' :
  latestMilestone >= 90  ? '90-Day Warrior' :
  latestMilestone >= 60  ? '60-Day Strong' :
  latestMilestone >= 30  ? '30-Day Keto!' :
  latestMilestone >= 21  ? '21 Days — New Habit' :
  latestMilestone >= 14  ? 'Two Weeks Strong' :
  latestMilestone >= 7   ? 'First Week Done' :
  'Day ' + currentDay;

const units   = profile.preferred_units || 'metric';
const wUnit   = units === 'imperial' ? 'lbs' : 'kg';
const weightLostDisplay = units === 'imperial'
  ? Math.round(weightLost * 2.20462 * 10) / 10
  : weightLost;

const canShare = false; // determined client-side
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Share Progress — KetoJourney</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=Fraunces:ital,wght@1,700;1,800&display=swap" rel="stylesheet" />
</head>
<body>

<DashNav userId={user.id} userName={userName} tierLabel={tierLabel} planType={planType} activePage="share" />

<main class="page">

  <!-- ── Header ──────────────────────────────────────────── -->
  <header class="page-header fade-up">
    <div class="header-icon">
      <Share2 size={22} />
    </div>
    <div>
      <h1 class="page-title">Share Your Progress</h1>
      <p class="page-sub">Generate a milestone card to inspire others on their keto journey</p>
    </div>
  </header>

  <!-- ── Next milestone banner ───────────────────────────── -->
  <div class="milestone-banner fade-up" style="animation-delay:.04s">
    <Trophy size={16} />
    <span>Next milestone: <strong>Day {nextMilestone}</strong> — {nextMilestone - currentDay} days to go</span>
  </div>

  <!-- ── Layout ──────────────────────────────────────────── -->
  <div class="layout">

    <!-- LEFT — Options -->
    <section class="card options-card fade-up" style="animation-delay:.08s">
      <h2 class="card-title">Card Style</h2>

      <!-- Template picker -->
      <div class="field">
        <label class="field-label">Template</label>
        <div class="template-grid" id="templateGrid">
          <button class="tpl-btn active" data-tpl="milestone" onclick="setTemplate('milestone')">
            <span class="tpl-emoji">🏆</span>
            <span class="tpl-name">Milestone</span>
          </button>
          <button class="tpl-btn" data-tpl="weight" onclick="setTemplate('weight')">
            <span class="tpl-emoji">⚖️</span>
            <span class="tpl-name">Weight Loss</span>
          </button>
          <button class="tpl-btn" data-tpl="streak" onclick="setTemplate('streak')">
            <span class="tpl-emoji">🔥</span>
            <span class="tpl-name">Streak</span>
          </button>
          <button class="tpl-btn" data-tpl="stats" onclick="setTemplate('stats')">
            <span class="tpl-emoji">📊</span>
            <span class="tpl-name">Full Stats</span>
          </button>
        </div>
      </div>

      <!-- Theme picker -->
      <div class="field">
        <label class="field-label">Theme</label>
        <div class="theme-grid" id="themeGrid">
          <button class="theme-btn active" data-theme="dark" onclick="setCardTheme('dark')">
            <span class="theme-swatch dark"></span>Dark
          </button>
          <button class="theme-btn" data-theme="forest" onclick="setCardTheme('forest')">
            <span class="theme-swatch forest"></span>Forest
          </button>
          <button class="theme-btn" data-theme="gold" onclick="setCardTheme('gold')">
            <span class="theme-swatch gold"></span>Gold
          </button>
          <button class="theme-btn" data-theme="ocean" onclick="setCardTheme('ocean')">
            <span class="theme-swatch ocean"></span>Ocean
          </button>
        </div>
      </div>

      <!-- Format -->
      <div class="field">
        <label class="field-label">Format</label>
        <div class="seg" id="formatSeg">
          <button class="seg-btn active" data-val="square"   onclick="setFormat('square')">Square (1:1)</button>
          <button class="seg-btn"        data-val="portrait" onclick="setFormat('portrait')">Story (9:16)</button>
        </div>
      </div>

      <!-- Name toggle -->
      <div class="field toggle-field">
        <label class="field-label">Show your name</label>
        <button class="toggle" id="nameToggle" onclick="toggleName()" aria-pressed="true">
          <span class="toggle-knob"></span>
        </button>
      </div>

      <!-- Hashtag toggle -->
      <div class="field toggle-field">
        <label class="field-label">Show #KetoJourney</label>
        <button class="toggle on" id="tagToggle" onclick="toggleTag()" aria-pressed="true">
          <span class="toggle-knob"></span>
        </button>
      </div>

      <!-- Action buttons -->
      <div class="action-btns">
        <button class="btn-download" onclick="downloadCard()">
          <Download size={16} />
          Download PNG
        </button>
        <button class="btn-share" id="shareBtn" onclick="shareCard()" style="display:none">
          <Share2 size={16} />
          Share
        </button>
      </div>
      <p class="action-note">1080×1080px · Instagram-ready</p>
    </section>

    <!-- RIGHT — Preview -->
    <div class="preview-col fade-up" style="animation-delay:.12s">
      <div class="preview-wrap">
        <canvas id="shareCanvas" width="1080" height="1080"></canvas>
      </div>
      <p class="preview-hint">Live preview — changes update instantly</p>
    </div>

  </div><!-- /layout -->

</main>

<style>
.page {
  max-width: 1100px; margin: 0 auto;
  padding: 2rem 1.5rem 6rem;
}
@media (max-width: 600px) { .page { padding: 1.25rem 1rem 5rem; } }

/* Header */
.page-header {
  display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;
}
.header-icon {
  width: 48px; height: 48px; border-radius: var(--r);
  background: var(--green-bg); border: 1.5px solid var(--border2);
  display: flex; align-items: center; justify-content: center;
  color: var(--green); flex-shrink: 0;
}
.page-title {
  font-family: 'Fraunces', serif; font-style: italic;
  font-size: 1.8rem; font-weight: 800; color: var(--text); margin: 0;
}
.page-sub { color: var(--soft); font-size: .88rem; margin: 0; }

/* Milestone banner */
.milestone-banner {
  display: flex; align-items: center; gap: .6rem;
  padding: .7rem 1rem; margin-bottom: 1.5rem;
  background: var(--amber-bg); border: 1px solid rgba(245,158,11,.25);
  border-radius: var(--r-sm); font-size: .84rem; color: var(--amber);
}
.milestone-banner strong { font-weight: 800; }

/* Layout */
.layout {
  display: grid; grid-template-columns: 300px 1fr;
  gap: 1.25rem; align-items: start;
}
@media (max-width: 800px) { .layout { grid-template-columns: 1fr; } }

/* Card */
.card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: var(--r-lg); padding: 1.5rem;
  box-shadow: var(--shadow-sm);
}
.card-title { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 1.25rem; }

/* Fields */
.field { margin-bottom: 1.1rem; }
.field-label {
  display: block; font-size: .74rem; font-weight: 700;
  color: var(--soft); letter-spacing: .03em; text-transform: uppercase;
  margin-bottom: .45rem;
}

/* Template grid */
.template-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: .5rem;
}
.tpl-btn {
  display: flex; flex-direction: column; align-items: center; gap: .25rem;
  padding: .65rem .3rem; border: 1.5px solid var(--border);
  border-radius: var(--r); background: var(--bg2); cursor: pointer;
  transition: border-color .15s, background .15s, transform .12s;
}
.tpl-btn:hover { border-color: var(--border2); transform: translateY(-1px); }
.tpl-btn.active { border-color: var(--green); background: var(--green-bg); }
.tpl-emoji { font-size: 1.3rem; }
.tpl-name { font-size: .68rem; font-weight: 700; color: var(--soft); }

/* Theme swatches */
.theme-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: .5rem;
}
.theme-btn {
  display: flex; flex-direction: column; align-items: center; gap: .3rem;
  padding: .6rem .3rem; border: 1.5px solid var(--border);
  border-radius: var(--r); background: var(--bg2); cursor: pointer;
  font-size: .7rem; font-weight: 700; color: var(--soft);
  transition: border-color .15s, transform .12s;
}
.theme-btn:hover { border-color: var(--border2); transform: translateY(-1px); }
.theme-btn.active { border-color: var(--green); color: var(--text); }
.theme-swatch {
  width: 28px; height: 28px; border-radius: 8px;
  border: 1.5px solid var(--border);
}
.theme-swatch.dark   { background: linear-gradient(135deg, #060d09 0%, #10b981 100%); }
.theme-swatch.forest { background: linear-gradient(135deg, #14532d 0%, #4ade80 100%); }
.theme-swatch.gold   { background: linear-gradient(135deg, #1a0a00 0%, #f59e0b 100%); }
.theme-swatch.ocean  { background: linear-gradient(135deg, #0c1445 0%, #06b6d4 100%); }

/* Seg control */
.seg {
  display: flex; background: var(--bg2);
  border: 1.5px solid var(--border); border-radius: var(--r-sm);
  padding: 3px; gap: 3px;
}
.seg-btn {
  flex: 1; padding: .45rem .5rem;
  border: none; border-radius: calc(var(--r-sm) - 2px);
  font-size: .78rem; font-weight: 700; cursor: pointer;
  background: transparent; color: var(--soft);
  transition: background .15s, color .15s;
}
.seg-btn.active {
  background: var(--card); color: var(--text);
  box-shadow: var(--shadow-xs); border: 1px solid var(--border);
}

/* Toggle */
.toggle-field { display: flex; align-items: center; justify-content: space-between; }
.toggle {
  position: relative; width: 40px; height: 22px;
  background: var(--muted); border: none; border-radius: 99px;
  cursor: pointer; transition: background .2s; padding: 0;
}
.toggle.on { background: var(--green); }
.toggle-knob {
  position: absolute; top: 3px; left: 3px;
  width: 16px; height: 16px; border-radius: 50%;
  background: #fff; transition: transform .2s;
  pointer-events: none;
}
.toggle.on .toggle-knob { transform: translateX(18px); }

/* Action buttons */
.action-btns { display: flex; gap: .6rem; margin-top: 1.25rem; }
.btn-download, .btn-share {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: .45rem;
  padding: .7rem 1rem; border-radius: var(--r-sm); font-size: .84rem; font-weight: 700;
  cursor: pointer; border: none; transition: opacity .15s, transform .12s;
}
.btn-download:hover, .btn-share:hover { opacity: .88; transform: translateY(-1px); }
.btn-download { background: var(--green); color: #fff; }
.btn-share    { background: var(--blue);  color: #fff; }
.action-note  { font-size: .72rem; color: var(--soft); margin-top: .5rem; text-align: center; }

/* Preview */
.preview-col { display: flex; flex-direction: column; align-items: center; gap: .75rem; }
.preview-wrap {
  width: 100%; max-width: 480px;
  border-radius: var(--r-lg); overflow: hidden;
  box-shadow: var(--shadow-xl);
  border: 1px solid var(--border);
}
.preview-wrap canvas {
  display: block; width: 100%; height: auto;
}
.preview-hint { font-size: .76rem; color: var(--soft); }

/* Animations */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.fade-up { animation: fadeUp .4s ease both; }
</style>

<script is:inline define:vars={{
  userName,
  currentDay,
  streakDays,
  totalXP,
  xpLevel,
  weightLostDisplay,
  wUnit,
  journeyPct,
  maxDays,
  milestoneLabel,
  latestMilestone,
  planType
}}>

/* ══ State ═══════════════════════════════════════════════════ */
var cfg = {
  template: 'milestone',
  theme:    'dark',
  format:   'square',
  showName: true,
  showTag:  true,
};

/* Theme palettes */
var THEMES = {
  dark: {
    bg1: '#060d09', bg2: '#0d1a0f',
    accent: '#10b981', accent2: '#34d399',
    text: '#dfeedd', soft: '#4d7055',
    overlay: 'rgba(6,13,9,0.7)',
    glow: 'rgba(16,185,129,0.3)',
  },
  forest: {
    bg1: '#0a2010', bg2: '#14532d',
    accent: '#4ade80', accent2: '#86efac',
    text: '#f0fdf4', soft: '#86efac',
    overlay: 'rgba(10,32,16,0.65)',
    glow: 'rgba(74,222,128,0.3)',
  },
  gold: {
    bg1: '#1a0a00', bg2: '#2d1a00',
    accent: '#f59e0b', accent2: '#fbbf24',
    text: '#fffbeb', soft: '#d97706',
    overlay: 'rgba(26,10,0,0.7)',
    glow: 'rgba(245,158,11,0.35)',
  },
  ocean: {
    bg1: '#0c1445', bg2: '#1e3a6e',
    accent: '#06b6d4', accent2: '#67e8f9',
    text: '#ecfeff', soft: '#67e8f9',
    overlay: 'rgba(12,20,69,0.7)',
    glow: 'rgba(6,182,212,0.3)',
  },
};

/* ══ Boot ════════════════════════════════════════════════════ */
(function () {
  // Show native share button if supported
  if (navigator.share) {
    var sb = document.getElementById('shareBtn');
    if (sb) sb.style.display = 'flex';
  }
  draw();
})();

/* ══ Setters ════════════════════════════════════════════════ */
function setTemplate(val) {
  cfg.template = val;
  document.querySelectorAll('#templateGrid .tpl-btn').forEach(function(b) {
    b.classList.toggle('active', b.dataset.tpl === val);
  });
  draw();
}
function setCardTheme(val) {
  cfg.theme = val;
  document.querySelectorAll('#themeGrid .theme-btn').forEach(function(b) {
    b.classList.toggle('active', b.dataset.theme === val);
  });
  draw();
}
function setFormat(val) {
  cfg.format = val;
  document.querySelectorAll('#formatSeg .seg-btn').forEach(function(b) {
    b.classList.toggle('active', b.dataset.val === val);
  });
  var canvas = document.getElementById('shareCanvas');
  if (val === 'portrait') {
    canvas.width  = 1080;
    canvas.height = 1920;
  } else {
    canvas.width  = 1080;
    canvas.height = 1080;
  }
  draw();
}
function toggleName() {
  cfg.showName = !cfg.showName;
  var btn = document.getElementById('nameToggle');
  btn.classList.toggle('on', cfg.showName);
  draw();
}
function toggleTag() {
  cfg.showTag = !cfg.showTag;
  var btn = document.getElementById('tagToggle');
  btn.classList.toggle('on', cfg.showTag);
  draw();
}

/* ══ Canvas Drawing ═════════════════════════════════════════ */
function draw() {
  var canvas = document.getElementById('shareCanvas');
  var ctx    = canvas.getContext('2d');
  var W = canvas.width, H = canvas.height;
  var p = THEMES[cfg.theme];

  ctx.clearRect(0, 0, W, H);

  // Background gradient
  var bg = ctx.createLinearGradient(0, 0, W, H);
  bg.addColorStop(0, p.bg1);
  bg.addColorStop(1, p.bg2);
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // Decorative glow circles
  drawGlow(ctx, W * 0.15, H * 0.2, 320, p.glow);
  drawGlow(ctx, W * 0.85, H * 0.75, 280, p.glow);

  // Dot grid texture
  drawDotGrid(ctx, W, H, p.soft);

  // Route to template
  if      (cfg.template === 'milestone') drawMilestone(ctx, W, H, p);
  else if (cfg.template === 'weight')    drawWeight(ctx, W, H, p);
  else if (cfg.template === 'streak')    drawStreak(ctx, W, H, p);
  else                                    drawStats(ctx, W, H, p);

  // Footer branding
  drawFooter(ctx, W, H, p);
}

/* ── Helpers ─────────────────────────────────────────────── */
function drawGlow(ctx, x, y, r, color) {
  var g = ctx.createRadialGradient(x, y, 0, x, y, r);
  g.addColorStop(0, color);
  g.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = g;
  ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI * 2);
  ctx.fill();
}

function drawDotGrid(ctx, W, H, color) {
  ctx.save();
  ctx.fillStyle = color.replace(')', ', 0.18)').replace('rgb', 'rgba');
  var spacing = 48;
  for (var x = spacing; x < W; x += spacing) {
    for (var y = spacing; y < H; y += spacing) {
      ctx.beginPath(); ctx.arc(x, y, 1.5, 0, Math.PI * 2); ctx.fill();
    }
  }
  ctx.restore();
}

function drawRoundRect(ctx, x, y, w, h, r, fill, stroke) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.arcTo(x + w, y, x + w, y + r, r);
  ctx.lineTo(x + w, y + h - r);
  ctx.arcTo(x + w, y + h, x + w - r, y + h, r);
  ctx.lineTo(x + r, y + h);
  ctx.arcTo(x, y + h, x, y + h - r, r);
  ctx.lineTo(x, y + r);
  ctx.arcTo(x, y, x + r, y, r);
  ctx.closePath();
  if (fill)   { ctx.fillStyle   = fill;   ctx.fill();   }
  if (stroke) { ctx.strokeStyle = stroke; ctx.lineWidth = 2; ctx.stroke(); }
}

function drawLogo(ctx, cx, y, p) {
  var logoSize = 38;
  var lx = cx - logoSize / 2;
  // Logo bg
  var grad = ctx.createLinearGradient(lx, y, lx + logoSize, y + logoSize);
  grad.addColorStop(0, p.accent);
  grad.addColorStop(1, p.bg2);
  drawRoundRect(ctx, lx, y, logoSize, logoSize, 10, grad, null);
  // Leaf icon (simplified path)
  ctx.save();
  ctx.fillStyle = '#fff';
  ctx.font = 'bold 22px sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText('🥑', cx, y + logoSize / 2);
  ctx.restore();
}

function drawFooter(ctx, W, H, p) {
  var y = H - 80;
  // Divider
  ctx.strokeStyle = p.soft + '55';
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(80, y); ctx.lineTo(W - 80, y); ctx.stroke();

  ctx.fillStyle = p.soft;
  ctx.font = '500 28px "DM Sans", sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';

  var footerText = 'ketojourney.app';
  if (cfg.showTag) footerText = '#KetoJourney · ' + footerText;

  ctx.fillText(footerText, W / 2, y + 40);
}

function statBox(ctx, x, y, w, h, label, value, p) {
  drawRoundRect(ctx, x, y, w, h, 20, 'rgba(255,255,255,0.06)', p.accent + '44');
  ctx.fillStyle = p.accent;
  ctx.font = 'bold 14px "DM Sans", sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  ctx.fillText(label.toUpperCase(), x + w / 2, y + 16);

  ctx.fillStyle = p.text;
  ctx.font = 'italic bold 38px "Fraunces", serif';
  ctx.textBaseline = 'middle';
  ctx.fillText(value, x + w / 2, y + h / 2 + 8);
}

/* ── Template: Milestone ─────────────────────────────────── */
function drawMilestone(ctx, W, H, p) {
  var cx = W / 2;

  // Big day number circle
  var cr = H > W ? 200 : 170;
  var cy = H > W ? H * 0.35 : H * 0.38;
  ctx.beginPath(); ctx.arc(cx, cy, cr, 0, Math.PI * 2);
  ctx.fillStyle = 'rgba(255,255,255,0.05)'; ctx.fill();
  ctx.strokeStyle = p.accent; ctx.lineWidth = 4; ctx.stroke();

  // Inner glow
  var ig = ctx.createRadialGradient(cx, cy, 0, cx, cy, cr * 0.8);
  ig.addColorStop(0, p.glow);
  ig.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = ig; ctx.fill();

  // Day number
  ctx.fillStyle = p.accent2;
  ctx.font = 'italic bold 110px "Fraunces", serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  ctx.fillText(latestMilestone, cx, cy - 18);

  ctx.fillStyle = p.text;
  ctx.font = 'bold 38px "DM Sans", sans-serif';
  ctx.fillText('DAYS', cx, cy + 62);

  // Milestone title
  var titleY = H > W ? cy + cr + 70 : cy + cr + 60;
  ctx.fillStyle = p.text;
  ctx.font = 'italic bold 56px "Fraunces", serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'top';
  ctx.fillText(milestoneLabel, cx, titleY);

  // Stats row
  var statsY = H > W ? titleY + 110 : titleY + 100;
  var bw = 200, bh = 110, gap = 20;
  var startX = cx - bw - gap / 2;
  statBox(ctx, startX,        statsY, bw, bh, 'Streak',    streakDays + ' days', p);
  statBox(ctx, startX + bw + gap, statsY, bw, bh, 'Lost', weightLostDisplay + ' ' + wUnit, p);

  // Name
  if (cfg.showName) {
    ctx.fillStyle = p.soft;
    ctx.font = '600 32px "DM Sans", sans-serif';
    ctx.textAlign = 'center'; ctx.textBaseline = 'top';
    ctx.fillText(userName + "'s Journey", cx, statsY + bh + 36);
  }
}

/* ── Template: Weight Loss ───────────────────────────────── */
function drawWeight(ctx, W, H, p) {
  var cx = W / 2;
  var topY = H > W ? H * 0.14 : H * 0.12;

  // Heading
  ctx.fillStyle = p.accent;
  ctx.font = 'bold 28px "DM Sans", sans-serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'top';
  ctx.fillText('WEIGHT LOST', cx, topY);

  // Big number
  ctx.fillStyle = p.text;
  ctx.font = 'italic bold 160px "Fraunces", serif';
  ctx.textBaseline = 'middle';
  var bigY = H > W ? H * 0.36 : H * 0.38;
  ctx.fillText(weightLostDisplay, cx, bigY);

  // Unit badge
  var unitY = bigY + 98;
  var ubW = 140, ubH = 52;
  drawRoundRect(ctx, cx - ubW / 2, unitY, ubW, ubH, 26, p.accent, null);
  ctx.fillStyle = '#fff';
  ctx.font = 'bold 28px "DM Sans", sans-serif';
  ctx.textBaseline = 'middle';
  ctx.fillText(wUnit, cx, unitY + ubH / 2);

  // Progress bar
  var barY    = H > W ? H * 0.62 : H * 0.63;
  var barW    = W - 180;
  var barH    = 24;
  var barPct  = journeyPct / 100;
  drawRoundRect(ctx, 90, barY, barW, barH, 12, 'rgba(255,255,255,0.1)', null);
  if (barPct > 0) {
    drawRoundRect(ctx, 90, barY, Math.max(24, barW * barPct), barH, 12, p.accent, null);
  }
  ctx.fillStyle = p.soft;
  ctx.font = '500 24px "DM Sans", sans-serif';
  ctx.textAlign = 'left'; ctx.textBaseline = 'top';
  ctx.fillText('Journey progress', 90, barY + barH + 16);
  ctx.textAlign = 'right';
  ctx.fillText(journeyPct + '%', W - 90, barY + barH + 16);

  // Stats
  var statsY = H > W ? H * 0.74 : H * 0.75;
  var bw = 200, bh = 110, gap = 20;
  var startX = cx - bw - gap / 2;
  statBox(ctx, startX,             statsY, bw, bh, 'Day',    currentDay + '',          p);
  statBox(ctx, startX + bw + gap,  statsY, bw, bh, 'Streak', streakDays + ' days',    p);

  if (cfg.showName) {
    ctx.fillStyle = p.soft;
    ctx.font = '600 30px "DM Sans", sans-serif';
    ctx.textAlign = 'center'; ctx.textBaseline = 'top';
    ctx.fillText(userName + "'s KetoJourney", cx, statsY + bh + 36);
  }
}

/* ── Template: Streak ────────────────────────────────────── */
function drawStreak(ctx, W, H, p) {
  var cx = W / 2;
  var topY = H > W ? H * 0.1 : H * 0.09;

  // Flame emoji big
  ctx.font = H > W ? '160px sans-serif' : '140px sans-serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'top';
  ctx.fillText('🔥', cx, topY);

  // Streak number
  var numY = H > W ? topY + 200 : topY + 180;
  ctx.fillStyle = p.accent2;
  ctx.font = 'italic bold 160px "Fraunces", serif';
  ctx.textBaseline = 'top';
  ctx.fillText(streakDays, cx, numY);

  // "day streak"
  var subY = numY + (H > W ? 175 : 165);
  ctx.fillStyle = p.text;
  ctx.font = 'bold 52px "DM Sans", sans-serif';
  ctx.fillText('day streak', cx, subY);

  // Motivational line
  var msgs = [
    'You\'re unstoppable!',
    'The keto machine!',
    'Consistency is key!',
    'Nothing can stop you!',
  ];
  var msg = msgs[streakDays % msgs.length];
  ctx.fillStyle = p.soft;
  ctx.font = 'italic 36px "DM Sans", sans-serif';
  ctx.fillText(msg, cx, subY + 76);

  // Stats
  var statsY = H > W ? H * 0.72 : H * 0.73;
  var bw = 200, bh = 110, gap = 20;
  var startX = cx - bw - gap / 2;
  statBox(ctx, startX,             statsY, bw, bh, 'Day',  currentDay + '',          p);
  statBox(ctx, startX + bw + gap,  statsY, bw, bh, 'XP',  totalXP.toLocaleString(), p);

  if (cfg.showName) {
    ctx.fillStyle = p.soft;
    ctx.font = '600 30px "DM Sans", sans-serif';
    ctx.textAlign = 'center'; ctx.textBaseline = 'top';
    ctx.fillText(userName + ' · #KetoJourney', cx, statsY + bh + 36);
  }
}

/* ── Template: Full Stats ────────────────────────────────── */
function drawStats(ctx, W, H, p) {
  var cx = W / 2;
  var topY = H > W ? H * 0.08 : H * 0.09;

  // Logo + app name header
  drawLogo(ctx, cx - 130, topY, p);
  ctx.fillStyle = p.text;
  ctx.font = 'italic bold 44px "Fraunces", serif';
  ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
  ctx.fillText('My Keto Progress', cx - 80, topY + 19);

  var divY = topY + 60;
  ctx.strokeStyle = p.accent + '55'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(80, divY); ctx.lineTo(W - 80, divY); ctx.stroke();

  // Name
  if (cfg.showName) {
    ctx.fillStyle = p.accent;
    ctx.font = 'bold 36px "DM Sans", sans-serif';
    ctx.textAlign = 'center'; ctx.textBaseline = 'top';
    ctx.fillText(userName, cx, divY + 28);
  }

  // Big day display
  var dayY = H > W ? divY + 100 : divY + 90;
  ctx.fillStyle = p.text;
  ctx.font = 'italic bold 120px "Fraunces", serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'top';
  ctx.fillText('Day ' + currentDay, cx, dayY);

  ctx.fillStyle = p.soft;
  ctx.font = '500 30px "DM Sans", sans-serif';
  ctx.fillText('of ' + maxDays + ' · ' + journeyPct + '% complete', cx, dayY + 128);

  // Progress bar
  var barY = H > W ? dayY + 196 : dayY + 186;
  var barW = W - 180;
  drawRoundRect(ctx, 90, barY, barW, 18, 9, 'rgba(255,255,255,0.1)', null);
  if (journeyPct > 0) {
    drawRoundRect(ctx, 90, barY, Math.max(18, barW * journeyPct / 100), 18, 9, p.accent, null);
  }

  // 4-box stat grid
  var gridY = H > W ? barY + 60 : barY + 56;
  var bw = (W - 200) / 2;
  var bh = H > W ? 140 : 130;
  var gap = 20;
  statBox(ctx, 90,          gridY,        bw, bh, 'Lost',   weightLostDisplay + ' ' + wUnit, p);
  statBox(ctx, 90 + bw + gap, gridY,      bw, bh, 'Streak', streakDays + ' days',            p);
  statBox(ctx, 90,          gridY + bh + gap, bw, bh, 'Level', 'Lv. ' + xpLevel,             p);
  statBox(ctx, 90 + bw + gap, gridY + bh + gap, bw, bh, 'XP',   totalXP.toLocaleString(),    p);
}

/* ══ Download ═══════════════════════════════════════════════ */
function downloadCard() {
  var canvas = document.getElementById('shareCanvas');
  var link   = document.createElement('a');
  link.download = 'keto-progress-day' + currentDay + '.png';
  link.href      = canvas.toDataURL('image/png');
  link.click();
}

/* ══ Share ══════════════════════════════════════════════════ */
function shareCard() {
  var canvas = document.getElementById('shareCanvas');
  canvas.toBlob(function(blob) {
    if (!blob) return;
    var file = new File([blob], 'keto-progress.png', { type: 'image/png' });
    navigator.share({
      title: 'My Keto Progress — Day ' + currentDay,
      text:  'Check out my keto journey progress! 🥑🔥 #KetoJourney',
      files: [file],
    }).catch(function() {
      // Fallback to download if share fails
      downloadCard();
    });
  }, 'image/png');
}
</script>

</body>
</html>
