---
import { requireAuth } from '../../lib/auth';
import { getUserJourney, updateCurrentDay } from '../../lib/supabase';
import Sidebar from '../../components/Sidebar.astro';
import { getTranslator, normaliseLang } from '../../lib/i18n';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? 'Elite' : planType === 'pro_6' ? 'Pro' : 'Basic';
const userName  = profile.full_name?.split(' ')[0] || 'Friend';
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);
await updateCurrentDay(user.id).catch(() => null);
const journey    = await getUserJourney(user.id, db).catch(() => null);
const currentDay = journey?.current_day || 1;

// Compute current week (Mon–Sun) from ?week= param or today
function getMonday(dateStr: string): Date {
  const d = new Date(dateStr + 'T00:00:00Z');
  const day = d.getUTCDay();
  const diff = day === 0 ? -6 : 1 - day;
  d.setUTCDate(d.getUTCDate() + diff);
  return d;
}

const weekParam = Astro.url.searchParams.get('week') || new Date().toISOString().slice(0, 10);
const monday = getMonday(weekParam);

// Build 7-day array
const days = Array.from({ length: 7 }, (_, i) => {
  const d = new Date(monday);
  d.setUTCDate(d.getUTCDate() + i);
  return {
    date:  d.toISOString().slice(0, 10),
    label: d.toLocaleDateString('en-US', { weekday: 'short', timeZone: 'UTC' }),
    day:   d.toLocaleDateString('en-US', { day: 'numeric', timeZone: 'UTC' }),
    month: d.toLocaleDateString('en-US', { month: 'short', timeZone: 'UTC' }),
  };
});

const weekStart = days[0].date;
const weekEnd   = days[6].date;

// Prev / next week ISO dates
const prevMonday = (() => { const d = new Date(monday); d.setUTCDate(d.getUTCDate() - 7); return d.toISOString().slice(0, 10); })();
const nextMonday = (() => { const d = new Date(monday); d.setUTCDate(d.getUTCDate() + 7); return d.toISOString().slice(0, 10); })();

const MEAL_TYPES = ['breakfast', 'lunch', 'dinner', 'snack'];
const MEAL_EMOJI: Record<string, string> = { breakfast: '🍳', lunch: '🥗', dinner: '🍽️', snack: '🥑' };

// Fetch this week's planned entries
const { data: entries } = await db
  .from('user_meal_plan')
  .select('id, plan_date, meal_type, recipe_id, recipes(id, title, calories, net_carbs, image_url)')
  .eq('user_id', user.id)
  .gte('plan_date', weekStart)
  .lte('plan_date', weekEnd)
  .order('plan_date', { ascending: true });

// Build lookup: plan_date → meal_type → entries[]
const grid: Record<string, Record<string, any[]>> = {};
for (const day of days) {
  grid[day.date] = { breakfast: [], lunch: [], dinner: [], snack: [] };
}
for (const e of (entries || [])) {
  if (grid[e.plan_date]?.[e.meal_type]) {
    grid[e.plan_date][e.meal_type].push(e);
  }
}

// Week label e.g. "Apr 14 – Apr 20, 2026"
const weekLabel = `${days[0].month} ${days[0].day} – ${days[6].month} ${days[6].day}, ${monday.getUTCFullYear()}`;

// Today's ISO date for highlighting
const todayStr = new Date().toISOString().slice(0, 10);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Meal Planner — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:#FAF6F1; --card:#FFFFFF; --card2:#F2EDE5;
      --border:rgba(255,90,122,.12); --border2:rgba(255,90,122,.28);
      --text:#1A110D; --soft:#7A5C52; --muted:#C8B5AD;
      --green:#10b981; --green2:#34d399;
      --gold:#f59e0b; --purple:#8b5cf6; --blue:#3b82f6; --red:#ef4444;
      --rv-accent:#FF5C7A;
    }
    body { background:var(--bg); color:var(--text); font-family:'Bricolage Grotesque',system-ui,sans-serif; min-height:100vh; }
    .rv-pg-shell{display:grid;grid-template-columns:232px 1fr;min-height:100vh;}
    .rv-pg-main{overflow-y:auto;}
    @media(max-width:900px){.rv-pg-shell{grid-template-columns:1fr;}}
    .page-wrap { max-width:1200px; margin:0 auto; padding:28px 16px 80px; }

    /* Header */
    .page-header { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin-bottom:24px; animation:fadeUp .4s ease both; }
    .header-left h1 { font-size:clamp(1.4rem,3.5vw,1.9rem); font-weight:800; display:flex; align-items:center; gap:.5rem; }
    .header-sub { font-size:.85rem; color:var(--soft); margin-top:3px; }

    /* Week nav */
    .week-nav { display:flex; align-items:center; gap:.5rem; background:var(--card); border:1.5px solid var(--border); border-radius:14px; padding:.35rem .5rem; }
    .week-btn { display:flex; align-items:center; justify-content:center; width:32px; height:32px; border-radius:8px; background:transparent; border:none; color:var(--soft); cursor:pointer; transition:all .15s; }
    .week-btn:hover { background:var(--muted); color:var(--text); }
    .week-label { font-size:.82rem; font-weight:600; color:var(--text); white-space:nowrap; padding:0 .4rem; }

    /* Grid */
    .planner-wrap { overflow-x:auto; }
    .planner-grid { display:grid; grid-template-columns:90px repeat(7,1fr); min-width:700px; gap:0; border:1.5px solid var(--border); border-radius:18px; overflow:hidden; }

    /* Header row */
    .grid-corner { background:var(--card2); border-right:1px solid var(--border); border-bottom:1px solid var(--border); padding:.65rem .5rem; }
    .day-header { background:var(--card2); border-right:1px solid var(--border); border-bottom:1px solid var(--border); padding:.55rem .5rem; text-align:center; }
    .day-header:last-child { border-right:none; }
    .day-header.today { background:rgba(16,185,129,.07); }
    .day-dow { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:var(--soft); }
    .day-num { font-size:1.05rem; font-weight:700; color:var(--text); line-height:1.2; }
    .day-mon { font-size:.68rem; color:var(--soft); }
    .day-header.today .day-num { color:var(--green); }
    .today-dot { width:5px; height:5px; border-radius:50%; background:var(--green); margin:.1rem auto 0; }

    /* Meal rows */
    .meal-label { background:var(--card2); border-right:1px solid var(--border); border-bottom:1px solid var(--border); padding:.6rem .5rem; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:.2rem; }
    .meal-label:last-of-type { border-bottom:none; }
    .ml-emoji { font-size:1.1rem; }
    .ml-name { font-size:.65rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--soft); }
    .meal-cell { background:var(--card); border-right:1px solid var(--border); border-bottom:1px solid var(--border); padding:.4rem; min-height:90px; display:flex; flex-direction:column; gap:.3rem; vertical-align:top; }
    .meal-cell:last-child { border-right:none; }
    /* last row — no bottom border */
    .meal-row:last-child .meal-cell,
    .meal-row:last-child .meal-label { border-bottom:none; }
    .meal-cell.today-col { background:rgba(16,185,129,.03); }

    /* Recipe chip in cell */
    .mp-chip { display:flex; align-items:center; gap:.3rem; background:var(--card2); border:1px solid var(--border); border-radius:8px; padding:.3rem .4rem; font-size:.72rem; color:var(--text); position:relative; }
    .mp-chip:hover { border-color:var(--border2); }
    .mp-chip-img { width:26px; height:26px; border-radius:5px; object-fit:cover; flex-shrink:0; }
    .mp-chip-ph  { width:26px; height:26px; border-radius:5px; background:var(--muted); flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:.8rem; }
    .mp-chip-name { flex:1; line-height:1.25; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; }
    .mp-chip-cal { font-size:.66rem; color:var(--soft); white-space:nowrap; }
    .mp-chip-del { background:transparent; border:none; color:var(--soft); cursor:pointer; padding:.05rem; border-radius:4px; flex-shrink:0; transition:color .15s; line-height:1; }
    .mp-chip-del:hover { color:var(--red); }

    /* Add button */
    .add-slot-btn { display:flex; align-items:center; justify-content:center; width:100%; border-radius:7px; border:1.5px dashed var(--border); background:transparent; color:var(--soft); cursor:pointer; font-size:.75rem; padding:.28rem; transition:all .18s; gap:.2rem; margin-top:auto; }
    .add-slot-btn:hover { border-color:var(--green); color:var(--green); background:rgba(16,185,129,.05); }

    /* Mobile: day tabs view */
    @media(max-width:700px) {
      .planner-wrap { overflow:visible; }
      .planner-grid { display:none; }
      .mobile-planner { display:block; }
    }
    @media(min-width:701px) { .mobile-planner { display:none; } }

    .mobile-planner { animation:fadeUp .4s ease both; }
    .day-tabs { display:flex; gap:.4rem; overflow-x:auto; padding-bottom:.5rem; margin-bottom:12px; }
    .day-tab { padding:.35rem .75rem; border-radius:10px; border:1.5px solid var(--border); background:transparent; color:var(--soft); font-size:.78rem; font-weight:600; cursor:pointer; white-space:nowrap; transition:all .15s; flex-shrink:0; }
    .day-tab.active { background:var(--green); border-color:var(--green); color:#fff; }
    .day-tab.today-tab { border-color:var(--green2); color:var(--green2); }
    .day-tab.today-tab.active { background:var(--green); border-color:var(--green); color:#fff; }
    .mobile-day-panel { display:none; }
    .mobile-day-panel.active { display:block; }
    .mobile-meal-section { margin-bottom:14px; background:var(--card); border:1px solid var(--border); border-radius:14px; overflow:hidden; }
    .mobile-meal-head { display:flex; align-items:center; gap:.5rem; padding:.55rem .75rem; background:var(--card2); border-bottom:1px solid var(--border); font-size:.8rem; font-weight:700; color:var(--soft); }
    .mobile-meal-body { padding:.5rem .6rem; display:flex; flex-direction:column; gap:.35rem; }

    /* Recipe search modal */
    .modal-backdrop { position:fixed; inset:0; z-index:9000; background:rgba(6,13,9,.82); backdrop-filter:blur(6px); display:flex; align-items:flex-start; justify-content:center; padding-top:5vh; opacity:0; pointer-events:none; transition:opacity .2s; }
    .modal-backdrop.show { opacity:1; pointer-events:all; }
    .modal { background:var(--card); border:1.5px solid var(--border2); border-radius:20px; width:min(560px,95vw); max-height:80vh; display:flex; flex-direction:column; box-shadow:0 24px 60px rgba(0,0,0,.5); overflow:hidden; }
    .modal-head { display:flex; align-items:center; gap:.6rem; padding:.85rem 1rem; border-bottom:1px solid var(--border); }
    .modal-title { font-size:1rem; font-weight:700; flex:1; }
    .modal-close { background:transparent; border:none; color:var(--soft); cursor:pointer; font-size:1rem; padding:.2rem; }
    .modal-search-wrap { display:flex; align-items:center; gap:.4rem; background:var(--card2); border:1.5px solid var(--border); border-radius:10px; padding:.4rem .7rem; margin:.7rem 1rem .5rem; }
    .modal-search-wrap:focus-within { border-color:var(--green); }
    .modal-search-input { flex:1; background:transparent; border:none; outline:none; color:var(--text); font-size:.9rem; }
    .modal-search-input::placeholder { color:var(--soft); }
    .modal-results { flex:1; overflow-y:auto; padding:.3rem .75rem .75rem; }
    .modal-results::-webkit-scrollbar { width:4px; }
    .modal-results::-webkit-scrollbar-thumb { background:var(--border2); border-radius:2px; }
    .ms-status { font-size:.8rem; color:var(--soft); padding:.4rem .25rem; }
    .ms-card { display:flex; align-items:center; gap:.7rem; padding:.5rem .6rem; border-radius:10px; border:1.5px solid var(--border); background:var(--card2); margin-bottom:.4rem; cursor:pointer; transition:all .18s; }
    .ms-card:hover { border-color:var(--green); background:rgba(16,185,129,.05); }
    .ms-img { width:44px; height:44px; border-radius:8px; object-fit:cover; flex-shrink:0; background:var(--muted); }
    .ms-img-ph { width:44px; height:44px; border-radius:8px; background:var(--muted); flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:1.2rem; }
    .ms-info { flex:1; min-width:0; }
    .ms-title { font-size:.87rem; font-weight:700; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .ms-meta { font-size:.73rem; color:var(--soft); margin-top:.15rem; }

    .toast { position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(20px); background:var(--card); border:1px solid var(--border2); border-radius:12px; padding:.6rem 1.1rem; font-size:.87rem; color:var(--text); opacity:0; pointer-events:none; transition:all .3s; z-index:9999; white-space:nowrap; }
    .toast.show { opacity:1; transform:translateX(-50%) translateY(0); }

    @keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
  </style>
</head>
<body>
<div class="rv-pg-shell">
<Sidebar userName={userName} planType={planType} tierLabel={tierLabel} currentDay={currentDay} activePage="meal-planner" />
<div class="rv-pg-main">
  <div class="page-wrap">

    <!-- Header -->
    <div class="page-header">
      <div class="header-left">
        <h1>📅 Meal Planner</h1>
        <div class="header-sub">{weekLabel}</div>
      </div>
      <div class="week-nav">
        <a href={`/dashboard/meal-planner?week=${prevMonday}`} class="week-btn" aria-label="Previous week">‹</a>
        <div class="week-label">{weekLabel}</div>
        <a href={`/dashboard/meal-planner?week=${nextMonday}`} class="week-btn" aria-label="Next week">›</a>
      </div>
    </div>

    <!-- Desktop grid -->
    <div class="planner-wrap">
      <div class="planner-grid">

        <!-- Corner + day headers -->
        <div class="grid-corner"></div>
        {days.map((d) => (
          <div class={`day-header${d.date === todayStr ? ' today' : ''}`}>
            <div class="day-dow">{d.label}</div>
            <div class="day-num">{d.day}</div>
            <div class="day-mon">{d.month}</div>
            {d.date === todayStr && <div class="today-dot"></div>}
          </div>
        ))}

        <!-- Meal rows -->
        {MEAL_TYPES.map((mealType) => (
          <div class="meal-row" style="display:contents;">
            <div class="meal-label">
              <div class="ml-emoji">{MEAL_EMOJI[mealType]}</div>
              <div class="ml-name">{mealType}</div>
            </div>
            {days.map((d) => {
              const cellEntries = grid[d.date][mealType] || [];
              return (
                <div class={`meal-cell${d.date === todayStr ? ' today-col' : ''}`}>
                  {cellEntries.map((e: any) => (
                    <div class="mp-chip" id={`chip-${e.id}`}>
                      {e.recipes?.image_url
                        ? <img class="mp-chip-img" src={e.recipes.image_url} alt="" loading="lazy" />
                        : <div class="mp-chip-ph">🍽️</div>
                      }
                      <a href={`/dashboard/recipe/${e.recipe_id}`} style="flex:1;text-decoration:none;color:inherit;" class="mp-chip-name">{e.recipes?.title || 'Recipe'}</a>
                      {e.recipes?.calories && <span class="mp-chip-cal">{e.recipes.calories}cal</span>}
                      <button class="mp-chip-del" aria-label="Remove" onclick={`window.removeEntry('${e.id}')`}>✕</button>
                    </div>
                  ))}
                  <button class="add-slot-btn" onclick={`window.openPicker('${d.date}','${mealType}')`}>
                    + Add
                  </button>
                </div>
              );
            })}
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile view: day tabs -->
    <div class="mobile-planner">
      <div class="day-tabs">
        {days.map((d, i) => (
          <button
            class={`day-tab${d.date === todayStr ? ' today-tab' : ''}${i === 0 ? ' active' : ''}`}
            data-date={d.date}
            onclick={`window.switchDay('${d.date}')`}
          >{d.label} {d.day}</button>
        ))}
      </div>

      {days.map((d, i) => (
        <div class={`mobile-day-panel${i === 0 ? ' active' : ''}`} id={`mobile-${d.date}`}>
          {MEAL_TYPES.map((mealType) => {
            const cellEntries = grid[d.date][mealType] || [];
            return (
              <div class="mobile-meal-section">
                <div class="mobile-meal-head">{MEAL_EMOJI[mealType]} {mealType.charAt(0).toUpperCase() + mealType.slice(1)}</div>
                <div class="mobile-meal-body" id={`mob-body-${d.date}-${mealType}`}>
                  {cellEntries.map((e: any) => (
                    <div class="mp-chip" id={`mob-chip-${e.id}`}>
                      {e.recipes?.image_url
                        ? <img class="mp-chip-img" src={e.recipes.image_url} alt="" loading="lazy" />
                        : <div class="mp-chip-ph">🍽️</div>
                      }
                      <a href={`/dashboard/recipe/${e.recipe_id}`} style="flex:1;text-decoration:none;color:inherit;" class="mp-chip-name">{e.recipes?.title || 'Recipe'}</a>
                      {e.recipes?.calories && <span class="mp-chip-cal">{e.recipes.calories}cal</span>}
                      <button class="mp-chip-del" aria-label="Remove" onclick={`window.removeEntry('${e.id}','${d.date}','${mealType}')`}>✕</button>
                    </div>
                  ))}
                  <button class="add-slot-btn" onclick={`window.openPicker('${d.date}','${mealType}')`}>
                    + Add recipe
                  </button>
                </div>
              </div>
            );
          })}
        </div>
      ))}
    </div>

  </div>

  <!-- Recipe Picker Modal -->
  <div class="modal-backdrop" id="pickerModal" onclick="if(event.target===this)window.closePicker()">
    <div class="modal">
      <div class="modal-head">
        <div class="modal-title" id="pickerTitle">Add to Breakfast</div>
        <button class="modal-close" onclick="window.closePicker()">✕</button>
      </div>
      <div class="modal-search-wrap">
        🔍
        <input class="modal-search-input" id="pickerSearch" type="text" placeholder="Search recipes…" autocomplete="off" />
      </div>
      <div class="modal-results" id="pickerResults">
        <div class="ms-status">Start typing to search…</div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

</div>
</div>

  <script is:inline define:vars={{ todayStr }}>
    var pickerDate = '';
    var pickerMeal = '';
    var pickerTimer = null;

    function showToast(msg) {
      var t = document.getElementById('toast');
      if (!t) return;
      t.textContent = msg;
      t.className = 'toast show';
      setTimeout(function() { t.classList.remove('show'); }, 3000);
    }

    // Mobile day tabs
    window.switchDay = function(date) {
      document.querySelectorAll('.day-tab').forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.date === date);
      });
      document.querySelectorAll('.mobile-day-panel').forEach(function(p) {
        p.classList.toggle('active', p.id === 'mobile-' + date);
      });
    };

    // Open recipe picker
    window.openPicker = function(date, meal) {
      pickerDate = date;
      pickerMeal = meal;
      var emoji = { breakfast:'🍳', lunch:'🥗', dinner:'🍽️', snack:'🥑' };
      document.getElementById('pickerTitle').textContent =
        'Add to ' + (emoji[meal] || '') + ' ' + meal.charAt(0).toUpperCase() + meal.slice(1) +
        ' · ' + new Date(date + 'T00:00:00Z').toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric', timeZone:'UTC' });
      document.getElementById('pickerResults').innerHTML = '<div class="ms-status">Start typing to search…</div>';
      document.getElementById('pickerSearch').value = '';
      document.getElementById('pickerModal').classList.add('show');
      setTimeout(function() { document.getElementById('pickerSearch').focus(); }, 80);
    };

    window.closePicker = function() {
      document.getElementById('pickerModal').classList.remove('show');
      clearTimeout(pickerTimer);
    };

    // Debounced search
    document.getElementById('pickerSearch').addEventListener('input', function() {
      var q = this.value.trim();
      clearTimeout(pickerTimer);
      if (!q) {
        document.getElementById('pickerResults').innerHTML = '<div class="ms-status">Start typing to search…</div>';
        return;
      }
      document.getElementById('pickerResults').innerHTML = '<div class="ms-status">Searching…</div>';
      pickerTimer = setTimeout(function() {
        fetch('/api/recipes/search?q=' + encodeURIComponent(q) + '&page=1')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var recipes = data.recipes || [];
            if (!recipes.length) {
              document.getElementById('pickerResults').innerHTML = '<div class="ms-status">No results for "' + q + '"</div>';
              return;
            }
            var html = '';
            recipes.forEach(function(r) {
              var img = r.image_url
                ? '<img class="ms-img" src="' + r.image_url + '" alt="" loading="lazy" />'
                : '<div class="ms-img-ph">🍽️</div>';
              html += '<div class="ms-card" onclick="window.addToPlanner(\'' + r.id + '\',\'' + escJs(r.title) + '\',' + (r.calories || 0) + ',\'' + (r.image_url || '') + '\')">' +
                img +
                '<div class="ms-info"><div class="ms-title">' + escHtml(r.title) + '</div>' +
                '<div class="ms-meta">🔥 ' + r.calories + ' cal &nbsp;·&nbsp; 🥩 ' + r.net_carbs + 'g carbs</div></div>' +
                '</div>';
            });
            document.getElementById('pickerResults').innerHTML = html;
          })
          .catch(function() {
            document.getElementById('pickerResults').innerHTML = '<div class="ms-status">Network error. Try again.</div>';
          });
      }, 320);
    });

    window.addToPlanner = function(recipeId, title, calories, imageUrl) {
      fetch('/api/meal-planner', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plan_date: pickerDate, meal_type: pickerMeal, recipe_id: recipeId }),
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) { showToast('❌ ' + data.error); return; }
        window.closePicker();
        var e = data.entry;

        // Build chip HTML
        var imgHtml = imageUrl
          ? '<img class="mp-chip-img" src="' + imageUrl + '" alt="" loading="lazy" />'
          : '<div class="mp-chip-ph">🍽️</div>';
        var calHtml = calories ? '<span class="mp-chip-cal">' + calories + 'cal</span>' : '';

        // Desktop: find the correct cell
        // Cells are identified by onclick on add-slot-btn containing the date+meal
        document.querySelectorAll('.add-slot-btn').forEach(function(btn) {
          var attr = btn.getAttribute('onclick') || '';
          if (attr.indexOf("'" + pickerDate + "','" + pickerMeal + "'") !== -1) {
            var chip = document.createElement('div');
            chip.className = 'mp-chip';
            chip.id = 'chip-' + e.id;
            chip.innerHTML = imgHtml +
              '<a href="/dashboard/recipe/' + recipeId + '" style="flex:1;text-decoration:none;color:inherit;" class="mp-chip-name">' + escHtml(title) + '</a>' +
              calHtml +
              '<button class="mp-chip-del" aria-label="Remove" onclick="window.removeEntry(\'' + e.id + '\')">' +
              '<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>' +
              '</button>';
            btn.parentNode.insertBefore(chip, btn);
          }
        });

        // Mobile: same logic for mob-body divs
        var mobBody = document.getElementById('mob-body-' + pickerDate + '-' + pickerMeal);
        if (mobBody) {
          var addBtn = mobBody.querySelector('.add-slot-btn');
          var chip2 = document.createElement('div');
          chip2.className = 'mp-chip';
          chip2.id = 'mob-chip-' + e.id;
          chip2.innerHTML = imgHtml +
            '<a href="/dashboard/recipe/' + recipeId + '" style="flex:1;text-decoration:none;color:inherit;" class="mp-chip-name">' + escHtml(title) + '</a>' +
            calHtml +
            '<button class="mp-chip-del" aria-label="Remove" onclick="window.removeEntry(\'' + e.id + '\',\'' + pickerDate + '\',\'' + pickerMeal + '\')">' +
            '<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>' +
            '</button>';
          if (addBtn) mobBody.insertBefore(chip2, addBtn);
          else mobBody.appendChild(chip2);
        }

        showToast('✅ Added to ' + pickerMeal);
      })
      .catch(function() { showToast('❌ Could not add recipe'); });
    };

    window.removeEntry = function(entryId) {
      fetch('/api/meal-planner', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: entryId }),
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) { showToast('❌ ' + data.error); return; }
        ['chip-' + entryId, 'mob-chip-' + entryId].forEach(function(id) {
          var el = document.getElementById(id);
          if (el) {
            el.style.transition = 'opacity .25s, transform .25s';
            el.style.opacity = '0';
            el.style.transform = 'scale(.9)';
            setTimeout(function() { el.remove(); }, 260);
          }
        });
      })
      .catch(function() { showToast('❌ Could not remove'); });
    };

    function escHtml(s) {
      return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function escJs(s) {
      return (s||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'");
    }
  </script>
</body>
</html>
