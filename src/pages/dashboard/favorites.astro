---
import { requireAuth } from '../../lib/auth';
import Sidebar from '../../components/Sidebar.astro';
import { getUserJourney, updateCurrentDay } from '../../lib/supabase';
import { getTranslator, normaliseLang } from '../../lib/i18n';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? 'Elite' : planType === 'pro_6' ? 'Pro' : 'Basic';
const userName  = profile.full_name?.split(' ')[0] || 'Friend';

await updateCurrentDay(user.id).catch(() => null);
const journey    = await getUserJourney(user.id, db).catch(() => null);
const currentDay = journey?.current_day || 1;
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);

const { data: favs } = await db
  .from('recipe_favorites')
  .select('recipe_id, created_at, recipes(id, title, calories, protein, fat, net_carbs, image_url, prep_time, cook_time, tags, difficulty, book_id)')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false });

const favorites = (favs || []).map((f: any) => ({
  ...(f.recipes || {}),
  saved_at: f.created_at,
})).filter((r: any) => r.id);
const favCount = favorites.length;

// Derive book category label from book_id prefix
function bookCategory(bookId: string | null): string {
  if (!bookId) return '';
  if (bookId.startsWith('sm')) return 'Smoothies';
  if (bookId.startsWith('bk')) return 'Baking';
  if (bookId.startsWith('ds')) return 'Desserts';
  if (bookId.startsWith('b'))  return 'Breakfast';
  if (bookId.startsWith('l'))  return 'Lunch';
  if (bookId.startsWith('d'))  return 'Dinner';
  if (bookId.startsWith('s'))  return 'Snacks';
  return '';
}

// Collect unique meal-type tags present in the user's favorites for filter chips
const MEAL_TAGS = ['breakfast','lunch','dinner','snack','dessert','smoothie','baking'];
const presentTags = Array.from(new Set(
  favorites.flatMap((r: any) => (r.tags || []).filter((t: string) => MEAL_TAGS.includes(t)))
));
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t('favorites.title')} — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet" />
  <style>
    :root{
      --bg:#FAF6F1;--card:#FFFFFF;--card2:#F2EDE5;
      --border:rgba(22,17,15,.08);--border2:rgba(255,92,122,.25);
      --text:#16110F;--soft:#4A4340;--muted:#C8BFBA;
      --green:#10b981;--green2:#34d399;--gold:#f59e0b;
      --rv-accent:#FF5C7A;--rv-warm:#FF914D;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      min-height: 100vh;
    }

    .rv-pg-shell{display:grid;grid-template-columns:232px 1fr;min-height:100vh;}
    .rv-pg-main{min-width:0;overflow-x:hidden;}
    @media(max-width:900px){.rv-pg-shell{grid-template-columns:1fr;}.rv-pg-main{padding-bottom:5.5rem;}}

    .page-wrap {
      max-width: 1100px;
      margin: 0 auto;
      padding: 32px 20px 80px;
    }

    /* ── Header ── */
    .page-header {
      margin-bottom: 28px;
      animation: fadeUp .5s ease both;
    }
    .page-header h1 {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 700;
      color: var(--text, #dfeedd);
      line-height: 1.2;
    }
    .page-header .subtitle {
      margin-top: 6px;
      font-size: .9rem;
      color: var(--soft, #4d7055);
    }
    .page-header .subtitle strong {
      color: var(--green, #10b981);
    }

    /* ── Toolbar ── */
    .toolbar {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: .7rem;
      margin-bottom: 20px;
      animation: fadeUp .5s .05s ease both;
    }
    .search-box {
      position: relative;
      flex: 1;
      min-width: 180px;
      max-width: 340px;
    }
    .search-box input {
      width: 100%;
      background: var(--card, #0d1a0f);
      border: 1px solid var(--border, rgba(16,185,129,.1));
      border-radius: 12px;
      padding: 10px 14px 10px 38px;
      color: var(--text, #dfeedd);
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      outline: none;
      transition: border-color .2s;
    }
    .search-box input:focus { border-color: var(--green, #10b981); }
    .search-box input::placeholder { color: var(--soft, #4d7055); }
    .search-icon {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
      color: var(--soft, #4d7055);
    }
    .sort-select {
      background: var(--card, #0d1a0f);
      border: 1px solid var(--border, rgba(16,185,129,.1));
      border-radius: 10px;
      padding: 9px 12px;
      color: var(--text, #dfeedd);
      font-family: 'DM Sans', sans-serif;
      font-size: .85rem;
      outline: none;
      cursor: pointer;
    }
    .sort-select:focus { border-color: var(--green, #10b981); }

    /* ── Tag filter chips ── */
    .tag-filters {
      display: flex;
      flex-wrap: wrap;
      gap: .4rem;
      margin-bottom: 20px;
      animation: fadeUp .5s .08s ease both;
    }
    .tf-chip {
      padding: .28rem .7rem;
      border-radius: 20px;
      font-size: .75rem;
      font-weight: 600;
      border: 1.5px solid var(--border, rgba(16,185,129,.1));
      background: transparent;
      color: var(--soft, #4d7055);
      cursor: pointer;
      transition: all .15s;
      text-transform: capitalize;
    }
    .tf-chip:hover { border-color: var(--border2, rgba(16,185,129,.22)); color: var(--text, #dfeedd); }
    .tf-chip.active { background: var(--green, #10b981); border-color: var(--green, #10b981); color: #fff; }

    /* ── Grid ── */
    .recipe-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    @media (max-width: 800px) { .recipe-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px) { .recipe-grid { grid-template-columns: 1fr; } }

    /* ── Card ── */
    .recipe-card {
      background: var(--card, #0d1a0f);
      border: 1px solid var(--border, rgba(16,185,129,.1));
      border-radius: 18px;
      overflow: hidden;
      transition: transform .25s, border-color .25s, box-shadow .25s;
      animation: fadeUp .5s ease both;
      display: flex;
      flex-direction: column;
    }
    .recipe-card:hover {
      transform: translateY(-3px);
      border-color: var(--border2, rgba(16,185,129,.22));
      box-shadow: 0 8px 32px rgba(16,185,129,.1);
    }

    .card-image-wrap {
      position: relative;
      height: 160px;
      overflow: hidden;
    }
    .card-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .card-image-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #F2EDE5, #E8DDD0);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.4rem;
    }
    .unfav-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      background: rgba(255,255,255,.9);
      border: 1px solid var(--border, rgba(16,185,129,.15));
      border-radius: 50%;
      width: 34px;
      height: 34px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 1rem;
      transition: background .2s, transform .2s;
      backdrop-filter: blur(6px);
    }
    .unfav-btn:hover {
      background: rgba(239,68,68,.2);
      transform: scale(1.1);
    }

    .card-body {
      padding: 14px 16px 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      flex: 1;
    }
    .card-title-link {
      text-decoration: none;
      color: inherit;
    }
    .card-title {
      font-family: 'Fraunces', serif;
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.3;
      color: var(--text, #dfeedd);
      transition: color .2s;
    }
    .card-title-link:hover .card-title { color: var(--green2, #34d399); }

    .card-meta {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: .78rem;
      color: var(--soft, #4d7055);
    }
    .card-meta span { display: flex; align-items: center; gap: 3px; }

    .macro-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .macro-pill {
      padding: 3px 8px;
      border-radius: 20px;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .02em;
    }
    .pill-cal  { background: rgba(245,158,11,.15); color: #f59e0b; }
    .pill-pro  { background: rgba(59,130,246,.15);  color: #3b82f6; }
    .pill-fat  { background: rgba(139,92,246,.15);  color: #8b5cf6; }
    .pill-carb { background: rgba(16,185,129,.15);  color: #10b981; }

    .tags-row {
      display: flex;
      gap: 5px;
      flex-wrap: wrap;
      align-items: center;
    }
    .tag-chip {
      background: var(--card2, #111f13);
      border: 1px solid var(--border, rgba(16,185,129,.1));
      border-radius: 20px;
      padding: 2px 8px;
      font-size: .7rem;
      color: var(--soft, #4d7055);
    }
    .book-badge {
      font-size: .68rem;
      font-weight: 700;
      padding: .15rem .5rem;
      border-radius: 6px;
      background: rgba(59,130,246,.12);
      color: #60a5fa;
      border: 1px solid rgba(59,130,246,.2);
      white-space: nowrap;
    }
    .diff-badge {
      font-size: .65rem;
      font-weight: 800;
      text-transform: uppercase;
      padding: .13rem .42rem;
      border-radius: 5px;
      letter-spacing: .05em;
    }
    .diff-badge.easy   { background: rgba(16,185,129,.15);  color: #34d399; }
    .diff-badge.medium { background: rgba(245,158,11,.15);  color: #fbbf24; }
    .diff-badge.hard   { background: rgba(239,68,68,.15);   color: #f87171; }

    /* ── Empty state ── */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      animation: fadeUp .5s ease both;
    }
    .empty-icon { font-size: 3.5rem; margin-bottom: 16px; }
    .empty-state h2 {
      font-family: 'Fraunces', serif;
      font-size: 1.4rem;
      color: var(--text, #dfeedd);
      margin-bottom: 8px;
    }
    .empty-state p { color: var(--soft, #4d7055); margin-bottom: 24px; }
    .btn-browse {
      display: inline-block;
      background: var(--green, #10b981);
      color: #fff;
      text-decoration: none;
      padding: 11px 24px;
      border-radius: 12px;
      font-weight: 600;
      font-size: .9rem;
      transition: background .2s, transform .2s;
    }
    .btn-browse:hover { background: var(--green2, #34d399); transform: translateY(-2px); }

    /* ── No results ── */
    .no-results {
      display: none;
      text-align: center;
      padding: 40px 20px;
      color: var(--soft, #4d7055);
      font-size: .95rem;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
<div class="rv-pg-shell">
<Sidebar userName={userName} planType={planType} tierLabel={tierLabel} currentDay={currentDay} activePage="favorites" />
<div class="rv-pg-main">
  <div class="page-wrap">
    <div class="page-header">
      <h1>❤️ Favourite Recipes</h1>
      {favCount > 0 && (
        <p class="subtitle">
          You have <strong>{favCount}</strong> saved recipe{favCount === 1 ? '' : 's'}
        </p>
      )}
    </div>

    {favCount > 0 && (
      <>
        <div class="toolbar">
          <div class="search-box">
            <span class="search-icon">🔍</span>
            <input type="text" id="searchInput" placeholder="Search your favourites…" autocomplete="off" />
          </div>
          <select class="sort-select" id="sortSelect">
            <option value="newest">Newest saved</option>
            <option value="carbs">Lowest carbs</option>
            <option value="protein">Highest protein</option>
            <option value="calories">Fewest calories</option>
          </select>
        </div>
        {presentTags.length > 0 && (
          <div class="tag-filters">
            <button class="tf-chip active" data-tag="all">All</button>
            {presentTags.map((tag: string) => (
              <button class="tf-chip" data-tag={tag}>{tag}</button>
            ))}
          </div>
        )}
      </>
    )}

    {favCount === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">❤️</div>
        <h2>No favourites yet</h2>
        <p>Heart a recipe to save it here for quick access.</p>
        <a href="/dashboard/recipes" class="btn-browse">Browse Recipes</a>
      </div>
    ) : (
      <>
        <div class="no-results" id="noResults">No recipes match your search.</div>
        <div class="recipe-grid" id="recipeGrid">
          {favorites.map((recipe: any, idx: number) => {
            const tags = Array.isArray(recipe.tags) ? recipe.tags : [];
            const displayTags = tags.filter((t: string) => !MEAL_TAGS.includes(t)).slice(0, 2);
            const delay = (idx * 0.06).toFixed(2);
            const bookCat = bookCategory(recipe.book_id || null);
            const diff = recipe.difficulty?.toLowerCase() || '';
            return (
              <div
                class="recipe-card"
                data-title={recipe.title?.toLowerCase()}
                data-tags={tags.join(',')}
                data-carbs={recipe.net_carbs || 999}
                data-protein={recipe.protein || 0}
                data-calories={recipe.calories || 0}
                data-saved={recipe.saved_at || ''}
                style={`animation-delay:${delay}s`}
                id={`card-${recipe.id}`}
              >
                <div class="card-image-wrap">
                  {recipe.image_url ? (
                    <img src={recipe.image_url} alt={recipe.title} loading="lazy" width="400" height="160" />
                  ) : (
                    <div class="card-image-placeholder">🍽️</div>
                  )}
                  <button
                    class="unfav-btn"
                    aria-label="Remove from favourites"
                    onclick={`window.removeFav(event, '${recipe.id}')`}
                  >❤️</button>
                </div>
                <div class="card-body">
                  <a href={`/dashboard/recipe/${recipe.id}`} class="card-title-link">
                    <div class="card-title">{recipe.title}</div>
                  </a>
                  <div class="card-meta">
                    {recipe.prep_time && <span>⏱ {recipe.prep_time}m prep</span>}
                    {recipe.cook_time && <span>🔥 {recipe.cook_time}m cook</span>}
                  </div>
                  <div class="macro-row">
                    {recipe.calories  && <span class="macro-pill pill-cal">{recipe.calories} kcal</span>}
                    {recipe.protein   && <span class="macro-pill pill-pro">{recipe.protein}g P</span>}
                    {recipe.fat       && <span class="macro-pill pill-fat">{recipe.fat}g F</span>}
                    {recipe.net_carbs && <span class="macro-pill pill-carb">{recipe.net_carbs}g C</span>}
                  </div>
                  <div class="tags-row">
                    {bookCat && <span class="book-badge">📖 {bookCat}</span>}
                    {diff && <span class={`diff-badge ${diff}`}>{diff}</span>}
                    {displayTags.map((tag: string) => (
                      <span class="tag-chip">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </>
    )}
  </div>
</div></div>

  <script is:inline>
    var activeTag  = 'all';
    var activeSort = 'newest';

    function applyFilters() {
      var query = (document.getElementById('searchInput')?.value || '').toLowerCase().trim();
      var grid  = document.getElementById('recipeGrid');
      if (!grid) return;

      var cards = Array.from(grid.querySelectorAll('.recipe-card'));
      var visible = 0;

      cards.forEach(function(card) {
        var title = card.getAttribute('data-title') || '';
        var tags  = card.getAttribute('data-tags')  || '';

        var passSearch = !query || title.includes(query);
        var passTag    = activeTag === 'all' || tags.split(',').indexOf(activeTag) !== -1;

        var show = passSearch && passTag;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      var noResults = document.getElementById('noResults');
      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    }

    function applySort() {
      var grid = document.getElementById('recipeGrid');
      if (!grid) return;
      var cards = Array.from(grid.querySelectorAll('.recipe-card'));

      cards.sort(function(a, b) {
        if (activeSort === 'carbs')    return parseFloat(a.dataset.carbs)    - parseFloat(b.dataset.carbs);
        if (activeSort === 'protein')  return parseFloat(b.dataset.protein)  - parseFloat(a.dataset.protein);
        if (activeSort === 'calories') return parseFloat(a.dataset.calories) - parseFloat(b.dataset.calories);
        // newest: sort by saved_at desc (lexicographic ISO string comparison works)
        return (b.dataset.saved || '') > (a.dataset.saved || '') ? 1 : -1;
      });

      cards.forEach(function(c) { grid.appendChild(c); });
    }

    // Search
    var searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', applyFilters);
    }

    // Sort
    var sortSelect = document.getElementById('sortSelect');
    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        activeSort = this.value;
        applySort();
      });
    }

    // Tag filter chips
    document.querySelectorAll('.tf-chip').forEach(function(chip) {
      chip.addEventListener('click', function() {
        activeTag = this.dataset.tag;
        document.querySelectorAll('.tf-chip').forEach(function(c) { c.classList.remove('active'); });
        this.classList.add('active');
        applyFilters();
      });
    });

    // Remove from favourites
    window.removeFav = function(event, recipeId) {
      event.preventDefault();
      event.stopPropagation();
      var btn = event.currentTarget;
      btn.textContent = '🤍';
      btn.style.pointerEvents = 'none';

      fetch('/api/recipes/favorite', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ recipeId: recipeId })
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        var card = document.getElementById('card-' + recipeId);
        if (card) {
          card.style.transition = 'opacity .3s, transform .3s';
          card.style.opacity = '0';
          card.style.transform = 'scale(.92)';
          setTimeout(function() {
            card.remove();
            var remaining = document.querySelectorAll('#recipeGrid .recipe-card').length;
            var subtitle = document.querySelector('.subtitle');
            if (subtitle) {
              subtitle.innerHTML = 'You have <strong>' + remaining + '</strong> saved recipe' + (remaining === 1 ? '' : 's');
            }
            if (remaining === 0) window.location.reload();
          }, 320);
        }
      })
      .catch(function() {
        btn.textContent = '❤️';
        btn.style.pointerEvents = '';
      });
    };
  </script>
</body>
</html>
