---
import { supabase } from '../../lib/supabase';
import { requireAuth } from '../../lib/auth';
import DashNav from '../../components/DashNav.astro';
import Heart from 'lucide-astro/Heart';
import Star from 'lucide-astro/Star';
import UtensilsCrossed from 'lucide-astro/UtensilsCrossed';
import Clock from 'lucide-astro/Clock';
import Flame from 'lucide-astro/Flame';
import Trash2 from 'lucide-astro/Trash2';
import Search from 'lucide-astro/Search';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile } = auth;

const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? '👑 Elite' : planType === 'pro_6' ? '⚡ Pro' : '🥑 Basic';
const userName  = profile.full_name?.split(' ')[0] || 'Friend';

const { data: favs } = await supabase
  .from('recipe_favorites')
  .select('recipe_id, recipes(id, title, calories, protein, fat, net_carbs, image_url, prep_time, cook_time, tags)')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false });

const favorites = (favs || []).map((f) => f.recipes).filter(Boolean);
const favCount = favorites.length;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Favourite Recipes — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg, #060d09);
      color: var(--text, #dfeedd);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
    }

    .page-wrap {
      max-width: 1100px;
      margin: 0 auto;
      padding: 32px 20px 80px;
    }

    /* ── Header ── */
    .page-header {
      margin-bottom: 28px;
      animation: fadeUp .5s ease both;
    }
    .page-header h1 {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 700;
      color: var(--text, #dfeedd);
      line-height: 1.2;
    }
    .page-header .subtitle {
      margin-top: 6px;
      font-size: .9rem;
      color: var(--soft, #4d7055);
    }
    .page-header .subtitle strong {
      color: var(--green, #10b981);
    }

    /* ── Search ── */
    .search-wrap {
      margin-bottom: 28px;
      animation: fadeUp .5s .05s ease both;
    }
    .search-box {
      position: relative;
      max-width: 400px;
    }
    .search-box input {
      width: 100%;
      background: var(--card, #0d1a0f);
      border: 1px solid var(--border, rgba(16,185,129,.1));
      border-radius: 12px;
      padding: 12px 16px 12px 42px;
      color: var(--text, #dfeedd);
      font-family: 'DM Sans', sans-serif;
      font-size: .95rem;
      outline: none;
      transition: border-color .2s;
    }
    .search-box input:focus {
      border-color: var(--green, #10b981);
    }
    .search-box input::placeholder { color: var(--soft, #4d7055); }
    .search-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 1rem;
      pointer-events: none;
    }

    /* ── Grid ── */
    .recipe-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    @media (max-width: 800px) { .recipe-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px) { .recipe-grid { grid-template-columns: 1fr; } }

    /* ── Card ── */
    .recipe-card {
      background: var(--card, #0d1a0f);
      border: 1px solid var(--border, rgba(16,185,129,.1));
      border-radius: 18px;
      overflow: hidden;
      transition: transform .25s, border-color .25s, box-shadow .25s;
      animation: fadeUp .5s ease both;
      display: flex;
      flex-direction: column;
    }
    .recipe-card:hover {
      transform: translateY(-3px);
      border-color: var(--border2, rgba(16,185,129,.22));
      box-shadow: 0 8px 32px rgba(16,185,129,.1);
    }

    .card-image-wrap {
      position: relative;
      height: 160px;
      overflow: hidden;
    }
    .card-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .card-image-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #0d2a18, #1a3d25);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.4rem;
    }
    .unfav-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      background: rgba(6,13,9,.75);
      border: 1px solid var(--border, rgba(16,185,129,.15));
      border-radius: 50%;
      width: 34px;
      height: 34px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 1rem;
      transition: background .2s, transform .2s;
      backdrop-filter: blur(6px);
    }
    .unfav-btn:hover {
      background: rgba(239,68,68,.2);
      transform: scale(1.1);
    }

    .card-body {
      padding: 14px 16px 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      flex: 1;
    }
    .card-title-link {
      text-decoration: none;
      color: inherit;
    }
    .card-title {
      font-family: 'Fraunces', serif;
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.3;
      color: var(--text, #dfeedd);
      transition: color .2s;
    }
    .card-title-link:hover .card-title { color: var(--green2, #34d399); }

    .card-meta {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: .78rem;
      color: var(--soft, #4d7055);
    }
    .card-meta span { display: flex; align-items: center; gap: 3px; }

    .macro-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .macro-pill {
      padding: 3px 8px;
      border-radius: 20px;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .02em;
    }
    .pill-cal  { background: rgba(245,158,11,.15); color: #f59e0b; }
    .pill-pro  { background: rgba(59,130,246,.15);  color: #3b82f6; }
    .pill-fat  { background: rgba(139,92,246,.15);  color: #8b5cf6; }
    .pill-carb { background: rgba(16,185,129,.15);  color: #10b981; }

    .tags-row {
      display: flex;
      gap: 5px;
      flex-wrap: wrap;
    }
    .tag-chip {
      background: var(--card2, #111f13);
      border: 1px solid var(--border, rgba(16,185,129,.1));
      border-radius: 20px;
      padding: 2px 8px;
      font-size: .7rem;
      color: var(--soft, #4d7055);
    }

    /* ── Empty state ── */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      animation: fadeUp .5s ease both;
    }
    .empty-icon { font-size: 3.5rem; margin-bottom: 16px; }
    .empty-state h2 {
      font-family: 'Fraunces', serif;
      font-size: 1.4rem;
      color: var(--text, #dfeedd);
      margin-bottom: 8px;
    }
    .empty-state p { color: var(--soft, #4d7055); margin-bottom: 24px; }
    .btn-browse {
      display: inline-block;
      background: var(--green, #10b981);
      color: #fff;
      text-decoration: none;
      padding: 11px 24px;
      border-radius: 12px;
      font-weight: 600;
      font-size: .9rem;
      transition: background .2s, transform .2s;
    }
    .btn-browse:hover { background: var(--green2, #34d399); transform: translateY(-2px); }

    /* ── No results ── */
    .no-results {
      display: none;
      text-align: center;
      padding: 40px 20px;
      color: var(--soft, #4d7055);
      font-size: .95rem;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <DashNav
    userId={user.id}
    userName={userName}
    tierLabel={tierLabel}
    planType={planType}
    activePage="favorites"
  />

  <div class="page-wrap">
    <div class="page-header">
      <h1><Heart size={26} style="vertical-align:middle;margin-right:.5rem;" /> Favourite Recipes</h1>
      {favCount > 0 && (
        <p class="subtitle">
          You have <strong>{favCount}</strong> saved recipe{favCount === 1 ? '' : 's'}
        </p>
      )}
    </div>

    {favCount > 0 && (
      <div class="search-wrap">
        <div class="search-box">
          <span class="search-icon"><Search size={16} /></span>
          <input
            type="text"
            id="searchInput"
            placeholder="Search your favourites…"
            autocomplete="off"
          />
        </div>
      </div>
    )}

    {favCount === 0 ? (
      <div class="empty-state">
        <div class="empty-icon"><Heart size={42} /></div>
        <h2>No favourites yet</h2>
        <p>Heart a recipe to save it here for quick access.</p>
        <a href="/dashboard/recipes" class="btn-browse">Browse Recipes</a>
      </div>
    ) : (
      <>
        <div class="no-results" id="noResults">No recipes match your search.</div>
        <div class="recipe-grid" id="recipeGrid">
          {favorites.map((recipe, idx) => {
            const tags = Array.isArray(recipe.tags) ? recipe.tags.slice(0, 3) : [];
            const delay = (idx * 0.06).toFixed(2);
            return (
              <div
                class="recipe-card"
                data-title={recipe.title?.toLowerCase()}
                style={`animation-delay:${delay}s`}
                id={`card-${recipe.id}`}
              >
                <div class="card-image-wrap">
                  {recipe.image_url ? (
                    <img src={recipe.image_url} alt={recipe.title} loading="lazy" />
                  ) : (
                    <div class="card-image-placeholder"><UtensilsCrossed size={32} /></div>
                  )}
                  <button
                    class="unfav-btn"
                    aria-label="Remove from favourites"
                    onclick={`window.removeFav(event, '${recipe.id}')`}
                  ><Heart size={16} /></button>
                </div>
                <div class="card-body">
                  <a href={`/dashboard/recipe/${recipe.id}`} class="card-title-link">
                    <div class="card-title">{recipe.title}</div>
                  </a>
                  <div class="card-meta">
                    {recipe.prep_time && <span><Clock size={13} style="vertical-align:middle;margin-right:.2rem;" /> {recipe.prep_time}m prep</span>}
                    {recipe.cook_time && <span><Flame size={13} style="vertical-align:middle;margin-right:.2rem;" /> {recipe.cook_time}m cook</span>}
                  </div>
                  <div class="macro-row">
                    {recipe.calories && <span class="macro-pill pill-cal">{recipe.calories} kcal</span>}
                    {recipe.protein  && <span class="macro-pill pill-pro">{recipe.protein}g P</span>}
                    {recipe.fat      && <span class="macro-pill pill-fat">{recipe.fat}g F</span>}
                    {recipe.net_carbs && <span class="macro-pill pill-carb">{recipe.net_carbs}g C</span>}
                  </div>
                  {tags.length > 0 && (
                    <div class="tags-row">
                      {tags.map((tag) => (
                        <span class="tag-chip">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </>
    )}
  </div>

  <script is:inline>
    // Search filter
    var searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        var query = this.value.toLowerCase().trim();
        var cards = document.querySelectorAll('#recipeGrid .recipe-card');
        var visible = 0;
        cards.forEach(function(card) {
          var title = card.getAttribute('data-title') || '';
          var show = !query || title.includes(query);
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        var noResults = document.getElementById('noResults');
        if (noResults) {
          noResults.style.display = visible === 0 ? 'block' : 'none';
        }
      });
    }

    // Remove from favourites
    window.removeFav = function(event, recipeId) {
      event.preventDefault();
      event.stopPropagation();
      var btn = event.currentTarget;
      btn.textContent = '🤍';
      btn.style.pointerEvents = 'none';

      fetch('/api/recipes/favorite', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ recipeId: recipeId })
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        var card = document.getElementById('card-' + recipeId);
        if (card) {
          card.style.transition = 'opacity .3s, transform .3s';
          card.style.opacity = '0';
          card.style.transform = 'scale(.92)';
          setTimeout(function() {
            card.remove();
            // Update subtitle count
            var remaining = document.querySelectorAll('#recipeGrid .recipe-card').length;
            var subtitle = document.querySelector('.subtitle');
            if (subtitle) {
              subtitle.innerHTML = 'You have <strong>' + remaining + '</strong> saved recipe' + (remaining === 1 ? '' : 's');
            }
            if (remaining === 0) {
              window.location.reload();
            }
          }, 320);
        }
      })
      .catch(function() {
        btn.textContent = '❤️';
        btn.style.pointerEvents = '';
      });
    };
  </script>
</body>
</html>
