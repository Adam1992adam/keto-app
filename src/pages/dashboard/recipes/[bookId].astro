---
// src/pages/dashboard/recipes/[bookId].astro
// Shows all recipes belonging to a specific recipe book + tier access guard
import { requireAuth } from '../../../lib/auth';
import DashNav from '../../../components/DashNav.astro';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? '👑 Elite' : planType === 'pro_6' ? '⚡ Pro' : '🥑 Basic';
const userName  = profile.full_name?.split(' ')[0] || 'Friend';

const bookId = Astro.params.bookId || '';

// ── Tier access guard ────────────────────────────────────────────────────────
// Book IDs are prefixed (b, l, d, s, sm, bk, ds) followed by a number 1–12.
// Books 1-4 = Basic+, 5-8 = Pro+, 9-12 = Elite only.
const numMatch  = bookId.match(/(\d+)$/);
const bookNum   = numMatch ? parseInt(numMatch[1]) : 1;
const tierRank  = { basic_30: 0, pro_6: 1, elite_12: 2 };
const required  = bookNum <= 4 ? 'basic_30' : bookNum <= 8 ? 'pro_6' : 'elite_12';
const userRank  = tierRank[planType as keyof typeof tierRank] ?? 0;
const reqRank   = tierRank[required as keyof typeof tierRank] ?? 0;
if (userRank < reqRank) return Astro.redirect('/dashboard/recipes');

// ── Book metadata for all 84 books ──────────────────────────────────────────
const BK_G = 'linear-gradient(135deg,#f59e0b,#d97706)';
