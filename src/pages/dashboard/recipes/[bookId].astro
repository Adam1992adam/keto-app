const book = bookMeta[bookId] || { title:'Recipe Collection', emoji:'🍽️', desc:'Keto recipes', gradient:LU_G, accent:'#10b981', category:'Recipes' };

// ── Fetch recipes for this book ──────────────────────────────────────────────
const { data: recipes } = await db
  .from('recipes')
  .select('id, title, calories, protein, fat, net_carbs, prep_time, cook_time, image_url, tags, difficulty, servings')
  .eq('book_id', bookId)
  .order('title');

const recipeList = recipes || [];
const diffColor  = (d: string) => d === 'easy' ? '#10b981' : d === 'medium' ? '#f59e0b' : '#ef4444';

// Tier label for access badge
const accessLabel = bookNum <= 4 ? '🥑 Basic+' : bookNum <= 8 ? '⚡ Pro+' : '👑 Elite';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{book.title} · Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,700;1,700;1,900&family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <script is:inline>(function(){ var t=localStorage.getItem('keto-theme')||'dark'; document.documentElement.setAttribute('data-theme',t); })();</script>
  <style>
    :root {
      --bg:#060d09; --card:#0d1a0f; --card2:#111f13; --surface:#0a1209;
      --border:rgba(16,185,129,.1); --border2:rgba(16,185,129,.22);
      --text:#dfeedd; --soft:#4d7055; --muted:#233328;
      --green:#10b981; --green2:#34d399; --gold:#f59e0b;
      --blue:#3b82f6; --purple:#8b5cf6; --red:#ef4444;
      --radius:20px;
    }
    [data-theme="light"] {
      --bg:#f0faf4; --card:#fff; --card2:#f5fdf8; --surface:#f8fdf9;
      --border:rgba(16,185,129,.15); --border2:rgba(16,185,129,.3);
      --text:#0f2417; --soft:#4d7055; --muted:#b0d4bc;
    }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    html { scroll-behavior:smooth; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:none} }

    .page { max-width:1200px; margin:0 auto; padding:2rem 1.5rem 6rem; }

    /* ── Hero ───────────────────────────────────────────────── */
    .book-hero {
      border-radius:24px; padding:2.5rem 3rem; margin-bottom:2rem;
      position:relative; overflow:hidden;
      border:1px solid var(--border);
      animation:fadeUp .5s ease both;
    }
    .hero-bg {
      position:absolute; inset:0;
      background:var(--hero-grad); opacity:.12;
    }
    .hero-bg-line {
      position:absolute; top:0; left:0; right:0; height:3px;
      background:var(--hero-grad); opacity:.7;
    }
    .hero-content { position:relative; z-index:1; }
    .hero-breadcrumb {
      display:flex; align-items:center; gap:.4rem;
      font-size:.75rem; color:var(--soft); font-weight:600;
      margin-bottom:1.5rem; flex-wrap:wrap;
    }
    .hero-breadcrumb a { color:var(--soft); text-decoration:none; transition:color .2s; }
    .hero-breadcrumb a:hover { color:var(--green2); }
    .hero-breadcrumb .sep { opacity:.4; }
    .hero-top { display:flex; align-items:flex-start; gap:1.5rem; flex-wrap:wrap; }
    .hero-icon {
      width:72px; height:72px; border-radius:18px; flex-shrink:0;
      background:var(--hero-grad);
      display:flex; align-items:center; justify-content:center;
      font-size:2rem; box-shadow:0 8px 24px rgba(0,0,0,.25);
    }
    .hero-text { flex:1; min-width:0; }
    .hero-cat {
      font-size:.72rem; font-weight:800; text-transform:uppercase;
      letter-spacing:.1em; margin-bottom:.4rem;
      color:var(--hero-accent);
    }
    .hero-title {
      font-family:'Fraunces',serif; font-size:clamp(1.6rem,3vw,2.2rem);
      font-weight:700; line-height:1.15; margin-bottom:.5rem;
    }
    .hero-desc { font-size:.9rem; color:var(--soft); line-height:1.6; margin-bottom:1rem; }
    .hero-pills { display:flex; gap:.6rem; flex-wrap:wrap; }
    .hero-pill {
      display:inline-flex; align-items:center; gap:.35rem;
      font-size:.75rem; font-weight:700;
      padding:.3rem .8rem; border-radius:50px;
      background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.12);
      color:var(--text);
    }
    [data-theme="light"] .hero-pill { background:rgba(0,0,0,.04); border-color:rgba(0,0,0,.08); }
    .hero-pill.accent { background:var(--hero-accent-bg); border-color:var(--hero-accent-border); color:var(--hero-accent); }

    /* ── Toolbar ────────────────────────────────────────────── */
    .toolbar {
      display:flex; align-items:center; gap:.75rem; flex-wrap:wrap;
      background:var(--card); border:1px solid var(--border);
      border-radius:14px; padding:.75rem 1.1rem; margin-bottom:1.75rem;
      animation:fadeUp .4s .05s ease both;
    }
    .search-wrap { flex:1; min-width:180px; position:relative; }
    .search-wrap svg { position:absolute; left:.7rem; top:50%; transform:translateY(-50%); width:15px; height:15px; color:var(--soft); pointer-events:none; }
    .search-inp {
      width:100%; padding:.5rem .75rem .5rem 2.1rem;
      border-radius:9px; border:1.5px solid var(--border);
      background:var(--surface); color:var(--text); font-size:.84rem;
      font-family:'DM Sans',sans-serif; transition:border-color .2s; outline:none;
    }
    .search-inp:focus { border-color:var(--green); }
    .search-inp::placeholder { color:var(--soft); }
    .tb-divider { width:1px; height:22px; background:var(--border); flex-shrink:0; }
    .sort-select {
      padding:.5rem .85rem; border-radius:9px; border:1.5px solid var(--border);
      background:var(--surface); color:var(--text); font-size:.82rem;
      font-family:'DM Sans',sans-serif; cursor:pointer; outline:none; transition:border-color .2s;
    }
    .sort-select:focus { border-color:var(--green); }
    .tb-count { font-size:.78rem; color:var(--soft); font-weight:600; margin-left:auto; white-space:nowrap; }
    .diff-group { display:flex; gap:.35rem; }
    .diff-btn {
      padding:.35rem .7rem; border-radius:8px; font-size:.75rem; font-weight:700;
      border:1.5px solid var(--border); background:transparent; color:var(--soft);
      cursor:pointer; transition:all .2s; white-space:nowrap;
    }
    .diff-btn:hover { border-color:var(--border2); color:var(--text); }
    .diff-btn.active { background:var(--green); border-color:var(--green); color:#fff; }
    .diff-btn.easy.active  { background:#10b981; border-color:#10b981; }
    .diff-btn.medium.active{ background:#f59e0b; border-color:#f59e0b; }
    .diff-btn.hard.active  { background:#ef4444; border-color:#ef4444; }

    /* ── Grid ───────────────────────────────────────────────── */
    .recipes-grid {
      display:grid;
      grid-template-columns:repeat(auto-fill, minmax(270px, 1fr));
      gap:1.25rem;
    }

    /* ── Recipe card ────────────────────────────────────────── */
    .recipe-card {
      background:var(--card); border:1px solid var(--border);
      border-radius:18px; overflow:hidden;
      transition:all .25s; text-decoration:none; color:inherit;
      display:flex; flex-direction:column;
      animation:fadeUp .45s ease both;
    }
    .recipe-card:hover {
      border-color:var(--border2);
      transform:translateY(-5px);
      box-shadow:0 16px 40px rgba(0,0,0,.3);
    }
    .recipe-card.hidden { display:none; }
    .recipe-img { height:170px; overflow:hidden; position:relative; background:var(--muted); }
    .recipe-img img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .4s; }
    .recipe-card:hover .recipe-img img { transform:scale(1.07); }
    .recipe-img-overlay {
      position:absolute; inset:0;
      background:linear-gradient(to top,rgba(6,13,9,.75) 0%,transparent 55%);
    }
    .recipe-diff-badge {
      position:absolute; top:.6rem; right:.6rem;
      font-size:.63rem; font-weight:800; padding:.22rem .55rem;
      border-radius:50px; backdrop-filter:blur(8px);
    }
    .recipe-fav-btn {
      position:absolute; top:.55rem; left:.55rem;
      width:30px; height:30px; border-radius:50%;
      background:rgba(0,0,0,.45); border:none; cursor:pointer;
      display:flex; align-items:center; justify-content:center;
      font-size:.9rem; backdrop-filter:blur(8px); transition:all .2s;
      color:#fff; text-decoration:none;
    }
    .recipe-fav-btn:hover { background:rgba(236,72,153,.7); transform:scale(1.15); }
    .recipe-img-placeholder {
      width:100%; height:100%; display:flex; align-items:center; justify-content:center;
      font-size:3rem; background:var(--muted);
    }
    .recipe-body { padding:1rem 1.1rem; flex:1; display:flex; flex-direction:column; gap:.5rem; }
    .recipe-title { font-weight:700; font-size:.94rem; line-height:1.35; }
    .recipe-time {
      display:flex; align-items:center; gap:.35rem;
      font-size:.72rem; color:var(--soft); font-weight:600;
    }
    .recipe-macros {
      display:grid; grid-template-columns:repeat(4,1fr);
      gap:.2rem; margin-top:auto; padding-top:.5rem;
      border-top:1px solid var(--border);
    }
    .macro-chip { text-align:center; }
    .macro-chip-val { font-size:.84rem; font-weight:800; line-height:1; }
    .macro-chip-lbl { font-size:.58rem; color:var(--soft); margin-top:.12rem; text-transform:uppercase; letter-spacing:.04em; }

    /* ── Empty state ────────────────────────────────────────── */
    .empty-state {
      text-align:center; padding:5rem 2rem; color:var(--soft);
      animation:fadeUp .5s ease both;
    }
    .empty-icon { font-size:4rem; margin-bottom:1rem; display:block; }
    .empty-title { font-family:'Fraunces',serif; font-size:1.4rem; font-weight:700; color:var(--text); margin-bottom:.6rem; }
    .empty-sub   { font-size:.9rem; line-height:1.65; max-width:380px; margin:0 auto 1.5rem; }
    .empty-back  {
      display:inline-flex; align-items:center; gap:.5rem;
      padding:.7rem 1.5rem; border-radius:12px;
      background:linear-gradient(135deg,var(--green),var(--green2)); color:#fff;
      font-weight:700; font-size:.88rem; text-decoration:none;
      box-shadow:0 4px 14px rgba(16,185,129,.3); transition:all .2s;
    }
    .empty-back:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(16,185,129,.4); }

    /* ── No filter results ──────────────────────────────────── */
    .no-filter-msg {
      display:none; text-align:center;
      padding:3rem 1rem; color:var(--soft); font-size:.9rem;
      grid-column:1/-1;
    }
    .no-filter-msg.show { display:block; }

    @media(max-width:600px) {
      .book-hero { padding:1.5rem; }
      .hero-title { font-size:1.5rem; }
      .hero-top { gap:1rem; }
      .hero-icon { width:56px; height:56px; font-size:1.6rem; border-radius:14px; }
      .recipes-grid { grid-template-columns:1fr 1fr; gap:.75rem; }
      .recipe-img { height:130px; }
      .recipe-macros { grid-template-columns:repeat(2,1fr); }
      .toolbar { gap:.5rem; }
      .sort-select { font-size:.78rem; }
    }
  </style>
</head>
<body>
  <DashNav userId={user.id} userName={userName} tierLabel={tierLabel} planType={planType} activePage="recipes" />

  <div class="page">

    <!-- Hero -->
    <div class="book-hero" style={`--hero-grad:${book.gradient};--hero-accent:${book.accent};--hero-accent-bg:${book.accent}18;--hero-accent-border:${book.accent}35;`}>
      <div class="hero-bg"></div>
      <div class="hero-bg-line"></div>
      <div class="hero-content">
        <div class="hero-breadcrumb">
          <a href="/dashboard/recipes">Recipe Library</a>
          <span class="sep">›</span>
          <span style={`color:${book.accent};`}>{book.category}</span>
          <span class="sep">›</span>
          <span>{book.title}</span>
        </div>
        <div class="hero-top">
          <div class="hero-icon" style={`background:${book.gradient};`}>{book.emoji}</div>
          <div class="hero-text">
            <div class="hero-cat" style={`color:${book.accent};`}>{book.category}</div>
            <h1 class="hero-title">{book.title}</h1>
            <p class="hero-desc">{book.desc}</p>
            <div class="hero-pills">
              <span class="hero-pill">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                {recipeList.length} {recipeList.length === 1 ? 'recipe' : 'recipes'}
              </span>
              <span class="hero-pill accent">{accessLabel}</span>
              <span class="hero-pill">✓ Under 10g net carbs</span>
              {recipeList.length > 0 && (
                <span class="hero-pill">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {Math.round(recipeList.reduce((s: number, r: any) => s + ((r.prep_time||0)+(r.cook_time||0)), 0) / Math.max(recipeList.length, 1))} min avg
                </span>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Toolbar -->
    {recipeList.length > 0 && (
      <div class="toolbar" id="toolbar">
        <div class="search-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input class="search-inp" id="recipeSearch" type="text" placeholder="Search recipes in this book…" autocomplete="off" />
        </div>
        <div class="tb-divider"></div>
        <div class="diff-group">
          <button class="diff-btn active" data-diff="all">All</button>
          <button class="diff-btn easy"   data-diff="easy">Easy</button>
          <button class="diff-btn medium" data-diff="medium">Medium</button>
          <button class="diff-btn hard"   data-diff="hard">Hard</button>
        </div>
        <div class="tb-divider"></div>
        <select class="sort-select" id="sortSelect">
          <option value="default">Default order</option>
          <option value="cal-asc">Calories ↑</option>
          <option value="cal-desc">Calories ↓</option>
          <option value="carb-asc">Net carbs ↑</option>
          <option value="protein-desc">Protein ↓</option>
          <option value="time-asc">Fastest first</option>
        </select>
        <span class="tb-count" id="tbCount">{recipeList.length} recipes</span>
      </div>
    )}

    <!-- Recipe grid -->
    {recipeList.length > 0 ? (
      <div class="recipes-grid" id="recipesGrid">
        {recipeList.map((r: any, i: number) => (
          <a
            href={`/dashboard/recipe/${r.id}`}
            class="recipe-card"
            style={`animation-delay:${i * 0.04}s;`}
            data-title={r.title.toLowerCase()}
            data-diff={(r.difficulty || 'easy').toLowerCase()}
            data-cal={r.calories || 0}
            data-carb={r.net_carbs || 0}
            data-protein={r.protein || 0}
            data-time={(r.prep_time||0)+(r.cook_time||0)}
          >
            <div class="recipe-img">
              {r.image_url
                ? <img src={r.image_url} alt={r.title} loading="lazy" />
                : <div class="recipe-img-placeholder">{book.emoji}</div>
              }
              <div class="recipe-img-overlay"></div>
              <div class="recipe-diff-badge" style={`background:rgba(0,0,0,.55);color:${diffColor(r.difficulty||'easy')};border:1px solid ${diffColor(r.difficulty||'easy')}44;`}>
                {(r.difficulty||'easy').charAt(0).toUpperCase()+(r.difficulty||'easy').slice(1)}
              </div>
            </div>
            <div class="recipe-body">
              <div class="recipe-title">{r.title}</div>
              <div class="recipe-time">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {(r.prep_time||0)+(r.cook_time||0)} min
                {r.servings && (
                  <span style="margin-left:.5rem;opacity:.6;">· {r.servings} {r.servings === 1 ? 'serving' : 'servings'}</span>
                )}
              </div>
              <div class="recipe-macros">
                <div class="macro-chip">
                  <div class="macro-chip-val" style="color:var(--gold);">{r.calories}</div>
                  <div class="macro-chip-lbl">kcal</div>
                </div>
                <div class="macro-chip">
                  <div class="macro-chip-val" style="color:#60a5fa;">{r.protein}g</div>
                  <div class="macro-chip-lbl">protein</div>
                </div>
                <div class="macro-chip">
                  <div class="macro-chip-val" style="color:#f472b6;">{r.fat}g</div>
                  <div class="macro-chip-lbl">fat</div>
                </div>
                <div class="macro-chip">
                  <div class="macro-chip-val" style="color:var(--green2);">{r.net_carbs}g</div>
                  <div class="macro-chip-lbl">net carbs</div>
                </div>
              </div>
            </div>
          </a>
        ))}
        <div class="no-filter-msg" id="noFilterMsg">No recipes match your search or filter.</div>
      </div>
    ) : (
      <div class="empty-state">
        <span class="empty-icon">{book.emoji}</span>
        <div class="empty-title">Recipes Coming Soon</div>
        <p class="empty-sub">
          We're curating the best keto recipes for <strong>{book.title}</strong>.
          Check back shortly — new recipes are added weekly.
        </p>
        <a href="/dashboard/recipes" class="empty-back">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          Back to Recipe Library
        </a>
      </div>
    )}

  </div>

  <script is:inline>
    var cards = Array.from(document.querySelectorAll('.recipe-card'));
    var grid  = document.getElementById('recipesGrid');
    var noMsg = document.getElementById('noFilterMsg');
    var countEl = document.getElementById('tbCount');

    var activeSearch = '';
    var activeDiff   = 'all';

    function applyFilters() {
      var visible = 0;
      cards.forEach(function(c) {
        var title   = c.dataset.title || '';
        var diff    = c.dataset.diff  || '';
        var okSearch = !activeSearch || title.indexOf(activeSearch) !== -1;
        var okDiff   = activeDiff === 'all' || diff === activeDiff;
        if (okSearch && okDiff) { c.classList.remove('hidden'); visible++; }
        else                    { c.classList.add('hidden'); }
      });
      if (noMsg)   noMsg.classList.toggle('show', visible === 0);
      if (countEl) countEl.textContent = visible + (visible === 1 ? ' recipe' : ' recipes');
    }

    var searchInp = document.getElementById('recipeSearch');
    if (searchInp) {
      searchInp.addEventListener('input', function() {
        activeSearch = this.value.toLowerCase().trim();
        applyFilters();
      });
    }

    document.querySelectorAll('.diff-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        activeDiff = this.dataset.diff;
        document.querySelectorAll('.diff-btn').forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        applyFilters();
      });
    });

    var sortSel = document.getElementById('sortSelect');
    if (sortSel) {
      sortSel.addEventListener('change', function() {
        var val = this.value;
        var sorted = cards.slice().sort(function(a, b) {
          if (val === 'cal-asc')     return Number(a.dataset.cal)     - Number(b.dataset.cal);
          if (val === 'cal-desc')    return Number(b.dataset.cal)     - Number(a.dataset.cal);
          if (val === 'carb-asc')    return Number(a.dataset.carb)    - Number(b.dataset.carb);
          if (val === 'protein-desc')return Number(b.dataset.protein) - Number(a.dataset.protein);
          if (val === 'time-asc')    return Number(a.dataset.time)    - Number(b.dataset.time);
          return 0;
        });
        sorted.forEach(function(c) { if (grid) grid.appendChild(c); });
      });
    }
  </script>
</body>
</html>
