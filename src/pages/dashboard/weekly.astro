                  {m.val}<span style="font-size:.7rem;font-weight:600;margin-left:.2rem;">{m.unit}</span>
                </div>
                <div class="sb-lbl">{m.label}</div>
                {m.pct && <div style="font-size:.65rem;color:var(--muted);margin-top:.15rem;">{m.pct}% of calories</div>}
              </div>
            ))}
          </div>
        </div>
      </div>
    )}

    {/* ── HABITS WEEK SUMMARY ── */}
    {habitsForWeek.length > 0 && (
      <div class="card" style="animation:fadeUp .4s .1s ease both;margin-top:1.25rem;">
        <div class="card-title">🎯 Habit Compliance This Week</div>
        <div style="display:flex;align-items:center;gap:1.25rem;margin-bottom:1rem;">
          <div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:2.5rem;font-weight:900;color:var(--green);">{habitCompliancePct}%</div>
          <div>
            <div style="font-size:.82rem;font-weight:700;">{totalHabitDone} completions</div>
            <div style="font-size:.72rem;color:var(--soft);">out of {totalHabitOpportunities} possible this week</div>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:.5rem;">
          {habitsForWeek.map(h => {
            const done = habitWeekMap[h.id] || 0;
            const pct = Math.round((done / 7) * 100);
            return (
              <div style="display:flex;align-items:center;gap:.75rem;">
                <span style="font-size:1rem;flex-shrink:0;">{h.icon}</span>
                <div style="flex:1;min-width:0;">
                  <div style="display:flex;justify-content:space-between;margin-bottom:.2rem;">
                    <span style="font-size:.75rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{h.title}</span>
                    <span style="font-size:.7rem;color:var(--soft);flex-shrink:0;margin-left:.5rem;">{done}/7 days</span>
