          <div class="ch-chip" style="background:rgba(139,92,246,.1);border:1px solid rgba(139,92,246,.2);color:var(--purple);">Personalized</div>
        </div>
        <div class="card-body">
          <div class="grid3">
            {[
              { label:'Daily Calories', val:macroGoals.daily_calories, unit:'kcal', color:'var(--green)',  icon:'🔥', pct:100 },
              { label:'Protein',        val:macroGoals.protein_g,      unit:'g',    color:'var(--blue)',   icon:'🥩', pct:25 },
              { label:'Fat',            val:macroGoals.fat_g,          unit:'g',    color:'var(--gold)',   icon:'🥑', pct:70 },
              { label:'Net Carbs',      val:macroGoals.carbs_g,        unit:'g',    color:'var(--red)',    icon:'🥦', pct:5  },
              { label:'TDEE',           val:macroGoals.tdee,           unit:'kcal', color:'var(--soft)',   icon:'⚡', pct:null },
