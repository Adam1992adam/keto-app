---
// src/pages/dashboard/weekly.astro
import { getUserJourney, getMaxJourneyDays, updateCurrentDay } from '../../lib/supabase';
import { requireAuth } from '../../lib/auth';
import Sidebar from '../../components/Sidebar.astro';
import { getTranslator, normaliseLang } from '../../lib/i18n';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;
const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? 'Elite' : planType === 'pro_6' ? 'Pro' : 'Basic';
const userName  = profile.full_name?.split(' ')[0] || 'there';
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);

await updateCurrentDay(user.id).catch(() => null);
const journey = await getUserJourney(user.id, db);
const currentDay  = journey?.current_day  || 1;
const maxDays     = getMaxJourneyDays(planType);
const maxWeeks    = Math.ceil(maxDays / 7);
const currentWeek = Math.min(Math.ceil(currentDay / 7), maxWeeks);

// Check if already submitted this week
const { data: existingReport } = await db
  .from('weekly_reports')
  .select('*')
  .eq('user_id', user.id)
  .eq('week_number', currentWeek)
  .maybeSingle();

// Get all daily check-ins for this week
const weekStart = new Date();
weekStart.setDate(weekStart.getDate() - ((currentWeek - 1) * 7 + (currentDay % 7 || 7) - 1));
const weekStartStr = weekStart.toISOString().split('T')[0];

const { data: weekCheckins } = await db
  .from('daily_checkins')
  .select('*')
  .eq('user_id', user.id)
  .gte('checkin_date', weekStartStr)
  .order('checkin_date', { ascending: true });

// Get weight logs for this week
const { data: weightLogs } = await db
  .from('weight_logs')
  .select('weight, logged_date, notes')
  .eq('user_id', user.id)
  .order('logged_date', { ascending: false })
  .limit(10);

// Get macro goals
const { data: macroGoals } = await db
  .from('macro_goals')
  .select('*')
  .eq('user_id', user.id)
  .maybeSingle();

// Get onboarding data
const { data: onboarding } = await db
  .from('onboarding_data')
  .select('goal, target_weight, current_weight, fasting_protocol, activity_level')
  .eq('user_id', user.id)
  .maybeSingle();

// Get all previous weekly reports for history
const { data: prevReports } = await db
  .from('weekly_reports')
  .select('*')
  .eq('user_id', user.id)
  .order('week_number', { ascending: false })
  .limit(8);

// Compute week stats from check-ins
const checkinCount    = weekCheckins?.length || 0;
const avgEnergy       = checkinCount > 0
  ? (weekCheckins!.reduce((s, c) => s + (c.energy_level || 3), 0) / checkinCount).toFixed(1)
  : '—';
const avgMood         = checkinCount > 0
  ? (weekCheckins!.reduce((s, c) => s + (c.mood_level || 3), 0) / checkinCount).toFixed(1)
  : '—';
const avgWater        = checkinCount > 0
  ? (weekCheckins!.reduce((s, c) => s + (c.water_glasses || 0), 0) / checkinCount).toFixed(1)
  : '—';
const mealsFollowed   = weekCheckins?.filter(c => c.followed_meals).length || 0;
const complianceRate  = checkinCount > 0 ? Math.round((mealsFollowed / checkinCount) * 100) : 0;
const weekXP          = weekCheckins?.reduce((s, c) => s + (c.xp_earned || 0), 0) || 0;

// Starting weight = earliest log
const startWeight = weightLogs?.[weightLogs.length - 1]?.weight || onboarding?.current_weight || 0;
const latestWeight = weightLogs?.[0]?.weight || startWeight;

const tier        = profile.subscription_tier || 'basic_30';
const totalXP     = journey?.total_xp || 0;

// Habits for this week
const weekHabits = await db
  .from('habits').select('id, title, icon, category')
  .eq('user_id', user.id).eq('is_active', true)
  .order('sort_order');
const habitsForWeek = weekHabits.data || [];

const weekEnd = new Date();
const weekHabitComps = await db
  .from('habit_completions').select('habit_id, completed_date')
  .eq('user_id', user.id)
  .gte('completed_date', weekStartStr)
  .lte('completed_date', weekEnd.toISOString().split('T')[0]);
const weekHabitDone = weekHabitComps.data || [];

// Per-habit: how many days completed this week
const habitWeekMap: Record<string, number> = {};
for (const c of weekHabitDone) {
  habitWeekMap[c.habit_id] = (habitWeekMap[c.habit_id] || 0) + 1;
}
const totalHabitOpportunities = habitsForWeek.length * 7;
const totalHabitDone = Object.values(habitWeekMap).reduce((s: number, v: any) => s + v, 0);
const habitCompliancePct = totalHabitOpportunities > 0
  ? Math.round((totalHabitDone / totalHabitOpportunities) * 100) : 0;

// Build 7-slot day-by-day week map
const checkinByDate = {};
for (const c of (weekCheckins || [])) {
  checkinByDate[c.checkin_date] = c;
}
const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const weekSlots = Array.from({ length: 7 }, (_, i) => {
  const d = new Date(weekStartStr);
  d.setDate(d.getDate() + i);
  const dateStr = d.toISOString().split('T')[0];
  const ci = checkinByDate[dateStr] || null;
  return {
    label: dayNames[d.getDay()],
    date: dateStr,
    checkin: ci,
    energy: ci?.energy_level || 0,
    water: ci?.water_glasses || 0,
    meals: !!ci?.followed_meals,
    done: !!ci,
  };
});

// Week compliance star rating (0-5 full stars)
const weekStars = Math.round((complianceRate / 100) * 5);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{t('weekly.title')} — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet"/>
  <script is:inline>
    (function(){ const t=localStorage.getItem('keto-theme')||'light'; document.documentElement.setAttribute('data-theme',t); })();
  </script>
  <style>
    :root{
      --rv-bg:#FAF6F1;--rv-card:#FFFFFF;--rv-bg-alt:#F2EDE5;--rv-line:#E5DED2;
      --rv-ink:#16110F;--rv-ink-soft:#4A4340;--rv-muted:#8A8077;
      --rv-accent:#FF5C7A;--rv-accent-2:#B6FF3C;--rv-warm:#FF914D;
      --bg:var(--rv-bg);--card:var(--rv-card);--card2:var(--rv-bg-alt);
      --border:var(--rv-line);--border2:rgba(255,92,122,.3);--border3:rgba(255,92,122,.5);
      --text:var(--rv-ink);--soft:var(--rv-ink-soft);--muted:#C8BFBA;
      --green:#10b981;--green2:#34d399;--gold:#f59e0b;--red:#ef4444;
      --blue:#3b82f6;--purple:#8b5cf6;--cyan:#06b6d4;--indigo:#6366f1;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{font-family:'Bricolage Grotesque',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
    .rv-pg-shell{display:grid;grid-template-columns:232px 1fr;min-height:100vh;}
    .rv-pg-main{min-width:0;overflow-x:hidden;}
    @media(max-width:900px){.rv-pg-shell{grid-template-columns:1fr;}.rv-pg-main{padding-bottom:5.5rem;}}

    /* PAGE */
    .page{max-width:1000px;margin:0 auto;padding:2rem 1.75rem 4rem;}

    /* HERO */
    .hero{
      border-radius:24px;padding:2.5rem;
      background:linear-gradient(135deg,rgba(255,92,122,.06),rgba(255,145,77,.04),rgba(182,255,60,.03));
      border:1px solid rgba(255,92,122,.18);
      margin-bottom:2rem;position:relative;overflow:hidden;
      animation:fadeUp .5s ease both;
    }
    .hero-inner{position:relative;z-index:1;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;}
    .hero-badge{display:inline-flex;align-items:center;gap:.4rem;background:rgba(255,92,122,.08);border:1px solid rgba(255,92,122,.2);border-radius:99px;padding:.3rem .85rem;font-size:.7rem;font-weight:800;color:var(--rv-accent);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.875rem;}
    .hero-title{font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:clamp(1.6rem,3vw,2.4rem);font-weight:900;line-height:1.1;margin-bottom:.4rem;}
    .hero-title em{font-style:italic;background:linear-gradient(135deg,var(--rv-accent),var(--rv-warm));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
    .hero-sub{font-size:.85rem;color:var(--soft);line-height:1.6;max-width:440px;}
    .hero-rstats{display:flex;gap:.7rem;}
    .rstat{text-align:center;padding:.875rem 1.1rem;background:rgba(255,255,255,.7);border:1px solid var(--rv-line);border-radius:14px;min-width:75px;transition:all .25s;}
    .rstat:hover{border-color:var(--green);}
    .rstat-val{font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.7rem;font-weight:900;line-height:1;margin-bottom:.2rem;}
    .rstat-lbl{font-size:.62rem;font-weight:800;color:var(--soft);text-transform:uppercase;letter-spacing:.06em;}

    /* TABS */
    .tabs{display:flex;gap:.4rem;margin-bottom:1.75rem;background:var(--card);border:1px solid var(--border);border-radius:14px;padding:.4rem;animation:fadeUp .4s .05s ease both;}
    .tab{flex:1;padding:.6rem 1rem;border-radius:10px;font-size:.8rem;font-weight:800;text-align:center;cursor:pointer;transition:all .22s;color:var(--soft);border:none;background:transparent;font-family:'Bricolage Grotesque',system-ui,sans-serif;}
    .tab:hover{color:var(--text);}
    .tab.active{background:linear-gradient(135deg,var(--rv-accent),#FF7A95);color:#fff;box-shadow:0 4px 12px rgba(255,92,122,.3);}

    /* PANEL */
    .tab-panel{display:none;animation:fadeUp .3s ease both;}
    .tab-panel.active{display:block;}

    /* GRID */
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;}
    .grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.1rem;}
    .grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;}
    @media(max-width:700px){.grid2,.grid3,.grid4{grid-template-columns:1fr 1fr;}.hero-rstats{flex-wrap:wrap;}}
    @media(max-width:480px){.grid2{grid-template-columns:1fr;}}

    /* CARD */
    .card{background:var(--card);border:1px solid var(--border);border-radius:20px;overflow:hidden;transition:border-color .25s;margin-bottom:1.25rem;}
    .card:hover{border-color:var(--border2);}
    .card-head{display:flex;align-items:center;gap:.875rem;padding:1.1rem 1.5rem;border-bottom:1px solid var(--border);}
    .ch-icon{width:38px;height:38px;border-radius:11px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1rem;}
    .ch-title{font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:.95rem;font-weight:700;flex:1;}
    .ch-chip{font-size:.65rem;font-weight:800;padding:.2rem .6rem;border-radius:99px;}
    .card-body{padding:1.25rem 1.5rem;}

    /* STAT BOX */
    .stat-box{background:var(--card2);border:1px solid var(--border);border-radius:14px;padding:1.1rem;transition:all .25s;text-align:center;}
    .stat-box:hover{border-color:var(--border2);transform:translateY(-2px);}
    .sb-icon{font-size:1.4rem;margin-bottom:.4rem;}
    .sb-val{font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.8rem;font-weight:900;line-height:1;margin-bottom:.2rem;}
    .sb-lbl{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);}
    .sb-change{font-size:.72rem;font-weight:800;margin-top:.3rem;padding:.15rem .5rem;border-radius:99px;display:inline-block;}
    .change-good{background:rgba(16,185,129,.12);color:var(--green);}
    .change-warn{background:rgba(245,158,11,.12);color:var(--amber);}
    .change-bad{background:rgba(239,68,68,.1);color:var(--red);}

    /* PROGRESS BAR */
    .prog-wrap{margin-bottom:1rem;}
    .prog-head{display:flex;justify-content:space-between;margin-bottom:.4rem;}
    .prog-lbl{font-size:.8rem;font-weight:700;}
    .prog-val{font-size:.8rem;font-weight:800;color:var(--green);}
    .prog-track{height:8px;background:var(--muted);border-radius:99px;overflow:hidden;}
    .prog-fill{height:100%;border-radius:99px;transition:width 1.2s cubic-bezier(.4,0,.2,1);}

    /* ENERGY CHART (mini) */
    .mini-chart{display:flex;align-items:flex-end;gap:.3rem;height:64px;padding:.4rem 0;}
    .mc-bar{flex:1;border-radius:4px 4px 0 0;transition:all .5s ease;min-height:4px;cursor:pointer;position:relative;}
    .mc-bar:hover::after{content:attr(data-tip);position:absolute;bottom:calc(100% + 4px);left:50%;transform:translateX(-50%);background:var(--card2);border:1px solid var(--border);border-radius:6px;padding:.25rem .5rem;font-size:.65rem;font-weight:700;white-space:nowrap;pointer-events:none;z-index:10;}
    .chart-days{display:flex;gap:.3rem;margin-top:.3rem;}
    .chart-day{flex:1;text-align:center;font-size:.6rem;color:var(--muted);font-weight:600;}

    /* WEIGHT CHART */
    .weight-chart-wrap{position:relative;height:140px;margin-bottom:.5rem;}
    .weight-svg{width:100%;height:100%;}

    /* INSIGHT CARD */
    .insight-card{
      display:flex;gap:.875rem;padding:1rem 1.25rem;
      border-radius:14px;border:1px solid var(--border);
      background:var(--card2);margin-bottom:.65rem;
      transition:all .22s;
    }
    .insight-card:hover{border-color:var(--border2);transform:translateX(3px);}
    .ic-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:.3rem;}
    .ic-type{font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:.07em;margin-bottom:.2rem;opacity:.7;}
    .ic-text{font-size:.83rem;line-height:1.55;}
    .ic-action{font-size:.75rem;font-weight:800;margin-top:.35rem;padding:.2rem .6rem;border-radius:6px;display:inline-block;}

    /* ADJUSTMENT BOX */
    .adj-box{
      background:linear-gradient(135deg,rgba(16,185,129,.08),rgba(6,182,212,.05));
      border:1.5px solid rgba(16,185,129,.22);border-radius:16px;
      padding:1.25rem 1.5rem;margin-bottom:1rem;
    }
    .adj-title{font-weight:900;font-size:.85rem;color:var(--green);display:flex;align-items:center;gap:.5rem;margin-bottom:.6rem;}
    .adj-item{display:flex;align-items:flex-start;gap:.65rem;font-size:.82rem;line-height:1.55;margin-bottom:.5rem;}
    .adj-icon{font-size:1rem;flex-shrink:0;margin-top:.05rem;}

    /* HISTORY TABLE */
    .hist-table{width:100%;border-collapse:collapse;}
    .hist-table th{font-size:.7rem;font-weight:800;color:var(--soft);text-transform:uppercase;letter-spacing:.07em;padding:.5rem .875rem;text-align:left;border-bottom:1px solid var(--border);}
    .hist-table td{padding:.75rem .875rem;font-size:.82rem;border-bottom:1px solid var(--border);}
    .hist-table tr:last-child td{border-bottom:none;}
    .hist-table tr:hover td{background:rgba(16,185,129,.03);}

    /* FORM */
    .field{margin-bottom:1.1rem;}
    .field-label{display:block;font-size:.72rem;font-weight:800;color:var(--soft);text-transform:uppercase;letter-spacing:.07em;margin-bottom:.45rem;}
    .field-input{width:100%;background:var(--card2);border:1.5px solid var(--border);border-radius:11px;padding:.8rem 1rem;color:var(--text);font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:.875rem;font-weight:500;outline:none;transition:all .22s;}
    .field-input::placeholder{color:var(--muted);}
    .field-input:focus{border-color:var(--green);box-shadow:0 0 0 3px rgba(16,185,129,.1);background:rgba(16,185,129,.03);}
    .mood-row{display:flex;gap:.5rem;}
    .mood-btn{flex:1;padding:.65rem;background:var(--card2);border:1.5px solid var(--border);border-radius:10px;font-size:1.1rem;text-align:center;cursor:pointer;transition:all .22s;font-family:'Bricolage Grotesque',system-ui,sans-serif;}
    .mood-btn:hover{border-color:var(--border2);transform:scale(1.05);}
    .mood-btn.active{background:rgba(16,185,129,.12);border-color:var(--green);}

    /* CHALLENGE CHIPS */
    .chip-wrap{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;}
    .chip{padding:.35rem .85rem;border-radius:99px;background:var(--card2);border:1.5px solid var(--border);font-size:.75rem;font-weight:700;cursor:pointer;transition:all .2s;user-select:none;}
    .chip:hover{border-color:var(--border2);}
    .chip.active{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red);}

    /* SAVE BAR */
    .save-bar{position:sticky;bottom:1.5rem;z-index:50;background:rgba(7,13,9,.92);border:1px solid var(--border2);border-radius:16px;padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;backdrop-filter:blur(20px);box-shadow:0 16px 48px rgba(0,0,0,.4);animation:fadeUp .4s .3s ease both;flex-wrap:wrap;}
    [data-theme="light"] .save-bar{background:rgba(255,255,255,.95);}
    .sb-info{flex:1;min-width:0;}
    .sb-title{font-weight:800;font-size:.875rem;}
    .sb-sub{font-size:.72rem;color:var(--soft);margin-top:.1rem;}
    .sb-btns{display:flex;gap:.65rem;}
    .btn{display:inline-flex;align-items:center;gap:.45rem;padding:.7rem 1.4rem;border-radius:11px;font-family:'Bricolage Grotesque',system-ui,sans-serif;font-weight:800;font-size:.82rem;border:none;cursor:pointer;transition:all .22s;position:relative;overflow:hidden;}
    .btn::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.1),transparent);transform:translateX(-100%);transition:transform .45s;}
    .btn:hover::before{transform:translateX(100%);}
    .btn:hover{transform:translateY(-2px);}
    .btn-primary{background:linear-gradient(135deg,var(--rv-accent),#FF7A95);color:#fff;box-shadow:0 4px 14px rgba(255,92,122,.3);}
    .btn-primary:hover{box-shadow:0 8px 22px rgba(255,92,122,.4);}
    .btn-secondary{background:var(--card);border:1.5px solid var(--border);color:var(--soft);}
    .btn-secondary:hover{border-color:var(--green);color:var(--green);}
    .btn-spin{display:none;width:15px;height:15px;border-radius:50%;border:2px solid rgba(255,255,255,.35);border-top-color:#fff;animation:spin .7s linear infinite;}
    @keyframes spin{to{transform:rotate(360deg);}}

    /* XP PILL */
    .xp-pill{display:flex;align-items:center;gap:.35rem;background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.25);border-radius:99px;padding:.28rem .7rem;font-size:.73rem;font-weight:800;color:var(--gold);}

    /* TOAST */
    .toast{position:fixed;top:5rem;right:1.5rem;z-index:9999;padding:.75rem 1.25rem;border-radius:11px;font-weight:800;font-size:.8rem;box-shadow:0 10px 30px rgba(0,0,0,.3);transform:translateX(120px);opacity:0;pointer-events:none;transition:all .32s cubic-bezier(.4,0,.2,1);display:flex;align-items:center;gap:.5rem;}
    .toast.show{transform:translateX(0);opacity:1;}
    .toast-s{background:linear-gradient(135deg,var(--green),var(--green2));color:#fff;}
    .toast-e{background:linear-gradient(135deg,var(--red),#dc2626);color:#fff;}

    @keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}

    /* DAY TIMELINE */
    .day-strip{display:grid;grid-template-columns:repeat(7,1fr);gap:.5rem;margin-bottom:1.25rem;animation:fadeUp .35s .02s ease both;}
    .day-slot{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:.75rem .5rem;text-align:center;transition:all .22s;}
    .day-slot.has-ci{border-color:rgba(16,185,129,.3);background:rgba(16,185,129,.04);}
    .day-slot:hover{transform:translateY(-2px);}
    .ds-lbl{font-size:.65rem;font-weight:800;color:var(--soft);text-transform:uppercase;margin-bottom:.4rem;}
    .ds-dot{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto .4rem;font-size:.75rem;font-weight:800;}
    .ds-dot.done{background:rgba(16,185,129,.15);border:1.5px solid var(--green);color:var(--green);}
    .ds-dot.miss{background:var(--muted);border:1.5px solid var(--border);color:var(--soft);}
    .ds-energy{font-size:.58rem;font-weight:700;color:var(--soft);line-height:1.4;}
    .ds-bars{display:flex;flex-direction:column;gap:.18rem;margin-top:.35rem;}
    .ds-bar-wrap{height:3px;border-radius:99px;background:var(--muted);overflow:hidden;}
    .ds-bar-fill{height:100%;border-radius:99px;}
    /* STARS */
    .star-row{display:flex;gap:.2rem;align-items:center;}
    .star{font-size:1rem;color:var(--gold);opacity:.25;transition:opacity .3s;}
    .star.lit{opacity:1;}

    /* PRINT */
    @media print{
      nav,.save-bar,.tabs,button{display:none!important;}
      body{background:#fff;color:#000;}
      .card,.hero{border:1px solid #ddd;box-shadow:none;}
    }
  </style>
</head>
<body>
<div class="rv-pg-shell">
<Sidebar userName={userName} planType={planType} tierLabel={tierLabel} currentDay={currentDay} activePage="weekly" />
<div class="rv-pg-main">
<div class="page">

  <!-- HERO -->
  <div class="hero">
    <div class="hero-inner">
      <div>
        <div class="hero-badge">📊 Weekly Report · Week {currentWeek}</div>
        <h1 class="hero-title">{userName}'s <em>Week {currentWeek}</em><br/>Performance Report</h1>
        <p class="hero-sub">Your complete analysis — what worked, what to improve, and your adjusted targets for next week.</p>
      </div>
      <div class="hero-rstats">
        <div class="rstat">
          <div class="rstat-val" style="color:var(--green);">{checkinCount}</div>
          <div class="rstat-lbl">Check-ins</div>
        </div>
        <div class="rstat">
          <div class="rstat-val" style="color:var(--gold);">{complianceRate}%</div>
          <div class="rstat-lbl">Compliance</div>
        </div>
        <div class="rstat">
          <div class="rstat-val" style="color:var(--purple);">{weekXP}</div>
          <div class="rstat-lbl">XP Earned</div>
        </div>
        <div class="rstat">
          <div class="star-row">
            {[1,2,3,4,5].map(n => (
              <span class={`star${n <= weekStars ? ' lit' : ''}`}>★</span>
            ))}
          </div>
          <div class="rstat-lbl">Week Rating</div>
        </div>
      </div>
    </div>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <button class="tab active" onclick="switchTab('overview',this)">📊 Overview</button>
    <button class="tab" onclick="switchTab('checkin',this)">✅ Check-in</button>
    <button class="tab" onclick="switchTab('insights',this)">🧠 Insights</button>
    <button class="tab" onclick="switchTab('history',this)">📅 History</button>
  </div>

  <!-- ════════ TAB: OVERVIEW ════════ -->
  <div class="tab-panel active" id="tab-overview">

    <!-- Stats Grid -->
    <div class="grid4" style="margin-bottom:1.25rem;animation:fadeUp .4s ease both;">
      <div class="stat-box" style="animation:fadeUp .4s ease both;">
        <div class="sb-icon">📈</div>
        <div class="sb-val" style="color:var(--green);">{startWeight && latestWeight ? (startWeight - latestWeight).toFixed(1) + 'kg' : '—'}</div>
        <div class="sb-lbl">Weight Lost</div>
        <div class={`sb-change change-${startWeight > latestWeight ? 'good' : 'warn'}`}>{startWeight > latestWeight ? `▼ ${(startWeight - latestWeight).toFixed(1)}kg` : 'No change'}</div>
      </div>
      <div class="stat-box" style="animation:fadeUp .4s ease both;">
        <div class="sb-icon">⚡</div>
        <div class="sb-val" style="color:var(--gold);">{avgEnergy}/5</div>
        <div class="sb-lbl">Avg Energy</div>
        <div class="sb-change change-good">{Number(avgEnergy) >= 4 ? 'High' : Number(avgEnergy) >= 3 ? 'Good' : 'Low'}</div>
      </div>
      <div class="stat-box" style="animation:fadeUp .4s ease both;">
        <div class="sb-icon">💧</div>
        <div class="sb-val" style="color:var(--cyan);">{avgWater} gl</div>
        <div class="sb-lbl">Avg Water</div>
        <div class={`sb-change change-${Number(avgWater) >= 8 ? 'good' : 'warn'}`}>{Number(avgWater) >= 8 ? 'On target' : 'Below goal'}</div>
      </div>
      <div class="stat-box" style="animation:fadeUp .4s ease both;">
        <div class="sb-icon">🎯</div>
        <div class="sb-val" style="color:var(--blue);">{mealsFollowed}/{checkinCount}</div>
        <div class="sb-lbl">Meals Kept</div>
        <div class={`sb-change change-${complianceRate >= 80 ? 'good' : complianceRate >= 60 ? 'warn' : 'bad'}`}>{complianceRate}%</div>
      </div>
    </div>

    <!-- Day-by-day timeline strip -->
    <div class="day-strip">
      {weekSlots.map((slot) => (
        <div class={`day-slot${slot.done ? ' has-ci' : ''}`}>
          <div class="ds-lbl">{slot.label}</div>
          <div class={`ds-dot${slot.done ? ' done' : ' miss'}`}>
            {slot.done ? '✓' : '—'}
          </div>
          {slot.done && (
            <div class="ds-energy">
              {slot.energy >= 4 ? '⚡' : slot.energy >= 3 ? '✅' : slot.energy >= 1 ? '😴' : '—'}
            </div>
          )}
          <div class="ds-bars">
            <div class="ds-bar-wrap"><div class="ds-bar-fill" style={`width:${slot.done ? (slot.energy/5)*100 : 0}%;background:#f59e0b;`}></div></div>
            <div class="ds-bar-wrap"><div class="ds-bar-fill" style={`width:${slot.done ? (slot.water/8)*100 : 0}%;background:#3b82f6;`}></div></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Energy Chart + Compliance -->
    <div class="grid2">
      <!-- Energy / Mood Chart -->
      <div class="card" style="animation:fadeUp .4s .05s ease both;">
        <div class="card-head">
          <div class="ch-icon" style="background:linear-gradient(135deg,#f59e0b,#d97706);box-shadow:0 4px 10px rgba(245,158,11,.25);">📈</div>
          <div class="ch-title">Energy This Week</div>
        </div>
        <div class="card-body">
          <div class="mini-chart" id="energyChart">
            {weekCheckins && weekCheckins.length > 0 ? weekCheckins.map((c, i) => {
              const h = ((c.energy_level || 3) / 5) * 100;
              const day = new Date(c.checkin_date).toLocaleDateString('en',{weekday:'short'});
              return (
                <div
                  class="mc-bar"
                  style={`height:${h}%;background:linear-gradient(to top,#f59e0b,#fbbf24);border-radius:4px 4px 0 0;`}
                  data-tip={`${day}: ${c.energy_level}/5`}
                ></div>
              );
            }) : (
              <div style="text-align:center;font-size:.78rem;color:var(--soft);width:100%;align-self:center;">No check-ins this week yet</div>
            )}
          </div>
          <div class="chart-days">
            {weekCheckins && weekCheckins.length > 0
              ? weekCheckins.map(c => (
                  <div class="chart-day">{new Date(c.checkin_date).toLocaleDateString('en',{weekday:'short'}).slice(0,2)}</div>
                ))
              : ['M','T','W','T','F','S','S'].map(d => <div class="chart-day">{d}</div>)
            }
          </div>
          <div style="display:flex;gap:.5rem;margin-top:.875rem;font-size:.72rem;color:var(--soft);">
            <div style="display:flex;align-items:center;gap:.3rem;"><div style="width:10px;height:10px;border-radius:2px;background:#f59e0b;"></div> Energy</div>
          </div>
        </div>
      </div>

      <!-- Weight Progress -->
      <div class="card" style="animation:fadeUp .4s .1s ease both;">
        <div class="card-head">
          <div class="ch-icon" style="background:linear-gradient(135deg,#10b981,#059669);box-shadow:0 4px 10px rgba(16,185,129,.25);">📈</div>
          <div class="ch-title">Weight Progress</div>
        </div>
        <div class="card-body">
          {weightLogs && weightLogs.length >= 2 ? (
            <>
              <div style="display:flex;align-items:baseline;gap:.75rem;margin-bottom:1rem;">
                <div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:2.2rem;font-weight:900;color:var(--green);">{latestWeight}kg</div>
                <div>
                  <div style="font-size:.72rem;font-weight:800;color:var(--green);">↓ {(startWeight - latestWeight).toFixed(1)}kg lost</div>
                  <div style="font-size:.68rem;color:var(--soft);">from {startWeight}kg start</div>
                </div>
              </div>
              <!-- Simple SVG sparkline -->
              <svg class="weight-svg" viewBox={`0 0 ${Math.max(weightLogs.length - 1, 1) * 30} 60`} preserveAspectRatio="none">
                {weightLogs.length >= 2 && (() => {
                  const reversed = [...weightLogs].reverse();
                  const minW = Math.min(...reversed.map(w => w.weight)) - 1;
                  const maxW = Math.max(...reversed.map(w => w.weight)) + 1;
                  const range = maxW - minW || 1;
                  const W = (reversed.length - 1) * 30;
                  const points = reversed.map((w, i) => {
                    const x = i * 30;
                    const y = 55 - ((w.weight - minW) / range) * 50;
                    return `${x},${y}`;
                  }).join(' ');
                  return (
                    <>
                      <polyline points={points} fill="none" stroke="url(#wg)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <defs>
                        <linearGradient id="wg" x1="0%" y1="0%" x2="100%" y2="0%">
                          <stop offset="0%" stop-color="#3b82f6"/>
                          <stop offset="100%" stop-color="#10b981"/>
                        </linearGradient>
                      </defs>
                    </>
                  );
                })()}
              </svg>
              {onboarding?.target_weight && (
                <div style="margin-top:.75rem;">
                  <div class="prog-head">
                    <span style="font-size:.72rem;font-weight:700;color:var(--soft);">To Goal</span>
                    <span style="font-size:.72rem;font-weight:800;color:var(--green);">{latestWeight}kg → {onboarding.target_weight}kg</span>
                  </div>
                  <div class="prog-track">
                    <div class="prog-fill" style={`width:${Math.min(100, Math.round(((startWeight - latestWeight) / Math.max(startWeight - onboarding.target_weight, 1)) * 100))}%;background:linear-gradient(90deg,var(--green),var(--green2));`}></div>
                  </div>
                </div>
              )}
            </>
          ) : (
            <div style="text-align:center;padding:1.5rem 0;font-size:.82rem;color:var(--soft);">
              <div style="margin-bottom:.5rem;font-size:2rem;">📈</div>
              Log your weight in the check-in to<br/>see your progress chart here.
            </div>
