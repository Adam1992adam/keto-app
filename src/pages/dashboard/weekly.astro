                  <div style="height:5px;border-radius:99px;background:var(--muted);overflow:hidden;">
                    <div style={`height:100%;border-radius:99px;background:${pct >= 70 ? 'var(--green)' : pct >= 40 ? 'var(--gold)' : 'var(--red)'};width:${pct}%;`}></div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

  </div>

  <!-- ════════ TAB: CHECK-IN ════════ -->
  <div class="tab-panel" id="tab-checkin">

    {existingReport ? (
      <div style="text-align:center;padding:3rem;background:var(--card);border:1px solid var(--border2);border-radius:20px;animation:fadeUp .4s ease both;">
