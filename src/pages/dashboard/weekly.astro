      </div>

      <div class="card" style="animation:fadeUp .4s .06s ease both;">
        <div class="card-head">
          <div class="ch-icon" style="background:linear-gradient(135deg,#ef4444,#dc2626);box-shadow:0 4px 10px rgba(239,68,68,.25);">⚠️</div>
          <div class="ch-title">Biggest Challenges This Week</div>
        </div>
        <div class="card-body">
          <p style="font-size:.78rem;color:var(--soft);margin-bottom:.875rem;">Select all that apply — we'll adjust your plan accordingly.</p>
          <div class="chip-wrap" id="challengeChips">
            {[
              '🍕 Food cravings',
              '😴 Low energy',
              '🎉 Social events',
              '⏰ No time to cook',
              '🤢 Keto flu',
              '😤 Stress eating',
              '💰 Budget issues',
              '🤷 Boredom with meals',
              '💪 Workout fatigue',
              '😶 Skipped meals',
            ].map(c => (
              <div class="chip" onclick="toggleChip(this)">{c}</div>
            ))}
          </div>
        </div>
      </div>

      <div class="card" style="animation:fadeUp .4s .12s ease both;">
        <div class="card-head">
          <div class="ch-icon" style="background:linear-gradient(135deg,#3b82f6,#2563eb);box-shadow:0 4px 10px rgba(59,130,246,.25);">🏆</div>
          <div class="ch-title">Wins & Notes</div>
        </div>
        <div class="card-body">
          <div class="field">
            <label class="field-label">Best thing that happened this week</label>
            <input type="text" class="field-input" id="weekWin" placeholder="e.g. Resisted pizza at work, slept better, more energy..."/>
          </div>
          <div class="field">
            <label class="field-label">What will you do differently next week?</label>
            <textarea class="field-input" id="weekImprove" rows="3" style="resize:none;" placeholder="e.g. Meal prep on Sunday, drink more water, avoid snacking at night..."></textarea>
          </div>
        </div>
      </div>

      <!-- SAVE BAR -->
      <div class="save-bar">
        <div class="sb-info">
          <div class="sb-title">Submit Week {currentWeek} Report</div>
          <div class="sb-sub">Generates your personalized next-week plan</div>
        </div>
        <div class="xp-pill">⭐ +100 XP</div>
        <div class="sb-btns">
          <button class="btn btn-secondary" onclick="window.print()">PDF</button>
          <button class="btn btn-primary" id="saveWeekBtn" onclick="saveWeeklyReport()">
            <div class="btn-spin" id="weekSpin"></div>
            <span id="weekTxt">Submit Report →</span>
          </button>
        </div>
      </div>
      </>
    )}
  </div>

  <!-- ════════ TAB: INSIGHTS ════════ -->
  <div class="tab-panel" id="tab-insights">
    <div id="insightsContent">
      <!-- Populated by JS -->
    </div>
  </div>

  <!-- ════════ TAB: HISTORY ════════ -->
  <div class="tab-panel" id="tab-history">
    <div class="card" style="animation:fadeUp .4s ease both;">
      <div class="card-head">
        <div class="ch-icon" style="background:linear-gradient(135deg,#6366f1,#4f46e5);box-shadow:0 4px 10px rgba(99,102,241,.25);">📅</div>
        <div class="ch-title">Weekly Report History</div>
        <div class="ch-chip" style="background:rgba(99,102,241,.1);border:1px solid rgba(99,102,241,.2);color:var(--indigo);">{prevReports?.length || 0} weeks</div>
      </div>
      <div class="card-body" style="padding:0;">
        {prevReports && prevReports.length > 0 ? (
          <table class="hist-table">
            <thead>
              <tr>
                <th>Week</th>
                <th>Weight Lost</th>
                <th>Compliance</th>
                <th>Avg Energy</th>
                <th>XP</th>
              </tr>
            </thead>
            <tbody>
              {prevReports.map(r => (
                <tr>
                  <td><strong>Week {r.week_number}</strong><div style="font-size:.68rem;color:var(--soft);">{r.week_start_date}</div></td>
                  <td style="color:var(--green);font-weight:800;">{r.weight_lost ? '-' + r.weight_lost + 'kg' : '—'}</td>
                  <td>
                    <div style="display:flex;align-items:center;gap:.5rem;">
                      <div style="flex:1;height:6px;background:var(--muted);border-radius:99px;overflow:hidden;max-width:60px;">
                        <div style={`height:100%;background:var(--green);border-radius:99px;width:${Math.round((r.meals_completed / Math.max(r.tasks_completed || 1, 1)) * 100)}%;`}></div>
                      </div>
                      <span style="font-size:.75rem;font-weight:700;">{Math.round((r.meals_completed / Math.max(r.tasks_completed || 1, 1)) * 100)}%</span>
                    </div>
                  </td>
                  <td><span style="color:var(--gold);font-weight:800;">{r.avg_energy_level || '—'}</span>/5</td>
                  <td><span style="color:var(--purple);font-weight:800;">+{r.xp_earned_this_week || 0}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <div style="text-align:center;padding:2.5rem;font-size:.85rem;color:var(--soft);">
            <div style="margin-bottom:.75rem;font-size:2.5rem;">📊</div>
            Complete your first weekly check-in to start<br/>building your history.
          </div>
        )}
      </div>
    </div>
  </div>

</div><!-- /page -->
<div class="toast" id="toast"></div>

<script is:inline define:vars={{
  currentWeek, currentDay, maxWeeks, checkinCount, complianceRate,
  avgEnergy, avgMood, avgWater, mealsFollowed, weekXP,
  startWeight, latestWeight,
  onboardingGoal: onboarding?.goal || 'lose_weight',
  targetWeight: onboarding?.target_weight || 0,
  fastingProtocol: onboarding?.fasting_protocol || 'none',
  macroGoals,
  weekCheckins: weekCheckins || [],
  journeyStreak: journey?.streak_days || 0,
}}>

/* ── TABS ── */
function switchTab(id, el) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + id)?.classList.add('active');
  if (el) el.classList.add('active');
  if (id === 'insights') buildInsightsTab();
}
window.switchTab = switchTab;

/* ── FORM STATE ── */
let selectedMood = null;
const selectedChallenges = new Set();

function selectMood(el) {
  document.querySelectorAll('.mood-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  selectedMood = el.dataset.mood;
}
function toggleChip(el) {
  el.classList.toggle('active');
  const txt = el.textContent.trim();
  selectedChallenges.has(txt) ? selectedChallenges.delete(txt) : selectedChallenges.add(txt);
}
window.selectMood = selectMood;
window.toggleChip = toggleChip;

/* ── SMART INSIGHTS ENGINE ── */
function buildInsightsTab() {
  const container = document.getElementById('insightsContent');
  if (!container) return;

  const insights  = [];
  const adjustments = [];

  const energy = parseFloat(avgEnergy) || 3;
  const water  = parseFloat(avgWater)  || 0;
  const comp   = complianceRate;
  const wLost  = startWeight && latestWeight ? (startWeight - latestWeight) : 0;
  const checkIns = checkinCount;

  /* ── PERFORMANCE SCORE ── */
  let score = 0;
  if (comp >= 80)   score += 30;
  else if (comp >= 60) score += 15;
  if (energy >= 4)  score += 20;
  else if (energy >= 3) score += 10;
  if (water >= 8)   score += 15;
  else if (water >= 6) score += 8;
  if (wLost > 0)    score += 20;
  if (checkIns >= 6)  score += 15;
  else if (checkIns >= 4) score += 8;
  score = Math.min(score, 100);

  const scoreColor = score >= 75 ? '#10b981' : score >= 50 ? '#f59e0b' : '#ef4444';
  const scoreLabel = score >= 80 ? 'Excellent' : score >= 65 ? 'Good' : score >= 45 ? 'Fair' : 'Needs work';

  /* ── GENERATE INSIGHTS ── */

  // Compliance
  if (comp >= 90 && checkIns >= 6) {
    insights.push({ type:'🏆 Perfect', color:'#f59e0b', bg:'rgba(245,158,11,.08)', border:'rgba(245,158,11,.25)', text:`<strong>Near-perfect week at ${comp}% compliance with ${checkIns}/7 check-ins.</strong> You're in the top tier of keto practitioners. This level of consistency puts you in fat-burning mode 24/7.`, action:null });
  } else if (comp >= 80) {
    insights.push({ type:'✅ Win', color:'#10b981', bg:'rgba(16,185,129,.08)', border:'rgba(16,185,129,.22)', text:`<strong>Strong compliance at ${comp}%</strong> — you followed your meal plan on most days. This is the single most important factor for ketosis and fat loss.`, action:null });
  } else if (comp >= 60) {
    insights.push({ type:'⚠️ Moderate', color:'#f59e0b', bg:'rgba(245,158,11,.07)', border:'rgba(245,158,11,.2)', text:`Compliance was <strong>${comp}%</strong> — decent, but there's room to improve. Identify which days you fell off and why. Usually it's a lack of prepared food, not willpower.`, action:'Plan problem days' });
  } else {
    insights.push({ type:'⚠️ Issue', color:'#ef4444', bg:'rgba(239,68,68,.07)', border:'rgba(239,68,68,.2)', text:`Meal compliance was only <strong>${comp}%</strong>. Without consistent nutrition, ketosis cannot be maintained. Prepare 3 meals on Sunday so keto food is always available.`, action:'Plan Sunday meal prep' });
  }

  // Weight progress — nuanced by compliance
  if (wLost >= 1.5) {
    insights.push({ type:'🔥 Progress', color:'#10b981', bg:'rgba(16,185,129,.08)', border:'rgba(16,185,129,.22)', text:`You lost <strong>${wLost.toFixed(1)}kg this week</strong> — excellent progress! You're in active fat-burning mode. Maintain your current plan exactly.`, action:null });
  } else if (wLost >= 0.5 && wLost < 1.5) {
    insights.push({ type:'📈 Progress', color:'#10b981', bg:'rgba(16,185,129,.08)', border:'rgba(16,185,129,.22)', text:`<strong>${wLost.toFixed(1)}kg lost</strong> — steady, healthy progress. Sustainable fat loss is 0.5–1kg/week. You're right on track.`, action:null });
  } else if (wLost > 0 && wLost < 0.5 && comp >= 75) {
    insights.push({ type:'📉 Plateau', color:'#f59e0b', bg:'rgba(245,158,11,.07)', border:'rgba(245,158,11,.2)', text:`Only <strong>${wLost.toFixed(1)}kg</strong> despite good compliance. You may have hit a plateau — try reducing calories by 100 kcal or adding a 24h water fast once this week.`, action:'Break the plateau' });
  } else if (wLost > 0 && wLost < 0.5 && comp < 75) {
    insights.push({ type:'📉 Slow Progress', color:'#f59e0b', bg:'rgba(245,158,11,.07)', border:'rgba(245,158,11,.2)', text:`Only <strong>${wLost.toFixed(1)}kg lost</strong>, likely because of ${comp}% compliance. Fix the nutrition first before adjusting anything else — hidden carbs in sauces and condiments add up fast.`, action:'Audit hidden carbs' });
  } else if (wLost <= 0) {
    insights.push({ type:'⚡ No Loss', color:'#ef4444', bg:'rgba(239,68,68,.07)', border:'rgba(239,68,68,.2)', text:`No weight change this week. This could be water retention (normal, especially in women), or your calories aren't in a deficit. Weigh yourself at the same time each morning for accuracy.`, action:'Check scale timing' });
  }

  // Energy — detailed
  if (energy >= 4.5) {
    insights.push({ type:'⚡ Peak Energy', color:'#10b981', bg:'rgba(16,185,129,.08)', border:'rgba(16,185,129,.22)', text:`Energy average <strong>${energy}/5</strong> — you're running on ketones at full efficiency. This is the "keto advantage" most people talk about. You're fat-adapted.`, action:null });
  } else if (energy >= 3.5) {
    insights.push({ type:'⚡ Good Energy', color:'#f59e0b', bg:'rgba(245,158,11,.07)', border:'rgba(245,158,11,.2)', text:`Energy average <strong>${energy}/5</strong> — solid. To push it higher, try adding MCT oil to your morning coffee and ensure you're hitting your fat targets daily.`, action:null });
  } else if (energy <= 2.5 && water < 6) {
    insights.push({ type:'😴 Energy + Hydration', color:'#ef4444', bg:'rgba(239,68,68,.07)', border:'rgba(239,68,68,.2)', text:`Low energy <strong>${energy}/5</strong> combined with low water intake — this is almost certainly an electrolyte issue. Add salt to food, drink more water, take magnesium at night.`, action:'Fix electrolytes now' });
  } else if (energy <= 2.5) {
    insights.push({ type:'😴 Low Energy', color:'#ef4444', bg:'rgba(239,68,68,.07)', border:'rgba(239,68,68,.2)', text:`Low energy average of <strong>${energy}/5</strong>. Most common causes: not enough fat, too little food overall, or electrolyte deficiency. Increase healthy fats (avocado, MCT oil, nuts) immediately.`, action:'Increase fat intake' });
  }

  // Hydration
  if (water < 5) {
    insights.push({ type:'💧 Hydration', color:'#06b6d4', bg:'rgba(6,182,212,.07)', border:'rgba(6,182,212,.2)', text:`Average <strong>${parseFloat(water).toFixed(1)} glasses/day</strong> is dangerously low for keto. Dehydration causes fatigue, headaches, and cravings. Keto flushes water — you need 3L minimum daily.`, action:'Set hourly water alarms' });
  } else if (water < 7) {
    insights.push({ type:'💧 Hydration', color:'#06b6d4', bg:'rgba(6,182,212,.07)', border:'rgba(6,182,212,.2)', text:`Average <strong>${parseFloat(water).toFixed(1)} glasses/day</strong> — slightly below target. Add one glass before each meal and one before bed to hit your daily goal.`, action:'Add pre-meal water habit' });
  }

  // Streak
  if (journeyStreak >= 14) {
    insights.push({ type:'🔥 Streak', color:'#f59e0b', bg:'rgba(245,158,11,.08)', border:'rgba(245,158,11,.25)', text:`<strong>${journeyStreak}-day streak!</strong> Habit formation research shows 21 days is the tipping point — you're ${21 - journeyStreak > 0 ? 21 - journeyStreak + ' days away from keto becoming automatic.' : 'past the threshold — keto is your lifestyle now.'}`, action:null });
  } else if (journeyStreak >= 7) {
    insights.push({ type:'🔥 Streak', color:'#f59e0b', bg:'rgba(245,158,11,.07)', border:'rgba(245,158,11,.2)', text:`<strong>${journeyStreak}-day streak</strong> — one full week of consistency. Keep this going to reach the 21-day habit-formation milestone.`, action:null });
  }

  // Check-in consistency
  if (checkIns === 7) {
    insights.push({ type:'📋 Perfect Tracking', color:'#8b5cf6', bg:'rgba(139,92,246,.07)', border:'rgba(139,92,246,.2)', text:`<strong>7/7 check-ins this week</strong> — perfect tracking. Data shows you exactly what's working. This habit alone doubles your success rate.`, action:null });
  } else if (checkIns < 5) {
    insights.push({ type:'📋 Tracking Gap', color:'#8b5cf6', bg:'rgba(139,92,246,.07)', border:'rgba(139,92,246,.2)', text:`Only <strong>${checkIns}/7 check-ins</strong> this week. Without daily tracking, you lose the data that drives decisions. Set a 9pm phone reminder — it takes under 2 minutes.`, action:'Set 9pm daily reminder' });
  }

  /* ── GENERATE ADJUSTMENTS ── */
  if (wLost < 0.3 && comp >= 80) {
    adjustments.push({ icon:'🔢', text:'<strong>Reduce calories by 100–150 kcal</strong> next week. Your body has adapted to current intake. A small additional deficit should restart fat loss.' });
  }
  if (energy <= 2.5 && water >= 7) {
    adjustments.push({ icon:'🥑', text:'<strong>Increase daily fat target by 15g.</strong> Add 1 tbsp olive oil to each meal or half an avocado at lunch. Low energy with good hydration = fat deficit.' });
  }
  if (energy <= 2.5 && water < 7) {
    adjustments.push({ icon:'💧', text:'<strong>Fix water + electrolytes first.</strong> Add 1/4 tsp salt to 1L water, drink it in the morning. Take magnesium glycinate (200mg) at night. Most keto "low energy" is this.' });
  }
  if (fastingProtocol === 'none' && wLost < 0.5 && comp >= 75) {
    adjustments.push({ icon:'⏰', text:'<strong>Start 16:8 intermittent fasting next week.</strong> Your compliance is strong enough. Skip breakfast, eat 12pm–8pm. This alone can break a plateau.' });
  }
  if (water < 7) {
    adjustments.push({ icon:'💧', text:'<strong>Add a 500ml glass of water before each meal.</strong> This also reduces hunger and prevents overeating.' });
  }
  if (comp < 70) {
    adjustments.push({ icon:'📅', text:'<strong>Meal prep on Sunday — minimum 3 days of food.</strong> Low compliance is a preparation failure, not a willpower failure. Remove the decision entirely.' });
  }
  if (energy <= 2.5 && comp >= 70) {
    adjustments.push({ icon:'🧂', text:'<strong>Add electrolytes to every meal.</strong> Salt your food generously, eat 1 avocado daily (potassium), and take magnesium at night. This is the most common fix on keto.' });
  }
  if (adjustments.length === 0) {
    adjustments.push({ icon:'🎯', text:'<strong>Your plan is working perfectly.</strong> Stay the course and consider adding 10–15 mins of morning walking to further accelerate fat oxidation.' });
  }

  /* ── RENDER ── */
  container.innerHTML = `
    <!-- Score Card -->
    <div style="background:var(--card);border:1px solid var(--border);border-radius:20px;padding:1.75rem;margin-bottom:1.25rem;display:flex;align-items:center;gap:1.5rem;animation:fadeUp .4s ease both;flex-wrap:wrap;">
      <div style="text-align:center;flex-shrink:0;">
        <div style="position:relative;width:100px;height:100px;margin:0 auto .5rem;">
          <svg width="100" height="100" viewBox="0 0 100 100" style="transform:rotate(-90deg);">
            <circle cx="50" cy="50" r="42" fill="none" stroke="var(--muted)" stroke-width="8"/>
            <circle cx="50" cy="50" r="42" fill="none" stroke="${scoreColor}" stroke-width="8"
              stroke-linecap="round"
              stroke-dasharray="${2*Math.PI*42}"
              stroke-dashoffset="${2*Math.PI*42*(1-score/100)}"
              style="transition:stroke-dashoffset 1.2s ease;"
            />
          </svg>
          <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;">
            <div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.6rem;font-weight:900;color:${scoreColor};line-height:1;">${score}</div>
            <div style="font-size:.55rem;font-weight:800;color:var(--soft);text-transform:uppercase;">/100</div>
          </div>
        </div>
        <div style="font-weight:900;font-size:.85rem;color:${scoreColor};">${scoreLabel}</div>
      </div>
      <div style="flex:1;min-width:200px;">
        <div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.3rem;font-weight:900;margin-bottom:.4rem;">Week ${currentWeek} Performance Score</div>
        <p style="font-size:.82rem;color:var(--soft);line-height:1.6;">
          ${score >= 75 ? `Exceptional week. You're building unstoppable momentum. At this rate, you'll hit your target ${targetWeight ? `of ${targetWeight}kg ` : ''}ahead of schedule.`
            : score >= 55 ? `Solid week with room to grow. The adjustments below will help you break through to the next level.`
            : `Tough week — but showing up and tracking it already puts you ahead of 90% of people. Use the adjustments below to restart momentum.`}
        </p>
        <div style="display:flex;gap:.5rem;margin-top:.75rem;flex-wrap:wrap;">
          ${[
            { l:'Check-ins', v:checkinCount+'/7',         c:checkinCount>=6?'#10b981':'#f59e0b' },
            { l:'Compliance', v:comp+'%',                  c:comp>=75?'#10b981':comp>=55?'#f59e0b':'#ef4444' },
            { l:'XP Earned', v:'+'+weekXP,                 c:'#8b5cf6' },
          ].map(s => `
            <div style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:.35rem .65rem;font-size:.7rem;">
              <span style="color:${s.c};font-weight:900;">${s.v}</span>
              <span style="color:var(--muted);margin-left:.3rem;">${s.l}</span>
            </div>
          `).join('')}
        </div>
      </div>
    </div>

    <!-- Insights -->
    <div style="margin-bottom:1.25rem;animation:fadeUp .4s .05s ease both;">
      <div style="font-size:.72rem;font-weight:800;color:var(--soft);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.75rem;display:flex;align-items:center;gap:.5rem;">
        What this week revealed
        <div style="flex:1;height:1px;background:var(--border);"></div>
      </div>
      ${insights.length > 0 ? insights.map(i => `
        <div class="insight-card" style="background:${i.bg};border-color:${i.border};">
          <div class="ic-dot" style="background:${i.color};box-shadow:0 0 8px ${i.color}66;margin-top:.4rem;"></div>
          <div style="flex:1;">
            <div class="ic-type" style="color:${i.color};">${i.type}</div>
            <div class="ic-text">${i.text}</div>
            ${i.action ? `<div class="ic-action" style="background:${i.color}18;color:${i.color};border:1px solid ${i.color}33;">→ ${i.action}</div>` : ''}
          </div>
        </div>
      `).join('') : '<p style="font-size:.82rem;color:var(--soft);padding:1rem 0;">Submit your weekly check-in to generate insights.</p>'}
    </div>

    <!-- Next Week Adjustments -->
    <div class="adj-box" style="animation:fadeUp .4s .1s ease both;">
      <div class="adj-title">⚡ Adjustments for Week ${currentWeek + 1}</div>
      ${adjustments.map(a => `
        <div class="adj-item">
          <span class="adj-icon">${a.icon}</span>
          <span>${a.text}</span>
        </div>
      `).join('')}
    </div>
  `;
}

/* ── SAVE WEEKLY REPORT ── */
async function saveWeeklyReport() {
  if (currentWeek > maxWeeks) {
    showToast('⚠️ Week ' + currentWeek + ' exceeds your plan limit of ' + maxWeeks + ' weeks.', 'e');
    return;
  }

  const weightNow = parseFloat(document.getElementById('weightNow')?.value || '0');
  const weekWin   = document.getElementById('weekWin')?.value   || '';
  const improve   = document.getElementById('weekImprove')?.value || '';

  const btn  = document.getElementById('saveWeekBtn');
  const spin = document.getElementById('weekSpin');
  const txt  = document.getElementById('weekTxt');
  btn.disabled = true;
  spin.style.display = 'block';
  txt.textContent = 'Saving…';

  const challenges = [...selectedChallenges];

  const payload = {
    week_number:        currentWeek,
    weight_now:         weightNow || latestWeight,
    weight_start:       startWeight,
    mood:               selectedMood,
    challenges,
    week_win:           weekWin,
    improvement:        improve,
    checkin_count:      checkinCount,
    compliance_rate:    complianceRate,
    avg_energy:         parseFloat(avgEnergy) || 3,
    avg_water:          parseFloat(avgWater)  || 0,
    xp_earned:          weekXP + 100, // bonus for submitting weekly
    meals_completed:    mealsFollowed,
  };

  try {
    const res = await fetch('/api/weekly/save', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify(payload),
    });
    if (!res.ok) throw new Error('Failed');

    showToast('✅ Week ' + currentWeek + ' report saved!', 's');
    setTimeout(() => {
      switchTab('insights', document.querySelectorAll('.tab')[2]);
      buildInsightsTab();
    }, 800);

  } catch {
    btn.disabled = false; spin.style.display='none'; txt.textContent='Submit Report →';
    showToast('❌ Failed to save. Try again.', 'e');
  }
}
window.saveWeeklyReport = saveWeeklyReport;

/* ── TOAST ── */
function showToast(msg, type='s') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast toast-${type} show`;
  setTimeout(()=>t.classList.remove('show'), 3200);
}

/* ── AUTO INSIGHTS ON LOAD ── */
window.addEventListener('load', () => {
  // Pre-populate insights tab silently
  setTimeout(buildInsightsTab, 300);
});

</script>
</div></div></div>
</body>
</html>