      </div>
    </div>

    <!-- Macro Targets Compliance -->
    {macroGoals && (
      <div class="card" style="animation:fadeUp .4s .15s ease both;">
        <div class="card-head">
          <div class="ch-icon" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);box-shadow:0 4px 10px rgba(139,92,246,.25);">🎯</div>
