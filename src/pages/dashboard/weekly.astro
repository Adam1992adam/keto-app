        <h2 style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.6rem;font-weight:900;margin-bottom:.6rem;">Week {currentWeek} <span style="font-style:italic;background:linear-gradient(135deg,var(--green),var(--green2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;">submitted!</span></h2>
        <p style="font-size:.875rem;color:var(--soft);max-width:340px;margin:0 auto .5rem;line-height:1.6;">Your weekly check-in is complete. Check the Insights tab for your personalized analysis.</p>
        <div style="margin-top:1.5rem;display:flex;justify-content:center;gap:.75rem;flex-wrap:wrap;">
          <button class="btn btn-secondary" onclick="switchTab('insights', document.querySelector('.tab:nth-child(3)'))">🧠 View Insights</button>
