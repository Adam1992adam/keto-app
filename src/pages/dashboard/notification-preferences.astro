---
// src/pages/dashboard/notification-preferences.astro
// Notification Preferences — toggle notification types on/off

import { requireAuth } from '../../lib/auth';
import DashNav from '../../components/DashNav.astro';
import PushPermission from '../../components/PushPermission.astro';
import { getTranslator, normaliseLang } from '../../lib/i18n';
import Bell from 'lucide-astro/Bell';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? 'Elite' : planType === 'pro_6' ? 'Pro' : 'Basic';
const userName  = profile.full_name?.split(' ')[0] || 'there';
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);

const { data: existingPrefs } = await db
  .from('notification_preferences')
  .select('*')
  .eq('user_id', user.id)
  .maybeSingle();

const prefs = existingPrefs || {
  checkin_reminder: true,
  streak_warning:   true,
  incomplete_tasks: true,
  weight_reminder:  true,
  fasting_active:   true,
  weekly_review:    true,
  milestone:        true,
  level_up:         true,
};

const toggleItems = [
  {
    key:   'checkin_reminder',
    icon:  '📋',
    label: 'Daily Check-in Reminder',
    desc:  'Get reminded to complete your daily check-in',
    value: prefs.checkin_reminder !== false,
  },
  {
    key:   'streak_warning',
    icon:  '🔥',
    label: 'Streak at Risk Warning',
    desc:  'Alert when your streak is about to break',
    value: prefs.streak_warning !== false,
  },
  {
    key:   'incomplete_tasks',
    icon:  '✅',
    label: 'Incomplete Tasks Reminder',
    desc:  "Nudge when you have tasks left for the day",
    value: prefs.incomplete_tasks !== false,
  },
  {
    key:   'weight_reminder',
    icon:  '⚖️',
    label: 'Weight Log Reminder',
    desc:  "Prompt to log your weight if it has been a few days",
    value: prefs.weight_reminder !== false,
  },
  {
    key:   'fasting_active',
    icon:  '⏱️',
    label: 'Fasting Tips',
    desc:  'Receive tips and encouragement during active fasts',
    value: prefs.fasting_active !== false,
  },
  {
    key:   'weekly_review',
    icon:  '📊',
    label: 'Weekly Review Prompt',
    desc:  'Reminder to complete your weekly reflection',
    value: prefs.weekly_review !== false,
  },
  {
    key:   'milestone',
    icon:  '🏅',
    label: 'Day Milestones',
    desc:  'Celebrate reaching key journey milestones',
    value: prefs.milestone !== false,
  },
  {
    key:   'level_up',
    icon:  '⭐',
    label: 'Level Up Celebrations',
    desc:  'Notification when you gain a new XP level',
    value: prefs.level_up !== false,
  },
];

const enabledCount = toggleItems.filter(t => t.value).length;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{t('notif_prefs.title')} — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&display=swap" rel="stylesheet"/>
  <script is:inline>
    (function(){ var t=localStorage.getItem('keto-theme')||'light'; document.documentElement.setAttribute('data-theme',t); })();
  </script>
  <style>
    /* ── Tokens ── */
    :root {
      --bg:      #060d09;
      --card:    #0d1a0f;
      --card2:   #111f13;
      --border:  rgba(16,185,129,.1);
      --border2: rgba(16,185,129,.22);
      --text:    #dfeedd;
      --soft:    #4d7055;
      --muted:   #233328;
      --green:   #10b981;
      --green2:  #34d399;
      --gold:    #f59e0b;
      --purple:  #8b5cf6;
      --blue:    #3b82f6;
      --red:     #ef4444;
      --nav-h:   64px;
    }
    [data-theme="light"] {
      --bg:      #eef5ee;
      --card:    #ffffff;
      --card2:   #f5faf5;
      --border:  rgba(0,0,0,.07);
      --border2: rgba(16,185,129,.3);
      --text:    #071807;
      --soft:    #3a6040;
      --muted:   #b8cfb8;
    }
    *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body {
      font-family:'DM Sans',sans-serif;
      background:var(--bg); color:var(--text);
      min-height:100vh; overflow-x:hidden;
    }

    /* ── Layout ── */
    .page-wrap {
      max-width:720px; margin:0 auto;
      padding: calc(var(--nav-h) + 2rem) 1.25rem 6rem;
      display:flex; flex-direction:column; gap:1.5rem;
    }

    /* ── Header ── */
    .page-header { display:flex; flex-direction:column; gap:.4rem; }
    .page-header h1 {
      font-family:'Fraunces',serif; font-size:1.9rem; font-weight:900;
      line-height:1.15; color:var(--text);
    }
    .page-header h1 em { color:var(--green); font-style:italic; }
    .page-header p { color:var(--soft); font-size:.92rem; }

    /* ── Summary badge ── */
    .summary-badge {
      display:inline-flex; align-items:center; gap:.4rem;
      background:rgba(16,185,129,.1); border:1px solid var(--border2);
      color:var(--green); font-size:.8rem; font-weight:700;
      padding:.3rem .75rem; border-radius:99px;
      width:fit-content;
    }

    /* ── Card shell ── */
    .pref-card {
      background:var(--card); border:1px solid var(--border);
      border-radius:20px; overflow:hidden;
      transition:border-color .25s;
    }
    .pref-card:focus-within { border-color:var(--border2); }

    /* ── Toggle row ── */
    .toggle-row {
      display:flex; align-items:center; gap:1rem;
      padding:1rem 1.25rem;
      border-bottom:1px solid var(--border);
      transition:background .2s;
    }
    .toggle-row:last-child { border-bottom:none; }
    .toggle-row:hover { background:rgba(16,185,129,.04); }

    .row-icon {
      font-size:1.4rem; flex-shrink:0;
      width:2.4rem; text-align:center;
    }

    .row-text { flex:1; min-width:0; }
    .row-label {
      font-weight:700; font-size:.93rem; color:var(--text);
      margin-bottom:.15rem;
    }
    .row-desc { font-size:.78rem; color:var(--soft); line-height:1.4; }

    /* ── Toggle switch ── */
    .toggle-wrap { flex-shrink:0; }
    .toggle-input { display:none; }
    .toggle-track {
      display:inline-block;
      width:46px; height:26px; border-radius:99px;
      background:var(--muted); border:2px solid var(--border2);
      position:relative; cursor:pointer;
      transition:background .25s, border-color .25s;
    }
    .toggle-input:checked + .toggle-track {
      background:var(--green);
      border-color:var(--green);
    }
    .toggle-track::after {
      content:'';
      position:absolute; top:2px; left:2px;
      width:18px; height:18px; border-radius:50%;
      background:#fff;
      transition:transform .22s cubic-bezier(.4,0,.2,1), box-shadow .22s;
      box-shadow:0 1px 4px rgba(0,0,0,.28);
    }
    .toggle-input:checked + .toggle-track::after {
      transform:translateX(20px);
      box-shadow:0 1px 6px rgba(16,185,129,.45);
    }

    /* ── Actions ── */
    .actions { display:flex; gap:.75rem; flex-wrap:wrap; }
    .btn-save {
      flex:1; min-width:140px;
      background:var(--green); color:#fff;
      border:none; border-radius:14px;
      font-family:'DM Sans',sans-serif; font-weight:800; font-size:.95rem;
      padding:.75rem 1.5rem; cursor:pointer;
      transition:opacity .2s, transform .15s;
    }
    .btn-save:hover { opacity:.9; transform:translateY(-1px); }
    .btn-save:active { transform:translateY(0); }
    .btn-save:disabled { opacity:.5; cursor:not-allowed; transform:none; }

    .btn-all {
      background:transparent; color:var(--soft);
      border:1px solid var(--border2); border-radius:14px;
      font-family:'DM Sans',sans-serif; font-weight:700; font-size:.85rem;
      padding:.75rem 1.1rem; cursor:pointer;
      transition:color .2s, border-color .2s, background .2s;
    }
    .btn-all:hover { color:var(--text); border-color:var(--green); background:rgba(16,185,129,.07); }

    /* ── Back link ── */
    .back-link {
      display:inline-flex; align-items:center; gap:.4rem;
      color:var(--soft); font-size:.85rem; font-weight:600;
      text-decoration:none; transition:color .2s;
    }
    .back-link:hover { color:var(--green); }

    /* ── Toast ── */
    .toast {
      position:fixed; bottom:5rem; left:50%; transform:translateX(-50%) translateY(20px);
      background:var(--card); border:1px solid var(--border2);
      color:var(--text); font-size:.88rem; font-weight:700;
      padding:.7rem 1.4rem; border-radius:14px;
      box-shadow:0 8px 32px rgba(0,0,0,.4);
      opacity:0; pointer-events:none;
      transition:opacity .3s, transform .3s;
      z-index:9999; white-space:nowrap;
    }
    .toast.show {
      opacity:1; transform:translateX(-50%) translateY(0);
    }
    .toast.success { border-color:var(--green); color:var(--green); }
    .toast.error   { border-color:var(--red);   color:var(--red);   }

    /* ── Fade-up animation ── */
    @keyframes fadeUp {
      from { opacity:0; transform:translateY(18px); }
      to   { opacity:1; transform:translateY(0); }
    }
    .fade-up { animation:fadeUp .45s ease both; }
    .delay-1 { animation-delay:.06s; }
    .delay-2 { animation-delay:.12s; }
    .delay-3 { animation-delay:.18s; }

    @media(max-width:600px) {
      .page-header h1 { font-size:1.5rem; }
      .actions { flex-direction:column; }
      .btn-save { min-width:unset; }
    }
  </style>
</head>
<body>

<DashNav
  userId={user.id}
  userName={userName}
  tierLabel={tierLabel}
  planType={planType}
  activePage="notifications"
/>

<div class="page-wrap">

  <!-- Back -->
  <a href="/dashboard/notifications" class="back-link fade-up">
    ← Back to Notifications
  </a>

  <!-- Header -->
  <div class="page-header fade-up delay-1">
    <h1>Notification <em>Preferences</em></h1>
    <p>Choose which alerts you want to receive on your keto journey.</p>
    <div class="summary-badge" id="summaryBadge">
      <Bell size={14} style="vertical-align:middle;margin-right:.3rem;" /> {enabledCount} of {toggleItems.length} types enabled
    </div>
  </div>

  <!-- Push permission card -->
  <div style="margin-bottom:1.25rem;" class="fade-up delay-2">
    <PushPermission />
  </div>

  <!-- Toggle card -->
  <div class="pref-card fade-up delay-2" id="prefCard">
    {toggleItems.map((item) => (
      <div class="toggle-row">
        <span class="row-icon">{item.icon}</span>
        <div class="row-text">
          <div class="row-label">{item.label}</div>
          <div class="row-desc">{item.desc}</div>
        </div>
        <div class="toggle-wrap">
          <input
            type="checkbox"
            class="toggle-input pref-toggle"
            id={`toggle-${item.key}`}
            data-key={item.key}
            checked={item.value}
          />
          <label class="toggle-track" for={`toggle-${item.key}`}></label>
        </div>
      </div>
    ))}
  </div>

  <!-- Actions -->
  <div class="actions fade-up delay-3">
    <button class="btn-all" id="btnEnableAll" onclick="window.enableAll()">Enable All</button>
    <button class="btn-all" id="btnDisableAll" onclick="window.disableAll()">Disable All</button>
    <button class="btn-save" id="btnSave" onclick="window.savePrefs()">Save Preferences</button>
  </div>

</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script is:inline>
(function () {
  /* ── helpers ──────────────────────────────────────── */
  function getAllToggles() {
    return document.querySelectorAll('.pref-toggle');
  }

  function getEnabledCount() {
    var count = 0;
    getAllToggles().forEach(function(t) { if (t.checked) count++; });
    return count;
  }

  function updateBadge() {
    var badge = document.getElementById('summaryBadge');
    var total = getAllToggles().length;
    var enabled = getEnabledCount();
    if (badge) badge.textContent = '🔔 ' + enabled + ' of ' + total + ' types enabled';
  }

  /* ── listen to toggles ───────────────────────────── */
  getAllToggles().forEach(function(t) {
    t.addEventListener('change', function() {
      updateBadge();
    });
  });

  /* ── enable / disable all ─────────────────────────── */
  window.enableAll = function() {
    getAllToggles().forEach(function(t) { t.checked = true; });
    updateBadge();
  };

  window.disableAll = function() {
    getAllToggles().forEach(function(t) { t.checked = false; });
    updateBadge();
  };

  /* ── toast ─────────────────────────────────────────── */
  window.showToast = function(msg, type) {
    var el = document.getElementById('toast');
    if (!el) return;
    el.textContent = msg;
    el.className = 'toast ' + (type || '');
    requestAnimationFrame(function() {
      el.classList.add('show');
    });
    setTimeout(function() {
      el.classList.remove('show');
    }, 3000);
  };

  /* ── save ──────────────────────────────────────────── */
  window.savePrefs = function() {
    var btn = document.getElementById('btnSave');
    if (btn) { btn.disabled = true; btn.textContent = 'Saving…'; }

    var payload = {};
    getAllToggles().forEach(function(t) {
      payload[t.dataset.key] = t.checked;
    });

    fetch('/api/notifications/preferences', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          window.showToast('✅ Preferences saved!', 'success');
        } else {
          window.showToast('❌ ' + (data.error || 'Failed to save'), 'error');
        }
      })
      .catch(function() {
        window.showToast('❌ Network error — please retry', 'error');
      })
      .finally(function() {
        if (btn) { btn.disabled = false; btn.textContent = 'Save Preferences'; }
      });
  };
})();
</script>

</body>
</html>
