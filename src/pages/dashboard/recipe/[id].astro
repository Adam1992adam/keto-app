          <button class="mp-meal-btn" data-meal="snack">🥑 Snack</button>
        </div>
      </div>
      <button id="mpSaveBtn" onclick="window.saveMealPlan()" style="margin-top:.3rem;padding:.55rem 1rem;border-radius:10px;background:var(--green);border:none;color:#fff;font-family:'DM Sans',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer;transition:background .15s;width:100%;">Add to Plan</button>
    </div>
  </div>
</div>

