---
import { getUserJourney } from '../../../lib/supabase';
import { requireAuth } from '../../../lib/auth';
import DashNav from '../../../components/DashNav.astro';

const { id } = Astro.params;

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;
const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? '👑 Elite' : planType === 'pro_6' ? '⚡ Pro' : '🥑 Basic';
const userName  = profile.full_name?.split(' ')[0] || 'there';

const journey = await getUserJourney(user.id, db);
if (!journey) return Astro.redirect('/dashboard');

const currentDay = journey?.current_day || 1;

const { data: rawTasks } = await db
  .from('daily_tasks')
  .select('id, task_title, task_type, completed, xp_earned')
  .eq('user_id', user.id)
  .eq('day_number', currentDay);
const dailyTasks = rawTasks || [];

// Use maybeSingle() — .single() throws a hard error when 0 rows are returned
const { data: recipe, error: recipeErr } = await db.from('recipes').select('*').eq('id', id).maybeSingle();
if (recipeErr) console.error('Recipe fetch error:', recipeErr.message);
if (!recipe) return Astro.redirect('/dashboard/recipes');

const { data: mealPlan } = await db
  .from('meal_plans').select('*')
  .eq('recipe_id', id).eq('day_number', currentDay)
  .eq('plan_type', planType).maybeSingle();

const task        = mealPlan ? dailyTasks.find(t => t.task_type === mealPlan.meal_type) : null;
const isCompleted = task?.completed || false;
const canComplete = !!mealPlan && !isCompleted;

const { data: favRow } = await db
  .from('recipe_favorites').select('id')
  .eq('user_id', user.id).eq('recipe_id', recipe.id).maybeSingle();
const isFavorited = !!favRow;

const rawIngredients = recipe.ingredients  || [];
// Normalize to objects — DB stores either plain strings or {amount,unit,item} objects
const ingredients = rawIngredients.map((ing: any) =>
  typeof ing === 'string'
    ? { amount: '', unit: '', item: ing, isString: true }
    : { amount: ing.amount || '', unit: ing.unit || '', item: ing.item || '', isString: false }
);
const instructions = recipe.instructions || [];
const tips         = recipe.tips         || [];
const tags         = recipe.tags         || [];

// Similar recipes (same tags, excluding current)
const similarRaw = tags.length > 0
  ? await db.from('recipes').select('id, title, calories, net_carbs, protein, image_url, tags')
      .contains('tags', [tags[0]])
      .neq('id', recipe.id)
      .limit(4)
  : { data: [] };

const similarRecipes = similarRaw.data || [];

const mealType = mealPlan?.meal_type || tags[0] || 'other';
const categories = {
  breakfast: { name:'Breakfast', icon:'🍳', gradient:'linear-gradient(135deg,#f59e0b,#d97706)', glow:'rgba(245,158,11,.3)', accent:'#f59e0b' },
  lunch:     { name:'Lunch',     icon:'🥗', gradient:'linear-gradient(135deg,#10b981,#059669)', glow:'rgba(16,185,129,.3)', accent:'#10b981' },
  dinner:    { name:'Dinner',    icon:'🍽️', gradient:'linear-gradient(135deg,#3b82f6,#2563eb)', glow:'rgba(59,130,246,.3)', accent:'#3b82f6' },
  snack:     { name:'Snack',     icon:'🍎', gradient:'linear-gradient(135deg,#8b5cf6,#7c3aed)', glow:'rgba(139,92,246,.3)', accent:'#8b5cf6' },
  other:     { name:'Keto',      icon:'🥑', gradient:'linear-gradient(135deg,#10b981,#059669)', glow:'rgba(16,185,129,.3)', accent:'#10b981' },
};
const cat       = categories[mealType] || categories.other;
const totalTime = (recipe.prep_time || 0) + (recipe.cook_time || 0);
const diffColor = recipe.difficulty === 'Easy' ? '#10b981' : recipe.difficulty === 'Medium' ? '#f59e0b' : '#ef4444';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{recipe.title} — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,900;1,9..144,900&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&display=swap" rel="stylesheet"/>
  <script is:inline>(function(){ const t=localStorage.getItem('keto-theme')||'light'; document.documentElement.setAttribute('data-theme',t); })();</script>
  <style>
    :root{--bg:#060c08;--card:#0d1a0f;--card2:#122014;--surface:#0a1209;--border:rgba(16,185,129,.11);--border2:rgba(16,185,129,.24);--text:#e0ede0;--soft:#4e724e;--muted:#1e2e1e;--green:#10b981;--green2:#34d399;--gold:#f59e0b;--red:#ef4444;--blue:#3b82f6;--purple:#8b5cf6;}
    [data-theme="light"]{--bg:#ecf4ec;--card:#fff;--card2:#f2f8f2;--surface:#f8faf8;--border:rgba(0,0,0,.07);--border2:rgba(16,185,129,.25);--text:#071807;--soft:#3a6040;--muted:#b0cdb0;}
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;transition:background .3s,color .3s;}
    .bg-wrap{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;}
    .orb{position:absolute;border-radius:50%;filter:blur(120px);animation:drift ease-in-out infinite;}
    [data-theme="light"] .orb{opacity:.07;}
    .o1{width:700px;height:700px;background:rgba(16,185,129,.07);top:-200px;left:-200px;animation-duration:26s;opacity:.4;}
    .o2{width:500px;height:500px;background:rgba(245,158,11,.05);bottom:-150px;right:-150px;animation-duration:33s;animation-delay:-15s;opacity:.35;}
    @keyframes drift{0%,100%{transform:translate(0,0)scale(1);}40%{transform:translate(45px,-55px)scale(1.07);}70%{transform:translate(-38px,48px)scale(.93);}}
    nav{position:sticky;top:0;z-index:100;height:64px;background:rgba(6,12,8,.88);border-bottom:1px solid var(--border);backdrop-filter:blur(22px);}
    [data-theme="light"] nav{background:rgba(255,255,255,.92);}
    .nav-inner{max-width:1280px;margin:0 auto;padding:0 1.5rem;height:100%;display:flex;align-items:center;gap:.75rem;}
    .logo{font-family:'Fraunces',serif;font-weight:900;font-size:1.1rem;color:var(--text);text-decoration:none;flex-shrink:0;}
    .logo span{color:var(--green);}
    .nav-back{display:flex;align-items:center;gap:.4rem;padding:.4rem .9rem;border-radius:10px;font-size:.8rem;font-weight:700;color:var(--soft);text-decoration:none;background:var(--card);border:1px solid var(--border);transition:all .2s;}
    .nav-back:hover{border-color:var(--green);color:var(--green);}
    .nav-sp{flex:1;}
    .ibtn{width:36px;height:36px;border-radius:9px;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.88rem;transition:all .2s;}
    .ibtn:hover{border-color:var(--green);}
    .av{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--green),#059669);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:.82rem;color:#fff;text-decoration:none;}
    .page{position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:2rem 1.5rem 5rem;}
    .recipe-hero{border-radius:22px;overflow:hidden;margin-bottom:2rem;position:relative;background:var(--card);border:1px solid var(--border);animation:fadeUp .5s ease both;}
    .recipe-hero-img{width:100%;height:420px;object-fit:cover;display:block;transition:transform .4s ease;cursor:zoom-in;}
    .recipe-hero:hover .recipe-hero-img{transform:scale(1.02);}
    .hero-placeholder{height:420px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.75rem;}
    /* Photo Lightbox */
    .lightbox{position:fixed;inset:0;z-index:9000;background:rgba(0,0,0,.95);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .25s;}
    .lightbox.open{opacity:1;pointer-events:all;}
    .lightbox-img{max-width:100%;max-height:90vh;object-fit:contain;border-radius:12px;box-shadow:0 20px 60px rgba(0,0,0,.6);transform:scale(.94);transition:transform .25s;}
    .lightbox.open .lightbox-img{transform:scale(1);}
    .lightbox-close{position:absolute;top:1.25rem;right:1.25rem;width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.12);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#fff;backdrop-filter:blur(8px);transition:background .2s;}
    .lightbox-close:hover{background:rgba(255,255,255,.25);}
    .lightbox-hint{position:absolute;bottom:1.5rem;left:50%;transform:translateX(-50%);font-size:.72rem;color:rgba(255,255,255,.5);font-weight:600;letter-spacing:.05em;pointer-events:none;}
    /* Tap-to-expand hint on mobile */
    .hero-tap-hint{position:absolute;bottom:4.5rem;right:1rem;background:rgba(0,0,0,.5);color:rgba(255,255,255,.7);font-size:.68rem;font-weight:700;padding:.25rem .6rem;border-radius:99px;backdrop-filter:blur(8px);pointer-events:none;display:none;}
    @media(max-width:768px){
      .recipe-hero-img{height:260px;}
      .hero-placeholder{height:260px;}
      .hero-tap-hint{display:block;}
      .recipe-layout{gap:1rem;}
      .sc-head{padding:1rem 1.25rem;}
      .sc-body{padding:1rem 1.25rem;}
      .hero-content{padding:1.5rem;}
      .page{padding:1rem 1rem 5.5rem;}
    }
    .hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(6,12,8,.95) 0%,rgba(6,12,8,.45) 55%,transparent 100%);}
    [data-theme="light"] .hero-overlay{background:linear-gradient(to top,rgba(7,24,7,.88) 0%,rgba(7,24,7,.35) 55%,transparent 100%);}
    .hero-content{position:absolute;bottom:0;left:0;right:0;padding:2.5rem;}
    .hero-meta{display:flex;flex-wrap:wrap;gap:.55rem;margin-bottom:1rem;}
    .hero-pill{display:inline-flex;align-items:center;gap:.3rem;padding:.3rem .8rem;border-radius:99px;font-size:.73rem;font-weight:800;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:#fff;backdrop-filter:blur(10px);}
    .recipe-title{font-family:'Fraunces',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;color:#fff;line-height:1.1;margin-bottom:.6rem;text-shadow:0 4px 16px rgba(0,0,0,.5);}
    .recipe-desc{font-size:.9rem;color:rgba(255,255,255,.78);max-width:680px;line-height:1.65;}
    .done-ribbon{position:absolute;top:1.5rem;right:1.5rem;display:flex;align-items:center;gap:.4rem;padding:.4rem .9rem;border-radius:99px;background:rgba(16,185,129,.9);color:#fff;font-size:.78rem;font-weight:800;box-shadow:0 4px 14px rgba(16,185,129,.4);}
    .recipe-layout{display:grid;grid-template-columns:1fr 340px;gap:1.75rem;align-items:start;}
    @media(max-width:1024px){.recipe-layout{grid-template-columns:1fr;}}
    .sc{background:var(--card);border:1px solid var(--border);border-radius:20px;overflow:hidden;margin-bottom:1.5rem;transition:border-color .25s;animation:fadeUp .4s ease both;}
    .sc:hover{border-color:var(--border2);}
    .sc-head{display:flex;align-items:center;gap:.875rem;padding:1.4rem 1.75rem;border-bottom:1px solid var(--border);}
    .sc-ico{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;}
    .sc-title{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:700;}
    .sc-sub{font-size:.72rem;color:var(--soft);margin-top:.08rem;}
    .sc-body{padding:1.4rem 1.75rem;}
    .macros-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:.875rem;}
    @media(max-width:600px){.macros-grid{grid-template-columns:repeat(3,1fr);}}
    .macro-card{text-align:center;padding:1.2rem .75rem;border-radius:14px;border:1.5px solid;transition:all .25s;}
    .macro-card:hover{transform:translateY(-4px);}
    .macro-val{font-family:'Fraunces',serif;font-size:1.9rem;font-weight:900;line-height:1;display:block;margin-bottom:.25rem;}
    .macro-lbl{font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:.07em;}
    .ing-list{display:flex;flex-direction:column;gap:.5rem;}
    .ing-row{display:flex;align-items:center;gap:.875rem;padding:.875rem 1rem;border-radius:12px;background:var(--surface);border:1.5px solid transparent;transition:all .25s;cursor:pointer;user-select:none;}
    .ing-row:hover{border-color:rgba(16,185,129,.25);transform:translateX(4px);}
    .ing-row.checked{opacity:.45;}
    .ing-row.checked .ing-name{text-decoration:line-through;}
    .ing-num{width:28px;height:28px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;color:#fff;}
    .ing-amount{font-weight:800;font-size:.88rem;min-width:80px;flex-shrink:0;}
    .ing-name{font-size:.88rem;font-weight:600;flex:1;}
    .ing-chk{width:20px;height:20px;border-radius:6px;flex-shrink:0;border:2px solid rgba(16,185,129,.3);background:transparent;cursor:pointer;appearance:none;transition:all .2s;}
    .ing-chk:checked{background:var(--green);border-color:var(--green);}
    .ing-progress{margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid var(--border);}
    .ip-hd{display:flex;justify-content:space-between;margin-bottom:.4rem;font-size:.73rem;}
    .ip-lbl{font-weight:600;color:var(--soft);}
    .ip-val{font-weight:800;color:var(--green);}
    .ip-track{height:6px;background:var(--muted);border-radius:99px;overflow:hidden;}
    .ip-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--green),var(--green2));transition:width .4s ease;}
    .steps-list{display:flex;flex-direction:column;gap:1.1rem;}
    .step-row{display:flex;gap:1.1rem;padding:1.2rem;border-radius:14px;background:var(--surface);border:1.5px solid transparent;transition:all .25s;}
    .step-row:hover{border-color:rgba(59,130,246,.2);transform:translateX(4px);}
    .step-num{width:36px;height:36px;border-radius:10px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.88rem;font-weight:900;color:#fff;background:linear-gradient(135deg,var(--blue),#2563eb);box-shadow:0 4px 12px rgba(59,130,246,.3);}
    .step-text{font-size:.88rem;line-height:1.7;padding-top:.2rem;}
    .tips-list{display:flex;flex-direction:column;gap:.875rem;}
    .tip-row{display:flex;gap:.875rem;align-items:flex-start;padding:1rem 1.2rem;border-radius:12px;background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.15);transition:all .2s;}
    .tip-row:hover{background:rgba(245,158,11,.1);}
    .tip-ico{font-size:1.1rem;flex-shrink:0;margin-top:.1rem;}
    .tip-text{font-size:.85rem;line-height:1.65;color:var(--soft);}
    .sidebar{position:sticky;top:calc(64px + 1rem);}
    .side-card{background:var(--card);border:1px solid var(--border);border-radius:20px;overflow:hidden;margin-bottom:1.25rem;animation:fadeUp .4s .1s ease both;}
    .side-head{padding:1.1rem 1.4rem;border-bottom:1px solid var(--border);font-weight:800;font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;color:var(--soft);}
    .side-body{padding:1.2rem 1.4rem;}
    .task-box{background:linear-gradient(135deg,rgba(16,185,129,.1),rgba(52,211,153,.05));border:1.5px solid rgba(16,185,129,.25);border-radius:14px;padding:1.25rem;text-align:center;margin-bottom:.75rem;}
    .task-box-icon{font-size:2.2rem;margin-bottom:.4rem;}
    .task-box-title{font-family:'Fraunces',serif;font-size:1rem;font-weight:700;color:var(--green);margin-bottom:.2rem;}
    .task-box-sub{font-size:.78rem;color:var(--soft);}
    .time-grid{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin-bottom:.6rem;}
    .time-block{text-align:center;padding:1rem;border-radius:12px;background:var(--surface);border:1px solid var(--border);}
    .time-val{font-family:'Fraunces',serif;font-size:1.5rem;font-weight:900;line-height:1;margin-bottom:.2rem;}
    .time-lbl{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);}
    .time-total{display:flex;align-items:center;justify-content:space-between;padding:.875rem 1.2rem;border-radius:12px;font-weight:800;font-size:.9rem;color:#fff;}
    .detail-row{display:flex;align-items:center;justify-content:space-between;padding:.7rem 0;border-bottom:1px solid var(--border);}
    .detail-row:last-child{border:none;}
    .detail-lbl{font-size:.8rem;color:var(--soft);font-weight:600;}
    .detail-val{font-size:.8rem;font-weight:800;}
    .diff-pill{padding:.2rem .65rem;border-radius:99px;font-size:.7rem;font-weight:800;border:1px solid;}
    .tags-wrap{display:flex;flex-wrap:wrap;gap:.45rem;}
    .tag-pill{padding:.28rem .7rem;border-radius:99px;font-size:.7rem;font-weight:700;background:var(--surface);border:1px solid var(--border);color:var(--soft);transition:all .2s;}
    .tag-pill:hover{border-color:var(--green);color:var(--green);}
    .btn{display:flex;align-items:center;justify-content:center;gap:.5rem;width:100%;padding:.875rem;border-radius:13px;font-size:.875rem;font-weight:800;border:none;cursor:pointer;text-decoration:none;transition:all .25s;margin-bottom:.6rem;}
    .btn:last-child{margin-bottom:0;}
    .btn:hover{transform:translateY(-2px);}
    .btn-complete{background:linear-gradient(135deg,var(--green),var(--green2));color:#fff;box-shadow:0 4px 16px rgba(16,185,129,.35);}
    .btn-complete:hover{box-shadow:0 8px 24px rgba(16,185,129,.45);}
    .btn-outline{background:transparent;border:1px solid var(--border);color:var(--soft);}
    .btn-outline:hover{border-color:var(--green);color:var(--green);}
    .btn-green{background:linear-gradient(135deg,var(--green),var(--green2));color:#fff;box-shadow:0 4px 14px rgba(16,185,129,.3);}
    .btn-green:hover{box-shadow:0 8px 24px rgba(16,185,129,.4);}
    .btn-green:disabled{opacity:.6;cursor:not-allowed;transform:none;}
    .toast{position:fixed;top:5rem;right:1.5rem;z-index:9999;background:linear-gradient(135deg,var(--green),var(--green2));color:#fff;padding:.875rem 1.5rem;border-radius:12px;font-weight:700;font-size:.875rem;box-shadow:0 10px 30px rgba(16,185,129,.4);transform:translateY(-20px);opacity:0;pointer-events:none;transition:all .35s cubic-bezier(.4,0,.2,1);}
    .toast.show{transform:translateY(0);opacity:1;}
    /* ── Serving scaler ── */
    .serving-scaler{display:flex;flex-direction:column;align-items:flex-end;gap:.35rem;flex-shrink:0;}
    .scaler-label{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--soft);}
    .scaler-btns{display:flex;gap:.3rem;}
    .scaler-btn{
      padding:.28rem .6rem;border-radius:8px;font-size:.75rem;font-weight:800;
      border:1.5px solid var(--border);background:transparent;color:var(--soft);
      cursor:pointer;transition:all .2s;
    }
    .scaler-btn:hover{border-color:var(--border2);color:var(--text);}
    .scaler-btn.active{background:#ef4444;border-color:#ef4444;color:#fff;box-shadow:0 3px 8px rgba(239,68,68,.35);}
    @keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
    @media print{nav,.sidebar,.btn{display:none!important;}body{background:#fff!important;color:#000!important;}}
  </style>
</head>
<body>
<div class="bg-wrap"><div class="orb o1"></div><div class="orb o2"></div></div>
<DashNav userId={user.id} userName={userName} tierLabel={tierLabel} planType={planType} activePage="recipes" />
<div class="page">
  <div class="recipe-hero">
    {recipe.image_url
      ? <img src={recipe.image_url} alt={recipe.title} class="recipe-hero-img" loading="eager" width="800" height="420" onclick="window.openLightbox()" title="Tap to expand"/>
      : <div class="hero-placeholder" style={`background:${cat.gradient};`}>
          <span style="font-size:6rem;filter:drop-shadow(0 4px 16px rgba(0,0,0,.4));">{cat.icon}</span>
          <span style="font-size:.9rem;font-weight:700;color:rgba(255,255,255,.75);letter-spacing:.06em;text-transform:uppercase;">{cat.name}</span>
        </div>
    }
    <div class="hero-overlay"></div>
    {recipe.image_url && <div class="hero-tap-hint">🔍 Tap to expand</div>}
    {isCompleted && <div class="done-ribbon">✓ Completed Today</div>}
    <button
      id="favBtn"
      onclick="toggleFav(this)"
      data-recipe-id={recipe.id}
      data-favorited={isFavorited ? 'true' : 'false'}
      style={`position:absolute;top:1.5rem;left:1.5rem;width:40px;height:40px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.3rem;transition:all .25s;backdrop-filter:blur(10px);background:${isFavorited ? 'rgba(239,68,68,.85)' : 'rgba(255,255,255,.15)'};box-shadow:0 4px 14px rgba(0,0,0,.3);`}
      title={isFavorited ? 'Remove from favorites' : 'Add to favorites'}
    >{isFavorited ? '❤️' : '🤍'}</button>
    <div class="hero-content">
      <div class="hero-meta">
        <span class="hero-pill" style={`background:${cat.accent}25;border-color:${cat.accent}50;`}>{cat.icon} {cat.name}</span>
        <span class="hero-pill">⏱️ {totalTime} min</span>
        <span class="hero-pill">🍽️ {recipe.servings || 1} serving{(recipe.servings||1) > 1 ? 's' : ''}</span>
        {recipe.difficulty && <span class="hero-pill" style={`background:${diffColor}20;border-color:${diffColor}50;color:${diffColor};`}>{recipe.difficulty}</span>}
        {recipe.net_carbs && <span class="hero-pill" style="background:rgba(16,185,129,.2);border-color:rgba(16,185,129,.4);color:#34d399;">🥗 {recipe.net_carbs}g net carbs</span>}
      </div>
      <h1 class="recipe-title">{recipe.title}</h1>
      {recipe.description && <p class="recipe-desc">{recipe.description}</p>}
    </div>
  </div>

  <div class="recipe-layout">
    <div>
      <!-- NUTRITION -->
      <div class="sc" style="animation-delay:.04s;">
        <div class="sc-head">
          <div class="sc-ico" style="background:linear-gradient(135deg,#ef4444,#dc2626);box-shadow:0 4px 12px rgba(239,68,68,.3);">📊</div>
          <div style="flex:1;">
            <div class="sc-title">Nutrition Facts</div>
            <div class="sc-sub" id="nutritionServingLabel">Per serving · {recipe.servings || 1} serving{(recipe.servings||1) > 1 ? 's' : ''}</div>
          </div>
          <div class="serving-scaler">
            <span class="scaler-label">Servings</span>
            <div class="scaler-btns">
              <button class="scaler-btn" data-mult="0.5"  onclick="window.setMultiplier(0.5)">½×</button>
              <button class="scaler-btn active" data-mult="1" onclick="window.setMultiplier(1)">1×</button>
              <button class="scaler-btn" data-mult="1.5" onclick="window.setMultiplier(1.5)">1½×</button>
              <button class="scaler-btn" data-mult="2"   onclick="window.setMultiplier(2)">2×</button>
            </div>
          </div>
        </div>
        <div class="sc-body">
          <div class="macros-grid">
            <div class="macro-card" style="background:rgba(239,68,68,.1);border-color:#ef4444;color:#ef4444;">
              <span class="macro-val" id="macroCalories">{recipe.calories}</span>
              <span class="macro-lbl">Calories</span>
            </div>
            <div class="macro-card" style="background:rgba(59,130,246,.1);border-color:#3b82f6;color:#3b82f6;">
              <span class="macro-val" id="macroProtein">{recipe.protein}g</span>
              <span class="macro-lbl">Protein</span>
            </div>
            <div class="macro-card" style="background:rgba(245,158,11,.1);border-color:#f59e0b;color:#f59e0b;">
              <span class="macro-val" id="macroFat">{recipe.fat}g</span>
              <span class="macro-lbl">Fat</span>
            </div>
            <div class="macro-card" style="background:rgba(16,185,129,.1);border-color:#10b981;color:#10b981;">
              <span class="macro-val" id="macroCarbs">{recipe.net_carbs}g</span>
              <span class="macro-lbl">Net Carbs</span>
            </div>
            <div class="macro-card" style="background:rgba(139,92,246,.1);border-color:#8b5cf6;color:#8b5cf6;">
              <span class="macro-val" id="macroFiber">{recipe.fiber}g</span>
              <span class="macro-lbl">Fiber</span>
            </div>
          </div>
        </div>
      </div>

      <!-- INGREDIENTS -->
      <div class="sc" style="animation-delay:.08s;">
        <div class="sc-head">
          <div class="sc-ico" style="background:linear-gradient(135deg,var(--green),var(--green2));box-shadow:0 4px 12px rgba(16,185,129,.3);">🛒</div>
          <div style="flex:1;"><div class="sc-title">Ingredients</div><div class="sc-sub">{ingredients.length} items · tap to check off</div></div>
          <span id="ingCount" style="font-size:.72rem;font-weight:700;padding:.2rem .6rem;border-radius:99px;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.2);color:var(--green);">0 / {ingredients.length}</span>
        </div>
        <div class="sc-body">
          <div class="ing-list">
            {ingredients.map((ing, i) => (
              <div class="ing-row" onclick={`toggleIng(${i})`} id={`ing-${i}`}>
                <div class="ing-num" style={`background:${cat.gradient};box-shadow:0 3px 8px ${cat.glow};`}>{i+1}</div>
                {!ing.isString && <span class="ing-amount">{ing.amount} {ing.unit}</span>}
                <span class="ing-name">{ing.item}</span>
                <input type="checkbox" class="ing-chk" id={`ingc-${i}`} onclick="event.stopPropagation();"/>
              </div>
            ))}
          </div>
          <div class="ing-progress">
            <div class="ip-hd"><span class="ip-lbl">Ingredients prepared</span><span class="ip-val" id="ingPct">0%</span></div>
            <div class="ip-track"><div class="ip-fill" id="ingBar" style="width:0%"></div></div>
          </div>
        </div>
      </div>

      <!-- INSTRUCTIONS -->
      <div class="sc" style="animation-delay:.12s;">
        <div class="sc-head">
          <div class="sc-ico" style="background:linear-gradient(135deg,var(--blue),#2563eb);box-shadow:0 4px 12px rgba(59,130,246,.3);">👨‍🍳</div>
          <div><div class="sc-title">Instructions</div><div class="sc-sub">{instructions.length} steps</div></div>
        </div>
        <div class="sc-body">
          <div class="steps-list">
            {instructions.map((step, i) => (
              <div class="step-row">
                <div class="step-num">{i+1}</div>
                <div class="step-text">{typeof step === 'string' ? step : step.instruction || step.text || ''}</div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- TIPS -->
      {tips.length > 0 && (
        <div class="sc" style="animation-delay:.16s;">
          <div class="sc-head">
            <div class="sc-ico" style="background:linear-gradient(135deg,var(--gold),#d97706);box-shadow:0 4px 12px rgba(245,158,11,.3);">💡</div>
            <div><div class="sc-title">Pro Tips</div><div class="sc-sub">{tips.length} chef secrets</div></div>
          </div>
          <div class="sc-body">
            <div class="tips-list">
              {tips.map(tip => (
                <div class="tip-row">
                  <span class="tip-ico">✨</span>
                  <p class="tip-text">{typeof tip === 'string' ? tip : tip.text || ''}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">
      {canComplete && (
        <div class="side-card">
          <div class="side-head">Today's Task · Day {currentDay}</div>
          <div class="side-body">
            <p style="font-size:.8rem;color:var(--soft);margin-bottom:1rem;line-height:1.55;">Your <strong style="color:var(--text);">{mealPlan.meal_type}</strong> for today. Mark done to earn XP!</p>
            <button class="btn btn-complete" id="completeBtn">✓ Mark as Completed</button>
          </div>
        </div>
      )}
      {isCompleted && (
        <div class="side-card">
          <div class="side-body">
            <div class="task-box">
              <div class="task-box-icon">🎉</div>
              <div class="task-box-title">Completed!</div>
              <div class="task-box-sub">+{task?.xp_earned || 25} XP earned today</div>
            </div>
          </div>
        </div>
      )}
      <div class="side-card">
        <div class="side-head">Time Required</div>
        <div class="side-body">
          <div class="time-grid">
            <div class="time-block"><div class="time-val" style="color:var(--blue);">{recipe.prep_time||0}</div><div class="time-lbl">Prep min</div></div>
            <div class="time-block"><div class="time-val" style="color:var(--gold);">{recipe.cook_time||0}</div><div class="time-lbl">Cook min</div></div>
          </div>
          <div class="time-total" style={`background:${cat.gradient};box-shadow:0 4px 14px ${cat.glow};`}>
            <span>⏱️ Total</span>
            <span style="font-family:'Fraunces',serif;font-size:1.2rem;">{totalTime} min</span>
          </div>
        </div>
      </div>
      <div class="side-card">
        <div class="side-head">Details</div>
        <div class="side-body">
          <div class="detail-row"><span class="detail-lbl">Calories</span><span id="sideCalories" class="detail-val" style="color:var(--red);">{recipe.calories} kcal</span></div>
          <div class="detail-row"><span class="detail-lbl">Net Carbs</span><span id="sideCarbs" class="detail-val" style="color:var(--green);">{recipe.net_carbs}g</span></div>
          <div class="detail-row"><span class="detail-lbl">Protein</span><span id="sideProtein" class="detail-val" style="color:var(--blue);">{recipe.protein}g</span></div>
          <div class="detail-row"><span class="detail-lbl">Fat</span><span id="sideFat" class="detail-val" style="color:var(--gold);">{recipe.fat}g</span></div>
          {recipe.difficulty && <div class="detail-row"><span class="detail-lbl">Difficulty</span><span class="diff-pill" style={`background:${diffColor}15;border-color:${diffColor}40;color:${diffColor};`}>{recipe.difficulty}</span></div>}
          <div class="detail-row"><span class="detail-lbl">Servings</span><span id="sideServings" class="detail-val">{recipe.servings||1}</span></div>
        </div>
      </div>
      {tags.length > 0 && (
        <div class="side-card">
          <div class="side-head">Tags</div>
          <div class="side-body"><div class="tags-wrap">{tags.map(tag => <span class="tag-pill">#{tag}</span>)}</div></div>
        </div>
      )}
      <div class="side-card">
        <div class="side-head">Actions</div>
        <div class="side-body">
          <button id="foodLogBtn" onclick="window.logToFoodLog()" class="btn btn-green" style="width:100%;">📋 Add to Food Log</button>
          <button onclick="window.openColPicker()" class="btn btn-outline" style="width:100%;">📚 Save to Collection</button>
          <button onclick="window.openMealPlanPicker()" class="btn btn-outline" style="width:100%;">📅 Add to Meal Plan</button>
          <a href="/dashboard" class="btn btn-outline">🏠 Dashboard</a>
          <a href="/dashboard/recipes" class="btn btn-outline">📚 All Recipes</a>
          <button onclick="window.print()" class="btn btn-outline">🖨️ Print Recipe</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- You might also like -->
{similarRecipes.length > 0 && (
  <div style="max-width:1200px;margin:0 auto 3rem;padding:0 1.5rem;">
    <h2 style="font-family:'Fraunces',serif;font-size:1.15rem;font-weight:900;margin-bottom:1rem;color:var(--text);">
      You might also like
      <span style="font-size:.72rem;font-weight:600;color:var(--soft);font-family:'DM Sans',sans-serif;margin-left:.5rem;">similar recipes</span>
    </h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;">
      {similarRecipes.map((r: any) => (
        <a href={`/dashboard/recipe/${r.id}`} style="text-decoration:none;">
          <div style="background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;transition:all .2s;" onmouseenter="this.style.transform='translateY(-3px)';this.style.borderColor='rgba(16,185,129,.3)'" onmouseleave="this.style.transform='';this.style.borderColor=''">
            {r.image_url && <img src={r.image_url} alt={r.title} style="width:100%;aspect-ratio:4/3;object-fit:cover;" loading="lazy"/>}
            <div style="padding:.75rem;">
              <div style="font-weight:700;font-size:.82rem;color:var(--text);margin-bottom:.3rem;line-height:1.3;">{r.title}</div>
              <div style="display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;">
                <span style="font-size:.68rem;font-weight:700;padding:.1rem .4rem;border-radius:5px;background:rgba(239,68,68,.1);color:#ef4444;">{r.net_carbs}g C</span>
                <span style="font-size:.68rem;font-weight:700;padding:.1rem .4rem;border-radius:5px;background:rgba(16,185,129,.1);color:var(--green);">{r.calories} cal</span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
)}

<!-- Photo Lightbox -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Recipe photo" onclick="window.closeLightbox()">
  <button class="lightbox-close" onclick="window.closeLightbox()" aria-label="Close">✕</button>
  <img id="lightboxImg" class="lightbox-img" src="" alt="" onclick="event.stopPropagation()"/>
  <div class="lightbox-hint">Tap outside or press Esc to close</div>
</div>

<div class="toast" id="toast"></div>
<script is:inline define:vars={{ taskId: task?.id || null, mealPlanType: mealPlan?.meal_type || null, dayNum: currentDay, xpEarned: task?.xp_earned || 25, totalIng: ingredients.length, recipeTitle: recipe.title, recipeCal: recipe.calories || 0, recipeProtein: recipe.protein || 0, recipeFat: recipe.fat || 0, recipeCarbs: recipe.net_carbs || 0, recipeFiber: recipe.fiber || 0, recipeServings: recipe.servings || 1, recipeId: recipe.id, heroImgSrc: recipe.image_url || '' }}>
window.__recipeId = recipeId;

// ── Serving size scaler ──────────────────────────────────────────
var scalerMult = 1;
function round1(v) { return Math.round(v * 10) / 10; }

window.setMultiplier = function(mult) {
  scalerMult = mult;

  // Update macro cards
  document.getElementById('macroCalories').textContent = Math.round(recipeCal * mult);
  document.getElementById('macroProtein').textContent  = round1(recipeProtein * mult) + 'g';
  document.getElementById('macroFat').textContent      = round1(recipeFat     * mult) + 'g';
  document.getElementById('macroCarbs').textContent    = round1(recipeCarbs   * mult) + 'g';
  document.getElementById('macroFiber').textContent    = round1(recipeFiber   * mult) + 'g';

  // Update sidebar detail rows
  var sideEl = document.getElementById('sideCalories');
  if (sideEl) sideEl.textContent = Math.round(recipeCal * mult) + ' kcal';
  var sideC = document.getElementById('sideCarbs');
  if (sideC) sideC.textContent = round1(recipeCarbs * mult) + 'g';
  var sideP = document.getElementById('sideProtein');
  if (sideP) sideP.textContent = round1(recipeProtein * mult) + 'g';
  var sideF = document.getElementById('sideFat');
  if (sideF) sideF.textContent = round1(recipeFat * mult) + 'g';
  var sideS = document.getElementById('sideServings');
  if (sideS) sideS.textContent = round1(recipeServings * mult);

  // Update serving label
  var lbl = document.getElementById('nutritionServingLabel');
  var servCount = round1(recipeServings * mult);
  if (lbl) lbl.textContent = 'Per ' + mult + '× serving · ' + servCount + ' serving' + (servCount === 1 ? '' : 's');

  // Highlight active button
  document.querySelectorAll('.scaler-btn').forEach(function(btn) {
    btn.classList.toggle('active', parseFloat(btn.dataset.mult) === mult);
  });
};

var checked=0;
function updateIng(){
  const pct=totalIng>0?Math.round((checked/totalIng)*100):0;
  const bar=document.getElementById('ingBar');
  const pEl=document.getElementById('ingPct');
  const cEl=document.getElementById('ingCount');
  if(bar)bar.style.width=pct+'%';
  if(pEl)pEl.textContent=pct+'%';
  if(cEl)cEl.textContent=checked+' / '+totalIng;
  if(checked===totalIng&&totalIng>0)showToast('🎉 All ingredients ready! Time to cook!');
}
function toggleIng(i){
  const row=document.getElementById('ing-'+i);
  const cb=document.getElementById('ingc-'+i);
  if(!row||!cb)return;
  cb.checked=!cb.checked;
  if(cb.checked){row.classList.add('checked');checked++;}
  else{row.classList.remove('checked');checked--;}
  updateIng();
}
window.toggleIng=toggleIng;

const completeBtn=document.getElementById('completeBtn');
if(completeBtn&&taskId){
  completeBtn.addEventListener('click',async()=>{
    completeBtn.disabled=true;
    completeBtn.textContent='⏳ Saving...';
    try{
      const res=await fetch('/api/tasks/complete',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({task_id:taskId,task_type:mealPlanType,day_number:dayNum})});
      if(res.ok){showToast('🎉 Completed! +'+xpEarned+' XP earned!');setTimeout(()=>window.location.reload(),1500);}
      else{completeBtn.disabled=false;completeBtn.textContent='✓ Mark as Completed';showToast('❌ Something went wrong.');}
    }catch(e){completeBtn.disabled=false;completeBtn.textContent='✓ Mark as Completed';showToast('❌ Connection error.');}
  });
}

function showToast(msg){const t=document.getElementById('toast');if(!t)return;t.textContent=msg;t.className='toast show';setTimeout(()=>t.classList.remove('show'),3000);}

window.logToFoodLog = async function() {
  var btn = document.getElementById('foodLogBtn');
  if (btn) { btn.disabled=true; btn.textContent='⏳ Logging…'; }
  var suffix = scalerMult !== 1 ? ' (' + scalerMult + '× serving)' : '';
  try {
    var res = await fetch('/api/food-log/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        food_name:  recipeTitle + suffix,
        calories:   Math.round(recipeCal     * scalerMult),
        protein_g:  round1(recipeProtein * scalerMult),
        fat_g:      round1(recipeFat     * scalerMult),
        carbs_g:    round1(recipeCarbs   * scalerMult),
        meal_type:  mealPlanType || 'other',
        notes:      'Added from recipe #' + recipeId,
      }),
    });
    var data = await res.json();
    if (res.ok && data.success) {
      showToast('📋 Added to food log!');
      if (btn) { btn.textContent='✅ Logged!'; btn.style.background='rgba(16,185,129,.2)'; }
    } else {
      showToast('❌ ' + (data.error || 'Could not add to food log'));
      if (btn) { btn.disabled=false; btn.textContent='📋 Add to Food Log'; }
    }
  } catch(e) {
    showToast('❌ Connection error');
    if (btn) { btn.disabled=false; btn.textContent='📋 Add to Food Log'; }
  }
};

/* ── Photo Lightbox ── */
window.openLightbox = function() {
  if (!heroImgSrc) return;
  var lb = document.getElementById('lightbox');
  var img = document.getElementById('lightboxImg');
  if (!lb || !img) return;
  img.src = heroImgSrc;
  img.alt = recipeTitle;
  lb.classList.add('open');
  document.body.style.overflow = 'hidden';
};
window.closeLightbox = function() {
  var lb = document.getElementById('lightbox');
  if (!lb) return;
  lb.classList.remove('open');
  document.body.style.overflow = '';
};
// Keyboard close
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') window.closeLightbox();
});
// Touch swipe-down to close lightbox
(function() {
  var lb = document.getElementById('lightbox');
  if (!lb) return;
  var startY = 0;
  lb.addEventListener('touchstart', function(e) { startY = e.touches[0].clientY; }, { passive: true });
  lb.addEventListener('touchend', function(e) {
    var dy = e.changedTouches[0].clientY - startY;
    if (dy > 80) window.closeLightbox();
  }, { passive: true });
})();

window.toggleFav = function toggleFav(btn) {
  var recipeId  = btn.getAttribute('data-recipe-id');
  var favorited = btn.getAttribute('data-favorited') === 'true';
  btn.style.transform = 'scale(1.3)';
  setTimeout(function() { btn.style.transform = 'scale(1)'; }, 200);
  fetch('/api/recipes/favorite', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ recipeId: recipeId }),
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (typeof data.favorited !== 'undefined') {
      btn.setAttribute('data-favorited', data.favorited ? 'true' : 'false');
      btn.textContent = data.favorited ? '❤️' : '🤍';
      btn.style.background = data.favorited ? 'rgba(239,68,68,.85)' : 'rgba(255,255,255,.15)';
      showToast(data.favorited ? '❤️ Added to favorites!' : '🤍 Removed from favorites');
    }
  })
  .catch(function() { showToast('❌ Could not update favorite'); });
};

// ── MEAL PLAN PICKER ──
var mpSelectedMeal = 'breakfast';

window.openMealPlanPicker = function() {
  // Set today as default date
  var today = new Date().toISOString().slice(0, 10);
  document.getElementById('mpDate').value = today;
  document.getElementById('mealPlanModal').classList.add('show');
};
window.closeMealPlanPicker = function() {
  document.getElementById('mealPlanModal').classList.remove('show');
};

document.getElementById('mpMealBtns').addEventListener('click', function(e) {
  var btn = e.target.closest('.mp-meal-btn');
  if (!btn) return;
  mpSelectedMeal = btn.dataset.meal;
  document.querySelectorAll('.mp-meal-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
});

window.saveMealPlan = function() {
  var planDate = document.getElementById('mpDate').value;
  if (!planDate) { document.getElementById('mpDate').focus(); return; }
  var btn = document.getElementById('mpSaveBtn');
  btn.disabled = true; btn.textContent = 'Adding…';

  fetch('/api/meal-planner', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ plan_date: planDate, meal_type: mpSelectedMeal, recipe_id: window._recipeId }),
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    btn.disabled = false; btn.textContent = 'Add to Plan';
    if (data.error) { showToast('❌ ' + data.error); return; }
    window.closeMealPlanPicker();
    showToast('📅 Added to meal plan');
  })
  .catch(function() { btn.disabled = false; btn.textContent = 'Add to Plan'; showToast('❌ Connection error'); });
};

// ── SAVE TO COLLECTION ──
var colPickerOpen = false;

window.openColPicker = function() {
  var modal = document.getElementById('colPickerModal');
  if (!modal) return;
  modal.classList.add('show');
  colPickerOpen = true;
  // Load collections
  var list = document.getElementById('colPickerList');
  list.innerHTML = '<div style="color:var(--soft);font-size:.85rem;padding:.5rem 0;">Loading…</div>';
  fetch('/api/collections')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var cols = data.collections || [];
      if (cols.length === 0) {
        list.innerHTML = '<div style="color:var(--soft);font-size:.85rem;padding:.5rem 0;">No collections yet. <a href="/dashboard/collections" style="color:var(--green);">Create one</a>.</div>';
        return;
      }
      list.innerHTML = '';
      cols.forEach(function(col) {
        var btn = document.createElement('button');
        btn.className = 'col-pick-btn';
        btn.innerHTML = '<span>' + col.emoji + '</span><span style="flex:1;text-align:left;">' + col.name + '</span><span style="font-size:.75rem;color:var(--soft);">' + col.count + ' recipes</span>';
        btn.onclick = function() { window.saveToCol(col.id, col.name); };
        list.appendChild(btn);
      });
    })
    .catch(function() {
      list.innerHTML = '<div style="color:var(--soft);font-size:.85rem;">Could not load collections.</div>';
    });
};

window.closeColPicker = function() {
  var modal = document.getElementById('colPickerModal');
  if (modal) modal.classList.remove('show');
  colPickerOpen = false;
};

// recipeId comes from define:vars
window._recipeId = recipeId;

window.saveToCol = function(colId, colName) {
  fetch('/api/collections/items', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ collectionId: colId, recipeId: window._recipeId }),
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    window.closeColPicker();
    if (data.error) { showToast('❌ ' + data.error); return; }
    showToast('📚 Saved to "' + colName + '"');
  })
  .catch(function() { showToast('❌ Could not save'); });
};

</script>

<!-- Meal Plan Picker Modal -->
<div id="mealPlanModal" role="dialog" aria-modal="true" aria-label="Add to Meal Plan" style="position:fixed;inset:0;z-index:9200;background:rgba(6,13,9,.82);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;pointer-events:none;transition:opacity .2s;" onclick="if(event.target===this)window.closeMealPlanPicker()">
