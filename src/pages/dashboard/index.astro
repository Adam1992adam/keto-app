/* ── LEVEL-UP PAGE LOAD DETECTION ── */
(function checkLevelUp() {
  var KEY = 'keto_last_level';
  var stored = parseInt(localStorage.getItem(KEY) || '0', 10);
  var current = xpLevel;

  // Always keep stored in sync
  localStorage.setItem(KEY, String(current));

  // First ever visit — don't celebrate
  if (!stored || stored <= 0) return;

  // Level increased since last visit
  if (current > stored) {
    var diff = current - stored;
    setTimeout(function() { showLevelUpModal(current, diff); }, 600);
  }
})();

function showLevelUpModal(newLvl, levelsGained) {
  var modal = document.getElementById('levelUpModal');
  if (!modal) return;

  var lvlEl   = document.getElementById('lumLevel');
  var titleEl = document.getElementById('lumTitle');
  var subEl   = document.getElementById('lumSub');
  var rewardEl= document.getElementById('lumReward');

  if (lvlEl) lvlEl.textContent = String(newLvl);

  var titles = ['Keto Beginner','Keto Learner','Fat Burner','Keto Warrior','Ketosis Master','Keto Champion','Elite Keto','Keto Legend','Keto Immortal','Grand Keto'];
  var title  = titles[Math.min(Math.floor((newLvl - 1) / 2), titles.length - 1)];
  if (titleEl) titleEl.textContent = levelsGained > 1 ? ('+' + levelsGained + ' Levels!') : 'Level Up!';
  if (subEl)   subEl.textContent   = 'You reached Level ' + newLvl + ' — ' + title;

  // Milestone rewards at every 5 levels
  var rewards = {
    5:  'Unlocked: Streak Shield (1 grace day per month)',
    10: 'Unlocked: Bonus Recipe Pack',
    15: 'Unlocked: Custom Goal Settings',
    20: 'Unlocked: VIP Community Badge',
    25: 'Unlocked: Personal AI Coach session',
  };
  var milestone = Math.floor(newLvl / 5) * 5;
  if (rewardEl) {
    if (rewards[milestone] && newLvl % 5 === 0) {
      rewardEl.textContent = rewards[milestone];
      rewardEl.style.display = 'block';
    } else {
      rewardEl.style.display = 'none';
    }
  }

  modal.style.display = 'flex';

  // Auto-dismiss after 6s
  var autoClose = setTimeout(function() { closeLevelUpModal(); }, 6000);
  modal._autoClose = autoClose;

  // Spawn confetti bursts
  spawnConfetti();
}

function closeLevelUpModal() {
  var modal = document.getElementById('levelUpModal');
  if (!modal) return;
  if (modal._autoClose) clearTimeout(modal._autoClose);
  modal.style.opacity = '0';
  modal.style.transform = 'scale(.95)';
  setTimeout(function() {
    modal.style.display = 'none';
    modal.style.opacity = '';
    modal.style.transform = '';
  }, 280);
}

function spawnConfetti() {
  var colors = ['#f59e0b','#fcd34d','#10b981','#34d399','#8b5cf6','#a78bfa','#f87171','#60a5fa'];
  for (var i = 0; i < 30; i++) {
    (function(idx) {
      setTimeout(function() {
        var c = document.createElement('div');
        var color = colors[idx % colors.length];
        var startX = 20 + Math.random() * 60; // % across screen
        var size   = 6 + Math.random() * 8;
        var dur    = 1.2 + Math.random() * 1.4;
        var delay  = Math.random() * 0.4;
        c.style.cssText = [
          'position:fixed;top:-10px;left:' + startX + '%;',
          'width:' + size + 'px;height:' + size + 'px;',
          'background:' + color + ';border-radius:' + (Math.random() > 0.5 ? '50%' : '2px') + ';',
          'pointer-events:none;z-index:9998;',
          'animation:confettiFall ' + dur + 's ' + delay + 's ease-in forwards;',
          '--rx:' + (Math.random() * 720 - 360) + 'deg;',
          '--tx:' + (Math.random() * 100 - 50) + 'px;',
        ].join('');
        document.body.appendChild(c);
        setTimeout(function() { c.remove(); }, (dur + delay + 0.2) * 1000);
      }, idx * 30);
    })(i);
  }
}

// Inject confetti keyframes once
if (!document.getElementById('lumStyle')) {
  var lumS = document.createElement('style');
  lumS.id = 'lumStyle';
  lumS.textContent = [
    '@keyframes confettiFall{0%{opacity:1;transform:translateY(0) translateX(0) rotate(0)}',
    '100%{opacity:0;transform:translateY(110vh) translateX(var(--tx)) rotate(var(--rx))}}',
    '@keyframes lumPop{0%{opacity:0;transform:scale(.7) translateY(20px)}',
    '70%{transform:scale(1.05) translateY(-4px)}',
    '100%{opacity:1;transform:scale(1) translateY(0)}}',
    '@keyframes lumRing{0%{transform:scale(1)}50%{transform:scale(1.12)}100%{transform:scale(1)}}',
  ].join('');
  document.head.appendChild(lumS);
}

/* ── WEIGHT LOG WIDGET ── */
window.logWeight = function logWeight() {
  var weightInput = document.getElementById('wlWeightInput');
  var dateInput   = document.getElementById('wlDateInput');
  var btn         = document.getElementById('wlBtn');
  var confirm     = document.getElementById('wlConfirm');
  var currentVal  = document.getElementById('wlCurrentVal');

  if (!weightInput || !dateInput) return;

  var weightDisp  = parseFloat(weightInput.value);
  var logged_date = dateInput.value;

  if (!weightDisp || weightDisp <= 0) {
    weightInput.focus();
    return;
  }
  if (!logged_date) {
    dateInput.focus();
    return;
  }

  // Convert to kg for storage
  var weightKg = units === 'imperial'
    ? Math.round((weightDisp / 2.20462) * 10) / 10
    : weightDisp;

  btn.disabled    = true;
  btn.textContent = 'Logging…';

  fetch('/api/profile/add-weight', {
    method:  'POST',
    headers: { 'Content-Type': 'application/json' },
    body:    JSON.stringify({ weight: weightKg, logged_date: logged_date }),
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    btn.disabled    = false;
    btn.textContent = 'Log Weight';
    if (data.success) {
      if (currentVal) currentVal.textContent = weightDisp.toFixed(1);
      confirm.style.display = 'block';
      setTimeout(function() { confirm.style.display = 'none'; }, 3000);
      showToast('Weight logged — ' + weightDisp + ' ' + wUnit);
    } else {
      showToast(data.error || 'Failed to log weight');
    }
  })
  .catch(function() {
    btn.disabled    = false;
    btn.textContent = 'Log Weight';
    showToast('Connection error');
  });
};

window.dashToggleHabit = function(habitId, el) {
  var done = el.style.background.includes('185,129');
  fetch('/api/habits/toggle', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ habit_id: habitId, date: new Date().toISOString().split('T')[0] }),
  }).then(function(r){ return r.json(); }).then(function(d){
    if (d.success) {
      if (d.completed) {
        el.style.background = 'rgba(16,185,129,.08)';
        el.style.borderColor = 'rgba(16,185,129,.25)';
        var lbl = el.querySelector('span:nth-child(2)');
        var chk = el.querySelector('span:last-child');
        if (lbl) { lbl.style.textDecoration = 'line-through'; lbl.style.color = 'var(--soft)'; }
        if (chk) { chk.textContent = '✓'; chk.style.color = 'var(--green)'; }
      } else {
        el.style.background = 'var(--card2)';
        el.style.borderColor = 'var(--border)';
        var lbl2 = el.querySelector('span:nth-child(2)');
        var chk2 = el.querySelector('span:last-child');
        if (lbl2) { lbl2.style.textDecoration = 'none'; lbl2.style.color = ''; }
        if (chk2) { chk2.textContent = '○'; chk2.style.color = 'var(--muted)'; }
      }
    }
  });
};
</script>
