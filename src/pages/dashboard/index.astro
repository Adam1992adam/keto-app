   WEIGHT SPARKLINE — ApexCharts area chart
   ───────────────────────────────────────────────────────────── */
(function initWeightChart() {
  const el = document.getElementById('weightSparkline');
  if (!el) return;

  // Read weight data embedded by Astro server
  const raw = (window as any).__weightData as Array<{w: number; d: string}> | undefined;
  if (!raw || raw.length < 2) return;

  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  const green  = getComputedStyle(document.documentElement).getPropertyValue('--green').trim() || '#16a34a';
  const soft   = getComputedStyle(document.documentElement).getPropertyValue('--soft').trim()  || '#64748b';

  const opts = {
    chart: {
      type: 'area',
      height: 110,
      sparkline: { enabled: true },
      animations: {
        enabled: true,
        easing: 'easeinout',
        speed: 900,
        animateGradually: { enabled: true, delay: 80 },
      },
      background: 'transparent',
    },
    series: [{ name: 'Weight', data: raw.map(p => p.w) }],
    xaxis:  { categories: raw.map(p => p.d) },
    stroke: { curve: 'smooth', width: 2.5, colors: ['#10b981'] },
    fill: {
      type: 'gradient',
      gradient: {
        shadeIntensity: 1,
        opacityFrom: 0.35,
        opacityTo: 0.02,
        stops: [0, 100],
        colorStops: [
          { offset: 0,   color: '#10b981', opacity: 0.3 },
          { offset: 100, color: '#10b981', opacity: 0   },
        ],
      },
    },
    markers: {
      size: [3, 3, 3, 3, 3, 3, 3, 5],
      colors: ['#10b981'],
      strokeColors: isDark ? '#0d1a0f' : '#ffffff',
      strokeWidth: 2,
      hover: { size: 7 },
    },
    tooltip: {
      theme: isDark ? 'dark' : 'light',
      x: { show: true },
      y: { formatter: (v: number) => v + ' ' + ((window as any).__wUnit || 'kg') },
    },
    grid: { show: false },
    theme: { mode: isDark ? 'dark' : 'light' },
  };

  const chart = new ApexCharts(el, opts);
  chart.render();

  // Re-render on theme toggle
  document.getElementById('dnThemeBtn')?.addEventListener('click', () => {
    setTimeout(() => {
      const dark = document.documentElement.getAttribute('data-theme') === 'dark';
      chart.updateOptions({ theme: { mode: dark ? 'dark' : 'light' }, tooltip: { theme: dark ? 'dark' : 'light' } });
    }, 50);
  });
})();

/* ─────────────────────────────────────────────────────────────
   GSAP — staggered card reveals + number counters
   ───────────────────────────────────────────────────────────── */
(function initGSAP() {
  // Stagger stat cards
  gsap.from('.stat-card', {
    y: 22, opacity: 0, duration: 0.55,
    stagger: 0.08,
    ease: 'back.out(1.4)',
    clearProps: 'transform,opacity',
  });

  // Stagger quick action buttons
  gsap.from('.qa-btn', {
    y: 16, opacity: 0, duration: 0.45,
    stagger: 0.05,
    ease: 'back.out(1.6)',
    delay: 0.25,
    clearProps: 'transform,opacity',
  });

  // Number counter for stat values
  function countUp(selector: string, end: number, decimals = 0, prefix = '', suffix = '') {
    const el = document.querySelector(selector) as HTMLElement;
    if (!el || !end) return;
    gsap.from({ val: 0 }, {
      val: end, duration: 1.4,
      ease: 'power2.out',
      delay: 0.3,
      onUpdate: function() {
        el.textContent = prefix + this.targets()[0].val.toFixed(decimals) + suffix;
      },
    });
  }

  // Animate XP level display
  const xpEl = document.getElementById('xpLevelDisplay');
  if (xpEl) {
    const lvl = parseInt(xpEl.textContent?.replace('Lv.', '') || '1');
    gsap.from({ v: 1 }, {
      v: lvl, duration: 1.2, ease: 'power2.out', delay: 0.5,
      onUpdate: function() {
        xpEl.textContent = 'Lv.' + Math.round(this.targets()[0].v);
      },
    });
  }

  // Animate streak number
  const streakEl = document.querySelector('.stat-card:nth-child(2) .stat-val') as HTMLElement;
  if (streakEl) {
    const val = parseInt(streakEl.textContent || '0');
    if (val > 0) {
      gsap.from({ v: 0 }, {
        v: val, duration: 1.1, ease: 'power2.out', delay: 0.35,
        onUpdate: function() { streakEl.textContent = String(Math.round(this.targets()[0].v)); },
      });
    }
  }

  // Animate current day number
  const dayEl = document.querySelector('.stat-card:nth-child(4) .stat-val') as HTMLElement;
  if (dayEl) {
    const val = parseInt(dayEl.textContent || '0');
    if (val > 1) {
      gsap.from({ v: 1 }, {
        v: val, duration: 1.0, ease: 'power2.out', delay: 0.42,
        onUpdate: function() { dayEl.textContent = String(Math.round(this.targets()[0].v)); },
      });
    }
  }

  // Animate sidebar cards on scroll into view (IntersectionObserver)
  const cards = document.querySelectorAll('.card');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        gsap.from(entry.target, {
          y: 14, opacity: 0, duration: 0.4, ease: 'power2.out',
          clearProps: 'transform,opacity',
        });
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  cards.forEach(c => observer.observe(c));
})();
</script>

<!-- Embed weight data for ApexCharts (server → client) -->
<script is:inline define:vars={{ weightLogsForChart: (weightLogs || []).map((w: any) => ({ w: w.weight, d: w.logged_date?.slice(5) || '' })).reverse(), wUnitForChart: (profile.preferred_units === 'imperial' ? 'lbs' : 'kg') }}>
window.__weightData = weightLogsForChart;
window.__wUnit      = wUnitForChart;
</script>

<AppTour userName={userName} />
