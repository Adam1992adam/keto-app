---
// src/pages/dashboard/index.astro
import { getUserJourney, getMaxJourneyDays, getMealCycleDays } from '../../lib/supabase';
import { requireAuth } from '../../lib/auth';
import { getTranslator, normaliseLang } from '../../lib/i18n';
import { generateInsights } from '../../lib/insights';
import DashNav from '../../components/DashNav.astro';
import Sidebar from '../../components/Sidebar.astro';
import UpsellModal from '../../components/UpsellModal.astro';
// ── Lucide icons ──────────────────────────────────────────
import Scale         from 'lucide-astro/Scale';
import Flame         from 'lucide-astro/Flame';
import Zap           from 'lucide-astro/Zap';
import CalendarDays  from 'lucide-astro/CalendarDays';
import ClipboardCheck from 'lucide-astro/ClipboardCheck';
import Timer         from 'lucide-astro/Timer';
import BarChart3     from 'lucide-astro/BarChart3';
import Compass       from 'lucide-astro/Compass';
import TrendingUp    from 'lucide-astro/TrendingUp';
import ShoppingCart  from 'lucide-astro/ShoppingCart';
import CheckCircle2  from 'lucide-astro/CheckCircle2';
import Utensils      from 'lucide-astro/Utensils';
import Droplets      from 'lucide-astro/Droplets';
import Pill          from 'lucide-astro/Pill';
import Target        from 'lucide-astro/Target';
import Activity      from 'lucide-astro/Activity';
import LineChart     from 'lucide-astro/LineChart';
import Info          from 'lucide-astro/Info';
import Moon         from 'lucide-astro/Moon';
import AppTour      from '../../components/AppTour.astro';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);

const planType  = profile.subscription_tier || 'basic_30';
const maxDays   = getMaxJourneyDays(planType);
const tierLabel = planType === 'elite_12' ? 'Elite' : planType === 'pro_6' ? 'Pro' : 'Basic';

// ── Batch 1: onboarding + journey in parallel (critical — graceful error on DB failure) ──
let onboarding = null as any;
let journey = null as any;
try {
  const [ob, j] = await Promise.all([
    db.from('onboarding_data').select('*').eq('user_id', user.id).maybeSingle(),
    getUserJourney(user.id, db),
  ]);
  onboarding = ob.data;
  journey = j;
} catch (e) {
  console.error('[Dashboard] DB unavailable (batch 1):', e);
  return new Response(
    `<!DOCTYPE html><html><head><title>Temporarily Unavailable</title><meta http-equiv="refresh" content="15;url=/dashboard"></head><body style="background:#FAF6F1;color:#16110F;font-family:'DM Sans',sans-serif;display:flex;align-items:center;justify-content:center;height:100vh;margin:0;flex-direction:column;gap:1.2rem;text-align:center;padding:2rem"><h2 style="font-size:1.6rem;margin:0;color:#FF5C7A">Keto Journey</h2><p style="font-size:1.1rem;margin:0">Dashboard is temporarily unavailable</p><p style="color:#8A8077;margin:0;font-size:.9rem">Retrying automatically in 15 seconds…</p><a href="/dashboard" style="color:#FF5C7A;font-size:.9rem;margin-top:.5rem">Retry now</a></body></html>`,
    { status: 503, headers: { 'Content-Type': 'text/html' } }
  );
}
if (!onboarding) return Astro.redirect('/dashboard/onboarding');

const currentDay    = journey?.current_day    || 1;
const currentWeek   = Math.ceil(currentDay / 7);
const totalXP       = journey?.total_xp       || 0;
const xpLevel       = journey?.level          || 1;
const streakDays    = journey?.streak_days    || 0;
const streakShields = (journey as any)?.streak_shields    ?? 1;
const shieldLastUsed = (journey as any)?.shield_last_used ?? null;
const today         = new Date().toISOString().split('T')[0];
const twoWeeksAgo = new Date(Date.now() - 14 * 86400000).toISOString().split('T')[0];

const mealCycleDays = getMealCycleDays(planType);
const mealDayTarget = ((currentDay - 1) % mealCycleDays) + 1;

// ── Batch 2: all remaining queries fire in parallel ──
let batch2 = new Array(14).fill({ data: null });
try {
  batch2 = await Promise.all([
  db.from('daily_tasks').select('id, task_title, task_type, completed, xp_earned')
    .eq('user_id', user.id).eq('day_number', currentDay).order('created_at'),
  db.from('daily_tasks').select('id, task_title, task_type, completed, xp_earned')
    .eq('user_id', user.id).eq('day_number', 1).order('created_at'),
  db.from('daily_checkins').select('*')
    .eq('user_id', user.id).eq('checkin_date', today).maybeSingle(),
  db.from('weight_logs').select('weight, logged_date')
    .eq('user_id', user.id).order('logged_date', { ascending: false }).limit(8),
  db.from('fasting_sessions').select('*').eq('user_id', user.id)
    .is('ended_at', null).order('started_at', { ascending: false }).limit(1).maybeSingle(),
  db.from('daily_checkins').select('checkin_date, energy_level, followed_meals, water_glasses')
    .eq('user_id', user.id).order('checkin_date', { ascending: false }).limit(7),
  db.from('weekly_reports').select('id')
    .eq('user_id', user.id).eq('week_number', currentWeek).maybeSingle(),
  db.from('meal_plans')
    .select('*, recipe:recipes(id, title, calories, protein, fat, net_carbs, image_url, prep_time, cook_time, tags)')
    .eq('plan_type', planType).eq('day_number', mealDayTarget).order('meal_type'),
  db.from('meal_swaps').select('original_recipe_id')
    .eq('user_id', user.id).gte('swap_date', twoWeeksAgo),
  db.from('meal_completions').select('meal_type, recipe_id')
    .eq('user_id', user.id).eq('day_number', currentDay),
  db.from('macro_goals').select('daily_calories, protein_g, fat_g, carbs_g')
    .eq('user_id', user.id).maybeSingle(),
  db.from('food_logs').select('*')
    .eq('user_id', user.id).eq('logged_date', today).order('created_at', { ascending: true }),
  db.from('habits').select('id, title, icon, category')
    .eq('user_id', user.id).eq('is_active', true).order('sort_order').order('created_at').limit(6),
  db.from('habit_completions').select('habit_id')
    .eq('user_id', user.id).eq('completed_date', today),
  db.from('step_logs').select('steps, goal')
    .eq('user_id', user.id).eq('logged_date', today).maybeSingle(),
  ]);
} catch (e) {
  console.error('[Dashboard] DB unavailable (batch 2):', e);
}

const [
  { data: rawTasksCurrent },
  { data: rawTasksDay1 },
  { data: todayCheckin },
  { data: weightLogs },
  { data: activeFast },
  { data: recentCheckins },
  { data: weekReport },
  { data: rawMealsDirect },
  { data: recentSwaps },
  { data: mealCompletions },
  { data: macroGoals },
  { data: foodLogs },
  { data: habitsRaw },
  { data: habitDoneRaw },
  { data: todayStepLog },
] = batch2;

const todaySteps   = (todayStepLog as any)?.steps || 0;
const stepsGoal    = (todayStepLog as any)?.goal  || 10000;
const stepsPct     = Math.min(100, Math.round((todaySteps / stepsGoal) * 100));

const [rawMeals, smartInsights] = await Promise.all([
  (rawMealsDirect && rawMealsDirect.length > 0)
    ? Promise.resolve(rawMealsDirect)
    : db.from('meal_plans')
        .select('*, recipe:recipes(id, title, calories, protein, fat, net_carbs, image_url, prep_time, cook_time, tags)')
        .eq('plan_type', 'basic_30').eq('day_number', mealDayTarget).order('meal_type')
        .then(({ data }: any) => data || []),
  generateInsights(user.id, db, currentDay, streakDays).catch(() => []),
]);

const usingFallback  = !(rawTasksCurrent && rawTasksCurrent.length > 0);
const tasks          = !usingFallback ? rawTasksCurrent : (rawTasksDay1 || []);
const totalTasks     = tasks.length;
const completedTasks = tasks.filter((t) => t.completed).length;
const taskPct        = totalTasks > 0 ? Math.round((completedTasks / totalTasks) * 100) : 0;

const restrictions = onboarding?.dietary_restrictions || [];
const userGoal     = onboarding?.goal || 'weight_loss';
const rejectedIds = recentSwaps?.map((s) => s.original_recipe_id) || [];
const avgEnergy   = recentCheckins?.length
  ? recentCheckins.reduce((s, c) => s + (c.energy_level || 3), 0) / recentCheckins.length : 3;

const filteredMealTypes = new Set();
const allTodayMeals = (rawMeals || []).filter((meal) => {
  const recipe = meal.recipe;
  if (!recipe) return true;
  const tags  = recipe.tags || [];
  const title = (recipe.title || '').toLowerCase();
  if (restrictions.includes('no_pork') && ['bacon','ham','prosciutto','chorizo','sausage','pork'].some(w => title.includes(w))) {
    filteredMealTypes.add(meal.meal_type);
    return false;
  }
  if (restrictions.includes('vegetarian') && ['chicken','beef','steak','lamb','duck','salmon','tuna','shrimp','cod','fish'].some(w => title.includes(w))) {
    filteredMealTypes.add(meal.meal_type);
    return false;
  }
  if (restrictions.includes('no_seafood') && ['salmon','tuna','shrimp','cod','fish'].some(w => title.includes(w))) {
    filteredMealTypes.add(meal.meal_type);
    return false;
  }
  return true;
});

const todayMeals = allTodayMeals.map((meal) => {
  const r   = meal.recipe;
  const mt0 = meal.meal_type;
  meal.icon = mt0;
  meal.slot_adapted = restrictions.length > 0 && filteredMealTypes.has(mt0);
  if (!r) { meal.is_adapted = false; meal.adapt_reason = ''; return meal; }
  const totalTime  = (r.prep_time || 0) + (r.cook_time || 0);
  const adaptReason = (
    rejectedIds.includes(r.id)                          ? 'Previously swapped' :
    (avgEnergy < 2.5 && totalTime > 20 && meal.meal_type !== 'snack') ? 'Try something quicker' : ''
  );
  meal.is_adapted   = !!adaptReason;
  meal.adapt_reason = adaptReason;
  return meal;
});
const adaptedCount = todayMeals.filter((m) => m.is_adapted || m.slot_adapted).length;

const cycleNum  = Math.floor((currentDay - 1) / mealCycleDays);
const cycleWeek = Math.ceil(((((currentDay - 1) % mealCycleDays) + 1)) / 7);

const totalCalToday     = todayMeals.reduce((s, m) => s + (m.recipe?.calories || 0), 0);
const totalProteinToday = todayMeals.reduce((s, m) => s + parseFloat(m.recipe?.protein || '0'), 0);

const completedMealTypesArr = (mealCompletions || []).map((c: any) => c.meal_type);
const completedMealSet = new Set(completedMealTypesArr);

const consumedMacros = todayMeals
  .filter((m: any) => completedMealSet.has(m.meal_type) && m.recipe)
  .reduce((acc: any, m: any) => ({
    calories:  acc.calories  + (m.recipe.calories  || 0),
    protein:   acc.protein   + parseFloat(m.recipe.protein   || '0'),
    fat:       acc.fat       + parseFloat(m.recipe.fat       || '0'),
    net_carbs: acc.net_carbs + parseFloat(m.recipe.net_carbs || '0'),
  }), { calories: 0, protein: 0, fat: 0, net_carbs: 0 });

const goalCal  = macroGoals?.daily_calories || 1800;
const goalProt = macroGoals?.protein_g      || 120;
const goalFat  = macroGoals?.fat_g          || 120;
const goalCarb = macroGoals?.carbs_g        || 25;

const todayFoodLogs = foodLogs || [];
const foodLogMacros = todayFoodLogs.reduce((acc, f) => ({
  calories:  acc.calories  + (f.calories  || 0),
  protein:   acc.protein   + parseFloat(f.protein_g || '0'),
  fat:       acc.fat       + parseFloat(f.fat_g     || '0'),
  net_carbs: acc.net_carbs + parseFloat(f.carbs_g   || '0'),
}), { calories: 0, protein: 0, fat: 0, net_carbs: 0 });

const totalConsumed = {
  calories:  consumedMacros.calories  + foodLogMacros.calories,
  protein:   consumedMacros.protein   + foodLogMacros.protein,
  fat:       consumedMacros.fat       + foodLogMacros.fat,
  net_carbs: consumedMacros.net_carbs + foodLogMacros.net_carbs,
};
const calPct   = Math.min(100, Math.round((totalConsumed.calories  / goalCal)  * 100));
const protPct  = Math.min(100, Math.round((totalConsumed.protein   / goalProt) * 100));
const fatPct   = Math.min(100, Math.round((totalConsumed.fat       / goalFat)  * 100));
const carbPct  = Math.min(100, Math.round((totalConsumed.net_carbs / goalCarb) * 100));

// Weights are stored in kg everywhere. If a value looks like lbs (>200kg is unrealistic),
// it was stored without conversion — divide by 2.20462 to normalize.
const _rawStart    = onboarding?.current_weight || profile.weight_kg || 0;
const startWeight  = _rawStart > 250 ? Math.round((_rawStart / 2.20462) * 10) / 10 : _rawStart;
const latestWeight = weightLogs?.[0]?.weight    || startWeight;
const weightLost   = Math.max(0, startWeight - latestWeight);
const _rawTarget   = onboarding?.target_weight  || profile.target_weight_kg || 0;
const targetWeight = _rawTarget > 250 ? Math.round((_rawTarget / 2.20462) * 10) / 10 : _rawTarget;
const progressPct  = (targetWeight && startWeight > targetWeight)
  ? Math.min(100, Math.round((weightLost / (startWeight - targetWeight)) * 100)) : 0;

const xpInLevel  = totalXP % 500;
const xpPct      = Math.round((xpInLevel / 500) * 100);
const journeyPct = Math.min(100, Math.round((currentDay / maxDays) * 100));
const daysLeft   = Math.max(0, maxDays - currentDay);
const streakPct  = Math.min(100, Math.round((streakDays / 30) * 100));
const userName   = profile.full_name?.split(' ')[0] || 'there';
const hour      = new Date().getHours();
const greeting  = hour < 12 ? t('dash.good_morning') : hour < 17 ? t('dash.good_afternoon') : t('dash.good_evening');
const greetIcon = '';
const daysToGo   = Math.max(0, maxDays - currentDay);
const xpDisplay  = totalXP >= 1000 ? (totalXP / 1000).toFixed(1) + 'k' : String(totalXP);

const units       = (profile.preferred_units as string) || 'imperial';
const wUnit       = units === 'imperial' ? 'lbs' : 'kg';
const dispLatest  = latestWeight ? (units === 'imperial' ? Math.round(latestWeight * 2.20462 * 10) / 10 : Math.round(latestWeight * 10) / 10) : 0;
const dispWeightLost = units === 'imperial'
  ? Math.round(weightLost * 2.20462 * 10) / 10
  : Math.round(weightLost * 10) / 10;
const weekNum    = currentWeek;
const streak     = streakDays;
const level      = xpLevel;
const levelTitles = ['Keto Beginner','Keto Learner','Fat Burner','Keto Warrior','Ketosis Master','Keto Champion','Elite Keto','Keto Legend','Keto Immortal','Grand Keto'];
const levelTitle  = levelTitles[Math.min(Math.floor((xpLevel - 1) / 2), levelTitles.length - 1)];
const xpToNext    = 500 - xpInLevel;

const checkinDone    = !!todayCheckin;
const weeklyDone     = !!weekReport;
const fastingActive  = !!activeFast;
const weightLogToday = weightLogs?.[0]?.logged_date === today;
const waterGlasses   = (todayCheckin as any)?.water_glasses || 0;
const waterPct       = Math.min(100, Math.round((waterGlasses / 8) * 100));

const _rawSmartPct = usingFallback
  ? Math.min(100, (checkinDone ? 40 : 0) + (fastingActive ? 20 : 0) + (completedTasks > 0 ? 40 : 0))
  : taskPct;
const smartTaskPct = Number.isFinite(_rawSmartPct) ? Math.max(0, Math.min(100, _rawSmartPct)) : 0;

const weekPhase    = currentDay <= 7 ? 'adapt' : (currentDay <= 14 ? 'burn' : 'thrive');
const progressMsg  = smartTaskPct === 0 ? 'Start your day!' : (smartTaskPct < 50 ? 'Keep going!' : (smartTaskPct < 100 ? 'Almost there!' : 'Perfect day!'));
const streakDotMax = Math.min(streakDays + 3, 14);

const isDay1 = currentDay === 1;
const goalLabelMap: Record<string, string> = {
  lose_weight:  'Lose weight steadily',
  lose_fast:    'Lose weight fast',
  maintain:     'Maintain weight',
  build_muscle: 'Build muscle',
  energy:       'Boost energy',
  health:       'Improve overall health',
};
const d1GoalLabel = goalLabelMap[onboarding?.goal || ''] || 'Reach your goal';
const d1PlanLabel = planType === 'elite_12' ? `Elite ${maxDays}-Day Plan` : planType === 'pro_6' ? `Pro 90-Day Plan` : 'Basic 30-Day Plan';
const d1Meals = todayMeals.slice(0, 3).map((m: any) => ({
  type:     (m.meal_type || '').charAt(0).toUpperCase() + (m.meal_type || '').slice(1),
  title:    m.recipe?.title || 'Meal plan loading…',
  calories: m.recipe?.calories || 0,
  protein:  Math.round(parseFloat(m.recipe?.protein || '0')),
}));
const d1Tasks = tasks.slice(0, 5).map((t: any) => ({ title: t.task_title || t.task_type || 'Task' }));

const milestoneInterval = planType === 'basic_30' ? 7 : 30;
const milestoneCount = Math.floor(maxDays / milestoneInterval);
const journeyMilestones = Array.from({ length: milestoneCount }, (_, i) => {
  const d = (i + 1) * milestoneInterval;
  return { day: d, pct: Math.round((d / maxDays) * 100), reached: currentDay >= d };
});

const mealTypeConfig = {
  breakfast: { label: 'Breakfast', color: '#b45309', bg: 'linear-gradient(135deg,#92400e,#b45309)' },
  lunch:     { label: 'Lunch',     color: '#059669', bg: 'linear-gradient(135deg,#065f46,#059669)' },
  dinner:    { label: 'Dinner',    color: '#7c3aed', bg: 'linear-gradient(135deg,#3730a3,#6d28d9)' },
  snack:     { label: 'Snack',     color: '#0284c7', bg: 'linear-gradient(135deg,#0c4a6e,#0369a1)' },
};

const fastingData = activeFast ? {
  started_at:   activeFast.started_at,
  target_hours: activeFast.target_hours || 16,
  protocol:     activeFast.protocol || 'IF',
} : null;

const recentAvgEnergy = recentCheckins?.length
  ? recentCheckins.reduce((s, c) => s + (c.energy_level || 3), 0) / recentCheckins.length : 3;

const week1Tips = [
  { icon:'<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>', color:'#f59e0b', title:'Salt is your best friend this week', body:'Your kidneys dump sodium on keto. Add ½ tsp of salt to a glass of water each morning. This alone fixes most keto flu symptoms within hours.' },
  { icon:'<path d="M12 2C12 2 5 10 5 15a7 7 0 0014 0c0-5-7-13-7-13z"/>', color:'#3b82f6', title:'Drink before you feel thirsty', body:'On keto, thirst response lags behind. Aim for 2.5–3L of water per day. Set phone reminders if needed — dehydration causes false hunger cravings.' },
  { icon:'<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>', color:'#10b981', title:'Fat doesn\'t make you fat on keto', body:'The old "dietary fat = body fat" myth is wrong. On keto, dietary fat is your primary fuel. Eating fat turns OFF fat storage hormones and keeps you satiated for hours.' },
  { icon:'<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>', color:'#ef4444', title:'Keto flu is temporary — push through', body:'Headaches, fatigue, and brain fog in days 1–5 are normal. Your brain is switching fuel sources. Electrolytes + hydration + sleep will cut this phase short.' },
  { icon:'<path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>', color:'#8b5cf6', title:'Your brain runs on ketones now', body:'The brain is 25% of your energy budget. It\'s learning to use ketones instead of glucose. By week 2, most people report sharper mental clarity than they\'ve had in years.' },
  { icon:'<path d="M3 11l19-9-9 19-2-8-8-2z"/>', color:'#10b981', title:'Protein protects your muscle', body:'Aim for 1.2–1.7g of protein per kg of bodyweight per day. Too little = muscle loss. Too much = gluconeogenesis. For a 75kg person: 90–130g protein/day.' },
  { icon:'<path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>', color:'#8b5cf6', title:'Sleep is a keto superpower', body:'During sleep, growth hormone surges and fat burning peaks. Poor sleep raises cortisol → raises blood sugar → kicks you out of ketosis. Protect your sleep this week.' },
];

const week2Tips = [
  { icon:'<path d="M12 2c0 0-5 4.5-5 9a5 5 0 0010 0c0-4.5-5-9-5-9zm0 14a3 3 0 01-3-3c0-2 2-4.5 3-6 1 1.5 3 4 3 6a3 3 0 01-3 3z"/>', color:'#f97316', title:'You\'re building fat-burning machinery', body:'Week 2 is when your mitochondria start multiplying and fat-oxidation enzymes upregulate. Energy will stabilize. The keto flu is behind you — the real benefits are ahead.' },
  { icon:'<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>', color:'#3b82f6', title:'Scale stall? That\'s normal.', body:'After week 1\'s water loss, the scale often stalls for 3–5 days. Your body is adapting internally. Waist circumference is shrinking even when weight doesn\'t move. Keep going.' },
  { icon:'<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>', color:'#10b981', title:'You can exercise now — but go easy', body:'Light weights and walking are perfect this week. High-intensity training is best saved for week 4+ when fat adaptation is complete. Your muscles are still learning.' },
  { icon:'<path d="M3 11l19-9-9 19-2-8-8-2z"/>', color:'#f59e0b', title:'Meal prep is the #1 habit', body:'People who succeed on keto have one thing in common: they cook in batches. Spend 90 minutes on Sunday preparing proteins and vegetables. It removes daily willpower decisions.' },
];

const week3Tips = [
  { icon:'<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>', color:'#10b981', title:'You\'ve entered fat-adaptation', body:'By week 3, your fat-burning enzymes are maximized. Energy is stable all day. This is why keto feels so different from calorie restriction — you\'re running on a clean, abundant fuel.' },
  { icon:'<path d="M3 11l19-9-9 19-2-8-8-2z"/>', color:'#f59e0b', title:'Try combining keto + intermittent fasting', body:'Now that you\'re adapted, 16:8 fasting is effortless. Skip breakfast, eat noon–8pm. The synergy between keto and IF burns fat at a rate neither achieves alone.' },
  { icon:'<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>', color:'#8b5cf6', title:'Your inflammation is dropping', body:'Ketones are anti-inflammatory. By week 3, many people notice less joint pain, better skin, reduced bloating, and clearer sinuses. This is your body healing systemically.' },
];

const tipPool = weekPhase === 'adapt' ? week1Tips : (weekPhase === 'burn' ? week2Tips : week3Tips);
const dashHabits = habitsRaw || [];
const habitDoneIds = new Set((habitDoneRaw || []).map((h: any) => h.habit_id));
const habitsDoneCount = dashHabits.filter(h => habitDoneIds.has(h.id)).length;

const dailyTip = (() => {
  if (!checkinDone && currentDay > 1)
    return { icon:'<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>', color:'#10b981', title:'Complete your daily check-in', body:'Tracking energy, mood, and water takes 60 seconds but gives you weeks of insight. Your streak depends on it — don\'t break it today!' };
  if (waterGlasses === 0 && currentDay > 1)
    return { icon:'<path d="M12 2C12 2 5 10 5 15a7 7 0 0014 0c0-5-7-13-7-13z"/>', color:'#3b82f6', title:'Start drinking water now', body:'You haven\'t logged any water today. Keto demands more hydration than a standard diet. Low water = false hunger, headaches, and reduced fat burning. Drink a glass right now.' };
  if (recentAvgEnergy < 2.5 && recentCheckins && recentCheckins.length >= 3)
    return { icon:'<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>', color:'#f59e0b', title:'Low energy? Check your electrolytes', body:'3+ days of low energy usually means electrolyte deficiency, not a keto problem. Add sodium, potassium (avocado), and magnesium glycinate at bedtime. Results are felt within 24 hours.' };
  if (streakDays >= 7)
    return { icon:'<path d="M12 2c0 0-5 4.5-5 9a5 5 0 0010 0c0-4.5-5-9-5-9zm0 14a3 3 0 01-3-3c0-2 2-4.5 3-6 1 1.5 3 4 3 6a3 3 0 01-3 3z"/>', color:'#f97316', title:`${streakDays}-day streak — you're on fire!`, body:'Consistency is the #1 predictor of long-term keto success. Your body is adapting more deeply every day you stay on track. Each day now compounds the results of every day before it.' };
  if (fastingActive)
    return { icon:'<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>', color:'#8b5cf6', title:'Fasting + keto: the ultimate combo', body:'While you fast, your already-low glycogen burns away in hours instead of days. You\'ll reach deep fat-burning mode today faster than any non-keto faster. Stay strong — the hardest part is hour 10–14.' };
  return tipPool[(currentDay - 1) % tipPool.length];
})();

const lastCheckinDate = recentCheckins?.[0]?.checkin_date;
const daysSinceCheckin = lastCheckinDate
  ? Math.floor((new Date(today).getTime() - new Date(lastCheckinDate).getTime()) / 86400000)
  : currentDay > 1 ? 99 : 0;
const isLapsed    = daysSinceCheckin >= 1 && currentDay > 1;
const lapseLevel  = daysSinceCheckin >= 4 ? 'critical' : daysSinceCheckin >= 2 ? 'warning' : 'gentle';
const lapseTips: Record<string, { icon: string; title: string; body: string; color: string; bg: string; border: string }> = {
  gentle:   { icon: '💛', color: '#f59e0b', bg: 'rgba(245,158,11,.09)', border: 'rgba(245,158,11,.28)',
    title: 'You missed yesterday — no problem!',
    body: 'Missing one day doesn\'t break your keto progress. Your body is still adapting. Check in today to restart your streak and get back on track.' },
  warning:  { icon: '🔁', color: '#f87171', bg: 'rgba(239,68,68,.09)', border: 'rgba(239,68,68,.28)',
    title: `${daysSinceCheckin} days without a check-in`,
    body: 'Your streak has reset, but your keto adaptation isn\'t lost — the fat-burning pathways you built remain. A single check-in today gets you back on the board.' },
  critical: { icon: '🚀', color: '#8b5cf6', bg: 'rgba(139,92,246,.09)', border: 'rgba(139,92,246,.28)',
    title: 'Welcome back! Let\'s restart strong.',
    body: `It's been ${daysSinceCheckin} days. Life happens. The best keto journeys aren't perfect — they're persistent. Take 2 minutes to check in today and your streak starts fresh.` },
};
const lapseBanner = isLapsed ? lapseTips[lapseLevel] : null;

const shieldCooldownClear = !shieldLastUsed ||
  new Date(today).getTime() - new Date(shieldLastUsed).getTime() > 2 * 86400000;
const shieldUsable = lapseLevel === 'gentle' && streakShields > 0 && shieldCooldownClear && streakDays > 0;

const pendingTasks   = totalTasks - completedTasks;
const focusIconKey   = !checkinDone ? 'checkin' : (pendingTasks > 0 ? 'tasks' : 'done');
const focusCTA = checkinDone && pendingTasks === 0 && weeklyDone
  ? { label: "You're all caught up today!", sub: 'Great consistency — keep the streak alive', href: null,
      color: '#10b981', bg: 'rgba(16,185,129,.12)', border: 'rgba(16,185,129,.28)', btnLabel: 'View Progress', btnHref: '/dashboard/progress' }
  : !checkinDone
  ? { label: t('dash.checkin_now') + ' — protect your streak', sub: `${streakDays > 0 ? `${streakDays}-day ${t('dash.streak_at_risk')}` : 'Start your streak today'} · Earn 30 XP`,
      href: '/dashboard/checkin', color: '#f59e0b', bg: 'rgba(245,158,11,.1)', border: 'rgba(245,158,11,.3)', btnLabel: 'Check In Now →', btnHref: '/dashboard/checkin' }
  : pendingTasks > 0
  ? { label: `Complete today's tasks`, sub: `${completedTasks}/${totalTasks} tasks done · ${pendingTasks} remaining`,
      href: '#tour-tasks', color: '#3b82f6', bg: 'rgba(59,130,246,.1)', border: 'rgba(59,130,246,.28)', btnLabel: 'View Tasks →', btnHref: '#tour-tasks' }
  : { label: "Log your weight to track progress", sub: 'Weight tracking shows your true results',
      href: '#weight-card', color: '#10b981', bg: 'rgba(16,185,129,.1)', border: 'rgba(16,185,129,.25)', btnLabel: 'Log Weight →', btnHref: '#weight-card' };

// ── Rose Vital template data ──────────────────────────────
const wLogsArr = (weightLogs || []).slice(0, 8).reverse();
const wVals = wLogsArr.map(l => units === 'imperial' ? Math.round((l.weight || 0) * 2.20462 * 10) / 10 : Math.round((l.weight || 0) * 10) / 10);
const wMin = wVals.length > 1 ? Math.min(...wVals) * 0.99 : 0;
const wMax = wVals.length > 1 ? Math.max(...wVals) * 1.01 : 10;
const wRange = Math.max(wMax - wMin, 0.1);
const wChartH = 72;
const wChartW = 400;
const wPoints = wVals.map((v, i) => [
  Math.round((i / Math.max(wVals.length - 1, 1)) * wChartW * 10) / 10,
  Math.round((wChartH - ((v - wMin) / wRange) * wChartH * 0.85 + wChartH * 0.075) * 10) / 10,
]);
const wLinePath = wPoints.map((p, i) => (i === 0 ? 'M' : 'L') + p[0] + ',' + p[1]).join(' ');
const wAreaPath = wPoints.length >= 2 ? wLinePath + ' L' + wPoints[wPoints.length - 1][0] + ',' + wChartH + ' L' + wPoints[0][0] + ',' + wChartH + ' Z' : '';
const hasWeightChart = wVals.length >= 2;
const wDotsStr = wPoints.map(p => `<circle cx="${p[0]}" cy="${p[1]}" r="3.5" fill="var(--rv-accent)"/>`).join('');
const wSvgStr = hasWeightChart
  ? `<svg viewBox="0 0 ${wChartW} ${wChartH}" preserveAspectRatio="none" class="rv-weight-svg"><defs><linearGradient id="wg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="var(--rv-accent)" stop-opacity="0.22"/><stop offset="100%" stop-color="var(--rv-accent)" stop-opacity="0"/></linearGradient></defs>${wAreaPath ? '<path d="' + wAreaPath + '" fill="url(#wg)"/>' : ''}<path d="${wLinePath}" fill="none" stroke="var(--rv-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>${wDotsStr}</svg>`
  : '';

const rotdMeal = todayMeals.find(m => m.recipe) || null;
const rotd = rotdMeal?.recipe || null;
const targetWeightDisp = targetWeight ? (units === 'imperial' ? Math.round(targetWeight * 2.20462 * 10) / 10 : Math.round(targetWeight * 10) / 10) : 0;
const waterFillArr = Array.from({length: 8}, (_, i) => i < waterGlasses);
const todayDateStr = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const isElite = planType === 'elite_12';
const mealsForClient = todayMeals.map(m => ({
  mt: m.meal_type || '',
  title: m.recipe?.title || '',
  cal: m.recipe?.calories || 0,
  img: m.recipe?.image_url || '',
  rid: m.recipe?.id || null,
}));
const habitsForClient = dashHabits.map(h => ({ id: h.id, title: h.title, icon: h.icon || '' }));
const doneHabitsForClient = (habitDoneRaw || []).map(h => h.habit_id);
const tipSvgStr = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="${dailyTip.color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${dailyTip.icon}</svg>`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard — Keto Journey</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/icon-72.png"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet"/>
</head>
<body>
<DashNav userId={user.id} userName={userName} tierLabel={tierLabel} planType={planType} activePage="dashboard" />
<UpsellModal />
<AppTour />

<style is:global>
  body, body[data-theme="light"] {
    background: var(--rv-bg, #FAF6F1) !important;
    color: var(--rv-ink, #16110F) !important;
  }
  .dash-nav { display: none !important; }
  #dn-footer { display: none !important; }
  .rv-page-wrap { padding-top: 0 !important; }
</style>

<!-- ════════════════════════════ APP SHELL ════════════════════════════ -->
<div class="rv-shell">

  <Sidebar userName={userName} planType={planType} tierLabel={tierLabel} currentDay={currentDay} activePage="dashboard" />

  <!-- ── Main content ───────────────────────────────────────────────── -->
  <div class="rv-main">

    <!-- TopBar -->
    <header class="rv-topbar">
      <div class="rv-top-l">
        <p class="rv-top-greet">{greeting}, <em>{userName}</em></p>
        <p class="rv-top-meta">DAY {currentDay} · KETO · {todayDateStr}</p>
      </div>
      <div class="rv-top-r">
        <a href="/dashboard/notifications" class="rv-top-icon" aria-label="Notifications">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        </a>
        <a href="/dashboard/food-log" class="rv-top-cta">+ Quick log</a>
      </div>
    </header>

    <!-- Lapse Banner -->
    {lapseBanner && (
      <div class="rv-lapse" style={`background:${lapseBanner.bg};border-color:${lapseBanner.border}`}>
        <span class="rv-lapse-emoji">{lapseBanner.icon}</span>
        <div class="rv-lapse-text">
          <strong style={`color:${lapseBanner.color}`}>{lapseBanner.title}</strong>
          <span>{lapseBanner.body}</span>
        </div>
        <a href="/dashboard/checkin" class="rv-lapse-btn" style={`background:${lapseBanner.color}`}>Check in now</a>
      </div>
    )}

    <!-- ═══════════════ BENTO GRID ═══════════════ -->
    <div class="rv-grid">

      <!-- 1 · HeroToday ─────────────────────────────────────── span 12 -->
      <div class="rv-card rv-hero">
        <div class="rv-hero-glow"></div>
        <div class="rv-hero-left">
          <div class="rv-hero-eyebrow">
            <span class="rv-pulse"></span>
            DAY {currentDay} · {progressMsg.toUpperCase()}
          </div>
          <h1 class="rv-hero-h">
            You're <em>crushing</em> today,&nbsp;<span class="rv-hero-pill">{smartTaskPct}%</span>&nbsp;done.
          </h1>
          <div class="rv-hero-stats">
            <div class="rv-hs">
              <span class="rv-hs-v">{streakDays}</span>
              <span class="rv-hs-l">day streak</span>
            </div>
            <div class="rv-hs">
              <span class="rv-hs-v">{xpDisplay}</span>
              <span class="rv-hs-l">total XP</span>
            </div>
            <div class="rv-hs">
              <span class="rv-hs-v">{avgEnergy.toFixed(1)}</span>
              <span class="rv-hs-l">avg energy</span>
            </div>
            <div class="rv-hs">
              <span class="rv-hs-v">{journeyPct}%</span>
              <span class="rv-hs-l">journey</span>
            </div>
          </div>
          {focusCTA.btnHref && (
            <a href={focusCTA.btnHref} class="rv-hero-btn" style={`background:${focusCTA.color}`}>
              {focusCTA.btnLabel}
            </a>
          )}
        </div>
        <div class="rv-hero-right">
          <svg viewBox="0 0 180 180" class="rv-rings-svg" id="rvRings" aria-hidden="true">
            <defs>
              <linearGradient id="rg1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#FF5C7A"/>
                <stop offset="100%" stop-color="#FF8FA3"/>
              </linearGradient>
              <linearGradient id="rg2" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#FF914D"/>
                <stop offset="100%" stop-color="#FFB380"/>
              </linearGradient>
              <linearGradient id="rg3" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#B6FF3C"/>
                <stop offset="100%" stop-color="#D4FF6E"/>
              </linearGradient>
            </defs>
            <circle cx="90" cy="90" r="70" fill="none" stroke="rgba(255,255,255,.07)" stroke-width="13"/>
            <circle cx="90" cy="90" r="56" fill="none" stroke="rgba(255,255,255,.07)" stroke-width="13"/>
            <circle cx="90" cy="90" r="42" fill="none" stroke="rgba(255,255,255,.07)" stroke-width="13"/>
            <circle cx="90" cy="90" r="70" fill="none" stroke="url(#rg1)" stroke-width="13"
              stroke-linecap="round" stroke-dasharray="439.82" stroke-dashoffset="439.82"
              transform="rotate(-90 90 90)" id="ring-fat"/>
            <circle cx="90" cy="90" r="56" fill="none" stroke="url(#rg2)" stroke-width="13"
              stroke-linecap="round" stroke-dasharray="351.86" stroke-dashoffset="351.86"
              transform="rotate(-90 90 90)" id="ring-prot"/>
            <circle cx="90" cy="90" r="42" fill="none" stroke="url(#rg3)" stroke-width="13"
              stroke-linecap="round" stroke-dasharray="263.89" stroke-dashoffset="263.89"
              transform="rotate(-90 90 90)" id="ring-carb"/>
            <text x="90" y="83" text-anchor="middle" class="rv-ring-kcal" id="rvKcal">{totalConsumed.calories}</text>
            <text x="90" y="100" text-anchor="middle" class="rv-ring-sub">kcal</text>
            <text x="90" y="113" text-anchor="middle" class="rv-ring-goal">of {goalCal}</text>
          </svg>
          <div class="rv-ring-legend">
            <span class="rv-rl"><span class="rv-rl-dot" style="background:#FF5C7A"></span>Fat {fatPct}%</span>
            <span class="rv-rl"><span class="rv-rl-dot" style="background:#FF914D"></span>Protein {protPct}%</span>
            <span class="rv-rl"><span class="rv-rl-dot" style="background:#B6FF3C"></span>Carbs {carbPct}%</span>
          </div>
        </div>
      </div>

      <!-- 2 · Meals ──────────────────────────────────────────── span 8 -->
      <div class="rv-card rv-meals">
        <div class="rv-card-head">
          <h2 class="rv-card-title">Today's Meals</h2>
          <a href="/dashboard/food-log" class="rv-card-link">Food log →</a>
        </div>
        <div class="rv-meals-list" id="rvMealsList">
          {todayMeals.length === 0 && (
            <p class="rv-empty-state">No meals scheduled · <a href="/dashboard/recipes">Browse recipes</a></p>
          )}
          {todayMeals.map((meal) => (
            <div class={completedMealSet.has(meal.meal_type) ? 'rv-meal-row rv-meal-done' : 'rv-meal-row'} data-mtype={meal.meal_type || ''}>
              <a href={meal.recipe?.id ? `/dashboard/recipe/${meal.recipe.id}` : '/dashboard/recipes'} class="rv-meal-link" aria-label={`View recipe: ${meal.recipe?.title || ''}`}>
                <div class="rv-meal-thumb">
                  {meal.recipe?.image_url
                    ? <img src={meal.recipe.image_url} alt={meal.recipe.title || ''} loading="lazy"/>
                    : <span class="rv-meal-fb">{(meal.meal_type || 'M').charAt(0).toUpperCase()}</span>
                  }
                </div>
                <div class="rv-meal-body">
                  <span class="rv-meal-tag">{meal.meal_type || ''} {((meal.recipe?.prep_time || 0) + (meal.recipe?.cook_time || 0)) > 0 && `· ${(meal.recipe?.prep_time || 0) + (meal.recipe?.cook_time || 0)}min`}</span>
                  <span class="rv-meal-name">{meal.recipe?.title || 'Meal plan loading…'}</span>
                  <span class="rv-meal-macros">{meal.recipe?.calories || 0} kcal · {meal.recipe?.protein || 0}g prot · {meal.recipe?.net_carbs || 0}g carbs</span>
                </div>
              </a>
              <button class="rv-meal-check" data-mtype={meal.meal_type || ''} aria-label="Toggle complete">
                {completedMealSet.has(meal.meal_type)
                  ? <svg width="20" height="20" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#B6FF3C"/><polyline points="9 12 11 14 15 10" fill="none" stroke="#16110F" stroke-width="2.2" stroke-linecap="round"/></svg>
                  : <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C4BAB1" stroke-width="1.8"><circle cx="12" cy="12" r="10"/></svg>
                }
              </button>
            </div>
          ))}
        </div>
      </div>

      <!-- 3 · Habits ─────────────────────────────────────────── span 4 -->
      <div class="rv-card rv-habits">
        <div class="rv-card-head">
          <h2 class="rv-card-title">Habits</h2>
          <a href="/dashboard/habits" class="rv-card-link">All →</a>
        </div>
        <div class="rv-habits-score">
          <span class="rv-hscore-n" id="rvHabitsCount">{habitsDoneCount}</span>
          <span class="rv-hscore-d">/{dashHabits.length || 0}</span>
          <em class="rv-hscore-l">done today</em>
        </div>
        <div class="rv-hbar-wrap">
          <div class="rv-hbar" id="rvHabitsBar" style={`width:${dashHabits.length > 0 ? Math.round((habitsDoneCount / dashHabits.length) * 100) : 0}%`}></div>
        </div>
        <div class="rv-habits-list" id="rvHabitsList">
          {dashHabits.length === 0 && (
            <a href="/dashboard/habits" class="rv-empty-link">+ Set up habits</a>
          )}
          {dashHabits.map((h) => (
            <button class={habitDoneIds.has(h.id) ? 'rv-habit-row rv-habit-done' : 'rv-habit-row'}
              data-hid={h.id} data-done={habitDoneIds.has(h.id) ? 'true' : 'false'}>
              <span class="rv-habit-ic">{(h.icon && !/^\d/.test(String(h.icon))) ? h.icon : (h.category === 'water' ? '💧' : h.category === 'exercise' ? '🏃' : h.category === 'sleep' ? '🌙' : h.category === 'nutrition' ? '🥗' : '✓')}</span>
              <span class="rv-habit-nm">{h.title}</span>
              <span class="rv-habit-ck">{habitDoneIds.has(h.id) ? '✓' : ''}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- 4 · Fasting ────────────────────────────────────────── span 4 -->
      <div class="rv-card rv-fasting">
        <div class="rv-card-head">
          <h2 class="rv-card-title">Fasting</h2>
          <a href="/dashboard/fasting" class="rv-card-link">Details →</a>
        </div>
        {fastingData ? (
          <div class="rv-fast-active">
            <div class="rv-fast-ring-wrap">
              <svg viewBox="0 0 144 144" class="rv-fast-svg">
                <circle cx="72" cy="72" r="60" fill="none" stroke="rgba(255,92,122,.12)" stroke-width="11"/>
                <circle cx="72" cy="72" r="60" fill="none" stroke="#FF5C7A" stroke-width="11"
                  stroke-linecap="round" stroke-dasharray="376.99" stroke-dashoffset="376.99"
                  transform="rotate(-90 72 72)" id="fastRing"/>
              </svg>
              <div class="rv-fast-center">
                <span class="rv-fast-timer" id="fastTimer">--:--:--</span>
                <span class="rv-fast-proto">{fastingData.protocol}</span>
              </div>
            </div>
            <div class="rv-fast-meta">
              <span>Goal: {fastingData.target_hours}h</span>
              <span id="fastRemain">calculating…</span>
            </div>
          </div>
        ) : (
          <div class="rv-fast-idle">
            <div class="rv-fast-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="36" height="36"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <p class="rv-fast-hint">No active fast</p>
            <a href="/dashboard/fasting" class="rv-fast-start-btn">Start fasting</a>
          </div>
        )}
      </div>

      <!-- 5 · Weight ──────────────────────────────────────────── span 8 -->
      <div class="rv-card rv-weight" id="weight-card">
        <div class="rv-card-head">
          <h2 class="rv-card-title">Weight</h2>
          <a href="/dashboard/progress" class="rv-card-link">Progress →</a>
        </div>
        <div class="rv-weight-stats">
          <div class="rv-ws">
            <span class="rv-ws-v">{dispLatest ? `${dispLatest} ${wUnit}` : (startWeight ? `${units === 'imperial' ? Math.round(startWeight * 2.20462 * 10)/10 : Math.round(startWeight * 10)/10} ${wUnit}` : '—')}</span>
            <span class="rv-ws-l">{weightLogs && (weightLogs as any[]).length > 0 ? 'Current' : 'Starting'}</span>
          </div>
          <div class="rv-ws">
            <span class="rv-ws-v rv-ws-lost">{dispWeightLost > 0 ? `-${dispWeightLost} ${wUnit}` : '—'}</span>
            <span class="rv-ws-l">Lost</span>
          </div>
          <div class="rv-ws">
            <span class="rv-ws-v">{targetWeightDisp ? `${targetWeightDisp} ${wUnit}` : '—'}</span>
            <span class="rv-ws-l">Goal</span>
          </div>
          <div class="rv-ws">
            <span class="rv-ws-v">{progressPct}%</span>
            <span class="rv-ws-l">Progress</span>
          </div>
        </div>
        <div class="rv-weight-chart-wrap" id="rvWeightChart">
          {hasWeightChart
            ? <Fragment set:html={wSvgStr}/>
            : <p class="rv-weight-empty">Log weight entries to see your trend</p>
          }
        </div>
        <form class="rv-weight-form" id="rvWeightForm">
          <input type="number" step="0.1" min="20" max="500"
            placeholder={`Log weight (${wUnit})`}
            class="rv-weight-input" id="rvWeightInput" autocomplete="off"/>
          <button type="submit" class="rv-weight-btn">Log</button>
        </form>
      </div>

      <!-- 6 · AI Coach ────────────────────────────────────────── span 4 -->
      <div class="rv-card rv-coach">
        <div class="rv-coach-glow"></div>
        <div class="rv-card-head">
          <h2 class="rv-card-title rv-coach-title">AI Coach</h2>
          {!isElite && <span class="rv-coach-badge">Elite</span>}
        </div>
        {isElite ? (
          <div class="rv-coach-body">
            <p class="rv-coach-intro">Ask me anything about your keto journey.</p>
            <div class="rv-coach-chips">
              <a href="/dashboard/ai-coach" class="rv-coach-chip">Plateau help</a>
              <a href="/dashboard/ai-coach" class="rv-coach-chip">Snack idea</a>
              <a href="/dashboard/ai-coach" class="rv-coach-chip">Why tired?</a>
            </div>
            <a href="/dashboard/ai-coach" class="rv-coach-cta">Open AI Coach →</a>
          </div>
        ) : (
          <div class="rv-coach-body">
            <p class="rv-coach-intro rv-coach-muted">Get personalized AI coaching powered by Gemini.</p>
            <a href="/dashboard/upgrade" class="rv-coach-cta">Upgrade to Elite →</a>
          </div>
        )}
      </div>

      <!-- 7 · Water ───────────────────────────────────────────── span 4 -->
      <div class="rv-card rv-water">
        <div class="rv-card-head">
          <h2 class="rv-card-title">Water</h2>
          <span class="rv-card-meta" id="rvWaterLabel">{waterGlasses}/8 glasses</span>
        </div>
        <div class="rv-water-score">
          <span class="rv-water-n" id="rvWaterNum">{waterGlasses}</span>
          <span class="rv-water-d">/ 8</span>
        </div>
        <div class="rv-water-grid" id="rvWaterGrid">
          {waterFillArr.map((filled, i) => (
            <button class={filled ? 'rv-wg rv-wg-on' : 'rv-wg'} data-glass={i + 1} aria-label={`Glass ${i + 1}`}>
              <svg width="14" height="20" viewBox="0 0 14 20">
                <path d="M1.5 3.5l1 12h9l1-12H1.5z" fill={filled ? 'var(--rv-accent)' : 'none'}
                  stroke={filled ? 'var(--rv-accent)' : 'var(--rv-muted)'} stroke-width="1.4" stroke-linejoin="round"/>
              </svg>
            </button>
          ))}
        </div>
        <a href="/dashboard/checkin" class="rv-water-log">Log via check-in →</a>
      </div>

      <!-- 8 · Recipe of the Day ───────────────────────────────── span 4 -->
      <div class="rv-card rv-rotd">
        <div class="rv-card-head">
          <h2 class="rv-card-title">Recipe of the Day</h2>
        </div>
        {rotd ? (
          <div class="rv-rotd-body">
            {rotd.image_url
              ? <img src={rotd.image_url} alt={rotd.title || ''} class="rv-rotd-img" loading="lazy"/>
              : <div class="rv-rotd-img-fb">{(rotd.title || 'R').charAt(0)}</div>
            }
            <div class="rv-rotd-info">
              <span class="rv-rotd-tag">{rotdMeal?.meal_type || 'meal'}</span>
              <h3 class="rv-rotd-name">{rotd.title}</h3>
              <div class="rv-rotd-macros">
                <span>{rotd.calories} kcal</span>
                <span>{rotd.net_carbs}g net carbs</span>
              </div>
              <a href={`/dashboard/recipe/${rotd.id}`} class="rv-rotd-cta">View recipe →</a>
            </div>
          </div>
        ) : (
          <div class="rv-rotd-empty">
            <p class="rv-empty-state">No recipe today</p>
            <a href="/dashboard/recipes" class="rv-rotd-cta">Browse recipes →</a>
          </div>
        )}
      </div>

      <!-- 10 · Tasks ─────────────────────────────────────────── span 8 -->
      <div class="rv-card rv-tasks" id="tour-tasks">
        <div class="rv-card-head">
          <h2 class="rv-card-title">Today's Tasks</h2>
          <span class="rv-card-meta"><span id="rvTasksMetaDone">{completedTasks}</span>/{totalTasks}</span>
        </div>
        <div class="rv-tasks-bar-wrap">
          <div class="rv-tasks-bar" id="rvTasksBar" style={`width:${taskPct}%`}></div>
        </div>
        <div class="rv-tasks-list" id="rvTasksList">
          {tasks.length === 0 && (
            <p class="rv-empty-state">No tasks yet — they'll appear as you progress through your journey.</p>
          )}
          {tasks.map((task) => (
            <div class={task.completed ? 'rv-task-row rv-task-done' : 'rv-task-row'}
              data-tid={task.id} data-done={task.completed ? 'true' : 'false'}>
              <button class="rv-task-ck" data-tid={task.id} aria-label="Toggle task">
                {task.completed
                  ? <svg width="20" height="20" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#B6FF3C"/><polyline points="9 12 11 14 15 10" fill="none" stroke="#16110F" stroke-width="2.2" stroke-linecap="round"/></svg>
                  : <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C4BAB1" stroke-width="1.8"><circle cx="12" cy="12" r="10"/></svg>
                }
              </button>
              <div class="rv-task-body">
                <span class="rv-task-nm">{task.task_title || task.task_type}</span>
                {task.xp_earned > 0 && <span class="rv-task-xp">+{task.xp_earned} XP</span>}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 11 · Steps ──────────────────────────────────────────── span 4 -->
      <div class="rv-card rv-steps">
        <div class="rv-card-head">
          <h2 class="rv-card-title">Steps</h2>
          <a href="/dashboard/steps" class="rv-card-link">Details →</a>
        </div>
        <div class="rv-steps-ring-wrap">
          <svg viewBox="0 0 120 120" class="rv-steps-svg">
            <circle cx="60" cy="60" r="50" fill="none" stroke="var(--rv-bg-alt)" stroke-width="10"/>
            <circle cx="60" cy="60" r="50" fill="none" stroke="var(--rv-accent-3)" stroke-width="10"
              stroke-linecap="round" stroke-dasharray="314.16"
              stroke-dashoffset={314.16 * (1 - stepsPct / 100)}
              transform="rotate(-90 60 60)"/>
          </svg>
          <div class="rv-steps-center">
            <span class="rv-steps-n">{todaySteps.toLocaleString()}</span>
            <span class="rv-steps-l">steps</span>
          </div>
        </div>
        <div class="rv-steps-meta">
          <span>Goal: {stepsGoal.toLocaleString()}</span>
          <span class="rv-steps-pct">{stepsPct}%</span>
        </div>
        <a href="/dashboard/steps" class="rv-steps-log">Log steps →</a>
      </div>

      <!-- 9 · Daily Insight ───────────────────────────────────── span 4 -->
      <div class="rv-card rv-insight">
        <div class="rv-card-head">
          <h2 class="rv-card-title">Daily Insight</h2>
          {smartInsights && smartInsights.length > 0 && (
            <a href="/dashboard/notifications" class="rv-card-link">{smartInsights.length} more →</a>
          )}
        </div>
        <div class="rv-insight-body">
          <div class="rv-insight-icon" style={`color:${dailyTip.color};background:${dailyTip.color}18`}>
            <Fragment set:html={tipSvgStr}/>
          </div>
          <div class="rv-insight-text">
            <h3 class="rv-insight-title" style={`color:${dailyTip.color}`}>{dailyTip.title}</h3>
            <p class="rv-insight-desc">{dailyTip.body}</p>
          </div>
        </div>
      </div>

    </div><!-- /rv-grid -->
  </div><!-- /rv-main -->
</div><!-- /rv-shell -->

<!-- Mobile bottom nav -->
<nav class="rv-mob-nav" aria-label="Main navigation">
  <a href="/dashboard"          class="rv-mn rv-mn--active">
    <svg class="rv-mn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    <span>Today</span>
  </a>
  <a href="/dashboard/food-log" class="rv-mn">
    <svg class="rv-mn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
    <span>Meals</span>
  </a>
  <a href="/dashboard/fasting"  class="rv-mn">
    <svg class="rv-mn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    <span>Fasting</span>
  </a>
  <a href="/dashboard/progress" class="rv-mn">
    <svg class="rv-mn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
    <span>Progress</span>
  </a>
  <a href="/dashboard/profile"  class="rv-mn">
    <svg class="rv-mn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    <span>Profile</span>
  </a>
</nav>

<!-- ═══════════════════════════ STYLES ═══════════════════════════════ -->
<style>
  /* ── tokens ── */
  :root {
    --rv-bg:       #FAF6F1;
    --rv-bg-alt:   #F2EDE5;
    --rv-ink:      #16110F;
    --rv-ink-soft: #4A4340;
    --rv-muted:    #8A8077;
    --rv-line:     #E5DED2;
    --rv-accent:   #FF5C7A;
    --rv-accent-2: #B6FF3C;
    --rv-accent-3: #FF914D;
    --rv-card:     #FFFFFF;
    --rv-display:  'Bricolage Grotesque', system-ui, sans-serif;
    --rv-serif:    'Instrument Serif', Georgia, serif;
    --rv-body:     'Geist', 'DM Sans', system-ui, sans-serif;
  }
  [data-theme="dark"] {
    --rv-bg:       #130E0C;
    --rv-bg-alt:   #1C1512;
    --rv-ink:      #F0EBE5;
    --rv-ink-soft: #C4B8B0;
    --rv-muted:    #7A6E68;
    --rv-line:     #2A2220;
    --rv-card:     #1C1512;
  }

  /* ── shell ── */
  .rv-shell {
    display: grid;
    grid-template-columns: 232px 1fr;
    min-height: 100vh;
    background: var(--rv-bg);
    font-family: var(--rv-body);
    color: var(--rv-ink);
  }

  /* ── sidebar ── */
  .rv-sb {
    width: 232px;
    position: sticky;
    top: 0;
    height: 100vh;
    background: var(--rv-card);
    border-right: 1px solid var(--rv-line);
    display: flex;
    flex-direction: column;
    padding: 20px 14px 20px;
    overflow-y: auto;
    gap: 4px;
  }
  .rv-sb-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 24px;
    padding: 0 4px;
  }
  .rv-logo-mark {
    width: 30px; height: 30px;
    background: var(--rv-ink);
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--rv-display);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--rv-accent-2);
    flex-shrink: 0;
  }
  .rv-logo-word {
    font-family: var(--rv-display);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--rv-ink);
  }
  .rv-logo-word strong { font-weight: 700; }
  .rv-sb-nav { display: flex; flex-direction: column; gap: 2px; }
  .rv-ni {
    display: flex; align-items: center; gap: 11px;
    padding: 9px 12px;
    border-radius: 10px;
    text-decoration: none;
    font-family: var(--rv-display);
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--rv-ink-soft);
    transition: all .15s;
  }
  .rv-ni:hover { background: var(--rv-bg-alt); color: var(--rv-ink); }
  .rv-ni--active { background: var(--rv-ink); color: var(--rv-bg) !important; }
  .rv-ni--active .rv-ni-ic { color: var(--rv-accent-2); }
  .rv-ni--elite .rv-ni-ic { color: var(--rv-accent); }
  .rv-ni-ic { width: 17px; height: 17px; flex-shrink: 0; }
  .rv-sb-fill { flex: 1; }
  .rv-sb-user {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px;
    border-radius: 10px;
    text-decoration: none;
    border: 1px solid var(--rv-line);
    transition: border-color .15s;
  }
  .rv-sb-user:hover { border-color: var(--rv-accent); }
  .rv-sb-avatar {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: var(--rv-accent);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--rv-display);
    font-weight: 700; font-size: 0.9rem;
    flex-shrink: 0;
  }
  .rv-sb-info { display: flex; flex-direction: column; min-width: 0; }
  .rv-sb-name { font-family: var(--rv-display); font-size: 0.83rem; font-weight: 600; color: var(--rv-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .rv-sb-plan { font-size: 0.68rem; letter-spacing: .07em; color: var(--rv-muted); font-family: 'Geist Mono', monospace; margin-top: 1px; }

  /* ── main ── */
  .rv-main { display: flex; flex-direction: column; min-height: 100vh; background: var(--rv-bg); }

  /* ── topbar ── */
  .rv-topbar {
    position: sticky; top: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 20px;
    background: color-mix(in srgb, var(--rv-bg) 88%, transparent);
    backdrop-filter: blur(16px) saturate(1.2);
    border-bottom: 1px solid var(--rv-line);
  }
  .rv-top-l { display: flex; flex-direction: column; gap: 1px; }
  .rv-top-greet {
    font-family: var(--rv-display); font-size: 1.05rem; font-weight: 600;
    color: var(--rv-ink); margin: 0;
  }
  .rv-top-greet em { font-family: var(--rv-serif); font-style: italic; color: var(--rv-accent); }
  .rv-top-meta {
    font-size: 0.68rem; letter-spacing: .08em; color: var(--rv-muted);
    font-family: 'Geist Mono', monospace; margin: 0;
  }
  .rv-top-r { display: flex; align-items: center; gap: 10px; }
  .rv-top-icon {
    width: 36px; height: 36px; border-radius: 50%;
    border: 1px solid var(--rv-line);
    display: flex; align-items: center; justify-content: center;
    color: var(--rv-ink-soft); text-decoration: none;
    transition: border-color .15s, color .15s;
  }
  .rv-top-icon:hover { border-color: var(--rv-accent); color: var(--rv-accent); }
  .rv-top-cta {
    padding: 8px 16px; border-radius: 20px;
    background: var(--rv-ink); color: var(--rv-bg);
    font-family: var(--rv-display); font-size: 0.8rem; font-weight: 600;
    text-decoration: none; letter-spacing: .02em;
    transition: opacity .15s;
  }
  .rv-top-cta:hover { opacity: .82; }

  /* ── lapse banner ── */
  .rv-lapse {
    display: flex; align-items: flex-start; gap: 14px;
    margin: 12px 20px 0;
    padding: 14px 16px;
    border-radius: 14px;
    border: 1px solid transparent;
  }
  .rv-lapse-emoji { font-size: 1.5rem; flex-shrink: 0; margin-top: 1px; }
  .rv-lapse-text { flex: 1; display: flex; flex-direction: column; gap: 3px; }
  .rv-lapse-text strong { font-family: var(--rv-display); font-size: 0.9rem; font-weight: 700; }
  .rv-lapse-text span { font-size: 0.82rem; color: var(--rv-ink-soft); line-height: 1.4; }
  .rv-lapse-btn {
    padding: 7px 14px; border-radius: 10px;
    color: #fff; font-family: var(--rv-display);
    font-size: 0.78rem; font-weight: 700;
    text-decoration: none; white-space: nowrap; flex-shrink: 0;
    align-self: center;
  }

  /* ── grid ── */
  .rv-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
    padding: 16px 20px 32px;
  }
  .rv-hero    { grid-column: span 12; }
  .rv-meals   { grid-column: span 8; }
  .rv-habits  { grid-column: span 4; }
  .rv-fasting { grid-column: span 4; }
  .rv-weight  { grid-column: span 8; }
  .rv-coach   { grid-column: span 4; }
  .rv-water   { grid-column: span 4; }
  .rv-rotd    { grid-column: span 4; }
  .rv-tasks   { grid-column: span 8; }
  .rv-steps   { grid-column: span 4; }
  .rv-insight { grid-column: span 4; }

  /* ── base card ── */
  .rv-card {
    background: var(--rv-card);
    border: 1px solid var(--rv-line);
    border-radius: 20px;
    padding: 20px;
    overflow: hidden;
    position: relative;
  }
  .rv-card-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .rv-card-title {
    font-family: var(--rv-display); font-size: 0.9rem; font-weight: 700;
    color: var(--rv-ink); margin: 0;
  }
  .rv-card-link {
    font-size: 0.75rem; color: var(--rv-muted); text-decoration: none;
    font-family: var(--rv-display); transition: color .15s;
  }
  .rv-card-link:hover { color: var(--rv-accent); }
  .rv-card-meta { font-size: 0.75rem; color: var(--rv-muted); font-family: 'Geist Mono', monospace; }

  /* ── hero card ── */
  .rv-hero {
    background: var(--rv-ink);
    border-color: transparent;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 280px;
    padding: 32px 36px;
  }
  .rv-hero-glow {
    position: absolute; top: 50%; left: 35%; transform: translate(-50%, -50%);
    width: 320px; height: 320px;
    background: radial-gradient(circle, color-mix(in srgb, #FF5C7A 30%, transparent), transparent 65%);
    pointer-events: none;
  }
  .rv-hero-left { position: relative; z-index: 1; flex: 1; max-width: 520px; }
  .rv-hero-eyebrow {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.7rem; letter-spacing: .12em;
    color: rgba(255,255,255,.5);
    font-family: 'Geist Mono', monospace;
    margin-bottom: 14px;
  }
  .rv-pulse {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--rv-accent-2);
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:.6; transform:scale(1.3); } }
  .rv-hero-h {
    font-family: var(--rv-display);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 700; color: #fff;
    margin: 0 0 20px; line-height: 1.2;
  }
  .rv-hero-h em { font-family: var(--rv-serif); font-style: italic; color: var(--rv-accent); }
  .rv-hero-pill {
    display: inline-block;
    background: var(--rv-accent-2); color: var(--rv-ink);
    font-size: 0.75rem; font-weight: 800;
    padding: 2px 10px; border-radius: 20px;
    font-family: var(--rv-display); vertical-align: middle;
    transform: rotate(-2deg);
  }
  .rv-hero-stats {
    display: flex; gap: 28px; margin-bottom: 22px; flex-wrap: wrap;
  }
  .rv-hs { display: flex; flex-direction: column; gap: 2px; }
  .rv-hs-v { font-family: var(--rv-display); font-size: 1.5rem; font-weight: 700; color: #fff; }
  .rv-hs-l { font-size: 0.68rem; letter-spacing: .06em; color: rgba(255,255,255,.45); font-family: 'Geist Mono', monospace; }
  .rv-hero-btn {
    display: inline-flex; padding: 10px 22px; border-radius: 24px;
    font-family: var(--rv-display); font-size: 0.85rem; font-weight: 700;
    color: #fff; text-decoration: none;
    transition: filter .15s;
  }
  .rv-hero-btn:hover { filter: brightness(1.1); }
  .rv-hero-right { position: relative; z-index: 1; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 14px; }
  .rv-rings-svg { width: 180px; height: 180px; }
  .rv-ring-kcal { font-family: var(--rv-display); font-size: 24px; font-weight: 800; fill: #fff; }
  .rv-ring-sub  { font-size: 10px; fill: rgba(255,255,255,.5); font-family: 'Geist Mono', monospace; letter-spacing: .08em; }
  .rv-ring-goal { font-size: 9px; fill: rgba(255,255,255,.35); font-family: 'Geist Mono', monospace; }
  .rv-ring-legend { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .rv-rl { display: flex; align-items: center; gap: 5px; font-size: 0.7rem; color: rgba(255,255,255,.6); font-family: var(--rv-display); }
  .rv-rl-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

  /* ── meals card ── */
  .rv-meals-list { display: flex; flex-direction: column; gap: 6px; }
  .rv-meal-row {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 10px;
    border-radius: 12px;
    border: 1px solid var(--rv-line);
    transition: border-color .15s, opacity .2s;
  }
  .rv-meal-row:hover { border-color: var(--rv-accent); }
  .rv-meal-done { opacity: .5; }
  .rv-meal-thumb {
    width: 48px; height: 48px; border-radius: 10px;
    overflow: hidden; flex-shrink: 0;
    background: var(--rv-bg-alt);
    display: flex; align-items: center; justify-content: center;
  }
  .rv-meal-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .rv-meal-fb { font-family: var(--rv-display); font-size: 1.1rem; font-weight: 700; color: var(--rv-muted); }
  .rv-meal-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
  .rv-meal-tag { font-size: 0.68rem; letter-spacing: .06em; color: var(--rv-muted); text-transform: capitalize; font-family: 'Geist Mono', monospace; }
  .rv-meal-name { font-family: var(--rv-display); font-size: 0.88rem; font-weight: 600; color: var(--rv-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .rv-meal-macros { font-size: 0.72rem; color: var(--rv-muted); }
  .rv-meal-link { display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; text-decoration: none; color: inherit; }
  .rv-meal-link:hover .rv-meal-name { color: var(--rv-accent); }
  .rv-meal-check { background: none; border: none; cursor: pointer; padding: 4px; flex-shrink: 0; display: flex; }

  /* ── habits card ── */
  .rv-habits-score { display: flex; align-items: baseline; gap: 4px; margin-bottom: 10px; }
  .rv-hscore-n { font-family: var(--rv-display); font-size: 2.8rem; font-weight: 800; color: var(--rv-accent); line-height: 1; }
  .rv-hscore-d { font-family: var(--rv-display); font-size: 1.2rem; font-weight: 500; color: var(--rv-muted); }
  .rv-hscore-l { font-family: var(--rv-serif); font-style: italic; font-size: 0.85rem; color: var(--rv-muted); margin-left: 4px; }
