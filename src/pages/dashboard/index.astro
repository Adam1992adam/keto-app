<!-- ═══════════════════════════ SCRIPTS ══════════════════════════════ -->
<script is:inline define:vars={{
  rvFatPct:      fatPct,
  rvProtPct:     protPct,
  rvCarbPct:     carbPct,
  rvConsumedCal: totalConsumed.calories,
  rvGoalCal:     goalCal,
  rvFasting:     fastingData,
  rvDoneMeals:   completedMealTypesArr,
  rvDoneHabits:  doneHabitsForClient,
  rvWater:       waterGlasses,
  rvWUnit:       wUnit,
  rvDay:         currentDay,
  rvStreak:      streakDays,
}}>
(function () {
  /* ── Ring animation ───────────────────────────────────── */
  var C1 = 439.82, C2 = 351.86, C3 = 263.89;
  var r1 = document.getElementById('ring-fat');
  var r2 = document.getElementById('ring-prot');
  var r3 = document.getElementById('ring-carb');
  var targets = [
    { el: r1, c: C1, pct: rvFatPct },
    { el: r2, c: C2, pct: rvProtPct },
    { el: r3, c: C3, pct: rvCarbPct },
  ];
  function ease(t) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }
  var rStart = null;
  function ringTick(ts) {
    if (!rStart) rStart = ts;
    var p = Math.min((ts - rStart) / 1400, 1);
    var ep = ease(p);
    targets.forEach(function(t) {
      if (t.el) t.el.style.strokeDashoffset = t.c * (1 - (t.pct / 100) * ep);
    });
    if (p < 1) requestAnimationFrame(ringTick);
  }
  requestAnimationFrame(ringTick);

  /* ── Fasting timer ───────────────────────────────────── */
  if (rvFasting) {
    var fStart  = new Date(rvFasting.started_at).getTime();
    var fTarget = rvFasting.target_hours * 3600000;
    var fRing   = document.getElementById('fastRing');
    var fTimer  = document.getElementById('fastTimer');
    var fRemain = document.getElementById('fastRemain');
    var CF = 376.99;
    function pad(n) { return n < 10 ? '0' + n : '' + n; }
    function updateFast() {
      var elapsed = Date.now() - fStart;
      var progress = Math.min(elapsed / fTarget, 1);
      var h = Math.floor(elapsed / 3600000);
      var m = Math.floor((elapsed % 3600000) / 60000);
      var s = Math.floor((elapsed % 60000) / 1000);
      if (fTimer) fTimer.textContent = pad(h) + ':' + pad(m) + ':' + pad(s);
      if (fRing)  fRing.style.strokeDashoffset = CF * (1 - progress);
      if (fRemain) {
        var rem = Math.max(0, fTarget - elapsed);
        var rh = Math.floor(rem / 3600000);
        var rm = Math.floor((rem % 3600000) / 60000);
        fRemain.textContent = rh + 'h ' + pad(rm) + 'm remaining';
      }
    }
    updateFast();
    setInterval(updateFast, 1000);
  }

  /* ── Meal completion ────────────────────────────────── */
  var doneMeals = new Set(rvDoneMeals);
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.rv-meal-check');
    if (!btn) return;
    var mt  = btn.getAttribute('data-mtype');
    var row = btn.closest('[data-mtype]');
    if (!mt || !row) return;
    var nowDone = !doneMeals.has(mt);
    nowDone ? doneMeals.add(mt) : doneMeals.delete(mt);
    row.classList.toggle('rv-meal-done', nowDone);
    btn.innerHTML = nowDone
      ? '<svg width="20" height="20" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#B6FF3C"/><polyline points="9 12 11 14 15 10" fill="none" stroke="#16110F" stroke-width="2.2" stroke-linecap="round"/></svg>'
      : '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C4BAB1" stroke-width="1.8"><circle cx="12" cy="12" r="10"/></svg>';
    fetch('/api/meals/complete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ meal_type: mt, completed: nowDone, day_number: rvDay }),
    });
  });

  /* ── Habit toggle ────────────────────────────────────── */
  var doneHabits = new Set(rvDoneHabits);
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-hid]');
    if (!btn || !btn.classList.contains('rv-habit-row')) return;
    var id   = btn.getAttribute('data-hid');
    var nowD = !doneHabits.has(id);
    nowD ? doneHabits.add(id) : doneHabits.delete(id);
    btn.classList.toggle('rv-habit-done', nowD);
    var ck = btn.querySelector('.rv-habit-ck');
    if (ck) ck.textContent = nowD ? '✓' : '';
    var total = document.querySelectorAll('[data-hid].rv-habit-row').length;
    var done  = document.querySelectorAll('[data-hid].rv-habit-done').length;
    var cnt   = document.getElementById('rvHabitsCount');
    var bar   = document.getElementById('rvHabitsBar');
    if (cnt) cnt.textContent = done;
    if (bar) bar.style.width = (total > 0 ? Math.round((done/total)*100) : 0) + '%';
    fetch('/api/habits/toggle', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ habit_id: id, completed: nowD, day_number: rvDay }),
    });
  });

  /* ── Task toggle ────────────────────────────────────── */
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.rv-task-ck');
    if (!btn) return;
    var id  = btn.getAttribute('data-tid');
    var row = document.querySelector('.rv-task-row[data-tid="' + id + '"]');
    if (!id || !row) return;
    var nowDone = row.getAttribute('data-done') !== 'true';
    row.setAttribute('data-done', nowDone ? 'true' : 'false');
    row.classList.toggle('rv-task-done', nowDone);
    btn.innerHTML = nowDone
      ? '<svg width="20" height="20" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#B6FF3C"/><polyline points="9 12 11 14 15 10" fill="none" stroke="#16110F" stroke-width="2.2" stroke-linecap="round"/></svg>'
      : '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C4BAB1" stroke-width="1.8"><circle cx="12" cy="12" r="10"/></svg>';
    var total = document.querySelectorAll('.rv-task-row').length;
    var done  = document.querySelectorAll('.rv-task-done').length;
    var meta  = document.getElementById('rvTasksMetaDone');
    var bar   = document.getElementById('rvTasksBar');
    if (meta) meta.textContent = done;
    if (bar)  bar.style.width  = (total > 0 ? Math.round((done / total) * 100) : 0) + '%';
    fetch('/api/tasks/complete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ taskId: id, completed: nowDone }),
    });
  });

  /* ── Weight log form ─────────────────────────────────── */
  var wForm = document.getElementById('rvWeightForm');
  if (wForm) {
    wForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var inp = document.getElementById('rvWeightInput');
      var val = parseFloat(inp.value);
      if (!val || val < 20 || val > 500) return;
      var kg = rvWUnit === 'lbs' ? val / 2.20462 : val;
      kg = Math.round(kg * 100) / 100;
      inp.disabled = true;
      fetch('/api/profile/add-weight', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ weight: kg }),
      }).then(function(r) { return r.json(); }).then(function() {
        inp.value = '';
        inp.disabled = false;
        if (window.showToast) window.showToast('Weight logged!', 'success');
        else setTimeout(function() { location.reload(); }, 800);
      }).catch(function() { inp.disabled = false; });
    });
  }
})();
</script>
</body>
</html>
