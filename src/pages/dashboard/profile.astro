---
import {
  getWeightLogs,
  getUserJourney, getXPTransactions,
  calculateBMI, calculateCalorieTarget,
  formatWeight, weightLabel,
  kgToLbs, getPlan, getAchievements,
  type UnitSystem
} from '../../lib/supabase';
import { requireAuth } from '../../lib/auth';
import { getTranslator, normaliseLang } from '../../lib/i18n';
import DashNav from '../../components/DashNav.astro';
import Sidebar from '../../components/Sidebar.astro';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);
const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? '👑 Elite' : planType === 'pro_6' ? '⚡ Pro' : '🥑 Basic';
const userName  = profile.full_name?.split(' ')[0] || 'there';
const isElite   = planType === 'elite_12';

const units: UnitSystem = (profile.preferred_units as UnitSystem) || 'imperial';
const wLabel = weightLabel(units);
const plan   = getPlan(profile.subscription_tier);
const maxDays = planType === 'elite_12' ? 365 : planType === 'pro_6' ? 180 : 30;

// Journey first — needed for subsequent queries
const journey    = await getUserJourney(user.id, db).catch(() => null);
const currentDay = journey?.current_day || 1;

// All remaining queries fire in parallel
const [onboardingRes, weightRes, allTasksRes, bmiRes, calRes, waterRes] =
  await Promise.allSettled([
    db.from('onboarding_data').select('dietary_restrictions,fasting_protocol').eq('user_id', user.id).maybeSingle(),
    getWeightLogs(user.id, 30, db),
    db.from('daily_tasks').select('completed,task_type').eq('user_id', user.id),
    calculateBMI(profile.weight_kg as number, profile.height_cm as number),
    calculateCalorieTarget(profile),
    db.from('water_intake').select('glasses_count').eq('user_id', user.id),
  ]);

const onboarding    = onboardingRes.status === 'fulfilled' ? onboardingRes.value?.data : null;
const weightLogs    = weightRes.status    === 'fulfilled' ? weightRes.value       : [];
const allTasks      = allTasksRes.status  === 'fulfilled' ? allTasksRes.value?.data : null;
const bmi           = bmiRes.status        === 'fulfilled' ? bmiRes.value         : null;
const calorieTarget = calRes.status        === 'fulfilled' ? calRes.value         : 2000;
const totalWaterGlasses = waterRes.status  === 'fulfilled'
  ? (waterRes.value?.data?.reduce((s, w) => s + w.glasses_count, 0) || 0) : 0;

const totalTasksCompleted  = allTasks?.filter(t => t.completed).length || 0;
const totalMealsCompleted  = allTasks?.filter(t => t.completed && ['breakfast','lunch','dinner','snack'].includes(t.task_type)).length || 0;

const currentStreak = journey?.streak_days    || 0;
const perfectDays   = journey?.perfect_days   || 0;
const totalXP       = journey?.total_xp       || 0;
const level         = journey?.level          || 1;

const currentWeight = profile.weight_kg || 0;
const startWeight   = weightLogs.length > 0 ? weightLogs[weightLogs.length - 1].weight : currentWeight;
const weightChange  = startWeight - currentWeight;
const targetWeight  = profile.target_weight_kg || currentWeight - 5;
const progressPercent = Math.min(100, Math.max(0, ((startWeight - currentWeight) / Math.max(0.001, startWeight - targetWeight)) * 100));

const bmiCategory = !bmi ? { label:'Not set', color:'#8A8077' }
  : bmi < 18.5 ? { label:'Underweight', color:'#3b82f6' }
  : bmi < 25   ? { label:'Healthy',     color:'#10b981' }
  : bmi < 30   ? { label:'Above range', color:'#f59e0b' }
  : { label:'Working on it', color:'#f59e0b' };

const fatGrams     = Math.round((calorieTarget * 0.70) / 9);
const proteinGrams = Math.round((calorieTarget * 0.25) / 4);
const carbGrams    = Math.round((calorieTarget * 0.05) / 4);
const fatPct       = Math.round(fatGrams * 9 / (calorieTarget || 1) * 100);
const protPct      = Math.round(proteinGrams * 4 / (calorieTarget || 1) * 100);
const carbPct      = Math.round(carbGrams * 4 / (calorieTarget || 1) * 100);

const daysLeft = profile.subscription_end_date
  ? Math.max(0, Math.ceil((new Date(profile.subscription_end_date).getTime() - Date.now()) / 86400000)) : 0;

const displayWeight       = formatWeight(currentWeight, units);
const displayStartWeight  = formatWeight(startWeight, units);
const displayTargetWeight = formatWeight(targetWeight, units);
const displayHeight       = profile.height_cm
  ? (units === 'imperial'
      ? (() => { const ti = profile.height_cm! / 2.54; return `${Math.floor(ti/12)}'${Math.round(ti%12)}"`; })()
      : `${profile.height_cm} cm`)
  : '—';

const weightInputVal = profile.weight_kg
  ? (units === 'imperial' ? kgToLbs(profile.weight_kg) : profile.weight_kg) : '';
const targetInputVal = profile.target_weight_kg
  ? (units === 'imperial' ? kgToLbs(profile.target_weight_kg) : profile.target_weight_kg) : '';
const heightFtVal = profile.height_cm && units === 'imperial' ? Math.floor(profile.height_cm / 2.54 / 12) : '';
const heightInVal = profile.height_cm && units === 'imperial' ? Math.round((profile.height_cm / 2.54) % 12) : '';

const dbAchievements = await getAchievements(user.id, db);

const { data: macroGoals } = await db
  .from('macro_goals').select('*').eq('user_id', user.id).maybeSingle();
const mgCal  = macroGoals?.daily_calories || calorieTarget;
const mgProt = macroGoals?.protein_g      || proteinGrams;
const mgFat  = macroGoals?.fat_g          || fatGrams;
const mgCarb = macroGoals?.carbs_g        || carbGrams;

const achievementsList = [
  { name:'First Step',     icon:'🎯', done: perfectDays  >= 1  },
  { name:'Week Warrior',   icon:'📅', done: perfectDays  >= 7  },
  { name:'Two Weeks',      icon:'💪', done: perfectDays  >= 14 },
  { name:'On Fire',        icon:'🔥', done: currentStreak>= 7  },
  { name:'Level Master',   icon:'⭐', done: level        >= 5  },
  { name:'XP Hunter',      icon:'🏅', done: totalXP      >= 500 },
  { name:'First Kilo',     icon:'⚖️', done: weightChange >= 1  },
  { name:'Keto Champ',     icon:'👑', done: currentDay   >= 30 },
  { name:'Five Down',      icon:'🏆', done: weightChange >= 5  },
  { name:'Halfway Hero',   icon:'🌟', done: currentDay   >= 15 },
];

const dayProgress  = Math.min(100, Math.round((currentDay / maxDays) * 100));
const avatarLetter = profile.full_name?.charAt(0)?.toUpperCase() || '?';
const dietaryRestrictions = onboarding?.dietary_restrictions || [];
const fastingProtocol = onboarding?.fasting_protocol || null;
const allDietChips = ['Low-Carb', 'Dairy-Free', 'Nut-Free', 'Egg-Free', 'Vegetarian', 'Gluten-Free'];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Profile — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <script is:inline>(function(){ const t=localStorage.getItem('keto-theme')||'light'; document.documentElement.setAttribute('data-theme',t); })();</script>
  <style>
    :root {
      --rv-bg:       #FAF6F1;
      --rv-bg-alt:   #F2EDE5;
      --rv-ink:      #16110F;
      --rv-ink-soft: #4A4340;
      --rv-muted:    #8A8077;
      --rv-line:     #E5DED2;
      --rv-accent:   #FF5C7A;
      --rv-accent-2: #B6FF3C;
      --rv-accent-3: #FF914D;
      --rv-card:     #FFFFFF;
      --rv-display:  'Bricolage Grotesque', system-ui, sans-serif;
      --rv-serif:    'Instrument Serif', Georgia, serif;
      --rv-body:     'Geist', 'DM Sans', system-ui, sans-serif;
      --rv-mono:     'Geist Mono', monospace;
    }
    [data-theme="dark"] {
      --rv-bg:       #130E0C;
      --rv-bg-alt:   #1C1512;
      --rv-ink:      #F0EBE5;
      --rv-ink-soft: #C4B8B0;
      --rv-muted:    #7A6E68;
      --rv-line:     #2A2220;
      --rv-card:     #1C1512;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--rv-body); background: var(--rv-bg); color: var(--rv-ink); min-height: 100vh; overflow-x: hidden; }

    /* ── SHELL ── */
    .rv-shell {
      display: grid;
      grid-template-columns: 232px 1fr;
      min-height: 100vh;
      background: var(--rv-bg);
      font-family: var(--rv-body);
      color: var(--rv-ink);
    }

    /* ── SIDEBAR ── */
    .rv-sb {
      width: 232px;
      position: sticky; top: 0; height: 100vh;
      background: var(--rv-card);
      border-right: 1px solid var(--rv-line);
      display: flex; flex-direction: column;
      padding: 20px 14px; overflow-y: auto; gap: 4px;
    }
    .rv-sb-logo {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none; margin-bottom: 24px; padding: 0 4px;
    }
    .rv-logo-mark {
      width: 30px; height: 30px; background: var(--rv-ink);
      border-radius: 7px; display: flex; align-items: center; justify-content: center;
      font-family: var(--rv-display); font-weight: 700; font-size: .95rem;
      color: var(--rv-accent-2); flex-shrink: 0;
    }
    .rv-logo-word {
      font-family: var(--rv-display); font-size: .78rem;
      font-weight: 500; letter-spacing: .06em; color: var(--rv-ink);
    }
    .rv-logo-word strong { font-weight: 700; }
    .rv-sb-nav { display: flex; flex-direction: column; gap: 2px; }
    .rv-ni {
      display: flex; align-items: center; gap: 11px;
      padding: 9px 12px; border-radius: 10px; text-decoration: none;
      font-family: var(--rv-display); font-size: .84rem; font-weight: 500;
      color: var(--rv-ink-soft); transition: all .15s;
    }
    .rv-ni:hover { background: var(--rv-bg-alt); color: var(--rv-ink); }
    .rv-ni--active { background: var(--rv-ink); color: var(--rv-bg) !important; }
    .rv-ni--active .rv-ni-ic { color: var(--rv-accent-2); }
    .rv-ni--elite .rv-ni-ic { color: var(--rv-accent); }
    .rv-ni-ic { width: 17px; height: 17px; flex-shrink: 0; }
    .rv-sb-fill { flex: 1; }
    .rv-sb-user {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; border-radius: 10px; text-decoration: none;
      border: 1px solid var(--rv-accent); transition: border-color .15s;
    }
    .rv-sb-user:hover { border-color: var(--rv-accent); opacity: .85; }
    .rv-sb-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: var(--rv-accent); color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--rv-display); font-weight: 700; font-size: .9rem; flex-shrink: 0;
      overflow: hidden;
    }
    .rv-sb-info { display: flex; flex-direction: column; min-width: 0; }
    .rv-sb-name { font-family: var(--rv-display); font-size: .83rem; font-weight: 600; color: var(--rv-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .rv-sb-plan { font-size: .68rem; letter-spacing: .07em; color: var(--rv-muted); font-family: var(--rv-mono); margin-top: 1px; }

    /* ── MAIN ── */
    .rv-main { display: flex; flex-direction: column; min-height: 100vh; background: var(--rv-bg); }

    /* ── TOPBAR ── */
    .rv-topbar {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 20px;
      background: color-mix(in srgb, var(--rv-bg) 88%, transparent);
      backdrop-filter: blur(16px) saturate(1.2);
      border-bottom: 1px solid var(--rv-line);
    }
    .rv-top-l { display: flex; flex-direction: column; gap: 1px; }
    .rv-top-greet { font-family: var(--rv-display); font-size: 1.05rem; font-weight: 600; color: var(--rv-ink); margin: 0; }
    .rv-top-greet em { font-family: var(--rv-serif); font-style: italic; color: var(--rv-accent); }
    .rv-top-meta { font-size: .68rem; letter-spacing: .08em; color: var(--rv-muted); font-family: var(--rv-mono); margin: 0; }
    .rv-top-r { display: flex; align-items: center; gap: 10px; }
    .rv-top-icon {
      width: 36px; height: 36px; border-radius: 50%;
      border: 1px solid var(--rv-line);
      display: flex; align-items: center; justify-content: center;
      color: var(--rv-ink-soft); text-decoration: none; transition: border-color .15s, color .15s;
    }
    .rv-top-icon:hover { border-color: var(--rv-accent); color: var(--rv-accent); }
    .rv-top-cta {
      padding: 8px 16px; border-radius: 20px;
      background: var(--rv-ink); color: var(--rv-bg);
      font-family: var(--rv-display); font-size: .8rem; font-weight: 600;
      text-decoration: none; letter-spacing: .02em; transition: opacity .15s;
    }
    .rv-top-cta:hover { opacity: .82; }

    /* ── CONTENT GRID ── */
    .rv-content { padding: 20px 20px 40px; }
    .rv-pgrid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 16px;
    }
    .rv-p12 { grid-column: span 12; }
    .rv-p8  { grid-column: span 8; }
    .rv-p4  { grid-column: span 4; }

    /* ── HERO ── */
    .rv-hero {
      position: relative; border-radius: 24px; overflow: hidden;
      background: var(--rv-ink); color: #FAF6F1; grid-column: span 12;
    }
    .rv-hero-grad {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, #1a0a10 0%, #0f1520 50%, #0a1510 100%);
    }
    .rv-hero-glow {
      position: absolute; top: -100px; right: -100px;
      width: 500px; height: 500px; border-radius: 50%;
      background: radial-gradient(circle, rgba(255,92,122,.28) 0%, transparent 65%);
      pointer-events: none;
    }
    .rv-hero-glow2 {
      position: absolute; bottom: -80px; left: 25%;
      width: 350px; height: 350px; border-radius: 50%;
      background: radial-gradient(circle, rgba(182,255,60,.12) 0%, transparent 65%);
      pointer-events: none;
    }
    .rv-hero-body {
      position: relative; z-index: 1;
      display: grid; grid-template-columns: auto 1fr;
      gap: 2rem; padding: 2.25rem 2.5rem; align-items: center;
    }
    .rv-hero-av {
      width: 110px; height: 130px; border-radius: 18px;
      background: linear-gradient(160deg, var(--rv-accent), #c94060);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--rv-display); font-size: 2.8rem; font-weight: 800;
      color: #FAF6F1; overflow: hidden; flex-shrink: 0; cursor: pointer;
      border: 2px solid rgba(255,255,255,.1); transition: transform .25s;
    }
    .rv-hero-av:hover { transform: scale(1.04); }
    .rv-hero-eyebrow {
      font-family: var(--rv-mono); font-size: .65rem; font-weight: 500;
      letter-spacing: .12em; text-transform: uppercase;
      color: rgba(250,246,241,.42); margin-bottom: .5rem;
    }
    .rv-hero-name {
      font-family: var(--rv-display); font-size: clamp(1.8rem, 3.5vw, 3rem);
      font-weight: 800; line-height: 1.05; margin-bottom: .2rem;
    }
    .rv-hero-name em {
      font-family: var(--rv-serif); font-style: italic;
      font-weight: 400; color: var(--rv-accent);
    }
    .rv-hero-email { font-size: .8rem; color: rgba(250,246,241,.38); margin-bottom: 1.25rem; }
    .rv-hero-stats { display: flex; gap: 1.75rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .rv-hs-val {
      font-family: var(--rv-display); font-size: 1.6rem; font-weight: 800;
      line-height: 1; margin-bottom: .15rem;
    }
    .rv-hs-val.rose { color: var(--rv-accent); }
    .rv-hs-val.lime { color: var(--rv-accent-2); }
    .rv-hs-lbl {
      font-family: var(--rv-mono); font-size: .6rem; font-weight: 500;
      letter-spacing: .1em; text-transform: uppercase; color: rgba(250,246,241,.38);
    }
    .rv-hero-acts { display: flex; gap: .625rem; flex-wrap: wrap; }

    /* ── BUTTONS ── */
    .rv-btn {
      display: inline-flex; align-items: center; gap: .4rem;
      padding: .65rem 1.25rem; border-radius: 10px;
      font-family: var(--rv-display); font-weight: 600; font-size: .82rem;
      cursor: pointer; text-decoration: none; transition: all .2s; border: none;
    }
    .rv-btn-rose { background: var(--rv-accent); color: #fff; }
    .rv-btn-rose:hover { background: #e0465f; transform: translateY(-1px); }
    .rv-btn-ghost-light {
      background: transparent; color: rgba(250,246,241,.6);
      border: 1.5px solid rgba(255,255,255,.14);
    }
    .rv-btn-ghost-light:hover { border-color: rgba(255,255,255,.35); color: #FAF6F1; }
    .rv-btn-outline {
      background: transparent; color: var(--rv-ink-soft);
      border: 1.5px solid var(--rv-line); font-family: var(--rv-display);
    }
    .rv-btn-outline:hover { border-color: var(--rv-ink); color: var(--rv-ink); }
    .rv-btn-save {
      background: var(--rv-accent); color: #fff; border: none; font-family: var(--rv-display);
    }
    .rv-btn-save:hover { background: #e0465f; transform: translateY(-1px); }
    .rv-btn-danger {
      background: transparent; color: #ef4444;
      border: 1.5px solid rgba(239,68,68,.3); font-family: var(--rv-display);
    }
    .rv-btn-danger:hover { background: rgba(239,68,68,.06); }

    /* ── BASE CARD ── */
    .rv-pcard {
      background: var(--rv-card);
      border: 1px solid var(--rv-line);
      border-radius: 20px; overflow: hidden;
    }
    .rv-pcard-dark {
      background: var(--rv-ink); color: #FAF6F1;
      border: none; border-radius: 20px; overflow: hidden;
    }
    .rv-pcard-head {
      padding: 18px 20px 0;
      display: flex; align-items: flex-start; justify-content: space-between;
    }
    .rv-pcard-title {
      font-family: var(--rv-display); font-size: .95rem;
      font-weight: 700; color: var(--rv-ink); margin-bottom: .2rem;
    }
    .rv-pcard-sub { font-size: .73rem; color: var(--rv-muted); margin-bottom: 1rem; }

    /* ── ACHIEVEMENTS ── */
    .rv-ach-grid {
      display: grid; grid-template-columns: repeat(10, 1fr);
      gap: .5rem; padding: 14px 20px 18px;
    }
    .rv-ach-tile {
      aspect-ratio: 1; border-radius: 12px;
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; gap: .25rem; padding: .5rem .35rem;
      text-align: center; transition: transform .2s;
    }
    .rv-ach-tile.earned { background: var(--rv-ink); }
    .rv-ach-tile.locked { background: var(--rv-bg-alt); border: 1px dashed var(--rv-line); }
    .rv-ach-tile:hover { transform: translateY(-2px); }
    .rv-ach-icon { font-size: 1.25rem; line-height: 1; }
    .rv-ach-tile.locked .rv-ach-icon { filter: grayscale(1) opacity(.3); }
    .rv-ach-name {
      font-family: var(--rv-display); font-size: .55rem;
      font-weight: 700; line-height: 1.2; color: #FAF6F1;
    }
    .rv-ach-tile.locked .rv-ach-name { color: var(--rv-muted); }

    /* ── BODY STATS ── */
    .rv-stats6 {
      display: grid; grid-template-columns: repeat(6, 1fr);
      border-top: 1px solid var(--rv-line);
    }
    .rv-sc {
      padding: 1rem .75rem; border-right: 1px solid var(--rv-line); text-align: center;
    }
    .rv-sc:last-child { border-right: none; }
    .rv-sc-val {
      font-family: var(--rv-display); font-size: 1.1rem; font-weight: 800;
      line-height: 1; margin-bottom: .25rem;
    }
    .rv-sc-val.accent { color: var(--rv-accent); }
    .rv-sc-lbl {
      font-family: var(--rv-mono); font-size: .56rem; font-weight: 500;
      letter-spacing: .1em; text-transform: uppercase; color: var(--rv-muted);
    }
    .rv-prog-wrap { padding: 1rem 20px; border-top: 1px solid var(--rv-line); }
    .rv-prog-label {
      display: flex; justify-content: space-between;
      font-size: .7rem; color: var(--rv-muted); margin-bottom: .4rem;
    }
    .rv-prog-bar { height: 7px; background: var(--rv-bg-alt); border-radius: 99px; overflow: hidden; }
    .rv-prog-fill {
      height: 100%; border-radius: 99px;
      background: linear-gradient(90deg, var(--rv-accent), var(--rv-accent-3));
      transition: width .8s ease;
    }

    /* ── GOALS (dark) ── */
    .rv-goals-body { padding: 20px; }
    .rv-goals-ey {
      font-family: var(--rv-mono); font-size: .6rem; letter-spacing: .12em;
      text-transform: uppercase; color: rgba(250,246,241,.35); margin-bottom: .625rem;
    }
    .rv-goals-num {
      font-family: var(--rv-display); font-size: 3rem; font-weight: 800;
      color: var(--rv-accent-2); line-height: 1; margin-bottom: .1rem;
    }
    .rv-goals-unit {
      font-family: var(--rv-mono); font-size: .72rem;
      color: rgba(250,246,241,.3); margin-bottom: 1.5rem;
    }
    .rv-mbar { display: flex; height: 9px; border-radius: 99px; overflow: hidden; gap: 2px; margin-bottom: .45rem; }
    .rv-mseg { border-radius: 99px; flex-shrink: 0; }
    .rv-mleg { display: flex; gap: .875rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
    .rv-ml {
      display: flex; align-items: center; gap: .3rem;
      font-family: var(--rv-mono); font-size: .6rem; color: rgba(250,246,241,.4);
    }
    .rv-md { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }

    /* ── PLAN (dark) ── */
    .rv-plan-body { padding: 20px; }
    .rv-plan-tier {
      font-family: var(--rv-display); font-size: 2.4rem; font-weight: 800; line-height: 1; margin-bottom: .1rem;
    }
    .rv-plan-tier em {
      font-family: var(--rv-serif); font-style: italic; font-weight: 400; color: var(--rv-accent);
    }
    .rv-plan-sub {
      font-family: var(--rv-mono); font-size: .6rem; letter-spacing: .1em;
      text-transform: uppercase; color: rgba(250,246,241,.28); margin-bottom: 1.25rem;
    }
    .rv-plan-plbl {
      display: flex; justify-content: space-between; margin-bottom: .4rem;
      font-family: var(--rv-mono); font-size: .58rem; color: rgba(250,246,241,.35); letter-spacing: .06em;
    }
    .rv-plan-pbar { height: 5px; background: rgba(255,255,255,.07); border-radius: 99px; overflow: hidden; margin-bottom: 1.25rem; }
    .rv-plan-pfill {
      height: 100%; border-radius: 99px;
      background: linear-gradient(90deg, var(--rv-accent), var(--rv-accent-2));
    }
    .rv-plan-rows { margin-bottom: 1.25rem; }
    .rv-plan-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: .5rem 0; border-bottom: 1px solid rgba(255,255,255,.05);
    }
    .rv-plan-row:last-child { border-bottom: none; }
    .rv-plan-rl { font-family: var(--rv-mono); font-size: .58rem; letter-spacing: .07em; color: rgba(250,246,241,.32); text-transform: uppercase; }
    .rv-plan-rv { font-family: var(--rv-display); font-weight: 700; font-size: .85rem; }

    /* ── PHOTOS ── */
    .rv-photos-body { padding: 14px 20px 18px; }
    .rv-photos-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .875rem; }
    .rv-photo-slot {
      aspect-ratio: 3/4; border-radius: 12px; overflow: hidden;
      position: relative; background: var(--rv-bg-alt); border: 1px solid var(--rv-line);
    }
    .rv-photo-inner {
      width: 100%; height: 100%; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: .4rem; color: var(--rv-muted);
    }
    .rv-photo-empty {
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; gap: .4rem; border-style: dashed;
      cursor: pointer; text-decoration: none; color: var(--rv-muted); transition: all .2s;
      aspect-ratio: 3/4; border-radius: 12px; border: 1px dashed var(--rv-line);
      background: var(--rv-bg-alt);
    }
    .rv-photo-empty:hover { background: var(--rv-line); border-color: var(--rv-ink); }

    /* ── PREFS ── */
    .rv-prefs-body { padding: 14px 20px 18px; }
    .rv-psec { margin-bottom: 1.5rem; }
    .rv-psec:last-child { margin-bottom: 0; }
    .rv-plbl {
      font-family: var(--rv-mono); font-size: .6rem; font-weight: 500;
      letter-spacing: .12em; text-transform: uppercase; color: var(--rv-muted); margin-bottom: .75rem;
    }
    .rv-chips { display: flex; flex-wrap: wrap; gap: .4rem; }
    .rv-chip {
      padding: .38rem .875rem; border-radius: 99px; font-size: .76rem;
      font-weight: 600; border: 1px solid var(--rv-line); background: var(--rv-bg-alt); color: var(--rv-muted);
    }
    .rv-chip.on { background: var(--rv-ink); color: var(--rv-accent-2); border-color: var(--rv-ink); }
    .rv-seg {
      display: inline-flex; background: var(--rv-bg-alt); border-radius: 10px;
      padding: .18rem; border: 1px solid var(--rv-line);
    }
    .rv-seg-btn {
      padding: .45rem 1.1rem; border-radius: 8px; border: none; font-size: .78rem;
      font-weight: 600; cursor: pointer; color: var(--rv-muted); background: transparent;
      transition: all .2s; font-family: var(--rv-display);
    }
    .rv-seg-btn.on { background: var(--rv-card); color: var(--rv-ink); box-shadow: 0 2px 6px rgba(0,0,0,.07); }
    .rv-lang-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: .4rem; }
    .rv-lang-btn {
      display: flex; align-items: center; gap: .4rem;
      padding: .5rem .7rem; border-radius: 9px; border: 1px solid var(--rv-line);
      background: var(--rv-bg-alt); color: var(--rv-muted); cursor: pointer;
      transition: all .2s; font-weight: 600; font-size: .8rem; font-family: var(--rv-body);
    }
    .rv-lang-btn:hover { border-color: var(--rv-ink); color: var(--rv-ink); }
    .rv-lang-btn.on { border-color: var(--rv-accent); background: rgba(255,92,122,.06); color: var(--rv-accent); }

    /* ── SETTINGS ── */
    .rv-settings-body { padding: 14px 20px 18px; }
    .rv-ssec {
      margin-bottom: 1.75rem; padding-bottom: 1.75rem;
      border-bottom: 1px solid var(--rv-line);
    }
    .rv-ssec:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
    .rv-slbl {
      font-family: var(--rv-mono); font-size: .6rem; font-weight: 500;
      letter-spacing: .12em; text-transform: uppercase; color: var(--rv-muted); margin-bottom: .875rem;
    }
    .rv-fgrid { display: grid; grid-template-columns: repeat(auto-fit, minmax(175px, 1fr)); gap: .75rem; margin-bottom: 1rem; }
    .rv-fg { display: flex; flex-direction: column; gap: .3rem; }
    .rv-fg label {
      font-size: .65rem; font-weight: 700; color: var(--rv-muted);
      text-transform: uppercase; letter-spacing: .06em; font-family: var(--rv-mono);
    }
    .rv-fi {
      padding: .65rem .875rem; border-radius: 10px; border: 1px solid var(--rv-line);
      background: var(--rv-bg-alt); color: var(--rv-ink); font-size: .875rem;
      font-weight: 600; outline: none; transition: all .2s; font-family: var(--rv-body); width: 100%;
    }
    .rv-fi:focus { border-color: var(--rv-accent); box-shadow: 0 0 0 3px rgba(255,92,122,.1); }
    .rv-action-row {
      display: flex; align-items: center; gap: .6rem; width: 100%;
      padding: .8rem .9rem; border-radius: 10px; border: 1px solid var(--rv-line);
      background: var(--rv-bg-alt); color: var(--rv-ink); font-weight: 600;
      font-size: .8rem; cursor: pointer; text-decoration: none; transition: all .2s;
      margin-bottom: .4rem; font-family: var(--rv-body);
    }
    .rv-action-row:hover { border-color: var(--rv-ink); transform: translateX(3px); }
    .rv-action-row.danger { color: #ef4444; }
    .rv-action-row.danger:hover { background: rgba(239,68,68,.04); border-color: rgba(239,68,68,.2); }

    /* ── MODAL ── */
    .rv-modal {
      position: fixed; inset: 0; background: rgba(22,17,15,.6);
      backdrop-filter: blur(10px); z-index: 300; display: none;
      align-items: center; justify-content: center; padding: 1rem;
    }
    .rv-modal.open { display: flex; }
    .rv-modal-box {
      background: var(--rv-card); border: 1px solid var(--rv-line);
      border-radius: 20px; width: 100%; max-width: 400px; overflow: hidden;
      animation: rvUp .3s ease;
    }
    @keyframes rvUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .rv-modal-head {
      padding: 1.1rem 1.25rem; border-bottom: 1px solid var(--rv-line);
      display: flex; align-items: center; justify-content: space-between;
    }
    .rv-modal-title { font-family: var(--rv-display); font-size: 1rem; font-weight: 700; color: var(--rv-ink); }
    .rv-modal-close {
      width: 28px; height: 28px; border-radius: 7px; background: var(--rv-bg-alt);
      border: 1px solid var(--rv-line); cursor: pointer;
      display: flex; align-items: center; justify-content: center; color: var(--rv-muted); font-size: .95rem;
    }
    .rv-modal-body { padding: 1.25rem; }

    /* ── TOAST ── */
    .rv-toast {
      position: fixed; top: 4.5rem; right: 1.25rem; z-index: 9999;
      background: var(--rv-ink); color: #FAF6F1; padding: .75rem 1.25rem;
      border-radius: 10px; font-family: var(--rv-display); font-weight: 700;
      font-size: .82rem; box-shadow: 0 8px 24px rgba(0,0,0,.18);
      transform: translateY(-12px); opacity: 0; pointer-events: none;
      transition: all .3s cubic-bezier(.4,0,.2,1);
    }
    .rv-toast.show { transform: translateY(0); opacity: 1; }

    /* ── RESPONSIVE ── */
    @media(max-width: 1100px) {
      .rv-p8 { grid-column: span 12; }
      .rv-p4 { grid-column: span 12; }
      .rv-ach-grid { grid-template-columns: repeat(5, 1fr); }
      .rv-stats6 { grid-template-columns: repeat(3, 1fr); }
      .rv-sc:nth-child(3) { border-right: none; }
    }
    @media(max-width: 900px) {
      .rv-shell { grid-template-columns: 1fr; }
      .rv-sb { display: none; }
      .rv-ach-grid { grid-template-columns: repeat(5, 1fr); }
      .rv-hero-body { padding: 1.75rem 1.25rem; }
    }
    @media(max-width: 640px) {
      .rv-hero-body { grid-template-columns: 1fr; text-align: center; }
      .rv-hero-stats { justify-content: center; }
      .rv-hero-acts { justify-content: center; }
      .rv-ach-grid { grid-template-columns: repeat(4, 1fr); }
      .rv-stats6 { grid-template-columns: repeat(2, 1fr); }
      .rv-sc:nth-child(2) { border-right: none; }
      .rv-photos-grid { grid-template-columns: repeat(2, 1fr); }
      .rv-content { padding-bottom: 5.5rem; }
      .rv-fi, input.rv-fi, select.rv-fi { font-size: 16px !important; }
    }
  </style>
</head>
<body>

<DashNav userId={user.id} userName={userName} tierLabel={tierLabel} planType={planType} activePage="profile" />

<style is:global>
  body, body[data-theme="light"] {
    background: var(--rv-bg, #FAF6F1) !important;
    color: var(--rv-ink, #16110F) !important;
  }
  .dash-nav { display: none !important; }
  #dn-footer { display: none !important; }
  .rv-page-wrap { padding-top: 0 !important; }
</style>

<!-- ════════════════ APP SHELL ════════════════ -->
<div class="rv-shell">

  <Sidebar userName={userName} planType={planType} tierLabel={tierLabel} currentDay={currentDay} activePage="profile" />

  <!-- ── Main ── -->
  <div class="rv-main">

    <!-- Topbar -->
    <header class="rv-topbar">
      <div class="rv-top-l">
        <p class="rv-top-greet">Your <em>Profile</em></p>
        <p class="rv-top-meta">DAY {currentDay} · {plan.name.toUpperCase()} · LEVEL {level}</p>
      </div>
      <div class="rv-top-r">
        <a href="/dashboard/notifications" class="rv-top-icon" aria-label="Notifications">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        </a>
        <button class="rv-top-cta" onclick="document.getElementById('weightModal').classList.add('open')">+ Log Weight</button>
      </div>
    </header>

    <!-- Content -->
    <div class="rv-content">
      <div class="rv-pgrid">

        <!-- ── HERO (span 12) ── -->
        <div class="rv-hero">
          <div class="rv-hero-grad"></div>
          <div class="rv-hero-glow"></div>
          <div class="rv-hero-glow2"></div>
          <div class="rv-hero-body">
            <div class="rv-hero-av" id="openAvatarBtn" title="Change avatar">
              {profile.avatar_url?.startsWith('emoji:')
                ? profile.avatar_url.replace('emoji:','')
                : profile.avatar_url
                  ? <img src={profile.avatar_url} alt={profile.full_name} style="width:100%;height:100%;object-fit:cover;"/>
                  : avatarLetter}
            </div>
            <div>
              <div class="rv-hero-eyebrow">{plan.emoji} {plan.name} · Level {level}</div>
              <div class="rv-hero-name">
                {profile.full_name?.split(' ')[0]}
                {profile.full_name?.split(' ').length > 1 && <em> {profile.full_name?.split(' ').slice(1).join(' ')}</em>}
              </div>
              <div class="rv-hero-email">{profile.email}</div>
              <div class="rv-hero-stats">
                <div>
                  <div class="rv-hs-val rose">{currentStreak}</div>
                  <div class="rv-hs-lbl">Day Streak</div>
                </div>
                <div>
                  <div class="rv-hs-val">{totalXP.toLocaleString()}</div>
                  <div class="rv-hs-lbl">Total XP</div>
                </div>
                <div>
                  <div class="rv-hs-val lime">{weightChange > 0 ? weightChange.toFixed(1) : '0.0'}</div>
                  <div class="rv-hs-lbl">{wLabel} Lost</div>
                </div>
                <div>
                  <div class="rv-hs-val">{currentDay}</div>
                  <div class="rv-hs-lbl">Days In</div>
                </div>
              </div>
              <div class="rv-hero-acts">
                <button class="rv-btn rv-btn-rose" onclick="document.getElementById('editSection').scrollIntoView({behavior:'smooth'})">
                  Edit Profile
                </button>
                <a href="/dashboard/share" class="rv-btn rv-btn-ghost-light">Share Progress</a>
              </div>
            </div>
          </div>
        </div>

        <!-- ── Achievements (span 12) ── -->
        <div class="rv-p12 rv-pcard">
          <div class="rv-pcard-head">
            <div>
              <div class="rv-pcard-title">Achievements</div>
              <div class="rv-pcard-sub">{achievementsList.filter(a => a.done).length} of {achievementsList.length} earned</div>
            </div>
          </div>
          <div class="rv-ach-grid">
            {achievementsList.map(a => (
              <div class={`rv-ach-tile${a.done ? ' earned' : ' locked'}`}>
                <div class="rv-ach-icon">{a.done ? a.icon : '🔒'}</div>
                <div class="rv-ach-name">{a.name}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- ── Body Stats (span 8) ── -->
        <div class="rv-p8 rv-pcard">
          <div class="rv-pcard-head">
            <div>
              <div class="rv-pcard-title">Body Stats</div>
              <div class="rv-pcard-sub">Physical progress tracking</div>
            </div>
            <button class="rv-btn rv-btn-outline" onclick="document.getElementById('weightModal').classList.add('open')" style="font-size:.75rem;padding:.45rem .875rem;flex-shrink:0;">+ Log</button>
          </div>
          <div class="rv-stats6">
            <div class="rv-sc">
              <div class="rv-sc-val">{displayHeight}</div>
              <div class="rv-sc-lbl">Height</div>
            </div>
            <div class="rv-sc">
              <div class="rv-sc-val">{weightLogs.length > 0 ? displayStartWeight : '—'}</div>
              <div class="rv-sc-lbl">Start</div>
            </div>
            <div class="rv-sc">
              <div class="rv-sc-val accent">{displayWeight}</div>
              <div class="rv-sc-lbl">Current</div>
            </div>
            <div class="rv-sc">
              <div class="rv-sc-val">{displayTargetWeight}</div>
              <div class="rv-sc-lbl">Goal</div>
            </div>
            <div class="rv-sc">
              <div class="rv-sc-val">{bmi ? bmi.toFixed(1) : '—'}</div>
              <div class="rv-sc-lbl">BMI</div>
            </div>
            <div class="rv-sc">
              <div class="rv-sc-val" style={`font-size:.85rem;color:${bmiCategory.color};`}>{bmiCategory.label}</div>
              <div class="rv-sc-lbl">Category</div>
            </div>
          </div>
          <div class="rv-prog-wrap">
            <div class="rv-prog-label">
              <span>Progress to goal</span>
              <span>{Math.round(progressPercent)}%</span>
            </div>
            <div class="rv-prog-bar">
              <div class="rv-prog-fill" style={`width:${Math.round(progressPercent)}%`}></div>
            </div>
          </div>
        </div>

        <!-- ── Goals Card (span 4, dark) ── -->
        <div class="rv-p4 rv-pcard-dark">
          <div class="rv-goals-body">
            <div class="rv-goals-ey">TARGET WEIGHT</div>
            <div class="rv-goals-num">{displayTargetWeight}</div>
            <div class="rv-goals-unit">{wLabel} goal</div>
            <div style="font-family:var(--rv-mono);font-size:.58rem;letter-spacing:.08em;color:rgba(250,246,241,.32);margin-bottom:.5rem;text-transform:uppercase;">Daily Macros</div>
            <div class="rv-mbar">
              <div class="rv-mseg" style={`background:var(--rv-accent);width:${fatPct}%`}></div>
              <div class="rv-mseg" style={`background:var(--rv-accent-2);width:${protPct}%`}></div>
              <div class="rv-mseg" style={`background:#6366f1;width:${carbPct}%`}></div>
            </div>
            <div class="rv-mleg">
              <span class="rv-ml"><span class="rv-md" style="background:var(--rv-accent);"></span>Fat {fatGrams}g</span>
              <span class="rv-ml"><span class="rv-md" style="background:var(--rv-accent-2);"></span>Pro {proteinGrams}g</span>
              <span class="rv-ml"><span class="rv-md" style="background:#6366f1;"></span>Carbs {carbGrams}g</span>
            </div>
            <button class="rv-btn rv-btn-rose" onclick="document.getElementById('weightModal').classList.add('open')" style="width:100%;justify-content:center;">
              Log Weight
            </button>
          </div>
        </div>

        <!-- ── Progress Photos (span 8) ── -->
        <div class="rv-p8 rv-pcard">
          <div class="rv-pcard-head">
            <div>
              <div class="rv-pcard-title">Progress Photos</div>
              <div class="rv-pcard-sub">Visual transformation timeline</div>
            </div>
            <a href="/dashboard/photos" class="rv-btn rv-btn-outline" style="font-size:.75rem;padding:.45rem .875rem;flex-shrink:0;text-decoration:none;">View All →</a>
          </div>
          <div class="rv-photos-body">
            <div class="rv-photos-grid">
              <div class="rv-photo-slot">
                <div class="rv-photo-inner">
                  <span style="font-size:1.75rem;">📸</span>
                  <span style="font-size:.65rem;font-family:var(--rv-mono);">Before</span>
                </div>
              </div>
              <div class="rv-photo-slot">
                <div class="rv-photo-inner">
                  <span style="font-size:1.75rem;">📸</span>
                  <span style="font-size:.65rem;font-family:var(--rv-mono);">Progress</span>
                </div>
              </div>
              <a href="/dashboard/photos" class="rv-photo-empty">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                <span style="font-size:.68rem;font-family:var(--rv-mono);">Add Photo</span>
              </a>
            </div>
          </div>
        </div>

        <!-- ── Plan (span 4, dark) ── -->
        <div class="rv-p4 rv-pcard-dark">
          <div class="rv-plan-body">
            <div class="rv-goals-ey">CURRENT PLAN</div>
            <div class="rv-plan-tier">{plan.name} <em>{plan.emoji}</em></div>
            <div class="rv-plan-sub">{maxDays}-DAY JOURNEY</div>
            <div class="rv-plan-plbl">
              <span>Day {currentDay} of {maxDays}</span>
              <span>{dayProgress}%</span>
            </div>
            <div class="rv-plan-pbar">
              <div class="rv-plan-pfill" style={`width:${dayProgress}%`}></div>
            </div>
            <div class="rv-plan-rows">
              <div class="rv-plan-row">
                <span class="rv-plan-rl">DAYS LEFT</span>
                <span class="rv-plan-rv" style="color:var(--rv-accent-2);">{daysLeft}</span>
              </div>
              <div class="rv-plan-row">
                <span class="rv-plan-rl">LEVEL</span>
                <span class="rv-plan-rv">Level {level}</span>
              </div>
              <div class="rv-plan-row">
                <span class="rv-plan-rl">PERFECT DAYS</span>
                <span class="rv-plan-rv">{perfectDays}</span>
              </div>
              <div class="rv-plan-row">
                <span class="rv-plan-rl">TOTAL XP</span>
                <span class="rv-plan-rv">{totalXP.toLocaleString()}</span>
              </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:.4rem;">
              <a href="/dashboard/billing" class="rv-btn rv-btn-rose" style="justify-content:center;text-decoration:none;">Manage Billing</a>
              <a href="/dashboard/upgrade" class="rv-btn rv-btn-ghost-light" style="justify-content:center;text-decoration:none;border-color:rgba(255,255,255,.1);color:rgba(250,246,241,.45);">Upgrade Plan</a>
            </div>
          </div>
        </div>

        <!-- ── Preferences (span 12) ── -->
        <div class="rv-p12 rv-pcard">
          <div class="rv-pcard-head">
            <div>
              <div class="rv-pcard-title">Preferences</div>
              <div class="rv-pcard-sub">Units, language and dietary settings</div>
            </div>
          </div>
          <div class="rv-prefs-body">
            <div class="rv-psec">
              <div class="rv-plbl">Units of measurement</div>
              <div class="rv-seg">
                <button class={`rv-seg-btn${units === 'imperial' ? ' on' : ''}`} onclick="setUnits('imperial')">Imperial (lbs / ft)</button>
                <button class={`rv-seg-btn${units === 'metric' ? ' on' : ''}`} onclick="setUnits('metric')">Metric (kg / cm)</button>
              </div>
            </div>
            <div class="rv-psec">
              <div class="rv-plbl">Language</div>
              <div class="rv-lang-grid">
                {[
                  { code:'en', flag:'🇺🇸', label:'English' },
                  { code:'fr', flag:'🇫🇷', label:'Français' },
                  { code:'de', flag:'🇩🇪', label:'Deutsch' },
                  { code:'es', flag:'🇪🇸', label:'Español' },
                  { code:'pt', flag:'🇧🇷', label:'Português' },
                ].map(l => (
                  <button class={`rv-lang-btn${lang === l.code ? ' on' : ''}`} onclick={`setLang('${l.code}')`}>
                    {l.flag} {l.label}
                  </button>
                ))}
              </div>
            </div>
            {dietaryRestrictions.length > 0 && (
              <div class="rv-psec">
                <div class="rv-plbl">Dietary preferences</div>
                <div class="rv-chips">
                  {allDietChips.map(chip => (
                    <span class={`rv-chip${dietaryRestrictions.includes(chip) ? ' on' : ''}`}>{chip}</span>
                  ))}
                </div>
              </div>
            )}
            {fastingProtocol && (
              <div class="rv-psec">
                <div class="rv-plbl">Fasting protocol</div>
                <span class="rv-chip on">{fastingProtocol}</span>
              </div>
            )}
          </div>
        </div>

        <!-- ── Settings (span 12) ── -->
        <div class="rv-p12 rv-pcard" id="editSection">
          <div class="rv-pcard-head">
            <div>
              <div class="rv-pcard-title">Account Settings</div>
              <div class="rv-pcard-sub">Profile, macros, security and account</div>
            </div>
          </div>
          <div class="rv-settings-body">

            <div class="rv-ssec">
              <div class="rv-slbl">Profile</div>
              <form id="editForm" onsubmit="saveProfile(event)">
                <div class="rv-fgrid">
                  <div class="rv-fg">
                    <label>Full Name</label>
                    <input class="rv-fi" name="full_name" value={profile.full_name || ''} placeholder="Your name"/>
                  </div>
                </div>
                {units === 'imperial' ? (
                  <div class="rv-fgrid">
                    <div class="rv-fg">
                      <label>Weight (lbs)</label>
                      <input class="rv-fi" name="weight" type="number" step="0.1" min="44" max="1100" value={weightInputVal} placeholder="lbs"/>
                    </div>
                    <div class="rv-fg">
                      <label>Height (ft)</label>
                      <input class="rv-fi" name="height_ft" type="number" min="1" max="9" value={heightFtVal} placeholder="ft"/>
                    </div>
                    <div class="rv-fg">
                      <label>Height (in)</label>
                      <input class="rv-fi" name="height_in" type="number" min="0" max="11" value={heightInVal} placeholder="in"/>
                    </div>
                    <div class="rv-fg">
                      <label>Target Weight (lbs)</label>
                      <input class="rv-fi" name="target_weight" type="number" step="0.1" min="44" max="1100" value={targetInputVal} placeholder="lbs"/>
                    </div>
                  </div>
                ) : (
                  <div class="rv-fgrid">
                    <div class="rv-fg">
                      <label>Weight (kg)</label>
                      <input class="rv-fi" name="weight" type="number" step="0.1" min="20" max="500" value={profile.weight_kg || ''} placeholder="kg"/>
                    </div>
                    <div class="rv-fg">
                      <label>Height (cm)</label>
                      <input class="rv-fi" name="height_cm" type="number" min="50" max="300" value={profile.height_cm || ''} placeholder="cm"/>
                    </div>
                    <div class="rv-fg">
                      <label>Target Weight (kg)</label>
                      <input class="rv-fi" name="target_weight" type="number" step="0.1" min="20" max="500" value={profile.target_weight_kg || ''} placeholder="kg"/>
                    </div>
                  </div>
                )}
                <button type="submit" class="rv-btn rv-btn-save">Save Profile</button>
              </form>
            </div>

            <div class="rv-ssec">
              <div class="rv-slbl">Daily Macro Goals</div>
              <form id="macroForm" onsubmit="saveMacros(event)">
                <div class="rv-fgrid">
                  <div class="rv-fg">
                    <label>Calories (kcal)</label>
                    <input class="rv-fi" name="calories" type="number" min="800" max="9999" value={mgCal} placeholder="kcal"/>
                  </div>
                  <div class="rv-fg">
                    <label>Protein (g)</label>
                    <input class="rv-fi" name="protein" type="number" min="10" max="500" value={mgProt} placeholder="g"/>
                  </div>
                  <div class="rv-fg">
                    <label>Fat (g)</label>
                    <input class="rv-fi" name="fat" type="number" min="10" max="500" value={mgFat} placeholder="g"/>
                  </div>
                  <div class="rv-fg">
                    <label>Carbs (g)</label>
                    <input class="rv-fi" name="carbs" type="number" min="0" max="500" value={mgCarb} placeholder="g"/>
                  </div>
                </div>
                <button type="submit" class="rv-btn rv-btn-save">Save Macros</button>
              </form>
            </div>

            <div class="rv-ssec">
              <div class="rv-slbl">Security</div>
              <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.25rem;" id="securityGrid">
                <form onsubmit="changeEmail(event)">
                  <div class="rv-fg" style="margin-bottom:.75rem;">
                    <label>New Email Address</label>
                    <input class="rv-fi" id="newEmail" type="email" placeholder="new@email.com"/>
                  </div>
                  <button type="submit" class="rv-btn rv-btn-save">Update Email</button>
                </form>
                <form onsubmit="changePwd(event)">
                  <div class="rv-fg" style="margin-bottom:.5rem;">
                    <label>Current Password</label>
                    <input class="rv-fi" id="curPwd" type="password" autocomplete="current-password"/>
                  </div>
                  <div class="rv-fg" style="margin-bottom:.5rem;">
                    <label>New Password</label>
                    <input class="rv-fi" id="newPwd" type="password" autocomplete="new-password"/>
                  </div>
                  <div class="rv-fg" style="margin-bottom:.75rem;">
                    <label>Confirm Password</label>
                    <input class="rv-fi" id="confirmPwd" type="password" autocomplete="new-password"/>
                  </div>
                  <button type="submit" class="rv-btn rv-btn-save">Update Password</button>
                </form>
              </div>
            </div>

            <div class="rv-ssec">
              <div class="rv-slbl">Data &amp; Account</div>
              <a href="/dashboard/export" class="rv-action-row">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Export My Data
              </a>
              <a href="/api/auth/logout" class="rv-action-row">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Sign Out
              </a>
              <button onclick="document.getElementById('deleteModal').classList.add('open')" class="rv-action-row danger" style="text-align:left;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                Delete Account
              </button>
            </div>

          </div>
        </div>

      </div><!-- /rv-pgrid -->
    </div><!-- /rv-content -->
  </div><!-- /rv-main -->
</div><!-- /rv-shell -->

<!-- ── Modals ── -->
<div class="rv-modal" id="weightModal">
  <div class="rv-modal-box">
    <div class="rv-modal-head">
      <span class="rv-modal-title">Log Weight</span>
      <button class="rv-modal-close" onclick="document.getElementById('weightModal').classList.remove('open')">×</button>
    </div>
    <div class="rv-modal-body">
      <form id="weightForm" onsubmit="logWeight(event)">
        <div class="rv-fg" style="margin-bottom:.875rem;">
          <label>Weight ({wLabel})</label>
          <input class="rv-fi" id="weightInput" type="number" step="0.1" min="44" max="1100" placeholder={`Enter in ${wLabel}`} required/>
        </div>
        <div class="rv-fg" style="margin-bottom:1.1rem;">
          <label>Date</label>
          <input class="rv-fi" id="weightDate" type="date" value={new Date().toISOString().split('T')[0]}/>
        </div>
        <button type="submit" class="rv-btn rv-btn-save" style="width:100%;justify-content:center;">Save Weight</button>
      </form>
    </div>
  </div>
</div>

<div class="rv-modal" id="avatarModal">
  <div class="rv-modal-box">
    <div class="rv-modal-head">
      <span class="rv-modal-title">Change Avatar</span>
      <button class="rv-modal-close" onclick="document.getElementById('avatarModal').classList.remove('open')">×</button>
    </div>
    <div class="rv-modal-body">
      <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:.4rem;margin-bottom:1rem;">
        {['🥑','🔥','💪','⚡','🏆','🌟','🚀','💎','👑','🏅','🎯','🌿'].map(emoji => (
          <button onclick={`setEmoji('${emoji}')`} class="ava-btn">{emoji}</button>
        ))}
      </div>
      <div style="border-top:1px solid var(--rv-line);padding-top:.875rem;">
        <label class="rv-btn rv-btn-outline" style="cursor:pointer;justify-content:center;width:100%;display:flex;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:.35rem;"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          Upload Photo
          <input type="file" id="avaUpload" accept="image/*" style="display:none;" onchange="uploadAvatar(event)"/>
        </label>
      </div>
    </div>
  </div>
</div>

<div class="rv-modal" id="deleteModal">
  <div class="rv-modal-box">
    <div class="rv-modal-head">
      <span class="rv-modal-title" style="color:#ef4444;">Delete Account</span>
      <button class="rv-modal-close" onclick="document.getElementById('deleteModal').classList.remove('open')">×</button>
    </div>
    <div class="rv-modal-body">
      <p style="margin-bottom:1rem;font-size:.82rem;color:var(--rv-muted);line-height:1.6;">This permanently deletes your account and all data. This cannot be undone.</p>
      <div class="rv-fg" style="margin-bottom:1rem;">
        <label>Type DELETE to confirm</label>
        <input class="rv-fi" id="deleteConfirm" placeholder="DELETE"/>
      </div>
      <button onclick="deleteAccount()" class="rv-btn rv-btn-danger" style="width:100%;justify-content:center;border-radius:10px;">Delete My Account</button>
    </div>
  </div>
</div>

<div class="rv-toast" id="toast"></div>

<style>
  .ava-btn {
    font-size: 1.4rem; padding: .4rem; border-radius: 9px;
    border: 1px solid var(--rv-line); background: var(--rv-bg-alt);
    cursor: pointer; transition: all .2s; line-height: 1;
  }
  .ava-btn:hover { border-color: var(--rv-accent); transform: scale(1.1); }
</style>

<script is:inline define:vars={{ unitsVar: units, langVar: lang }}>
  var cu = unitsVar;
  var cl = langVar;

  function showToast(msg) {
    var t = document.getElementById('toast');
    t.textContent = msg; t.classList.add('show');
    setTimeout(function() { t.classList.remove('show'); }, 3000);
  }

  document.querySelectorAll('.rv-modal').forEach(function(m) {
    m.addEventListener('click', function(e) { if (e.target === m) m.classList.remove('open'); });
  });

  document.getElementById('openAvatarBtn').addEventListener('click', function() {
    document.getElementById('avatarModal').classList.add('open');
  });

  function setEmoji(emoji) {
    fetch('/api/profile/update-avatar', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ avatar: 'emoji:' + emoji })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) { showToast('Avatar updated!'); setTimeout(function() { location.reload(); }, 700); }
      else showToast('Error: ' + (d.error || 'Failed'));
    });
  }

  function uploadAvatar(e) {
    var file = e.target.files[0]; if (!file) return;
    var fd = new FormData(); fd.append('avatar', file);
    fetch('/api/profile/update-avatar', { method: 'POST', body: fd })
      .then(function(r) { return r.json(); }).then(function(d) {
        if (d.success) { showToast('Photo updated!'); setTimeout(function() { location.reload(); }, 700); }
        else showToast('Error: ' + (d.error || 'Failed'));
      });
  }

  function saveProfile(e) {
    e.preventDefault();
    var fd = new FormData(e.target);
    var body = { full_name: fd.get('full_name') };
    if (cu === 'imperial') {
      var ft = parseFloat(fd.get('height_ft')) || 0;
      var inch = parseFloat(fd.get('height_in')) || 0;
      body.height_cm = Math.round((ft * 12 + inch) * 2.54);
      body.weight_kg = Math.round(parseFloat(fd.get('weight')) / 2.20462 * 10) / 10;
      body.target_weight_kg = Math.round(parseFloat(fd.get('target_weight')) / 2.20462 * 10) / 10;
    } else {
      body.height_cm = parseInt(fd.get('height_cm')) || null;
      body.weight_kg = parseFloat(fd.get('weight')) || null;
      body.target_weight_kg = parseFloat(fd.get('target_weight')) || null;
    }
    fetch('/api/profile/update', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) { showToast('Profile saved!'); setTimeout(function() { location.reload(); }, 700); }
      else showToast('Error: ' + (d.error || 'Failed'));
    });
  }

  function saveMacros(e) {
    e.preventDefault();
    var fd = new FormData(e.target);
    fetch('/api/macro-goals/save', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        daily_calories: parseInt(fd.get('calories')),
        protein_g: parseInt(fd.get('protein')),
        fat_g: parseInt(fd.get('fat')),
        carbs_g: parseInt(fd.get('carbs')),
      })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) showToast('Macros saved!');
      else showToast('Error: ' + (d.error || 'Failed'));
    });
  }

  function logWeight(e) {
    e.preventDefault();
    var w = parseFloat(document.getElementById('weightInput').value);
    var dt = document.getElementById('weightDate').value;
    var kg = cu === 'imperial' ? Math.round(w / 2.20462 * 10) / 10 : w;
    fetch('/api/profile/add-weight', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ weight: kg, logged_date: dt })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) {
        showToast('Weight logged!');
        document.getElementById('weightModal').classList.remove('open');
        setTimeout(function() { location.reload(); }, 700);
      } else showToast('Error: ' + (d.error || 'Failed'));
    });
  }

  function changeEmail(e) {
    e.preventDefault();
    var email = document.getElementById('newEmail').value;
    fetch('/api/auth/change-email', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) showToast('Check email to confirm');
      else showToast('Error: ' + (d.error || 'Failed'));
    });
  }

  function changePwd(e) {
    e.preventDefault();
    var cur = document.getElementById('curPwd').value;
    var nw  = document.getElementById('newPwd').value;
    var conf = document.getElementById('confirmPwd').value;
    if (nw !== conf) { showToast('Passwords do not match'); return; }
    fetch('/api/auth/change-password', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ currentPassword: cur, newPassword: nw })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) showToast('Password updated!');
      else showToast('Error: ' + (d.error || 'Failed'));
    });
  }

  function setUnits(u) {
    fetch('/api/profile/update-units', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ units: u })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) { showToast('Units updated!'); setTimeout(function() { location.reload(); }, 600); }
    });
  }

  function setLang(l) {
    fetch('/api/profile/update-language', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ lang: l })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) { showToast('Language updated!'); setTimeout(function() { location.reload(); }, 600); }
    });
  }

  function deleteAccount() {
    var conf = document.getElementById('deleteConfirm').value;
    if (conf !== 'DELETE') { showToast('Type DELETE to confirm'); return; }
    fetch('/api/auth/delete-account', { method: 'POST' })
      .then(function(r) { return r.json(); }).then(function(d) {
        if (d.success) { showToast('Account deleted'); location.href = '/'; }
        else showToast('Error: ' + (d.error || 'Failed'));
      });
  }
</script>

</body>
</html>
