---
import { getUserJourney, getMaxJourneyDays, getAchievements, kgToLbs, cmToInches } from '../../lib/supabase';
import { requireAuth } from '../../lib/auth';
import { generateInsights } from '../../lib/insights';
import Sidebar from '../../components/Sidebar.astro';
import { updateCurrentDay } from '../../lib/supabase';
import { getTranslator, normaliseLang } from '../../lib/i18n';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);
const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? 'Elite' : planType === 'pro_6' ? 'Pro' : 'Basic';

await updateCurrentDay(user.id).catch(() => null);

let journey = null as any;
try {
  journey = await getUserJourney(user.id, db);
} catch (e) {
  console.error('[Progress] DB unavailable:', e);
  return new Response(
    `<!DOCTYPE html><html><head><title>Temporarily Unavailable</title><meta http-equiv="refresh" content="15;url=/dashboard/progress"></head><body style="background:#FAF6F1;color:#16110F;font-family:'Bricolage Grotesque',system-ui,sans-serif;display:flex;align-items:center;justify-content:center;height:100vh;margin:0;flex-direction:column;gap:1.2rem;text-align:center;padding:2rem"><h2 style="font-size:1.6rem;margin:0;color:#FF5C7A">Keto Journey</h2><p style="font-size:1.1rem;margin:0">Progress page temporarily unavailable</p><p style="color:#8A8077;margin:0;font-size:.9rem">Retrying in 15 seconds…</p><a href="/dashboard/progress" style="color:#FF5C7A;font-size:.9rem;margin-top:.5rem">Retry now</a></body></html>`,
    { status: 503, headers: { 'Content-Type': 'text/html' } }
  );
}
if (!journey) return Astro.redirect('/dashboard');

const currentDay  = journey.current_day  || 1;
const totalXP     = journey.total_xp     || 0;
const xpLevel     = journey.level        || 1;
const streakDays  = journey.streak_days  || 0;
const longestStreak = journey.longest_streak || 0;
const perfectDays = journey.perfect_days || 0;
const maxDays     = getMaxJourneyDays(planType);
const xpInLevel   = totalXP % 500;
const xpPct       = Math.round((xpInLevel / 500) * 100);
const journeyPct  = Math.min(100, Math.round((currentDay / maxDays) * 100));
const userName    = profile.full_name?.split(' ')[0] || 'there';

// ── Unit helpers ──────────────────────────────────────────────────────────────
const units  = profile.preferred_units || 'imperial';
const wUnit  = units === 'imperial' ? 'lbs' : 'kg';
const mUnit  = units === 'imperial' ? 'in'  : 'cm';
const toW    = (kg) => units === 'imperial' ? kgToLbs(kg)    : Math.round(kg * 10) / 10;
const toM    = (cm) => units === 'imperial' ? cmToInches(cm) : Math.round(cm * 10) / 10;

// Pre-compute date ranges needed by parallel queries
const fourteenAgo  = new Date(Date.now() - 13 * 86400000).toISOString().split('T')[0];
const ninetyDaysAgo = new Date(Date.now() - 89 * 86400000).toISOString().split('T')[0];

// ── PARALLEL batch: all 12 independent DB queries (graceful empty state on failure) ─────
let progressBatch = new Array(12).fill({ data: null });
try {
  progressBatch = await Promise.all([
  db.from('weight_logs')
    .select('weight, logged_date')
    .eq('user_id', user.id)
    .gte('logged_date', ninetyDaysAgo)
    .order('logged_date', { ascending: true })
    .limit(90),
  db.from('onboarding_data').select('*').eq('user_id', user.id).maybeSingle(),
  db.from('daily_checkins')
    .select('checkin_date, energy_level, followed_meals, water_glasses, mood_level, sleep_hours, sleep_quality')
    .eq('user_id', user.id)
    .order('checkin_date', { ascending: false })
    .limit(14),
  db.from('xp_transactions')
    .select('action_type, xp_amount, description, created_at')
    .eq('user_id', user.id)
    .order('created_at', { ascending: false })
    .limit(10),
  db.from('daily_tasks').select('id').eq('user_id', user.id).eq('completed', true),
  db.from('ketone_logs')
    .select('id, ketone_mmol, measurement_type, logged_date, notes')
    .eq('user_id', user.id)
    .order('logged_date', { ascending: false })
    .limit(14),
  db.from('macro_goals').select('daily_calories, protein_g, fat_g, carbs_g').eq('user_id', user.id).maybeSingle(),
  db.from('food_logs')
    .select('logged_date, calories, protein_g, fat_g, carbs_g')
    .eq('user_id', user.id)
    .gte('logged_date', fourteenAgo)
    .order('logged_date', { ascending: true }),
  getAchievements(user.id, db),
  db.from('body_measurements')
    .select('logged_date, neck_cm, waist_cm, hips_cm, chest_cm, arm_cm, thigh_cm')
    .eq('user_id', user.id)
    .order('logged_date', { ascending: false })
    .limit(2),
  db.from('daily_checkins')
    .select('checkin_date, energy_level')
    .eq('user_id', user.id)
    .gte('checkin_date', ninetyDaysAgo)
    .order('checkin_date', { ascending: true }),
  db.from('progress_photos')
    .select('id, photo_data, taken_date, notes')
    .eq('user_id', user.id)
    .order('taken_date', { ascending: false })
    .limit(4),
  ]);
} catch (e) {
  console.error('[Progress] DB unavailable (batch):', e);
}

const [
  { data: weightLogs },
  { data: onboarding },
  { data: checkins },
  { data: xpTxnsRaw },
  { data: completedTasksData },
  { data: ketoneLogs },
  { data: macroGoals },
  { data: foodLogTrend },
  achievements,
  { data: measurements },
  { data: checkin90 },
  { data: progressPhotos },
] = progressBatch;

// Post-batch derivations
const xpTxns = xpTxnsRaw || [];
const totalCompletedTasks = completedTasksData?.length || 0;

// Smart Insights (fire after batch, non-blocking)
const smartInsights = await generateInsights(user.id, db, currentDay, streakDays).catch(() => []);

const startWeight  = onboarding?.current_weight || profile.weight_kg || 0;
const targetWeight = onboarding?.target_weight  || profile.target_weight_kg || 0;
const latestWeight = weightLogs?.[weightLogs.length - 1]?.weight || startWeight;
const weightLost   = Math.max(0, startWeight - latestWeight);
const weightGoalPct = targetWeight && startWeight > targetWeight
  ? Math.min(100, Math.round((weightLost / (startWeight - targetWeight)) * 100)) : 0;

// Stats
const avgEnergy   = checkins?.length
  ? (checkins.reduce((s,c) => s + (c.energy_level||3), 0) / checkins.length).toFixed(1)
  : '—';
const mealAdherence = checkins?.length
  ? Math.round((checkins.filter(c => c.followed_meals).length / checkins.length) * 100)
  : 0;
const avgWater = checkins?.length
  ? (checkins.reduce((s,c) => s + (c.water_glasses||0), 0) / checkins.length).toFixed(1)
  : '—';

// Body composition
const bcWeight = latestWeight || profile.weight_kg || 0;
const bcHeight = profile.height_cm || 0;
const bcAge    = profile.age    || 0;
const bcGender = profile.gender || 'male';
const bcBMI    = (bcWeight && bcHeight) ? Math.round((bcWeight / Math.pow(bcHeight / 100, 2)) * 10) / 10 : null;
const bcBMIcat = !bcBMI ? null
  : bcBMI < 18.5 ? { label:'Underweight', color:'#3b82f6', pct:15 }
  : bcBMI < 25   ? { label:'Healthy',     color:'#10b981', pct:40 }
  : bcBMI < 30   ? { label:'Overweight',  color:'#f59e0b', pct:65 }
  : { label:'Obese', color:'#ef4444', pct:88 };
// Deurenberg body fat estimate
const bcBodyFat = (bcBMI && bcAge)
  ? Math.round(((1.20 * bcBMI) + (0.23 * bcAge) - (10.8 * (bcGender === 'male' ? 1 : 0)) - 5.4) * 10) / 10
  : null;
// Healthy weight range for height
const bcHealthyMin = bcHeight ? Math.round(18.5 * Math.pow(bcHeight / 100, 2) * 10) / 10 : null;
const bcHealthyMax = bcHeight ? Math.round(24.9 * Math.pow(bcHeight / 100, 2) * 10) / 10 : null;
const bcKgToHealthy = (bcWeight && bcHealthyMax && bcWeight > bcHealthyMax)
  ? Math.round((bcWeight - bcHealthyMax) * 10) / 10 : 0;
// BMI gauge pct (scale: 15=0%, 40=100% for visual)
const bcGaugePct = bcBMI ? Math.min(100, Math.max(0, ((bcBMI - 15) / 25) * 100)) : 0;

const latestKetone = ketoneLogs?.[0] ?? null;
const ketoneStatus = !latestKetone ? null
  : latestKetone.ketone_mmol < 0.5  ? { label: 'Not in ketosis', color: '#ef4444', tip: 'Keep carbs under 20g net to enter ketosis.' }
  : latestKetone.ketone_mmol < 1.5  ? { label: 'Light ketosis', color: '#f59e0b', tip: 'You\'re in ketosis! Aim for 1.5–3.0 mmol/L for optimal fat burning.' }
  : latestKetone.ketone_mmol < 3.0  ? { label: 'Optimal ketosis 🔥', color: '#10b981', tip: 'Optimal range! This is where fat burning peaks.' }
  : latestKetone.ketone_mmol < 5.0  ? { label: 'Deep ketosis', color: '#8b5cf6', tip: 'Deep ketosis — great for therapeutic or athletic use.' }
  : { label: 'Very high — check health', color: '#ef4444', tip: 'Levels above 5 mmol/L should be discussed with a doctor.' };

// Weight SVG line chart (precomputed bezier path)
const wMinRaw  = weightLogs?.length ? Math.min(...weightLogs.map(w => w.weight)) : 0;
const wMaxRaw  = weightLogs?.length ? Math.max(...weightLogs.map(w => w.weight)) : 0;
const wRange   = (wMaxRaw - wMinRaw) || 1;
const wPad     = wRange * 0.12;
const wLow     = Math.max(0, wMinRaw - wPad);
const wHigh    = wMaxRaw + wPad;
const wSpan    = wHigh - wLow || 1;
const SVG_W    = 560;
const SVG_H    = 160;
const SVG_PL   = 48;
const SVG_PR   = 12;
const SVG_PT   = 14;
const SVG_PB   = 32;
const wChartPts = (weightLogs || []).map((w, i) => ({
  weight: w.weight,
  date:   new Date(w.logged_date).toLocaleDateString('en',{month:'short',day:'numeric'}),
  rawDate: w.logged_date,
  x: weightLogs.length > 1
    ? SVG_PL + Math.round((i / (weightLogs.length - 1)) * (SVG_W - SVG_PL - SVG_PR))
    : SVG_PL + Math.round((SVG_W - SVG_PL - SVG_PR) / 2),
  y: SVG_PT + Math.round(((wHigh - w.weight) / wSpan) * (SVG_H - SVG_PT - SVG_PB)),
  isLatest: i === (weightLogs || []).length - 1,
}));

// Build smooth cubic bezier SVG path
const buildBezierPath = (pts) => {
  if (!pts || pts.length === 0) return '';
  if (pts.length === 1) return `M ${pts[0].x} ${pts[0].y}`;
  const d = [`M ${pts[0].x} ${pts[0].y}`];
  for (let i = 1; i < pts.length; i++) {
    const prev = pts[i - 1];
    const cur  = pts[i];
    const cpx  = Math.round((prev.x + cur.x) / 2);
    d.push(`C ${cpx} ${prev.y} ${cpx} ${cur.y} ${cur.x} ${cur.y}`);
  }
  return d.join(' ');
};
const wLinePath = buildBezierPath(wChartPts);

// Build fill polygon path (line + bottom border)
const buildFillPath = (pts, svgH, svgPB) => {
  if (!pts || pts.length === 0) return '';
  const bottom = svgH - svgPB + 2;
  const line   = buildBezierPath(pts);
  return `${line} L ${pts[pts.length-1].x} ${bottom} L ${pts[0].x} ${bottom} Z`;
};
const wFillPath = buildFillPath(wChartPts, SVG_H, SVG_PB);

// Axis labels: up to 5 horizontal weight ticks
const wTickCount = 5;
const wTicks = Array.from({length: wTickCount}, (_, i) => {
  const val = wLow + (wSpan * i / (wTickCount - 1));
  const y   = SVG_PT + Math.round((i / (wTickCount - 1)) * (SVG_H - SVG_PT - SVG_PB));
  return { val: Math.round(val * 10) / 10, y };
}).reverse();

// Date labels: show first, middle, last
const wDateLabels = wChartPts.length > 1
  ? [wChartPts[0], wChartPts[Math.floor((wChartPts.length - 1) / 2)], wChartPts[wChartPts.length - 1]]
  : wChartPts.slice(0, 1);

// Hero stats — new set: current weight, goal, days active, checkins count
const daysActive = journey.start_date
  ? Math.max(1, Math.floor((Date.now() - new Date(journey.start_date).getTime()) / 86400000) + 1)
  : currentDay;
const totalCheckins = checkins?.length
  ? (await db.from('daily_checkins').select('id', { count: 'exact', head: true }).eq('user_id', user.id)).count || checkins.length
  : 0;
const weightDeltaFromStart = latestWeight && startWeight ? Math.round((latestWeight - startWeight) * 10) / 10 : 0;
const kgToGoal = targetWeight && latestWeight ? Math.round(Math.abs(latestWeight - targetWeight) * 10) / 10 : null;

// ── Display values (converted based on preferred_units) ──────────────────────
const dispWeight       = latestWeight   ? toW(latestWeight)   : null;
const dispStartWeight  = startWeight    ? toW(startWeight)    : null;
const dispTargetWeight = targetWeight   ? toW(targetWeight)   : null;
const dispWeightLost   = weightLost     ? toW(weightLost)     : 0;
const dispWeightDelta  = weightDeltaFromStart ? Math.round(toW(Math.abs(weightDeltaFromStart)) * 10) / 10 : 0;
const dispToGoal       = kgToGoal       ? toW(kgToGoal)       : null;
const dispBcWeight     = bcWeight       ? toW(bcWeight)       : null;
const dispHealthyMin   = bcHealthyMin   ? toW(bcHealthyMin)   : null;
const dispHealthyMax   = bcHealthyMax   ? toW(bcHealthyMax)   : null;
const dispToHealthy    = bcKgToHealthy  ? toW(bcKgToHealthy)  : 0;
const dispHeightStr    = bcHeight ? (() => {
  if (units === 'imperial') {
    const totalIn = bcHeight / 2.54;
    return `${Math.floor(totalIn / 12)}'${Math.round(totalIn % 12)}"`;
  }
  return `${Math.round(bcHeight)} cm`;
})() : '—';
// Weight chart ticks in display unit
const wTicksLbs = wTicks.map(t => ({ ...t, valLbs: toW(t.val) }));
// Chart points with display unit labels for tooltips
const wChartPtsLbs = wChartPts.map(p => ({ ...p, weightLbs: toW(p.weight) }));

// Raw data for client-side range filtering
const wRaw = (weightLogs || []).map(w => ({ w: w.weight, d: w.logged_date }));
const wImperial = units === 'imperial';

// Weight chart bars (kept for fallback reference — not used in new SVG chart)
const weightChartBars = (weightLogs || []).map(w => ({
  weight:  w.weight,
  date:    new Date(w.logged_date).toLocaleDateString('en',{month:'short',day:'numeric'}),
  height:  Math.max(8, Math.round(((w.weight - wMinRaw) / wRange) * 80 + 10)),
  isLatest: w.logged_date === weightLogs?.[weightLogs.length-1]?.logged_date,
}));

// Energy chart (last 7 days, newest last)
const energyChart = (checkins || []).slice(0,7).reverse().map(c => ({
  day:     new Date(c.checkin_date).toLocaleDateString('en',{weekday:'short'}).slice(0,2),
  energy:  c.energy_level || 0,
  pct:     Math.round(((c.energy_level||0)/5)*100),
  water:   c.water_glasses || 0,
  meals:   c.followed_meals,
}));

// Sleep chart (last 7 days, newest last, only entries with sleep_hours)
const sleepChart = (checkins || []).slice(0,7).reverse().filter(c => c.sleep_hours != null).map(c => ({
  day:     new Date(c.checkin_date).toLocaleDateString('en',{weekday:'short'}).slice(0,2),
  hours:   c.sleep_hours || 0,
  quality: c.sleep_quality || 0,
  pct:     Math.round(((c.sleep_hours || 0) / 9) * 100),
  color:   (c.sleep_hours || 0) >= 7 ? '#10b981' : (c.sleep_hours || 0) >= 5 ? '#f59e0b' : '#ef4444',
}));
const avgSleepHours = sleepChart.length
  ? (sleepChart.reduce((s,c) => s + c.hours, 0) / sleepChart.length).toFixed(1)
  : null;

// Aggregate by day
const macroByDay = {};
for (const f of (foodLogTrend || [])) {
  const d = f.logged_date;
  if (!macroByDay[d]) macroByDay[d] = { cal:0, prot:0, fat:0, carb:0 };
  macroByDay[d].cal  += (f.calories   || 0);
  macroByDay[d].prot += parseFloat(f.protein_g || 0);
  macroByDay[d].fat  += parseFloat(f.fat_g     || 0);
  macroByDay[d].carb += parseFloat(f.carbs_g   || 0);
}
const macroTrend = Array.from({ length: 14 }, (_, i) => {
  const dd = new Date(Date.now() - (13 - i) * 86400000).toISOString().split('T')[0];
  const m  = macroByDay[dd] || { cal:0, prot:0, fat:0, carb:0 };
  return {
    date:    dd,
    day:     new Date(dd + 'T12:00:00').toLocaleDateString('en',{weekday:'short'}).slice(0,2),
    cal:     Math.round(m.cal),
    prot:    Math.round(m.prot),
    fat:     Math.round(m.fat),
    carb:    Math.round(m.carb),
    hasData: m.cal > 0,
  };
});
const macroGoalCal  = macroGoals?.daily_calories || 1800;
const maxTrendCal   = Math.max(...macroTrend.map(d => d.cal), macroGoalCal, 1);

// Water history (last 14 checkins)
const waterHistory = (checkins || []).slice(0,14).reverse().map(c => ({
  day:     new Date(c.checkin_date + 'T12:00:00').toLocaleDateString('en',{weekday:'short'}).slice(0,2),
  glasses: c.water_glasses || 0,
  pct:     Math.min(100, Math.round(((c.water_glasses || 0) / 8) * 100)),
  met:     (c.water_glasses || 0) >= 8,
}));
const avgWaterAll = waterHistory.length ? (waterHistory.reduce((s,d) => s + d.glasses, 0) / waterHistory.length).toFixed(1) : null;
const goalMetDays = waterHistory.filter(d => d.met).length;

// Ketone trend bars (pre-computed to avoid const-in-map)
const ketoneTrendBars = (ketoneLogs || []).slice(0,7).reverse().map(k => ({
  pct:   Math.min(100, Math.round((k.ketone_mmol / 5) * 100)),
  color: k.ketone_mmol < 0.5 ? '#ef4444' : k.ketone_mmol < 1.5 ? '#f59e0b' : k.ketone_mmol < 3 ? '#10b981' : '#8b5cf6',
  label: new Date(k.logged_date + 'T12:00:00').toLocaleDateString('en',{month:'short',day:'numeric'}),
  val:   k.ketone_mmol,
}));

// Milestones
const milestones = [
  { day:1,  icon:'🚀', label:'Journey Started',      done: currentDay >= 1 },
  { day:3,  icon:'💧', label:'3 Days Strong',         done: currentDay >= 3 },
  { day:7,  icon:'🔥', label:'First Week Complete',   done: currentDay >= 7 },
  { day:10, icon:'⚡', label:'Keto Adapted',          done: currentDay >= 10 },
  { day:14, icon:'🏅', label:'2 Weeks Champion',      done: currentDay >= 14 },
  { day:21, icon:'💪', label:'21-Day Habit Formed',   done: currentDay >= 21 },
  { day:30, icon:'🏆', label:'30-Day Hero',           done: currentDay >= 30 },
];

const tier      = planType;
const planLabel = tierLabel;

const latestMeasurements = measurements?.[0] || null;
const prevMeasurements   = measurements?.[1] || null;

const checkinMap = {};
for (const c of (checkin90 || [])) {
  checkinMap[c.checkin_date] = c.energy_level || 0;
}

// Build calDays: array of 91 days (today + 90 back) aligned to full weeks
// Find the Sunday on or before ninetyDaysAgo so the grid starts cleanly
const calStartRaw = new Date(ninetyDaysAgo + 'T12:00:00');
const calStartDow  = calStartRaw.getDay(); // 0=Sun
const calGridStart = new Date(calStartRaw.getTime() - calStartDow * 86400000);

const calDays: any[] = [];
const calToday = new Date(new Date().toISOString().split('T')[0] + 'T12:00:00');
const calTodayStr = new Date().toISOString().split('T')[0];
const calGridStartStr = calGridStart.toISOString().split('T')[0];

// Build enough days to cover from grid start through today (max ~13 weeks = 91 days)
const calTotalDays = Math.round((calToday.getTime() - calGridStart.getTime()) / 86400000) + 1;
for (let i = 0; i < calTotalDays; i++) {
  const d = new Date(calGridStart.getTime() + i * 86400000);
  const ds = d.toISOString().split('T')[0];
  const isFuture = ds > calTodayStr;
  const energyVal = checkinMap[ds];
  const hasCheckin = ds in checkinMap;
  const colorClass = isFuture
    ? 'cal-future'
    : !hasCheckin
    ? 'cal-none'
    : energyVal >= 5
    ? 'cal-5'
    : energyVal >= 4
    ? 'cal-4'
    : energyVal === 3
    ? 'cal-3'
    : energyVal >= 1
    ? 'cal-12'
    : 'cal-none';
  calDays.push({ date: ds, energy: energyVal || 0, colorClass, isFuture, hasCheckin });
}

// Month labels: find first day of each month in the grid and record its column index
const calMonthLabels: any[] = [];
for (let i = 0; i < calDays.length; i++) {
  const ds = calDays[i].date;
  const dayOfMonth = parseInt(ds.split('-')[2], 10);
  if (dayOfMonth === 1 || i === 0) {
    const monthName = new Date(ds + 'T12:00:00').toLocaleDateString('en', { month: 'short' });
    const colIndex = Math.floor(i / 7);
    // Avoid duplicate same column
    if (!calMonthLabels.length || calMonthLabels[calMonthLabels.length - 1].col !== colIndex) {
      calMonthLabels.push({ month: monthName, col: colIndex });
    }
  }
}
const calNumCols = Math.ceil(calDays.length / 7);

// Goal Weight Milestone Timeline
const goalStartWeight   = onboarding?.current_weight || weightLogs?.[0]?.weight || profile.weight_kg || 0;
const goalWeight        = onboarding?.target_weight  || profile.target_weight_kg || 0;
const goalCurrentWeight = weightLogs?.[weightLogs?.length - 1]?.weight || goalStartWeight;
const goalTotalToLose   = goalStartWeight - goalWeight;
const goalLost          = goalStartWeight - goalCurrentWeight;
const goalPctDone       = (goalTotalToLose !== 0)
  ? Math.min(100, Math.max(0, Math.round((goalLost / goalTotalToLose) * 100)))
  : 0;
const goalKgToGo        = Math.max(0, Math.round(Math.abs(goalCurrentWeight - goalWeight) * 10) / 10);
const goalLostAbs       = Math.round(Math.abs(goalLost) * 10) / 10;

// Milestone weights at 25 / 50 / 75 / 100 % — display in preferred unit
const goalMs25Weight  = toW(Math.round((goalStartWeight - goalTotalToLose * 0.25) * 10) / 10);
const goalMs50Weight  = toW(Math.round((goalStartWeight - goalTotalToLose * 0.50) * 10) / 10);
const goalMs75Weight  = toW(Math.round((goalStartWeight - goalTotalToLose * 0.75) * 10) / 10);
const goalMs100Weight = toW(Math.round(goalWeight * 10) / 10);
const goalKgToGoLbs   = toW(goalKgToGo);
const goalLostAbsLbs  = toW(goalLostAbs);
const goalStartLbs    = toW(goalStartWeight);
const goalWeightLbs   = toW(goalWeight);

// Pre-compute achievement booleans (avoids nested ternary with < NUMBER in JSX)
const goalMs25Done  = goalPctDone >= 25;
const goalMs50Done  = goalPctDone >= 50;
const goalMs75Done  = goalPctDone >= 75;
const goalMs100Done = goalPctDone >= 100;

// Progress bar gradient color: ramps red → gold → green as pct grows
const goalBarColor = goalPctDone >= 75
  ? 'linear-gradient(90deg,#ef4444,#f59e0b,#10b981)'
  : goalPctDone >= 50
  ? 'linear-gradient(90deg,#ef4444,#f59e0b,#34d399)'
  : goalPctDone >= 25
  ? 'linear-gradient(90deg,#ef4444,#f59e0b)'
  : 'linear-gradient(90deg,#ef4444,#f87171)';

const goalHasTarget = goalWeight > 0 && goalStartWeight > 0 && goalTotalToLose !== 0;

// ── Weight Projection Chart ───────────────────────────────────────────────────
const projHasData     = goalHasTarget && (weightLogs?.length || 0) >= 2;
const projFirstLog    = weightLogs?.[0] || null;
const projLastLog     = weightLogs?.[(weightLogs?.length || 0) - 1] || null;
const projElapsedDays = (projHasData && projFirstLog && projLastLog)
  ? Math.max(1, Math.round((new Date(projLastLog.logged_date).getTime() - new Date(projFirstLog.logged_date).getTime()) / 86400000))
  : 1;
const projLostSoFar     = (projHasData && projFirstLog && projLastLog) ? (projFirstLog.weight - projLastLog.weight) : 0;
const projRatePerDay    = projElapsedDays > 0 ? projLostSoFar / projElapsedDays : 0;
const projRatePerWeekKg = Math.round(projRatePerDay * 7 * 100) / 100;
const projRateWeekDisp  = projRatePerWeekKg ? (units === 'imperial' ? Math.round(projRatePerWeekKg * 2.20462 * 10) / 10 : projRatePerWeekKg) : 0;
const projIsLosing      = projRatePerDay > 0 && goalTotalToLose > 0;
const projDaysToGoal    = (projIsLosing && projRatePerDay > 0) ? Math.ceil(goalKgToGo / projRatePerDay) : null;
const projGoalDateMs    = projDaysToGoal ? Date.now() + projDaysToGoal * 86400000 : null;
const projGoalDateStr   = projGoalDateMs
  ? new Date(projGoalDateMs).toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric' })
  : null;
const projWeeksLeft = projDaysToGoal ? Math.ceil(projDaysToGoal / 7) : null;

const PROJ_W  = 560;
const PROJ_H  = 160;
const PROJ_PL = 48;
const PROJ_PR = 24;
const PROJ_PT = 18;
const PROJ_PB = 32;

const projAllWeights = projHasData ? (weightLogs || []).map(w => w.weight) : [goalStartWeight, goalCurrentWeight];
const projMinW = Math.min(goalWeight, ...projAllWeights);
const projMaxW = Math.max(...projAllWeights);
const projWRange = (projMaxW - projMinW) || 1;
const projWPad   = projWRange * 0.15;
const projWLow   = Math.max(0, projMinW - projWPad);
const projWHigh  = projMaxW + projWPad;
const projWSpan  = projWHigh - projWLow || 1;

const projTodayMs = Date.now();
const projFirstMs = (projHasData && projFirstLog) ? new Date(projFirstLog.logged_date).getTime() : projTodayMs;
const projEndMs   = projGoalDateMs || (projTodayMs + 60 * 86400000);
const projTotalMs = Math.max(projEndMs - projFirstMs, 1);

const projXfn = (ms) => PROJ_PL + Math.round(((ms - projFirstMs) / projTotalMs) * (PROJ_W - PROJ_PL - PROJ_PR));
const projYfn = (kg) => PROJ_PT + Math.round(((projWHigh - kg) / projWSpan) * (PROJ_H - PROJ_PT - PROJ_PB));

const projHistPts = projHasData ? (weightLogs || []).map(w => ({
  x: projXfn(new Date(w.logged_date).getTime()),
  y: projYfn(w.weight),
  weightDisp: toW(w.weight),
  date: new Date(w.logged_date + 'T12:00:00').toLocaleDateString('en', { month: 'short', day: 'numeric' }),
})) : [];
const projHistPath  = buildBezierPath(projHistPts);
const projLastX     = projHistPts.length > 0 ? projHistPts[projHistPts.length - 1].x : PROJ_PL;
const projLastY     = projHistPts.length > 0 ? projHistPts[projHistPts.length - 1].y : projYfn(goalCurrentWeight);
const projGoalSvgX  = projGoalDateMs ? projXfn(projGoalDateMs) : PROJ_W - PROJ_PR;
const projGoalSvgY  = projYfn(goalWeight);
const projTodayX    = projXfn(projTodayMs);
const projTargetY   = projYfn(goalWeight);
const projGoalDisp  = toW(goalWeight);

const projXLabel1 = (projHasData && projFirstLog)
  ? new Date(projFirstLog.logged_date + 'T12:00:00').toLocaleDateString('en', { month: 'short', day: 'numeric' })
  : '';
const projXLabel2 = projGoalDateMs
  ? new Date(projGoalDateMs).toLocaleDateString('en', { month: 'short', year: '2-digit' })
  : '';

const projYTicks = Array.from({ length: 4 }, (_, i) => {
  const weight = projWLow + (projWSpan * i / 3);
  return { valDisp: toW(Math.round(weight * 10) / 10), y: projYfn(weight) };
}).reverse();

const showProjection = projIsLosing && projHasData;

// Pre-compute achievement display data to avoid const-in-map
const achievementsDisplay = achievements.map(a => ({
  icon:       a.icon || '🏅',
  name:       a.achievement_name || a.name || '',
  desc:       a.description || a.desc || '',
  earnedDate: a.earned_at || a.created_at || '',
  isGreen:    a.type === 'streak' || a.type === 'journey' || a.type === 'compliance',
}));

const initialPhotos = progressPhotos || [];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{t('progress.title')} — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet"/>
  <script is:inline>(function(){const t=localStorage.getItem('keto-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
  <style>
    :root{
      /* Rose Vital design tokens */
      --rv-bg:#FAF6F1;--rv-card:#FFFFFF;--rv-bg-alt:#F2EDE5;--rv-line:#E5DED2;
      --rv-ink:#16110F;--rv-ink-soft:#4A4340;--rv-muted:#8A8077;
      --rv-accent:#FF5C7A;--rv-accent-2:#B6FF3C;--rv-warm:#FF914D;
      /* Alias legacy vars to Rose Vital */
      --bg:var(--rv-bg);--card:var(--rv-card);--card2:var(--rv-bg-alt);--surface:var(--rv-bg-alt);
      --border:var(--rv-line);--border2:rgba(255,92,122,.3);
      --text:var(--rv-ink);--soft:var(--rv-ink-soft);--muted:#C8BFBA;
      /* Keep semantic data/chart colors unchanged */
      --green:#10b981;--green2:#34d399;--gold:#f59e0b;--red:#ef4444;
      --blue:#3b82f6;--purple:#8b5cf6;--cyan:#06b6d4;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Bricolage Grotesque',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
    /* Shell layout */
    .rv-pg-shell{display:grid;grid-template-columns:232px 1fr;min-height:100vh;}
    .rv-pg-main{min-width:0;overflow-x:hidden;}
    @media(max-width:900px){.rv-pg-shell{grid-template-columns:1fr;}.rv-pg-main{padding-bottom:5.5rem;}}
    /* PAGE */
    .page{padding:2rem 1.75rem 4rem;}
    /* HEADER */
    .pg-header{margin-bottom:2rem;animation:fadeUp .4s ease both;}
    .pg-eyebrow{font-size:.72rem;font-weight:800;color:var(--rv-accent);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.4rem;}
    .pg-title{font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:800;line-height:1.1;margin-bottom:.5rem;}
    .pg-title em{font-style:italic;font-family:'Instrument Serif',serif;color:var(--rv-accent);}
    .pg-sub{font-size:.85rem;color:var(--soft);line-height:1.6;}
    /* HERO STATS */
    .hero-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.75rem;}
    .hstat{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:1.4rem 1.2rem;text-align:center;transition:all .3s;animation:fadeUp .4s ease both;position:relative;overflow:hidden;}
    .hstat::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:3px 3px 0 0;}
    .hstat.g::before{background:linear-gradient(90deg,var(--green),var(--green2));}
    .hstat.gold::before{background:linear-gradient(90deg,var(--gold),#fbbf24);}
    .hstat.blue::before{background:linear-gradient(90deg,var(--blue),var(--cyan));}
    .hstat.purple::before{background:linear-gradient(90deg,var(--purple),#a78bfa);}
    .hstat:hover{border-color:var(--border2);transform:translateY(-3px);}
    .hstat-icon{font-size:1.6rem;margin-bottom:.5rem;}
    .hstat-val{font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:2.2rem;font-weight:800;line-height:1;margin-bottom:.25rem;}
    .hstat-lbl{font-size:.66rem;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:var(--soft);}
    .hstat-sub{font-size:.68rem;margin-top:.3rem;padding:.18rem .55rem;border-radius:99px;display:inline-block;font-weight:700;}
    /* LAYOUT */
    .grid2{display:grid;grid-template-columns:1fr 360px;gap:1.5rem;margin-bottom:1.5rem;}
    .grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.5rem;}
    @media(max-width:1060px){.grid2{grid-template-columns:1fr;}}
    @media(max-width:700px){.grid3{grid-template-columns:1fr 1fr;}.hero-stats{grid-template-columns:1fr 1fr;}}
    @media(max-width:480px){
      .grid3{grid-template-columns:1fr;}
      .hero-stats{grid-template-columns:1fr 1fr;}
      .page{padding-left:1rem;padding-right:1rem;padding-bottom:5.5rem;}
      .card .cb{padding:1rem;}
      .ch{padding:.9rem 1rem;}
      /* iOS Safari input zoom prevention */
      input[type="number"],input[type="date"],input[type="text"],textarea,select{font-size:16px!important;min-height:44px;}
      /* Measurement grid → 2 cols on small screens */
      .meas-grid,[style*="grid-template-columns:repeat(3"]{grid-template-columns:1fr 1fr!important;}
    }
    /* CARD */
    .card{background:var(--rv-card);border:1px solid var(--rv-line);border-radius:20px;overflow:hidden;transition:border-color .25s;animation:fadeUp .4s ease both;}
    .card:hover{border-color:var(--rv-accent);}
    .ch{display:flex;align-items:center;gap:.8rem;padding:1.1rem 1.5rem;border-bottom:1px solid var(--border);}
    .ch-ic{width:38px;height:38px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
    .ch-tt{font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:.95rem;font-weight:700;flex:1;color:var(--rv-ink);}
    .ch-sub{font-size:.7rem;color:var(--soft);}
    .cb{padding:1.25rem 1.5rem;}
    /* PROGRESS BAR */
    .prog{margin-bottom:1rem;}
    .prog:last-child{margin-bottom:0;}
    .prog-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:.4rem;}
    .prog-lbl{font-size:.8rem;font-weight:700;}
    .prog-val{font-size:.8rem;font-weight:800;}
    .prog-trk{height:9px;background:var(--rv-line);border-radius:99px;overflow:hidden;}
    .prog-fill{height:100%;border-radius:99px;transition:width 1.4s cubic-bezier(.4,0,.2,1);}
    /* WEIGHT CHART */
    .wchart{display:flex;align-items:flex-end;gap:3px;height:90px;margin-bottom:.75rem;}
    .wbar{flex:1;border-radius:3px 3px 0 0;min-height:4px;transition:opacity .2s;cursor:pointer;}
    .wbar:hover{opacity:.7;}
    .wchart-labels{display:flex;gap:3px;overflow:hidden;}
    .wlbl{flex:1;text-align:center;font-size:.5rem;color:var(--muted);white-space:nowrap;overflow:hidden;}
    /* ENERGY CHART */
    .echart{display:flex;align-items:flex-end;gap:.4rem;height:70px;margin-bottom:.5rem;}
    .ebar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:.2rem;}
    .ebar{width:100%;border-radius:3px 3px 0 0;min-height:3px;transition:height .5s ease;}
    .ebar-day{font-size:.58rem;font-weight:700;color:var(--soft);}
    /* MILESTONES */
    .milestones{display:flex;flex-direction:column;gap:.6rem;}
    .ms{display:flex;align-items:center;gap:.9rem;padding:.8rem 1rem;border-radius:12px;border:1.5px solid var(--border);transition:all .25s;}
    .ms.done{border-color:rgba(255,92,122,.3);background:rgba(255,92,122,.05);}
    .ms.next{border-color:rgba(255,145,77,.3);background:rgba(255,145,77,.04);animation:pulse-ms 2s ease-in-out infinite;}
    @keyframes pulse-ms{0%,100%{border-color:rgba(255,145,77,.3);}50%{border-color:rgba(255,145,77,.6);}}
    .ms-icon{font-size:1.3rem;flex-shrink:0;}
    .ms-info{flex:1;}
    .ms-lbl{font-size:.83rem;font-weight:700;}
    .ms-day{font-size:.68rem;color:var(--soft);}
    .ms-check{font-size:.9rem;color:var(--rv-accent);}
    /* XP TABLE */
    .xp-row{display:flex;align-items:center;justify-content:space-between;padding:.65rem 0;border-bottom:1px solid var(--rv-line);}
    .xp-row:last-child{border:none;}
    .xp-type{font-size:.8rem;font-weight:600;flex:1;color:var(--rv-ink);}
    .xp-date{font-size:.68rem;color:var(--rv-ink-soft);}
    .xp-pts{font-size:.8rem;font-weight:800;color:var(--gold);background:rgba(245,158,11,.1);padding:.18rem .5rem;border-radius:7px;}
    /* STAT MINI CARDS */
    .mini3{display:grid;grid-template-columns:repeat(3,1fr);gap:.65rem;margin-bottom:1rem;}
    .mini-c{background:var(--rv-bg-alt);border:1px solid var(--rv-line);border-radius:12px;padding:.9rem;text-align:center;}
    .mini-val{font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.5rem;font-weight:800;line-height:1;margin-bottom:.2rem;}
    .mini-lbl{font-size:.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);}
    /* RING */
    .ring-wrap{position:relative;width:90px;height:90px;margin:0 auto .75rem;}
    .rsvg{transform:rotate(-90deg);}
    .r-trk{fill:none;stroke:var(--rv-line);stroke-width:8;}
    .r-fill{fill:none;stroke-width:8;stroke-linecap:round;stroke-dasharray:245;}
    .ring-c{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;}
    .ring-pct{font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.2rem;font-weight:800;line-height:1;}
    .ring-lbl{font-size:.52rem;font-weight:700;color:var(--soft);}
    @keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
    /* ACTIVITY HEATMAP */
    .cal-wrap{overflow-x:auto;padding-bottom:.25rem;position:relative;}
    .cal-grid-area{display:inline-flex;flex-direction:column;gap:0;}
    .cal-month-row{display:flex;gap:3px;margin-bottom:4px;min-height:16px;}
    .cal-month-cell{width:13px;font-size:.55rem;color:var(--soft);font-weight:700;white-space:nowrap;overflow:visible;}
    .cal-cols{display:flex;flex-direction:row;gap:3px;}
    .cal-col{display:flex;flex-direction:column;gap:3px;}
    .cal-sq{width:13px;height:13px;border-radius:3px;cursor:pointer;transition:transform .12s,opacity .15s;}
    .cal-sq:hover{transform:scale(1.35);opacity:1;}
    .cal-none{background:#E5DED2;}
    .cal-future{background:rgba(0,0,0,.04);border:1px solid rgba(0,0,0,.04);}
    .cal-12{background:rgba(239,68,68,.35);}
    .cal-3{background:rgba(245,158,11,.4);}
    .cal-4{background:rgba(16,185,129,.4);}
    .cal-5{background:#10b981;}
    .cal-legend{display:flex;align-items:center;gap:.55rem;flex-wrap:wrap;margin-top:.7rem;}
    .cal-legend-sq{width:11px;height:11px;border-radius:2px;display:inline-block;flex-shrink:0;}
    .cal-legend-lbl{font-size:.67rem;color:var(--soft);font-weight:600;}
    /* CALENDAR TOOLTIP */
    .cal-tip{
      position:fixed;z-index:200;
      background:var(--rv-ink);border:1px solid var(--rv-ink);
      border-radius:10px;padding:.45rem .75rem;
      font-size:.72rem;font-weight:700;color:var(--rv-bg);
      pointer-events:none;white-space:nowrap;
      box-shadow:0 6px 20px rgba(0,0,0,.2);
      opacity:0;transition:opacity .15s;
    }
    .cal-tip.visible{opacity:1;}
    /* ACHIEVEMENT CARDS */
    .ach-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;}
    .ach-card{
      background:var(--rv-bg-alt);
      border:1.5px solid rgba(255,92,122,.2);
      border-radius:16px;padding:1rem 1.1rem;
      display:flex;align-items:flex-start;gap:.75rem;
      transition:all .25s;
    }
    .ach-card:hover{border-color:rgba(255,92,122,.45);transform:translateY(-2px);box-shadow:0 6px 20px rgba(255,92,122,.08);}
    .ach-card.green-ach{border-color:rgba(16,185,129,.25);}
    .ach-card.green-ach:hover{border-color:rgba(16,185,129,.55);box-shadow:0 6px 20px rgba(16,185,129,.1);}
    .ach-icon{font-size:2rem;line-height:1;flex-shrink:0;margin-top:.1rem;}
    .ach-body{flex:1;min-width:0;}
    .ach-name{font-weight:800;font-size:.83rem;color:var(--rv-accent);margin-bottom:.2rem;}
    .ach-card.green-ach .ach-name{color:var(--green);}
    .ach-desc{font-size:.7rem;color:var(--rv-ink-soft);line-height:1.4;margin-bottom:.3rem;}
    .ach-date{font-size:.62rem;color:var(--rv-muted);font-weight:700;}
    /* GOAL TIMELINE */
    .goal-bar-wrap{position:relative;height:14px;background:var(--rv-line);border-radius:99px;overflow:hidden;margin-bottom:1.75rem;}
    .goal-bar-fill{height:100%;border-radius:99px;transition:width 1.4s cubic-bezier(.4,0,.2,1);}
    .goal-markers{display:grid;grid-template-columns:repeat(4,1fr);gap:.5rem;}
    .gm{display:flex;flex-direction:column;align-items:center;gap:.3rem;text-align:center;}
    .gm-icon{font-size:.9rem;line-height:1;}
    .gm-weight{font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:.85rem;font-weight:800;color:var(--rv-ink-soft);}
    .gm-weight.done{color:var(--green2);}
    .gm-label{font-size:.6rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);}
    .gm-label.done{color:var(--green);}
    .goal-stats{display:flex;flex-wrap:wrap;gap:.4rem 1.25rem;justify-content:center;margin-top:.9rem;padding:.65rem 1rem;background:var(--rv-bg-alt);border:1px solid var(--rv-line);border-radius:12px;}
    .gs-item{font-size:.77rem;font-weight:700;color:var(--rv-ink-soft);}
    .gs-item strong{color:var(--rv-ink);font-weight:800;}
    /* PROGRESS PHOTOS */
    .photo-grid{display:grid;grid-template-columns:1fr 1fr;gap:.65rem;}
    .photo-thumb{width:100%;aspect-ratio:1;border-radius:12px;object-fit:cover;border:1px solid var(--border);background:var(--muted);cursor:pointer;transition:all .2s;}
    .photo-thumb:hover{border-color:var(--border2);transform:scale(1.02);}
    .photo-thumb-wrap{position:relative;}
    .photo-date{position:absolute;bottom:0;left:0;right:0;padding:.25rem .45rem;background:rgba(0,0,0,.6);font-size:.58rem;font-weight:700;color:#fff;border-radius:0 0 11px 11px;text-align:center;}
    .photo-empty{text-align:center;padding:2rem 1rem;color:var(--soft);}
    .photo-empty-icon{font-size:2.5rem;margin-bottom:.5rem;}
    .photo-empty-msg{font-size:.82rem;font-weight:700;margin-bottom:.25rem;color:var(--text);}
    .photo-empty-sub{font-size:.74rem;line-height:1.5;}
  </style>
</head>
<body>
<div id="calTip" class="cal-tip"></div>

<div class="rv-pg-shell">
<Sidebar userName={userName} planType={planType} tierLabel={tierLabel} currentDay={currentDay} activePage="progress" />
<div class="rv-pg-main">
<div class="page">

  <!-- HEADER -->
  <div class="pg-header">
    <div class="pg-eyebrow">📈 Progress Tracker</div>
    <h1 class="pg-title">Your Journey, <em>{userName}</em></h1>
    <p class="pg-sub">Day {currentDay} of 30 · {planLabel} · Tracking your transformation in real time</p>
  </div>

  <!-- HERO STATS -->
  <div class="hero-stats">
    <div class="hstat g" style="animation-delay:.04s;">
      <div class="hstat-icon">⚖️</div>
      <div class="hstat-val" style="color:var(--green);">{dispWeightLost > 0 ? `-${dispWeightLost}` : '—'}</div>
      <div class="hstat-lbl">{wUnit} Lost</div>
      <div class="hstat-sub" style="background:rgba(16,185,129,.1);color:var(--green);">{weightGoalPct}% of goal</div>
    </div>
    <div class="hstat gold" style="animation-delay:.08s;">
      <div class="hstat-icon">🔥</div>
      <div class="hstat-val" style="color:var(--gold);">{streakDays}</div>
      <div class="hstat-lbl">Day Streak</div>
      <div class="hstat-sub" style="background:rgba(245,158,11,.1);color:var(--gold);">Best: {longestStreak}d</div>
    </div>
    <div class="hstat blue" style="animation-delay:.12s;">
      <div class="hstat-icon">⭐</div>
      <div class="hstat-val" style="color:var(--purple);">Lv.{xpLevel}</div>
      <div class="hstat-lbl">{totalXP.toLocaleString()} XP</div>
      <div class="hstat-sub" style="background:rgba(139,92,246,.1);color:var(--purple);">{xpInLevel}/500 to next</div>
    </div>
    <div class="hstat purple" style="animation-delay:.16s;">
      <div class="hstat-icon">✅</div>
      <div class="hstat-val" style="color:var(--cyan);">{totalCompletedTasks}</div>
      <div class="hstat-lbl">Tasks Done</div>
      <div class="hstat-sub" style="background:rgba(6,182,212,.1);color:var(--cyan);">{perfectDays} perfect days</div>
    </div>
  </div>

  <!-- SMART INSIGHTS -->
  {smartInsights.length > 0 && (
    <div class="card" id="insightsCard" style="animation-delay:.19s;margin-bottom:1.75rem;padding:1.25rem 1.4rem;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.9rem;">
        <span style="font-size:.75rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--green2);">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="display:inline;vertical-align:-1px;margin-right:.3rem"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Smart Insights
        </span>
        <button onclick="document.getElementById('insightsCard').style.display='none'" style="background:none;border:none;color:var(--soft);font-size:1.1rem;cursor:pointer;padding:.1rem .3rem;border-radius:6px;">×</button>
      </div>
      <div style="display:flex;flex-direction:column;gap:.6rem;">
        {smartInsights.map((ins: any) => (
          <div style={`display:flex;gap:.7rem;align-items:flex-start;padding:.7rem .85rem;border-radius:12px;border:1px solid;background:${ins.level==='positive'?'rgba(16,185,129,.06)':ins.level==='warning'?'rgba(245,158,11,.06)':'rgba(59,130,246,.05)'};border-color:${ins.level==='positive'?'rgba(16,185,129,.18)':ins.level==='warning'?'rgba(245,158,11,.2)':'rgba(59,130,246,.15)'};`}>
            <span style="font-size:1.1rem;flex-shrink:0;">{ins.icon}</span>
            <div>
              <div style="font-size:.82rem;font-weight:700;color:var(--text);margin-bottom:.15rem;">{ins.title}</div>
              <div style="font-size:.77rem;color:var(--soft);line-height:1.55;">{ins.body}</div>
              {ins.action && <a href={ins.action.url} style="font-size:.73rem;font-weight:700;color:var(--rv-accent);text-decoration:none;margin-top:.2rem;display:inline-block;">{ins.action.label} →</a>}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- GOAL WEIGHT MILESTONE TIMELINE -->
  {goalHasTarget && (
    <div class="card" style="animation-delay:.2s;margin-bottom:1.75rem;">
      <div class="ch">
        <div class="ch-ic" style="background:linear-gradient(135deg,#ef4444,#f59e0b,#10b981);box-shadow:0 4px 10px rgba(16,185,129,.2);">🎯</div>
        <div style="flex:1;">
          <div class="ch-tt">Goal Timeline</div>
          <div class="ch-sub">{goalStartLbs} {wUnit} → {goalWeightLbs} {wUnit} · {goalPctDone}% complete</div>
        </div>
        <div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.4rem;font-weight:800;color:var(--rv-accent);">{goalPctDone}%</div>
      </div>
      <div class="cb">

        <!-- Progress bar -->
        <div class="goal-bar-wrap">
          <div class="goal-bar-fill" style={`width:${goalPctDone}%;background:${goalBarColor};`}></div>
        </div>

        <!-- Milestone markers -->
        <div class="goal-markers">

          <!-- 25% -->
          <div class="gm">
            <div class="gm-icon">{goalMs25Done ? '✅' : '⬜'}</div>
            <div class={`gm-weight ${goalMs25Done ? 'done' : ''}`}>{goalMs25Weight} {wUnit}</div>
            <div class={`gm-label ${goalMs25Done ? 'done' : ''}`}>25% goal</div>
          </div>

          <!-- 50% -->
          <div class="gm">
            <div class="gm-icon">{goalMs50Done ? '✅' : '⬜'}</div>
            <div class={`gm-weight ${goalMs50Done ? 'done' : ''}`}>{goalMs50Weight} {wUnit}</div>
            <div class={`gm-label ${goalMs50Done ? 'done' : ''}`}>Halfway!</div>
          </div>

          <!-- 75% -->
          <div class="gm">
            <div class="gm-icon">{goalMs75Done ? '✅' : '⬜'}</div>
            <div class={`gm-weight ${goalMs75Done ? 'done' : ''}`}>{goalMs75Weight} {wUnit}</div>
            <div class={`gm-label ${goalMs75Done ? 'done' : ''}`}>75% there</div>
          </div>

          <!-- 100% -->
          <div class="gm">
            <div class="gm-icon">{goalMs100Done ? '✅' : '⬜'}</div>
            <div class={`gm-weight ${goalMs100Done ? 'done' : ''}`}>{goalMs100Weight} {wUnit}</div>
            <div class={`gm-label ${goalMs100Done ? 'done' : ''}`}>Goal! 🎉</div>
          </div>

        </div>

        <!-- Summary stats -->
        <div class="goal-stats">
          <span class="gs-item">Lost <strong>{goalLostAbsLbs} {wUnit}</strong> so far</span>
          <span class="gs-item"><strong>{goalKgToGoLbs} {wUnit}</strong> to goal</span>
          <span class="gs-item"><strong>{goalPctDone}%</strong> complete</span>
        </div>

      </div>
    </div>
  )}

  <!-- WEIGHT GOAL PROJECTION CHART -->
  {showProjection && (
    <div class="card" style="animation-delay:.22s;margin-bottom:1.75rem;">
      <div class="ch">
        <div class="ch-ic" style="background:linear-gradient(135deg,#10b981,#f59e0b);box-shadow:0 4px 10px rgba(245,158,11,.18);">📈</div>
        <div style="flex:1;">
          <div class="ch-tt">Weight Projection</div>
          <div class="ch-sub">Trajectory to goal · {projRateWeekDisp} {wUnit}/week loss</div>
        </div>
        {projWeeksLeft && <div style="font-size:.72rem;font-weight:800;color:var(--gold);white-space:nowrap;">~{projWeeksLeft}w left</div>}
      </div>
      <div class="cb">
        {projGoalDateStr && (
          <div style="background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.18);border-radius:12px;padding:.7rem 1rem;margin-bottom:1.1rem;display:flex;align-items:center;gap:.75rem;">
            <span style="font-size:1.3rem;">🎯</span>
            <div>
              <div style="font-size:.8rem;font-weight:800;color:var(--gold);">Estimated goal date: {projGoalDateStr}</div>
              <div style="font-size:.72rem;color:var(--soft);margin-top:.1rem;">At {projRateWeekDisp} {wUnit}/week · {projWeeksLeft} weeks away · Goal: {projGoalDisp} {wUnit}</div>
            </div>
          </div>
        )}
        <svg width="100%" viewBox={`0 0 ${PROJ_W} ${PROJ_H}`} preserveAspectRatio="xMidYMid meet" style="overflow:visible;display:block;">
          <defs>
            <linearGradient id="projAreaGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#10b981" stop-opacity="0.22" />
              <stop offset="100%" stop-color="#10b981" stop-opacity="0" />
            </linearGradient>
          </defs>
          {projYTicks.map(tk => (
            <g>
              <line x1={PROJ_PL} y1={tk.y} x2={PROJ_W - PROJ_PR} y2={tk.y} stroke="rgba(0,0,0,0.06)" stroke-width="1" />
              <text x={PROJ_PL - 5} y={tk.y + 4} text-anchor="end" font-size="9" fill="var(--soft)">{tk.valDisp}</text>
            </g>
          ))}
          <line x1={PROJ_PL} y1={projTargetY} x2={PROJ_W - PROJ_PR} y2={projTargetY}
            stroke="#f59e0b" stroke-width="1.2" stroke-dasharray="5 3" opacity="0.45" />
          <text x={PROJ_W - PROJ_PR + 3} y={projTargetY + 4} font-size="9" fill="#f59e0b" opacity="0.8">goal</text>
          <line x1={projTodayX} y1={PROJ_PT} x2={projTodayX} y2={PROJ_H - PROJ_PB}
            stroke="var(--green)" stroke-width="1" stroke-dasharray="3 3" opacity="0.4" />
          <text x={projTodayX} y={PROJ_H - PROJ_PB + 16} text-anchor="middle" font-size="8" fill="var(--green)" opacity="0.65">today</text>
          {projHistPts.length > 1 && (
            <path
              d={`${projHistPath} L ${projHistPts[projHistPts.length-1].x} ${PROJ_H - PROJ_PB + 2} L ${projHistPts[0].x} ${PROJ_H - PROJ_PB + 2} Z`}
              fill="url(#projAreaGrad)" />
          )}
          {projHistPts.length > 1 && (
            <path d={projHistPath} fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          )}
          {projGoalDateMs && (
            <line x1={projLastX} y1={projLastY} x2={projGoalSvgX} y2={projGoalSvgY}
              stroke="#f59e0b" stroke-width="2" stroke-dasharray="7 4" stroke-linecap="round" opacity="0.75" />
          )}
          {projHistPts.map(p => (
            <circle cx={p.x} cy={p.y} r="3.5" fill="#10b981" stroke="#34d399" stroke-width="1.5">
              <title>{p.weightDisp} {wUnit} — {p.date}</title>
            </circle>
          ))}
          {projGoalDateMs && (
            <circle cx={projGoalSvgX} cy={projGoalSvgY} r="5" fill="#f59e0b" stroke="#fbbf24" stroke-width="1.5" opacity="0.9">
              <title>Goal: {projGoalDisp} {wUnit} — {projGoalDateStr}</title>
            </circle>
          )}
          <text x={PROJ_PL} y={PROJ_H - PROJ_PB + 28} text-anchor="middle" font-size="9" fill="var(--soft)">{projXLabel1}</text>
          {projGoalDateMs && (
            <text x={projGoalSvgX} y={PROJ_H - PROJ_PB + 28} text-anchor="middle" font-size="9" fill="#f59e0b" opacity="0.75">{projXLabel2}</text>
          )}
        </svg>
      </div>
    </div>
  )}

  <!-- MAIN GRID -->
  <div class="grid2">

    <!-- LEFT -->
    <div style="display:flex;flex-direction:column;gap:1.25rem;">

      <!-- JOURNEY PROGRESS -->
      <div class="card" style="animation-delay:.05s;">
        <div class="ch">
          <div class="ch-ic" style="background:linear-gradient(135deg,#10b981,#059669);box-shadow:0 4px 10px rgba(16,185,129,.2);">📅</div>
          <div style="flex:1;"><div class="ch-tt">Journey Progress</div><div class="ch-sub">Day {currentDay} of 30</div></div>
        </div>
        <div class="cb">
          <div class="prog">
            <div class="prog-hd">
              <span class="prog-lbl">30-Day Plan</span>
              <span class="prog-val" style="color:var(--green);">{journeyPct}% complete</span>
            </div>
            <div class="prog-trk">
              <div class="prog-fill" style={`width:${journeyPct}%;background:linear-gradient(90deg,var(--green),var(--green2));`}></div>
            </div>
          </div>
          <div class="prog">
            <div class="prog-hd">
              <span class="prog-lbl">Level {xpLevel} → {xpLevel+1}</span>
              <span class="prog-val" style="color:var(--purple);">{xpPct}%</span>
            </div>
            <div class="prog-trk">
              <div class="prog-fill" style={`width:${xpPct}%;background:linear-gradient(90deg,#8b5cf6,#a78bfa);`}></div>
            </div>
          </div>
          {targetWeight > 0 && (
            <div class="prog">
              <div class="prog-hd">
                <span class="prog-lbl">Weight Goal ({dispTargetWeight} {wUnit})</span>
                <span class="prog-val" style="color:var(--blue);">{weightGoalPct}%</span>
              </div>
              <div class="prog-trk">
                <div class="prog-fill" style={`width:${weightGoalPct}%;background:linear-gradient(90deg,#3b82f6,#10b981);`}></div>
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- WEIGHT CHART -->
      <div class="card" style="animation-delay:.1s;">
        <div class="ch">
          <div class="ch-ic" style="background:linear-gradient(135deg,#3b82f6,#2563eb);box-shadow:0 4px 10px rgba(59,130,246,.2);">⚖️</div>
          <div style="flex:1;"><div class="ch-tt">{t('progress.weight')} History</div><div id="weightChartCount" class="ch-sub">{wChartPts.length} measurements logged</div></div>
          <div style="display:flex;align-items:center;gap:.4rem;">
            <button class="w-range-btn" data-days="30" onclick="setWRange(30,this)" style="font-size:.68rem;font-weight:800;padding:.25rem .55rem;border-radius:6px;border:none;cursor:pointer;background:rgba(255,92,122,.12);color:#FF5C7A;transition:all .2s;">30d</button>
            <button class="w-range-btn" data-days="60" onclick="setWRange(60,this)" style="font-size:.68rem;font-weight:800;padding:.25rem .55rem;border-radius:6px;border:none;cursor:pointer;background:none;color:var(--rv-ink-soft);transition:all .2s;">60d</button>
            <button class="w-range-btn" data-days="90" onclick="setWRange(90,this)" style="font-size:.68rem;font-weight:800;padding:.25rem .55rem;border-radius:6px;border:none;cursor:pointer;background:none;color:var(--rv-ink-soft);transition:all .2s;">90d</button>
            <button id="openWeightModal" style="font-size:.72rem;font-weight:800;color:var(--rv-accent);background:none;border:none;cursor:pointer;padding:0;margin-left:.25rem;">+ {t('progress.log_weight')}</button>
          </div>
        </div>
        <div class="cb">
          {wChartPts.length > 0 ? (
            <>
              <div style="display:flex;justify-content:space-between;margin-bottom:1rem;">
                <div style="text-align:center;">
                  <div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.6rem;font-weight:900;color:var(--blue);">{dispStartWeight}<span style="font-size:.75rem;color:var(--soft);">{wUnit}</span></div>
                  <div style="font-size:.62rem;color:var(--soft);font-weight:700;">START</div>
                </div>
                <div style="text-align:center;">
                  <div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.6rem;font-weight:900;color:var(--green);">{dispWeight}<span style="font-size:.75rem;color:var(--soft);">{wUnit}</span></div>
                  <div style="font-size:.62rem;color:var(--soft);font-weight:700;">CURRENT</div>
                </div>
                {targetWeight > 0 && (
                  <div style="text-align:center;">
                    <div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.6rem;font-weight:900;color:var(--gold);">{dispTargetWeight}<span style="font-size:.75rem;color:var(--soft);">{wUnit}</span></div>
                    <div style="font-size:.62rem;color:var(--soft);font-weight:700;">GOAL</div>
                  </div>
                )}
                {weightLost > 0 && (
                  <div style="text-align:center;">
                    <div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.6rem;font-weight:900;color:var(--green);">-{dispWeightLost}<span style="font-size:.75rem;color:var(--soft);">{wUnit}</span></div>
                    <div style="font-size:.62rem;color:var(--soft);font-weight:700;">LOST</div>
                  </div>
                )}
              </div>
              <svg id="weightSvg" width="100%" viewBox={`0 0 ${SVG_W} ${SVG_H}`} preserveAspectRatio="xMidYMid meet" style="overflow:visible;display:block;margin-top:.5rem;">
                <defs>
                  <linearGradient id="wAreaGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.35" />
                    <stop offset="100%" stop-color="#3b82f6" stop-opacity="0" />
                  </linearGradient>
                  <linearGradient id="wLineGrad" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="#3b82f6" />
                    <stop offset="100%" stop-color="#10b981" />
                  </linearGradient>
                </defs>
                {wChartPts.length > 1 && <path d={wFillPath} fill="url(#wAreaGrad)" />}
                {wChartPts.length > 1 && <path d={wLinePath} fill="none" stroke="url(#wLineGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />}
                {wTicksLbs.map(t => (
                  <g>
                    <line x1={SVG_PL} y1={t.y} x2={SVG_W - SVG_PR} y2={t.y} stroke="rgba(0,0,0,0.06)" stroke-width="1" />
                    <text x={SVG_PL - 5} y={t.y + 4} text-anchor="end" font-size="9" fill="var(--soft)">{t.valLbs}</text>
                  </g>
                ))}
                {wChartPtsLbs.map(p => (
                  <circle cx={p.x} cy={p.y} r={p.isLatest ? 5 : 3.5}
                    fill={p.isLatest ? '#10b981' : '#3b82f6'}
                    stroke={p.isLatest ? '#34d399' : '#60a5fa'}
                    stroke-width="1.5">
                    <title>{p.weightLbs} {wUnit} — {p.date}</title>
                  </circle>
                ))}
                {wDateLabels.map(p => (
                  <text x={p.x} y={SVG_H - SVG_PB + 18} text-anchor="middle" font-size="9" fill="var(--soft)">{p.date}</text>
                ))}
              </svg>
            </>
          ) : (
            <div style="text-align:center;padding:2rem;color:var(--soft);">
              <div style="font-size:2.5rem;margin-bottom:.75rem;">⚖️</div>
              <div style="font-weight:700;margin-bottom:.3rem;">No weight logs yet</div>
              <div style="font-size:.78rem;">Log your first weight to start tracking progress</div>
              <button id="openWeightModalEmpty" style="display:inline-block;margin-top:1rem;padding:.6rem 1.4rem;background:var(--rv-ink);color:var(--rv-bg);border-radius:10px;font-weight:800;font-size:.8rem;border:none;cursor:pointer;">+ {t('progress.log_weight')}</button>
            </div>
          )}
        </div>
      </div>

      <!-- ACTIVITY HEATMAP CALENDAR -->
      <div class="card" style="animation-delay:.12s;">
        <div class="ch">
          <div class="ch-ic" style="background:linear-gradient(135deg,#10b981,#059669);box-shadow:0 4px 10px rgba(16,185,129,.2);">📆</div>
          <div style="flex:1;"><div class="ch-tt">Activity Calendar</div><div class="ch-sub">90-day check-in history</div></div>
          <div style="font-size:.72rem;font-weight:800;color:var(--green);">{Object.keys(checkinMap).length} days logged</div>
        </div>
        <div class="cb">
          <div class="cal-wrap">
            <div class="cal-grid-area">
              <!-- Month label row -->
              <div class="cal-month-row">
                {Array.from({ length: calNumCols }, (_, ci) => {
                  const label = calMonthLabels.find(m => m.col === ci);
                  return (
                    <div class="cal-month-cell">{label ? label.month : ''}</div>
                  );
                })}
              </div>
              <!-- Columns (each col = one week, rows = days Sun–Sat) -->
              <div class="cal-cols">
                {Array.from({ length: calNumCols }, (_, ci) => (
                  <div class="cal-col">
                    {Array.from({ length: 7 }, (_, ri) => {
                      const idx = ci * 7 + ri;
                      const sq = calDays[idx];
                      const tipText = sq
                        ? (sq.isFuture
                          ? sq.date + ' · future'
                          : sq.hasCheckin
                          ? sq.date + ' · Energy: ' + sq.energy + '/5'
                          : sq.date + ' · no check-in')
                        : '';
                      return sq ? (
                        <div
                          class={`cal-sq ${sq.colorClass}`}
                          onmouseenter={`window.showCalTip('${tipText}',event)`}
                          onmouseleave="window.hideCalTip()"
                        ></div>
                      ) : (
                        <div class="cal-sq cal-future"></div>
                      );
                    })}
                  </div>
                ))}
              </div>
            </div>
          </div>
          <!-- Legend -->
          <div class="cal-legend">
            <span class="cal-legend-sq cal-none"></span><span class="cal-legend-lbl">None</span>
            <span class="cal-legend-sq cal-12"></span><span class="cal-legend-lbl">Low (1–2)</span>
            <span class="cal-legend-sq cal-3"></span><span class="cal-legend-lbl">OK (3)</span>
            <span class="cal-legend-sq cal-4"></span><span class="cal-legend-lbl">Good (4)</span>
            <span class="cal-legend-sq cal-5"></span><span class="cal-legend-lbl">Great (5)</span>
          </div>
        </div>
      </div>

      <!-- ENERGY / COMPLIANCE CHART -->
      {energyChart.length > 0 && (
        <div class="card" style="animation-delay:.15s;">
          <div class="ch">
            <div class="ch-ic" style="background:linear-gradient(135deg,#f59e0b,#d97706);box-shadow:0 4px 10px rgba(245,158,11,.2);">⚡</div>
            <div style="flex:1;"><div class="ch-tt">Energy & Compliance</div><div class="ch-sub">Last 7 days</div></div>
          </div>
          <div class="cb">
            <div class="mini3">
              <div class="mini-c">
                <div class="mini-val" style="color:var(--gold);">{avgEnergy}/5</div>
                <div class="mini-lbl">Avg Energy</div>
              </div>
              <div class="mini-c">
                <div class="mini-val" style="color:var(--green);">{mealAdherence}%</div>
                <div class="mini-lbl">Meal Adherence</div>
              </div>
              <div class="mini-c">
                <div class="mini-val" style="color:var(--blue);">{avgWater}</div>
                <div class="mini-lbl">Avg Water/day</div>
              </div>
            </div>
            <div class="echart">
              {energyChart.map(d => (
                <div class="ebar-wrap">
                  <div class="ebar" style={`height:${d.pct}%;background:${d.energy >= 4 ? 'linear-gradient(to top,#10b981,#34d399)' : d.energy >= 2 ? 'linear-gradient(to top,#f59e0b,#fbbf24)' : 'linear-gradient(to top,#ef4444,#f87171)'};`} title={`Energy ${d.energy}/5 · ${d.water} glasses`}></div>
                  <div class="ebar-day">{d.day}</div>
                </div>
              ))}
            </div>
            <div style="display:flex;gap:1rem;font-size:.68rem;color:var(--soft);justify-content:center;">
              <span><span style="color:var(--green);">■</span> High (4-5)</span>
              <span><span style="color:var(--gold);">■</span> Mid (2-3)</span>
              <span><span style="color:var(--red);">■</span> Low (0-1)</span>
            </div>
          </div>
        </div>
      )}

      <!-- SLEEP TREND -->
      <div class="card" style="animation-delay:.18s;">
        <div class="ch">
          <div class="ch-ic" style="background:linear-gradient(135deg,#6366f1,#4f46e5);box-shadow:0 4px 10px rgba(99,102,241,.2);">🌙</div>
          <div>
            <div class="ch-tt">Sleep Trend</div>
            <div class="ch-sub">{sleepChart.length > 0 ? `Last ${sleepChart.length} logged nights` : 'No data yet'}</div>
          </div>
          {avgSleepHours && (
            <div style="margin-left:auto;text-align:right;">
              <div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.5rem;font-weight:900;color:#a5b4fc;">{avgSleepHours}h</div>
              <div style="font-size:.65rem;color:var(--soft);">avg / night</div>
            </div>
          )}
        </div>
        {sleepChart.length > 0 ? (
          <>
            <div class="echart" style="margin-top:.75rem;">
              {sleepChart.map(d => (
                <div class="ebar-wrap">
                  <div class="ebar" style={`height:${Math.max(8,d.pct)}%;background:linear-gradient(to top,${d.color},${d.color}88);`} title={`${d.hours}h sleep · Quality ${d.quality || '—'}/5`}></div>
                  <div class="ebar-day">{d.day}</div>
                </div>
              ))}
            </div>
            <div style="display:flex;align-items:center;gap:1rem;font-size:.68rem;color:var(--soft);justify-content:center;margin-top:.6rem;">
              <span><span style="color:var(--green);">■</span> 7+ hrs</span>
              <span><span style="color:var(--gold);">■</span> 5–7 hrs</span>
              <span><span style="color:var(--red);">■</span> Under 5 hrs</span>
            </div>
            {avgSleepHours && parseFloat(avgSleepHours) < 6 && (
              <div style="margin-top:.75rem;padding:.65rem .85rem;border-radius:11px;background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.2);font-size:.75rem;color:var(--red);">
                ⚠️ Low average sleep may slow fat loss and increase keto flu symptoms. Aim for 7–9 hours.
              </div>
            )}
          </>
        ) : (
          <div style="text-align:center;padding:1.5rem 1rem;">
            <div style="font-size:2.5rem;margin-bottom:.6rem;">😴</div>
            <div style="font-size:.82rem;font-weight:700;color:var(--soft);margin-bottom:.35rem;">No sleep data logged yet</div>
            <div style="font-size:.72rem;color:var(--muted);margin-bottom:1rem;">Track your sleep hours in your daily check-in to see trends here.</div>
            <a href="/dashboard/checkin" style="display:inline-flex;align-items:center;gap:.4rem;padding:.5rem 1.1rem;border-radius:10px;background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.3);color:#a5b4fc;font-size:.75rem;font-weight:700;text-decoration:none;">📝 Go to Check-in</a>
          </div>
        )}
      </div>

      <!-- MACRO TREND (14 days) -->
      {macroTrend.some(d => d.hasData) && (
        <div class="card" style="animation-delay:.2s;">
          <div class="ch">
            <div class="ch-ic" style="background:linear-gradient(135deg,#f59e0b,#d97706);box-shadow:0 4px 10px rgba(245,158,11,.2);">📊</div>
            <div>
              <div class="ch-tt">Calorie Trend</div>
              <div class="ch-sub">Last 14 days from food log</div>
            </div>
            <div style="margin-left:auto;text-align:right;">
              <div style="font-size:.65rem;color:var(--soft);">goal</div>
              <div style="font-weight:800;font-size:.9rem;color:var(--gold);">{macroGoalCal} kcal</div>
            </div>
          </div>
          <div class="echart" style="margin-top:.75rem;">
            {macroTrend.map(d => (
              <div class="ebar-wrap">
                <div class="ebar"
                  style={`height:${d.hasData ? Math.max(5, Math.round((d.cal/maxTrendCal)*100)) : 3}%;background:${!d.hasData ? 'var(--muted)' : d.cal > macroGoalCal * 1.1 ? 'linear-gradient(to top,#ef4444,#f87171)' : d.cal > 0 ? 'linear-gradient(to top,#f59e0b,#fbbf24)' : 'var(--muted)'};`}
                  title={d.hasData ? `${d.cal} kcal` : 'No data'}></div>
                <div class="ebar-day">{d.day}</div>
              </div>
            ))}
          </div>
          <div style="display:flex;gap:.75rem;font-size:.68rem;color:var(--soft);justify-content:center;margin-top:.5rem;">
            <span><span style="color:var(--gold);">■</span> On target</span>
            <span><span style="color:var(--red);">■</span> Over goal</span>
            <span><span style="color:var(--muted);">■</span> Not logged</span>
          </div>
        </div>
      )}

    </div>

    <!-- RIGHT -->
    <div style="display:flex;flex-direction:column;gap:1.25rem;">

      <!-- RINGS -->
      <div class="card" style="animation-delay:.08s;">
        <div class="ch">
          <div class="ch-ic" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);box-shadow:0 4px 10px rgba(139,92,246,.2);">🎯</div>
          <div class="ch-tt">Goal Rings</div>
        </div>
        <div class="cb" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          {[
            {pct:journeyPct,  color:'#10b981', stroke:'url(#g1)', lbl:'Journey',  val:`${currentDay}d`},
            {pct:xpPct,       color:'#8b5cf6', stroke:'url(#g2)', lbl:'Level XP', val:`Lv${xpLevel}`},
            {pct:weightGoalPct||0, color:'#3b82f6', stroke:'url(#g3)', lbl:'Weight',  val:`${weightGoalPct}%`},
            {pct:mealAdherence, color:'#f59e0b', stroke:'url(#g4)', lbl:'Meals',   val:`${mealAdherence}%`},
          ].map((r,ri) => (
            <div style="text-align:center;">
              <div class="ring-wrap">
                <svg class="rsvg" width="90" height="90" viewBox="0 0 90 90">
                  <defs>
                    <linearGradient id={`g${ri+1}`} x1="0%" y1="0%" x2="100%" y2="100%">
                      <stop offset="0%" stop-color={r.color}/>
                      <stop offset="100%" stop-color={r.color} stop-opacity=".6"/>
                    </linearGradient>
                  </defs>
                  <circle class="r-trk" cx="45" cy="45" r="39"/>
                  <circle class="r-fill" cx="45" cy="45" r="39" stroke={r.stroke} style={`stroke-dashoffset:${245-(245*r.pct/100)};`}/>
                </svg>
                <div class="ring-c">
                  <div class="ring-pct" style={`color:${r.color};`}>{r.val}</div>
                  <div class="ring-lbl">{r.lbl}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- WATER HISTORY -->
      {waterHistory.length > 0 && (
        <div class="card" style="animation-delay:.1s;">
          <div class="ch">
            <div class="ch-ic" style="background:linear-gradient(135deg,#3b82f6,#2563eb);box-shadow:0 4px 10px rgba(59,130,246,.2);">💧</div>
            <div>
              <div class="ch-tt">Water History</div>
              <div class="ch-sub">Goal: 8 glasses/day</div>
            </div>
            {avgWaterAll && (
              <div style="margin-left:auto;text-align:right;">
                <div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.4rem;font-weight:900;color:var(--blue);">{avgWaterAll}</div>
                <div style="font-size:.62rem;color:var(--soft);">avg glasses</div>
              </div>
            )}
          </div>
          <div class="echart" style="margin-top:.75rem;">
            {waterHistory.map(d => (
              <div class="ebar-wrap">
                <div class="ebar"
                  style={`height:${Math.max(5,d.pct)}%;background:${d.met ? 'linear-gradient(to top,#3b82f6,#60a5fa)' : 'linear-gradient(to top,#6b7280,#9ca3af)'};`}
                  title={`${d.glasses} glasses`}></div>
                <div class="ebar-day">{d.day}</div>
              </div>
            ))}
          </div>
          <div style="text-align:center;margin-top:.5rem;font-size:.7rem;color:var(--soft);">
            🎯 {goalMetDays}/{waterHistory.length} days hit 8-glass goal
          </div>
        </div>
      )}

      <!-- MILESTONES -->
      <div class="card" style="animation-delay:.12s;">
        <div class="ch">
          <div class="ch-ic" style="background:linear-gradient(135deg,#f59e0b,#d97706);box-shadow:0 4px 10px rgba(245,158,11,.2);">🏆</div>
          <div style="flex:1;"><div class="ch-tt">Milestones</div><div class="ch-sub">{milestones.filter(m => m.done).length}/{milestones.length} achieved</div></div>
        </div>
        <div class="cb">
          <div class="milestones">
            {milestones.map((m,i) => (
              <div class={`ms ${m.done ? 'done' : i === milestones.findIndex(x => !x.done) ? 'next' : ''}`}>
                <div class="ms-icon">{m.icon}</div>
                <div class="ms-info">
                  <div class="ms-lbl" style={m.done ? 'color:var(--rv-accent);' : ''}>{m.label}</div>
                  <div class="ms-day">Day {m.day}</div>
                </div>
                <div class="ms-check">{m.done ? '✓' : i === milestones.findIndex(x => !x.done) ? '⟳' : ''}</div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- XP HISTORY -->
      {xpTxns && xpTxns.length > 0 && (
        <div class="card" style="animation-delay:.18s;">
          <div class="ch">
            <div class="ch-ic" style="background:linear-gradient(135deg,#f59e0b,#d97706);box-shadow:0 4px 10px rgba(245,158,11,.2);">⭐</div>
            <div class="ch-tt">Recent XP</div>
          </div>
          <div class="cb">
            {xpTxns.slice(0,8).map(x => (
              <div class="xp-row">
                <div style="flex:1;">
                  <div class="xp-type">{x.description || x.action_type}</div>
                  <div class="xp-date">{new Date(x.created_at).toLocaleDateString('en',{month:'short',day:'numeric'})}</div>
                </div>
                <div class="xp-pts">+{x.xp_amount} XP</div>
              </div>
            ))}
          </div>
        </div>
      )}

    </div>
  </div>

  <!-- BODY MEASUREMENTS -->
  <div class="card" style="animation-delay:.2s;">
    <div class="ch">
      <div class="ch-ic" style="background:linear-gradient(135deg,#f97316,#ea580c);box-shadow:0 4px 10px rgba(249,115,22,.2);">📏</div>
      <div style="flex:1;"><div class="ch-tt">{t('progress.measurements')}</div><div class="ch-sub">{latestMeasurements ? `Last logged ${new Date(latestMeasurements.logged_date).toLocaleDateString('en',{month:'short',day:'numeric'})}` : 'No measurements yet'}</div></div>
      <button id="openMeasModal" style="font-size:.72rem;font-weight:800;color:var(--rv-accent);background:none;border:none;cursor:pointer;padding:0;">+ Log</button>
    </div>
    <div class="cb">
      {latestMeasurements ? (
        <div style="display:flex;flex-direction:column;gap:1rem;">
          <!-- Latest entry -->
          <div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem;">
              <span style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:var(--soft);">{new Date(latestMeasurements.logged_date).toLocaleDateString('en',{month:'short',day:'numeric',year:'numeric'})}</span>
              <button
                class="edit-meas-btn"
                data-date={latestMeasurements.logged_date}
                data-waist={latestMeasurements.waist_cm || ''}
                data-hips={latestMeasurements.hips_cm || ''}
                data-chest={latestMeasurements.chest_cm || ''}
                data-neck={latestMeasurements.neck_cm || ''}
                data-arm={latestMeasurements.arm_cm || ''}
                data-thigh={latestMeasurements.thigh_cm || ''}
                style="font-size:.68rem;font-weight:800;color:#f97316;background:rgba(249,115,22,.1);border:1px solid rgba(249,115,22,.25);border-radius:7px;padding:.2rem .55rem;cursor:pointer;">✏️ Edit</button>
            </div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;">
              {latestMeasurements.waist_cm && <div style="text-align:center;padding:.75rem;background:rgba(249,115,22,.06);border:1px solid rgba(249,115,22,.15);border-radius:12px;"><div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.3rem;font-weight:900;color:#f97316;">{toM(latestMeasurements.waist_cm)}<span style="font-size:.65rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.6rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.2rem;">{t('progress.waist')}</div></div>}
              {latestMeasurements.hips_cm  && <div style="text-align:center;padding:.75rem;background:rgba(249,115,22,.06);border:1px solid rgba(249,115,22,.15);border-radius:12px;"><div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.3rem;font-weight:900;color:#f97316;">{toM(latestMeasurements.hips_cm)}<span style="font-size:.65rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.6rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.2rem;">{t('progress.hips')}</div></div>}
              {latestMeasurements.chest_cm && <div style="text-align:center;padding:.75rem;background:rgba(249,115,22,.06);border:1px solid rgba(249,115,22,.15);border-radius:12px;"><div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.3rem;font-weight:900;color:#f97316;">{toM(latestMeasurements.chest_cm)}<span style="font-size:.65rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.6rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.2rem;">{t('progress.chest')}</div></div>}
              {latestMeasurements.neck_cm  && <div style="text-align:center;padding:.75rem;background:rgba(249,115,22,.06);border:1px solid rgba(249,115,22,.15);border-radius:12px;"><div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.3rem;font-weight:900;color:#f97316;">{toM(latestMeasurements.neck_cm)}<span style="font-size:.65rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.6rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.2rem;">{t('progress.neck')}</div></div>}
              {latestMeasurements.arm_cm   && <div style="text-align:center;padding:.75rem;background:rgba(249,115,22,.06);border:1px solid rgba(249,115,22,.15);border-radius:12px;"><div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.3rem;font-weight:900;color:#f97316;">{toM(latestMeasurements.arm_cm)}<span style="font-size:.65rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.6rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.2rem;">{t('progress.arm')}</div></div>}
              {latestMeasurements.thigh_cm && <div style="text-align:center;padding:.75rem;background:rgba(249,115,22,.06);border:1px solid rgba(249,115,22,.15);border-radius:12px;"><div style="font-family:'Bricolage Grotesque',system-ui,sans-serif;font-size:1.3rem;font-weight:900;color:#f97316;">{toM(latestMeasurements.thigh_cm)}<span style="font-size:.65rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.6rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.2rem;">{t('progress.thigh')}</div></div>}
            </div>
          </div>
          <!-- Previous entry (if any) -->
          {prevMeasurements && (
            <div style="border-top:1px solid var(--border);padding-top:.9rem;">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem;">
                <span style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:var(--soft);">{new Date(prevMeasurements.logged_date).toLocaleDateString('en',{month:'short',day:'numeric',year:'numeric'})}</span>
                <button
                  class="edit-meas-btn"
                  data-date={prevMeasurements.logged_date}
                  data-waist={prevMeasurements.waist_cm || ''}
                  data-hips={prevMeasurements.hips_cm || ''}
                  data-chest={prevMeasurements.chest_cm || ''}
                  data-neck={prevMeasurements.neck_cm || ''}
                  data-arm={prevMeasurements.arm_cm || ''}
                  data-thigh={prevMeasurements.thigh_cm || ''}
                  style="font-size:.68rem;font-weight:800;color:#f97316;background:rgba(249,115,22,.1);border:1px solid rgba(249,115,22,.25);border-radius:7px;padding:.2rem .55rem;cursor:pointer;">✏️ Edit</button>
              </div>
              <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem;">
                {prevMeasurements.waist_cm && <div style="text-align:center;padding:.5rem;background:rgba(249,115,22,.04);border:1px solid rgba(249,115,22,.1);border-radius:10px;"><div style="font-size:1rem;font-weight:900;color:#f97316;">{toM(prevMeasurements.waist_cm)}<span style="font-size:.6rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.58rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.15rem;">{t('progress.waist')}</div></div>}
                {prevMeasurements.hips_cm  && <div style="text-align:center;padding:.5rem;background:rgba(249,115,22,.04);border:1px solid rgba(249,115,22,.1);border-radius:10px;"><div style="font-size:1rem;font-weight:900;color:#f97316;">{toM(prevMeasurements.hips_cm)}<span style="font-size:.6rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.58rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.15rem;">{t('progress.hips')}</div></div>}
                {prevMeasurements.chest_cm && <div style="text-align:center;padding:.5rem;background:rgba(249,115,22,.04);border:1px solid rgba(249,115,22,.1);border-radius:10px;"><div style="font-size:1rem;font-weight:900;color:#f97316;">{toM(prevMeasurements.chest_cm)}<span style="font-size:.6rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.58rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.15rem;">{t('progress.chest')}</div></div>}
                {prevMeasurements.neck_cm  && <div style="text-align:center;padding:.5rem;background:rgba(249,115,22,.04);border:1px solid rgba(249,115,22,.1);border-radius:10px;"><div style="font-size:1rem;font-weight:900;color:#f97316;">{toM(prevMeasurements.neck_cm)}<span style="font-size:.6rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.58rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.15rem;">{t('progress.neck')}</div></div>}
                {prevMeasurements.arm_cm   && <div style="text-align:center;padding:.5rem;background:rgba(249,115,22,.04);border:1px solid rgba(249,115,22,.1);border-radius:10px;"><div style="font-size:1rem;font-weight:900;color:#f97316;">{toM(prevMeasurements.arm_cm)}<span style="font-size:.6rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.58rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.15rem;">{t('progress.arm')}</div></div>}
                {prevMeasurements.thigh_cm && <div style="text-align:center;padding:.5rem;background:rgba(249,115,22,.04);border:1px solid rgba(249,115,22,.1);border-radius:10px;"><div style="font-size:1rem;font-weight:900;color:#f97316;">{toM(prevMeasurements.thigh_cm)}<span style="font-size:.6rem;color:var(--soft);">{mUnit}</span></div><div style="font-size:.58rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--soft);margin-top:.15rem;">{t('progress.thigh')}</div></div>}
              </div>
            </div>
          )}
        </div>
      ) : (
        <div style="text-align:center;padding:1.5rem;color:var(--soft);">
          <div style="font-size:2rem;margin-bottom:.5rem;">📏</div>
          <div style="font-weight:700;font-size:.85rem;margin-bottom:.3rem;">No measurements yet</div>
          <div style="font-size:.76rem;margin-bottom:1rem;">Track neck, waist, hips and more to see body changes beyond the scale.</div>
          <button id="openMeasModalEmpty" style="padding:.55rem 1.2rem;background:linear-gradient(135deg,#f97316,#ea580c);color:#fff;border:none;border-radius:10px;font-weight:800;font-size:.78rem;cursor:pointer;">+ Log First Measurement</button>
        </div>
      )}
    </div>
  </div>

  <!-- KETONE TRACKER -->
  <div class="card" style="animation-delay:.28s;">
    <div class="ch">
      <div class="ch-ic" style="background:linear-gradient(135deg,#8b5cf6,#6d28d9);box-shadow:0 4px 10px rgba(139,92,246,.2);">🩸</div>
      <div style="flex:1;"><div class="ch-tt">Ketone Tracker</div><div class="ch-sub">{latestKetone ? `Last: ${latestKetone.ketone_mmol} mmol/L · ${new Date(latestKetone.logged_date).toLocaleDateString('en',{month:'short',day:'numeric'})}` : 'No readings yet'}</div></div>
      <button id="openKetoneModal" style="font-size:.72rem;font-weight:800;color:var(--rv-accent);background:none;border:none;cursor:pointer;padding:0;">+ Log</button>
    </div>
    <div class="cb">
      {ketoneStatus && (
        <div style={`display:flex;align-items:center;gap:.75rem;padding:.75rem 1rem;border-radius:12px;background:${ketoneStatus.color}18;border:1px solid ${ketoneStatus.color}30;margin-bottom:1rem;`}>
          <div style={`font-size:1.8rem;font-family:'Bricolage Grotesque',system-ui,sans-serif;font-weight:900;color:${ketoneStatus.color};`}>{latestKetone.ketone_mmol}</div>
          <div>
            <div style={`font-weight:800;font-size:.85rem;color:${ketoneStatus.color};`}>{ketoneStatus.label}</div>
            <div style="font-size:.72rem;color:var(--soft);margin-top:.15rem;">{ketoneStatus.tip}</div>
          </div>
        </div>
      )}

      {ketoneTrendBars.length > 1 && (
        <div class="echart" style="margin:.75rem 0;height:70px;">
          {ketoneTrendBars.map(k => (
            <div class="ebar-wrap">
              <div class="ebar" style={`height:${Math.max(5,k.pct)}%;background:linear-gradient(to top,${k.color},${k.color}88);`} title={`${k.val} mmol/L`}></div>
              <div class="ebar-day" style="font-size:.52rem;">{k.label}</div>
            </div>
          ))}
        </div>
      )}

      {ketoneLogs && ketoneLogs.length > 0 ? (
        <div style="display:flex;flex-direction:column;gap:.4rem;max-height:220px;overflow-y:auto;">
          {ketoneLogs.slice(0, 10).map(k => (
            <div style="display:flex;align-items:center;justify-content:space-between;padding:.5rem .8rem;background:var(--bg);border:1px solid var(--border);border-radius:10px;">
              <div style="display:flex;align-items:center;gap:.6rem;">
                <span style={`font-size:.7rem;font-weight:800;padding:.15rem .45rem;border-radius:6px;background:${k.ketone_mmol >= 1.5 && k.ketone_mmol < 3.0 ? 'rgba(16,185,129,.15)' : k.ketone_mmol >= 0.5 ? 'rgba(245,158,11,.15)' : 'rgba(239,68,68,.15)'};color:${k.ketone_mmol >= 1.5 && k.ketone_mmol < 3.0 ? 'var(--green)' : k.ketone_mmol >= 0.5 ? 'var(--gold)' : 'var(--red)'};`}>{k.measurement_type}</span>
                <span style="font-weight:800;font-size:.85rem;">{k.ketone_mmol} <span style="font-size:.65rem;color:var(--soft);">mmol/L</span></span>
              </div>
              <span style="font-size:.72rem;color:var(--soft);">{new Date(k.logged_date).toLocaleDateString('en',{month:'short',day:'numeric'})}</span>
            </div>
          ))}
        </div>
      ) : (
