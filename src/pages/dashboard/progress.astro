<script is:inline define:vars={{ wRaw, wUnit, wImperial }}>
(function() {
  var SVG_W = 560, SVG_H = 160, SVG_PL = 48, SVG_PR = 12, SVG_PT = 14, SVG_PB = 32;

  function toDisp(kg) {
    return wImperial ? Math.round(kg * 2.20462 * 10) / 10 : Math.round(kg * 10) / 10;
  }

  function buildPath(pts) {
    if (!pts.length) return '';
    if (pts.length === 1) return 'M ' + pts[0].x + ' ' + pts[0].y;
    var d = ['M ' + pts[0].x + ' ' + pts[0].y];
    for (var i = 1; i < pts.length; i++) {
      var prev = pts[i - 1], cur = pts[i];
      var cpx = Math.round((prev.x + cur.x) / 2);
      d.push('C ' + cpx + ' ' + prev.y + ' ' + cpx + ' ' + cur.y + ' ' + cur.x + ' ' + cur.y);
    }
    return d.join(' ');
  }

  function drawWChart(days) {
    var svg = document.getElementById('weightSvg');
    if (!svg || !wRaw.length) return;
    var cutoff = days > 0
      ? new Date(Date.now() - days * 86400000).toISOString().split('T')[0]
      : '0000-01-01';
    var pts0 = wRaw.filter(function(p) { return p.d >= cutoff; });
    if (!pts0.length) return;

    var weights = pts0.map(function(p) { return p.w; });
    var wMin = Math.min.apply(null, weights);
    var wMax = Math.max.apply(null, weights);
    var wRange = (wMax - wMin) || 1;
    var wPad = wRange * 0.12;
    var wLow = Math.max(0, wMin - wPad);
    var wHigh = wMax + wPad;
    var wSpan = wHigh - wLow || 1;

    var pts = pts0.map(function(p, i) {
      return {
        x: pts0.length > 1
          ? SVG_PL + Math.round((i / (pts0.length - 1)) * (SVG_W - SVG_PL - SVG_PR))
          : SVG_PL + Math.round((SVG_W - SVG_PL - SVG_PR) / 2),
        y: SVG_PT + Math.round(((wHigh - p.w) / wSpan) * (SVG_H - SVG_PT - SVG_PB)),
        w: p.w, d: p.d,
        date: new Date(p.d + 'T12:00:00Z').toLocaleDateString('en', {month:'short', day:'numeric'}),
        isLatest: i === pts0.length - 1,
      };
    });

    var linePath = buildPath(pts);
    var bottom = SVG_H - SVG_PB + 2;
    var fillPath = linePath + ' L ' + pts[pts.length-1].x + ' ' + bottom + ' L ' + pts[0].x + ' ' + bottom + ' Z';

    var ticks = Array.from({length: 5}, function(_, i) {
      return {
        val: Math.round(toDisp(wLow + wSpan * i / 4) * 10) / 10,
        y: SVG_PT + Math.round((i / 4) * (SVG_H - SVG_PT - SVG_PB)),
      };
    }).reverse();

    var dateLabels = pts.length > 1
      ? [pts[0], pts[Math.floor((pts.length - 1) / 2)], pts[pts.length - 1]]
      : pts.slice(0, 1);

    var html = '<defs>'
      + '<linearGradient id="wAreaGrad" x1="0" y1="0" x2="0" y2="1">'
      + '<stop offset="0%" stop-color="#3b82f6" stop-opacity="0.35"/>'
      + '<stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/>'
      + '</linearGradient>'
      + '<linearGradient id="wLineGrad" x1="0" y1="0" x2="1" y2="0">'
      + '<stop offset="0%" stop-color="#3b82f6"/>'
      + '<stop offset="100%" stop-color="#10b981"/>'
      + '</linearGradient></defs>';

    if (pts.length > 1) {
      html += '<path d="' + fillPath + '" fill="url(#wAreaGrad)"/>';
      html += '<path d="' + linePath + '" fill="none" stroke="url(#wLineGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>';
    }
    ticks.forEach(function(t) {
      html += '<line x1="' + SVG_PL + '" y1="' + t.y + '" x2="' + (SVG_W - SVG_PR) + '" y2="' + t.y + '" stroke="rgba(0,0,0,0.06)" stroke-width="1"/>';
      html += '<text x="' + (SVG_PL - 5) + '" y="' + (t.y + 4) + '" text-anchor="end" font-size="9" fill="var(--soft)">' + t.val + '</text>';
    });
    pts.forEach(function(p) {
      html += '<circle cx="' + p.x + '" cy="' + p.y + '" r="' + (p.isLatest ? 5 : 3.5) + '"'
        + ' fill="' + (p.isLatest ? '#10b981' : '#3b82f6') + '"'
        + ' stroke="' + (p.isLatest ? '#34d399' : '#60a5fa') + '" stroke-width="1.5">'
        + '<title>' + toDisp(p.w) + ' ' + wUnit + ' \u2014 ' + p.date + '</title></circle>';
    });
    dateLabels.forEach(function(p) {
      html += '<text x="' + p.x + '" y="' + (SVG_H - SVG_PB + 18) + '" text-anchor="middle" font-size="9" fill="var(--soft)">' + p.date + '</text>';
    });

    svg.innerHTML = html;
    var countEl = document.getElementById('weightChartCount');
    if (countEl) countEl.textContent = pts.length + ' measurements logged';
  }

  window.setWRange = function(days, btn) {
    document.querySelectorAll('.w-range-btn').forEach(function(b) {
      b.style.background = 'none';
      b.style.color = 'var(--soft)';
    });
    btn.style.background = 'rgba(255,92,122,.12)';
    btn.style.color = '#FF5C7A';
    drawWChart(days);
  };

  // Initial draw: 30d by default (or all data if fewer than 30 entries)
  document.addEventListener('DOMContentLoaded', function() {
    var defaultDays = wRaw.length >= 5 ? 30 : 90;
    var defaultBtn = document.querySelector('.w-range-btn[data-days="' + defaultDays + '"]');
    if (defaultBtn) window.setWRange(defaultDays, defaultBtn);
  });
})();
</script>
</body>
</html>