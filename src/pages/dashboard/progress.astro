        <input id="weightInput" type="number" step="0.1" min={units === 'imperial' ? 66 : 30} max={units === 'imperial' ? 660 : 300} placeholder={units === 'imperial' ? 'e.g. 185' : 'e.g. 84'}
          style="width:100%;padding:.7rem 1rem;background:var(--bg);border:1.5px solid var(--border2);border-radius:12px;color:var(--text);font-size:.95rem;font-family:'DM Sans',sans-serif;box-sizing:border-box;" />
