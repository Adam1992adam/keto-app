---
// src/pages/dashboard/learn.astro
import { requireAuth } from '../../lib/auth';
import DashNav from '../../components/DashNav.astro';
import { getTranslator, normaliseLang } from '../../lib/i18n';
import BookOpen    from 'lucide-astro/BookOpen';
import GraduationCap from 'lucide-astro/GraduationCap';
import Map         from 'lucide-astro/Map';
import CheckCircle from 'lucide-astro/CheckCircle';
import ClipboardCheck from 'lucide-astro/ClipboardCheck';
import Utensils    from 'lucide-astro/Utensils';
import BarChart3   from 'lucide-astro/BarChart3';
import Timer       from 'lucide-astro/Timer';
import Repeat      from 'lucide-astro/Repeat';
import Trophy      from 'lucide-astro/Trophy';
import ShoppingCart from 'lucide-astro/ShoppingCart';
import Sparkles    from 'lucide-astro/Sparkles';
import Users       from 'lucide-astro/Users';
import Target      from 'lucide-astro/Target';
import Zap         from 'lucide-astro/Zap';
import Play        from 'lucide-astro/Play';
import Lock        from 'lucide-astro/Lock';
import ChevronRight from 'lucide-astro/ChevronRight';
import HelpCircle  from 'lucide-astro/HelpCircle';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? 'Elite' : planType === 'pro_6' ? 'Pro' : 'Basic';
const userName  = profile.full_name?.split(' ')[0] || 'there';
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);

// ── Quick-start progress (server-side checks) ────────────────
const { data: weightLogCheck }  = await db.from('weight_logs').select('id').eq('user_id', user.id).limit(1);
const { data: checkinCheck }    = await db.from('daily_checkins').select('id').eq('user_id', user.id).limit(1);
const { data: taskCheck }       = await db.from('daily_tasks').select('id').eq('user_id', user.id).eq('completed', true).limit(1);
const { data: onboardingCheck } = await db.from('onboarding_data').select('fasting_protocol').eq('user_id', user.id).maybeSingle();

const hasWeight     = (weightLogCheck?.length || 0) > 0;
const hasCheckin    = (checkinCheck?.length   || 0) > 0;
const hasTask       = (taskCheck?.length      || 0) > 0;
const hasOnboarding = !!onboardingCheck;
const hasFasting    = !!(onboardingCheck?.fasting_protocol);

const quickStart = [
  { id: 'qs1', label: 'Complete your profile setup',           done: hasOnboarding, href: '/dashboard/onboarding', desc: 'Set your goals, dietary preferences, and starting stats' },
  { id: 'qs2', label: 'Log your starting weight',              done: hasWeight,     href: '/dashboard/progress',   desc: 'Track fat-loss progress from day one in the Progress page' },
  { id: 'qs3', label: 'Submit your first daily check-in',      done: hasCheckin,    href: '/dashboard/checkin',    desc: 'Earn 30 XP, log how you feel, and protect your streak' },
  { id: 'qs4', label: 'Complete at least one daily task',      done: hasTask,       href: '/dashboard',            desc: 'Check off tasks on the home dashboard to earn XP' },
  { id: 'qs5', label: 'Set up your fasting protocol',          done: hasFasting,    href: '/dashboard/fasting',    desc: 'Choose 12:12, 16:8, or 18:6 intermittent fasting' },
  { id: 'qs6', label: 'View a recipe from your meal plan',     done: false,         href: '/dashboard/recipes',    desc: 'Browse your personalized recipe library', clientId: 'qs6' },
  { id: 'qs7', label: 'Take the guided app tour',              done: false,         href: '/dashboard?tour=1',     desc: 'Get a step-by-step walkthrough of the whole dashboard', clientId: 'qs7', isTour: true },
];

const doneCount = quickStart.filter(i => i.done).length; // client items counted separately

// ── Tab definitions ──────────────────────────────────────────
const tabs = [
  { key: 'guide',  label: 'App Guide', color: '#10b981' },
  { key: 'basics',  label: 'Basics',  color: '#10b981' },
  { key: 'science', label: 'Science', color: '#3b82f6' },
  { key: 'faq',     label: 'FAQ',     color: '#f59e0b' },
  { key: 'tips',    label: '💡 Tips',    color: '#8b5cf6' },
];

// ── Article content ──────────────────────────────────────────
const articles = [
  // ── BASICS ──────────────────────────────────────────────
  {
    id: 'b1', tab: 'basics', icon: '🔥', color: '#10b981',
    title: 'What is Ketosis?',
    summary: 'How your body switches from glucose to fat as its primary fuel source.',
    body: [
      'Ketosis is a natural metabolic state in which your body burns fat for fuel instead of carbohydrates. When you drastically reduce carb intake — typically below 20–50g of net carbs per day — your liver begins converting fatty acids into molecules called ketones: beta-hydroxybutyrate (BHB), acetoacetate, and acetone.',
      'These ketones become the primary energy source for your brain, muscles, and organs. Most people enter nutritional ketosis within 2–7 days of strict carb restriction, though this varies based on activity level, metabolism, and prior diet.',
      'Signs you may be in ketosis: reduced appetite, increased mental clarity, a slight fruity smell on your breath (from acetone), and steady energy without blood-sugar crashes. Blood ketone levels of 0.5–3.0 mmol/L are considered nutritional ketosis.',
    ]
  },
  {
    id: 'b2', tab: 'basics', icon: '⚖️', color: '#10b981',
    title: 'Macros on Keto',
    summary: 'The ideal fat, protein, and carb ratios to stay in ketosis and feel great.',
    body: [
      'The ketogenic diet follows a specific macronutrient ratio that keeps carbohydrates low enough to maintain ketosis while providing adequate protein and plenty of healthy fats.',
      'Standard keto macro split: Fat 70–75% of daily calories · Protein 20–25% · Carbohydrates 5–10% (net carbs typically 20–50g/day).',
      'Net carbs = Total Carbs − Fiber − Sugar Alcohols. Fiber is subtracted because it passes through the gut without raising blood sugar.',
      'Protein matters: too little causes muscle loss; too much triggers gluconeogenesis, which can kick you out of ketosis. A good target is 0.7–1.0g per pound of lean body mass.',
      'Track your macros with a food app for the first few weeks until you develop an intuitive sense of what you are eating.',
    ]
  },
  {
    id: 'b3', tab: 'basics', icon: '✅', color: '#10b981',
    title: 'Foods to Eat',
    summary: 'Your go-to keto staples — fats, proteins, and low-carb vegetables.',
    body: [
      'FATS & OILS — Avocados, avocado oil, olive oil, coconut oil, butter, ghee, MCT oil, heavy cream, full-fat cheese.',
      'PROTEINS — Beef, pork, chicken, turkey, lamb, fatty fish (salmon, mackerel, sardines), eggs, shellfish.',
      'LOW-CARB VEGETABLES — Leafy greens, broccoli, cauliflower, zucchini, asparagus, bell peppers, cucumber, celery, mushrooms.',
      'DAIRY — Full-fat Greek yogurt (in moderation), hard cheeses, cream cheese, sour cream.',
      'NUTS & SEEDS — Macadamia nuts, pecans, walnuts, almonds, flaxseeds, chia seeds. Avoid cashews and most peanuts.',
      'BEVERAGES — Water, sparkling water, black coffee, unsweetened tea, bone broth.',
    ]
  },
  {
    id: 'b4', tab: 'basics', icon: '❌', color: '#10b981',
    title: 'Foods to Avoid',
    summary: 'What to cut out completely to enter and stay in ketosis.',
    body: [
      'GRAINS & STARCHES — Bread, pasta, rice, oats, cereal, crackers, tortillas, quinoa, corn.',
      'SUGARY FOODS — Candy, chocolate (unless 85%+ dark), ice cream, cakes, pastries, cookies, honey, maple syrup, agave.',
      'MOST FRUIT — Bananas, apples, oranges, grapes, mangoes, pineapple. Berries in small amounts are the exception.',
      'LEGUMES — Beans, lentils, chickpeas, peas — surprisingly high in net carbs.',
      'ROOT VEGETABLES — Potatoes, sweet potatoes, parsnips, yams, beets.',
      'SUGARY DRINKS — Soda, juice, sports drinks, sweetened coffee, most alcohol (beer, sweet cocktails, dessert wines).',
      'PROCESSED "LOW-FAT" FOODS — Often loaded with sugar to compensate for flavor. Always read the label.',
    ]
  },
  {
    id: 'b5', tab: 'basics', icon: '⚡', color: '#10b981',
    title: 'Electrolytes',
    summary: 'Why sodium, potassium, and magnesium are critical — and how to get enough.',
    body: [
      'When carb intake drops, insulin levels fall. Lower insulin signals the kidneys to excrete more sodium — and other electrolytes follow. This is why electrolyte management is essential on keto.',
      'SODIUM (2,000–4,000mg/day) — Your most important electrolyte. Salt your food generously. Drink bouillon or bone broth. Do not fear salt on keto.',
      'POTASSIUM (3,500–4,700mg/day) — Found in avocados, leafy greens, salmon, and nuts. Deficiency causes muscle cramps and heart palpitations.',
      'MAGNESIUM (300–500mg/day) — Often depleted on keto. Supports sleep, muscle relaxation, and hundreds of enzymes. Magnesium glycinate is well-tolerated.',
      'Signs of imbalance: fatigue, headaches, muscle cramps, brain fog, heart palpitations. Many people mistake keto flu for carb withdrawal when it is actually electrolyte depletion.',
    ]
  },
  {
    id: 'b6', tab: 'basics', icon: '🤒', color: '#10b981',
    title: 'Keto Flu',
    summary: 'The temporary symptoms that hit in week one — and how to power through them.',
    body: [
      'Keto flu refers to a cluster of symptoms many people experience during the first 1–2 weeks of starting keto. It happens as your body transitions from burning glucose to fat, and is almost entirely caused by electrolyte depletion.',
      'Common symptoms: headaches, fatigue, brain fog, irritability, nausea, muscle cramps, dizziness, sugar cravings. Usually peaks days 2–4 and resolves by day 7–10.',
      'Beat it step 1: Aggressively replenish electrolytes — salt food heavily, drink bouillon, supplement magnesium and potassium.',
      'Beat it step 2: Stay hydrated — aim for 2–3+ litres of water daily. Eat enough fat — do not restrict calories in week one.',
      'Beat it step 3: Avoid intense exercise for the first week. Rest — your body is adapting to a major metabolic shift. The discomfort is temporary and worth it.',
    ]
  },

  // ── SCIENCE ─────────────────────────────────────────────
  {
    id: 's1', tab: 'science', icon: '🧬', color: '#3b82f6',
    title: 'How Fat Burning Works',
    summary: 'The biochemistry of lipolysis and beta-oxidation explained simply.',
    body: [
      'When your body needs energy and glucose is scarce, it turns to stored fat through lipolysis. Triglycerides are broken down into glycerol and fatty acid chains by lipase, triggered by low insulin and high glucagon.',
      'Free fatty acids travel through the bloodstream to cells that need energy. Inside the mitochondria, they are broken down via beta-oxidation into two-carbon units called acetyl-CoA.',
      'In the liver, excess acetyl-CoA is converted into ketone bodies (BHB, acetoacetate) when more is produced than the Krebs cycle can handle. Ketones then travel to the brain and muscles as fuel.',
      'Fat contains 9 calories per gram versus 4 for carbs — making it an incredibly energy-dense fuel. When fully adapted, you have access to tens of thousands of stored calories without ever hitting an energy wall.',
    ]
  },
  {
    id: 's2', tab: 'science', icon: '💉', color: '#3b82f6',
    title: 'Insulin & Fat Storage',
    summary: 'Why insulin is the master switch between fat storage and fat burning.',
    body: [
      'Insulin is a hormone produced by the pancreas in response to rising blood sugar. It acts as a key that lets glucose enter cells — but it is also the primary fat-storage signal in the body.',
      'When insulin is elevated: lipolysis is suppressed (your body cannot access stored fat), the liver prioritises glucose metabolism, and excess glucose is converted to fat.',
      'When insulin is low (as on keto): lipolysis proceeds freely, the liver produces ketones, and fat burning is unlocked.',
      'The carb-insulin cycle: Eating carbs raises blood sugar, which spikes insulin, which stops fat burning, which causes blood sugar to drop, which triggers hunger. Keto breaks this cycle by keeping insulin chronically low.',
    ]
  },
  {
    id: 's3', tab: 'science', icon: '🧠', color: '#3b82f6',
    title: 'Ketones as Brain Fuel',
    summary: 'Why your brain actually prefers ketones — and the cognitive benefits this brings.',
    body: [
      'It was long thought that the brain could only run on glucose. We now know that is not true. The brain is very efficient at using ketones — particularly beta-hydroxybutyrate (BHB) — and may actually prefer them under certain conditions.',
      'BHB produces more ATP per unit than glucose, meaning the brain can do more with less oxygen. Ketone metabolism also produces fewer reactive oxygen species compared to glucose metabolism.',
      'BHB enhances GABA — an inhibitory neurotransmitter linked to calm and focus — and may increase BDNF (Brain-Derived Neurotrophic Factor), which supports neuron growth and plasticity.',
      'Many keto veterans describe a keto clarity — a state of sharp, calm mental focus without the afternoon energy crashes. This typically emerges around week 2–3 once the brain has fully adapted.',
    ]
  },
  {
    id: 's4', tab: 'science', icon: '🔄', color: '#3b82f6',
    title: 'Metabolic Adaptation',
    summary: 'What happens to your metabolism over weeks and months on keto.',
    body: [
      'Days 1–3: Glycogen depletion. Liver and muscle glycogen are exhausted. You lose water weight rapidly (glycogen binds water 3:1). This is not fat loss.',
      'Days 3–7: Ketosis onset. The liver ramps up ketone production. Brain and organs begin switching to ketone use. This is the keto flu window.',
      'Weeks 2–4: Fat adaptation begins. Mitochondrial density increases. Muscles become better at directly burning fatty acids.',
      'Months 2–6: Full fat adaptation. Exercise performance returns to or exceeds baseline. Appetite is regulated. Energy is stable throughout the day.',
      'Long-term adaptations include increased mitochondrial biogenesis, enhanced lipolytic enzyme activity, and greater capacity to oxidise fat at high exercise intensities. The magic happens for those who push through week three.',
    ]
  },
  {
    id: 's5', tab: 'science', icon: '⏰', color: '#3b82f6',
    title: 'Intermittent Fasting Synergy',
    summary: 'Why keto and fasting are a powerful combination for fat loss and metabolic health.',
    body: [
      'Keto and intermittent fasting (IF) both lower insulin and increase ketone production — which is why they work so powerfully together.',
      'Faster ketosis entry: Fasting depletes glycogen quickly. Combining an 18-hour fast with keto means you can enter deep ketosis within hours instead of days.',
      'Appetite suppression: Ketones blunt ghrelin (the hunger hormone). Keto-adapted people find fasting dramatically easier because they simply are not hungry.',
      'Autophagy: Extended fasting (16+ hours) triggers autophagy, a cellular self-cleaning process that removes damaged proteins and organelles.',
      'Common IF protocols on keto: 16:8 (fast 16 hours, eat in 8-hour window), 18:6 (more aggressive, preferred by advanced practitioners), OMAD (one meal a day — powerful for fat loss but requires careful nutrition attention).',
    ]
  },

  // ── FAQ ──────────────────────────────────────────────────
  {
    id: 'f1', tab: 'faq', icon: '⏱️', color: '#f59e0b',
    title: 'How Long to Ketosis?',
    summary: 'How quickly can you get into ketosis, and what affects the timeline?',
    body: [
      'Most people enter nutritional ketosis within 2–7 days of strict carbohydrate restriction. However, the exact timeline varies significantly between individuals.',
      'Factors that speed it up: starting with exercise (depletes glycogen faster), intermittent fasting alongside keto, keeping net carbs under 20g.',
      'Factors that slow it down: higher body weight (more glycogen storage capacity), hidden carbs in sauces or processed foods, stress and poor sleep (cortisol raises blood sugar).',
      'How to measure: Blood ketone meter (0.5–3.0 mmol/L = nutritional ketosis) is most accurate. Urine strips are cheap but less accurate long-term. Breath meters measure acetone non-invasively.',
      'Best approach: keep net carbs under 20g for the first two weeks and trust the process. Add daily exercise to accelerate glycogen depletion.',
    ]
  },
  {
    id: 'f2', tab: 'faq', icon: '🍓', color: '#f59e0b',
    title: 'Can I Eat Fruit?',
    summary: 'The truth about fruit on keto — what to avoid and what is allowed.',
    body: [
      'Most fruit is off-limits on strict keto due to high fructose content. High-carb fruits to avoid: bananas (23g net carbs), grapes (26g per cup), mangoes (22g per cup), apples (21g), oranges (15g).',
      'Fruits you can eat in moderation: raspberries (5g per 100g), blackberries (5g per 100g), strawberries (6g per 100g) — all excellent antioxidant sources with low carb impact.',
      'Blueberries at 12g per 100g are moderate — small servings only.',
      'Always-fine options: avocado (2g net carbs, high in healthy fat), lemon or lime juice (trace carbs, use freely for flavor), olives (near zero net carbs).',
      'Pro tip: A small handful of berries (50–80g) satisfies sweet cravings without derailing ketosis. Pair with whipped cream or full-fat Greek yogurt for a satisfying keto dessert.',
    ]
  },
  {
    id: 'f3', tab: 'faq', icon: '🛡️', color: '#f59e0b',
    title: 'Is Keto Safe Long Term?',
    summary: 'What the research says about years of ketogenic eating.',
    body: [
      'For most healthy adults, well-formulated keto appears safe for years. Research supports sustained improvements in blood sugar, insulin sensitivity, reduced triglycerides, increased HDL cholesterol, and reduced blood pressure.',
      'Keto has decades of clinical use in epilepsy patients with a good safety profile, and emerging evidence supports its role in type 2 diabetes remission.',
      'LDL cholesterol rises in some people — often as large, fluffy particles associated with lower cardiovascular risk rather than small, dense particles. Individual response varies and is worth monitoring.',
      'Common concerns addressed: kidney damage — no evidence in healthy people; heart disease — emerging evidence suggests keto is beneficial for most cardiovascular markers; nutrient deficiencies — a varied whole-food keto diet is nutritionally complete with attention to electrolytes.',
      'Consult your doctor, especially with existing conditions. For healthy people there is growing evidence supporting long-term keto as a viable and beneficial lifestyle.',
    ]
  },
  {
    id: 'f4', tab: 'faq', icon: '🚫', color: '#f59e0b',
    title: 'What Breaks a Fast?',
    summary: 'Which foods and drinks end your fast — and which are safe to consume.',
    body: [
      'Definitely breaks a fast: any food with calories, carbs, or protein; fruit juice, smoothies, or milk in coffee; sugar or sweeteners (debated but many raise insulin); BCAAs and most protein supplements.',
      'Generally safe during a fast: black coffee (may actually enhance fat burning), plain herbal tea, still or sparkling water, calorie-free electrolytes (pure sodium, potassium, magnesium without sweeteners).',
      'MCT oil in very small amounts has minimal insulin response but technically has calories — this is called a "dirty fast," acceptable for weight loss but not for maximum autophagy.',
      'Keto + fasting note: Black coffee with under 1 tbsp of heavy cream has negligible effect on most people\'s fast — acceptable for weight loss, but not for maximum autophagy benefit.',
    ]
  },
  {
    id: 'f5', tab: 'faq', icon: '🏃', color: '#f59e0b',
    title: 'Keto and Exercise',
    summary: 'How to train effectively on keto and what to expect during the adaptation period.',
    body: [
      'The adaptation window (weeks 1–4): Expect reduced performance, especially in high-intensity exercise. Your body is still learning to mobilise fat efficiently. Be patient — do not judge keto by week-one gym performance.',
      'After adaptation (month 2+): Many keto athletes return to or exceed pre-keto performance. Endurance sports especially benefit — you have access to far more stored fat energy than glycogen can ever provide.',
      'Low intensity exercise (walking, yoga, light cycling): Works great from day one. Fat is the primary fuel for these activities anyway.',
      'Moderate intensity (strength training, recreational sports): Works well after adaptation. Performance returns to baseline.',
      'High intensity (sprinting, CrossFit, HIIT): These rely on glycogen. A targeted keto diet — a small carb serving pre-workout only — works well for athletes who need explosive power.',
      'Pro tips: Train fasted in the morning to maximise fat oxidation. Salt your pre-workout water to prevent cramps. Do not chase performance metrics in the first four weeks.',
    ]
  },
  {
    id: 'f6', tab: 'faq', icon: '😮', color: '#f59e0b',
    title: 'Keto Breath',
    summary: 'Why keto causes a distinctive breath odour and what you can do about it.',
    body: [
      'Keto breath is caused by acetone — one of the three ketone bodies — which is expelled through the lungs as a metabolic by-product. It is distinct from regular bad breath (halitosis).',
      'What it smells like: Most describe it as fruity, slightly sweet, or similar to nail polish remover or overripe fruit.',
      'Does it go away? Yes, for most people. As your body becomes more efficient at using ketones, less acetone is produced and exhaled. Keto breath typically fades by weeks 4–8.',
      'What to do in the meantime: stay well hydrated (helps clear acetone via urine), maintain good oral hygiene, use sugar-free gum or mints, or slightly increase protein intake to reduce acetone production.',
      'Know this: keto breath is a sign that ketosis is actively working. It is your body exhaling evidence of fat metabolism in progress.',
    ]
  },

  // ── TIPS ────────────────────────────────────────────────
  {
    id: 't1', tab: 'tips', icon: '🥡', color: '#8b5cf6',
    title: 'Meal Prep Tips',
    summary: 'How to set yourself up for a successful week in just a few hours on Sunday.',
    body: [
      'Meal prep is the single most effective strategy for staying consistent on keto. Without it, you are one busy day away from a bad food decision.',
      'Sunday prep session (2–3 hours): Bake 8–10 chicken thighs (400F, 35 min, olive oil + salt + spices); hard boil a dozen eggs; cook a large batch of ground beef with onion and garlic.',
      'Roast two sheet pans of vegetables (broccoli, zucchini, bell peppers, asparagus) at 425F for 20 minutes. Make a large batch of cauliflower rice.',
      'Storage tips: Use glass containers so you can see what you have and microwave directly. Label with the prep date. Always stock 2–3 emergency keto snacks: cheese, nuts, deli meat, hard-boiled eggs.',
      'Weekly template: Mon–Wed = protein A + roasted veg; Thu–Fri = protein B + cauliflower rice; Saturday = wild card; Sunday = prep again.',
    ]
  },
  {
    id: 't2', tab: 'tips', icon: '🔍', color: '#8b5cf6',
    title: 'Reading Food Labels',
    summary: 'How to spot hidden carbs, sugars, and keto-unfriendly ingredients on any package.',
    body: [
      '"Low carb," "sugar-free," and "keto-friendly" on the front of a package mean nothing. Always flip it and read the nutrition facts panel.',
      'Net carbs formula: Total Carbs minus Dietary Fiber minus (Sugar Alcohols x 0.5). Erythritol is fully subtracted; other sugar alcohols get a 50% discount.',
      'What to check first: serving size (many are unrealistically small), total carbohydrates, dietary fiber, sugar (target 0–2g), added sugars (target zero).',
      'Hidden carb culprits: maltodextrin (higher glycemic index than sugar — common in protein powders and sauces), dextrose, modified food starch, fruit juice concentrate.',
      'Sugar alcohol reality check: erythritol is safe with no blood sugar impact; xylitol has low impact; maltitol has significant glycemic impact and is common in "sugar-free" chocolates — do not count it as zero.',
    ]
  },
  {
    id: 't3', tab: 'tips', icon: '🍽️', color: '#8b5cf6',
    title: 'Eating Out on Keto',
    summary: 'How to navigate restaurants, fast food, and social dining without derailing your progress.',
    body: [
      'The universal keto order: protein + salad or non-starchy vegetable + healthy fat. Any restaurant works with this formula.',
      'Burger joints: order protein style (lettuce wrap instead of bun) or as a bowl. Skip fries, add avocado or a side salad.',
      'Steakhouses: your easiest option. Steak or salmon with a side salad (olive oil + vinegar dressing) and buttered vegetables.',
      'Mexican: fajitas without tortillas, rice, or beans — just the meat and peppers with guacamole, cheese, and sour cream.',
      'Fast food: bunless burgers, grilled chicken, side salads, egg-based breakfast items. Avoid anything breaded or with sweet sauces.',
      'Questions to ask your server: "What is in this sauce?", "Can I substitute the starchy side for extra vegetables?", "Is the protein grilled or breaded?"',
    ]
  },
  {
    id: 't4', tab: 'tips', icon: '👥', color: '#8b5cf6',
    title: 'Social Situations',
    summary: 'How to handle parties, family dinners, and peer pressure while staying on track.',
    body: [
      'At parties: Eat before you go — arriving hungry sets you up to fail. Scan the food spread first and fill your plate with protein, cheese, vegetables, and dips.',
      'Drink sparkling water with lime and hold it — people assume it is a cocktail. You do not owe anyone an explanation.',
      'At family dinners: Bring a keto dish to share. Load up on meat and vegetables; skip bread, pasta, and dessert. Do not announce you are keto unless asked.',
      'Handling comments — "Just have a little": say "I am good, thanks" and repeat as needed. "Is that even healthy?": say "It is working great for me, actually."',
      'If you choose to drink at social events: dry wines (under 2g carbs per 5oz) are the best option; spirits (vodka, whiskey, tequila, gin) are carb-free — use soda water as a mixer. Beer is almost always off-limits.',
    ]
  },
  {
    id: 't5', tab: 'tips', icon: '📉', color: '#8b5cf6',
    title: 'Breaking a Stall',
    summary: 'Why fat loss stalls happen and exactly what to do when the scale stops moving.',
    body: [
      'A stall is when the scale does not move for 2–4+ weeks despite following keto. It is completely normal. Common causes: caloric adaptation, water retention masking fat loss, hidden carbs, or too much dietary fat preventing stored fat mobilisation.',
      'Track everything for one week: hidden carbs are the number-one cause. You may discover you are eating 60g net carbs thinking it is 20g.',
      'Try intermittent fasting: add an 18:6 or 20:4 window to create additional caloric deficit without conscious restriction.',
      'Counterintuitively, reduce dietary fat: eating less added fat (butter, oil, cream) forces your body to burn more stored body fat for fuel.',
      'Other strategies: increase protein (boosts metabolism through the thermic effect of food), add strength training, or take a 1–2 week diet break at maintenance calories to reset leptin and thyroid hormones.',
    ]
  },
  {
    id: 't6', tab: 'tips', icon: '💪', color: '#8b5cf6',
    title: 'Staying Motivated',
    summary: 'Evidence-based strategies to stay consistent when willpower and motivation fade.',
    body: [
      'Motivation is unreliable. Systems, habits, and identity are what actually carry you through a 30, 180, or 365-day journey.',
      'Reframe your identity: Do not say "I am trying keto." Say "I am someone who eats keto." Identity-based goals are stickier than outcome-based goals. Act as the person you want to become.',
      'Track what matters beyond the scale: energy levels, mental clarity, sleep quality, mood stability, clothes fitting differently, blood work improvements. The scale is a lagging, noisy indicator.',
      'Build a streak: Each day you stay keto, your streak grows. Missing one day breaks momentum. Use the app streak tracker as a game — it works.',
      'Find your why and revisit it daily: Write down why you started. Read it every morning. When willpower fades, your why carries you.',
      'Handle slips without shame: If you eat off-plan, the meal is over. One meal does not undo weeks of progress. Get back to it at your next meal — not tomorrow, not Monday. Now.',
    ]
  },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t('learn.title')} | Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,900;1,9..144,900&family=DM+Sans:opsz,wght@9..40,400;9..40,700;9..40,800&display=swap" rel="stylesheet" />
  <script is:inline>(function(){var t=localStorage.getItem('keto-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
  <style>
    /* ── Design Tokens ─────────────────────────────────── */
    :root {
      --bg:      #060d09;
      --bg2:     #0a1410;
      --card:    #0d1a0f;
      --card2:   #111f13;
      --border:  rgba(16,185,129,.1);
      --border2: rgba(16,185,129,.22);
      --text:    #dfeedd;
      --soft:    #4d7055;
      --muted:   #233328;
      --green:   #10b981;
      --green2:  #34d399;
      --gold:    #f59e0b;
      --purple:  #8b5cf6;
      --blue:    #3b82f6;
      --red:     #ef4444;
    }
    [data-theme="light"] {
      --bg:      #eef5ee;
      --bg2:     #e4ede4;
      --card:    #ffffff;
      --card2:   #f5faf5;
      --border:  rgba(0,0,0,.07);
      --border2: rgba(16,185,129,.3);
      --text:    #071807;
      --soft:    #3a6040;
      --muted:   #b8cfb8;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Page Hero ─────────────────────────────────────── */
    .learn-hero {
      background: linear-gradient(135deg, rgba(16,185,129,.08) 0%, rgba(99,102,241,.04) 100%);
      border-bottom: 1px solid var(--border);
      padding: 2.25rem 1.5rem 1.75rem;
      animation: fadeUp .5s ease both;
    }
    .learn-hero-inner { max-width: 960px; margin: 0 auto; }
    .lh-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 1.25rem; flex-wrap: wrap; }
    .lh-eyebrow { font-size: .7rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; color: var(--green); margin-bottom: .45rem; display: flex; align-items: center; gap: .35rem; }
    .learn-title {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.55rem, 3.5vw, 2.2rem);
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: .45rem;
    }
    .learn-title em { font-style: italic; color: var(--green2); }
    .learn-sub {
      color: var(--soft);
      font-size: .88rem;
      font-weight: 500;
      max-width: 520px;
      line-height: 1.6;
    }
    .tour-launch-btn {
      display: inline-flex; align-items: center; gap: .45rem; flex-shrink: 0;
      background: linear-gradient(135deg, var(--green), var(--green2));
      color: #fff; font-weight: 800; font-size: .82rem;
      padding: .65rem 1.35rem; border-radius: 12px;
      text-decoration: none;
      box-shadow: 0 6px 20px rgba(16,185,129,.35);
      transition: transform .2s, box-shadow .2s;
      margin-top: .35rem;
      white-space: nowrap;
    }
    .tour-launch-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(16,185,129,.45); }

    /* ── App Guide Tab ──────────────────────────────────── */
    .guide-section { margin-bottom: 2rem; }
    .guide-section-title {
      font-family: 'Fraunces', serif; font-weight: 900; font-size: 1.1rem;
      color: var(--text); margin-bottom: 1rem;
      display: flex; align-items: center; gap: .55rem;
    }
    /* Quick-start checklist */
    .qs-list { display: flex; flex-direction: column; gap: .55rem; }
    .qs-item {
      display: flex; align-items: center; gap: .85rem;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 14px; padding: .9rem 1.1rem;
      transition: border-color .2s, transform .2s;
      cursor: default;
      animation: fadeUp .4s ease both;
    }
    .qs-item:hover { border-color: var(--border2); transform: translateX(3px); }
    .qs-item.done { border-color: rgba(16,185,129,.25); background: rgba(16,185,129,.04); }
    .qs-check {
      width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0;
      border: 2px solid var(--border2); background: transparent;
      display: flex; align-items: center; justify-content: center;
      transition: background .2s, border-color .2s;
    }
    .qs-item.done .qs-check { background: var(--green); border-color: var(--green); }
    .qs-body { flex: 1; min-width: 0; }
    .qs-label { font-size: .85rem; font-weight: 700; color: var(--text); margin-bottom: .12rem; }
    .qs-item.done .qs-label { color: var(--soft); text-decoration: line-through; }
    .qs-desc { font-size: .75rem; color: var(--soft); line-height: 1.4; }
    .qs-cta {
      font-size: .75rem; font-weight: 800; color: var(--green);
      text-decoration: none; white-space: nowrap; flex-shrink: 0;
      display: flex; align-items: center; gap: .2rem;
      opacity: 0; transition: opacity .15s;
    }
    .qs-item:hover .qs-cta { opacity: 1; }
    .qs-item.done .qs-cta { display: none; }
    .qs-progress {
      display: flex; align-items: center; gap: .85rem;
      margin-bottom: .9rem; padding: .75rem 1rem;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 14px;
    }
    .qs-prog-bar { flex: 1; height: 6px; background: var(--muted); border-radius: 99px; overflow: hidden; }
    .qs-prog-fill { height: 100%; background: linear-gradient(90deg, var(--green), var(--green2)); border-radius: 99px; transition: width 1s ease; }
    .qs-prog-label { font-size: .72rem; font-weight: 800; color: var(--soft); white-space: nowrap; }
    .qs-prog-count { font-size: .72rem; font-weight: 900; color: var(--green); white-space: nowrap; }

    /* Feature cards grid */
    .feat-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: .85rem;
    }
    @media (max-width: 640px) { .feat-grid { grid-template-columns: 1fr; } }
    .feat-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 18px; padding: 1.15rem 1.2rem;
      cursor: pointer;
      transition: border-color .2s, transform .2s, box-shadow .2s;
      animation: fadeUp .4s ease both;
      position: relative; overflow: hidden;
    }
    .feat-card:hover { border-color: var(--border2); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,.15); }
    .feat-card.open { border-color: var(--fc, var(--green)); box-shadow: 0 8px 32px rgba(0,0,0,.2); }
    .fc-top { display: flex; align-items: flex-start; gap: .75rem; }
    .fc-icon {
      width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
      background: var(--fi-bg, rgba(16,185,129,.1)); color: var(--fc, var(--green));
      display: flex; align-items: center; justify-content: center;
    }
    .fc-info { flex: 1; min-width: 0; }
    .fc-title { font-size: .9rem; font-weight: 800; color: var(--text); margin-bottom: .2rem; display: flex; align-items: center; gap: .45rem; }
    .fc-badge { font-size: .62rem; font-weight: 900; padding: .15rem .5rem; border-radius: 99px; letter-spacing: .04em; }
    .fc-badge.elite { background: rgba(245,158,11,.15); color: var(--gold, #f59e0b); }
    .fc-badge.pro   { background: rgba(139,92,246,.15); color: var(--purple, #8b5cf6); }
    .fc-desc { font-size: .77rem; color: var(--soft); line-height: 1.45; }
    .fc-caret { font-size: .85rem; color: var(--soft); transition: transform .25s; flex-shrink: 0; margin-top: .1rem; }
    .feat-card.open .fc-caret { transform: rotate(90deg); color: var(--fc, var(--green)); }
    .fc-body { max-height: 0; overflow: hidden; transition: max-height .35s ease; }
    .feat-card.open .fc-body { max-height: 600px; }
    .fc-steps {
      border-top: 1px solid var(--border); margin-top: .85rem;
      padding-top: .85rem; display: flex; flex-direction: column; gap: .45rem;
    }
    .fc-step { display: flex; align-items: flex-start; gap: .6rem; font-size: .79rem; color: var(--soft); line-height: 1.45; }
    .fc-step-num {
      width: 18px; height: 18px; border-radius: 50%; flex-shrink: 0;
      background: var(--fi-bg, rgba(16,185,129,.1)); color: var(--fc, var(--green));
      font-size: .65rem; font-weight: 900;
      display: flex; align-items: center; justify-content: center;
    }
    .fc-goto {
      display: inline-flex; align-items: center; gap: .3rem;
      margin-top: .8rem; font-size: .77rem; font-weight: 800;
      color: var(--fc, var(--green)); text-decoration: none;
      padding: .4rem .85rem; border-radius: 8px;
      background: var(--fi-bg, rgba(16,185,129,.1));
      transition: background .15s, transform .15s;
    }
    .fc-goto:hover { background: rgba(16,185,129,.18); transform: translateX(2px); }
    .fc-locked { opacity: .5; pointer-events: none; }
    .fc-lock-overlay {
      position: absolute; inset: 0; border-radius: 18px;
      background: rgba(0,0,0,.04); display: flex; align-items: center; justify-content: center;
      pointer-events: none;
    }

    /* ── Sticky Tab Bar ────────────────────────────────── */
    .tab-bar-wrap {
      position: sticky;
      top: 64px;
      z-index: 100;
      background: rgba(6,13,9,.92);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 0 1.5rem;
    }
    [data-theme="light"] .tab-bar-wrap { background: rgba(238,245,238,.95); }
    .tab-bar {
      max-width: 960px;
      margin: 0 auto;
      display: flex;
      gap: .3rem;
      overflow-x: auto;
      scrollbar-width: none;
      padding: .65rem 0;
    }
    .tab-bar::-webkit-scrollbar { display: none; }
    .tab-btn {
      flex-shrink: 0;
      padding: .5rem 1.35rem;
      border-radius: 10px;
      border: 1px solid transparent;
      background: transparent;
      color: var(--soft);
      font-family: 'DM Sans', sans-serif;
      font-size: .85rem;
      font-weight: 700;
      cursor: pointer;
      transition: all .2s;
      white-space: nowrap;
    }
    .tab-btn:hover { color: var(--text); background: rgba(255,255,255,.05); }
    .tab-btn.active {
      color: var(--tc, var(--green));
      background: color-mix(in srgb, var(--tc, var(--green)) 13%, transparent);
      border-color: color-mix(in srgb, var(--tc, var(--green)) 32%, transparent);
    }

    /* ── Content Area ──────────────────────────────────── */
    .learn-content {
      max-width: 960px;
      margin: 0 auto;
      padding: 2rem 1.5rem 6rem;
    }
    .tab-panel { display: none; }
    .tab-panel.active {
      display: block;
      animation: fadeUp .3s ease both;
    }

    /* ── Article Grid ───────────────────────────────────── */
    .article-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    @media (max-width: 660px) { .article-grid { grid-template-columns: 1fr; } }

    /* ── Article Card ───────────────────────────────────── */
    .article-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-left: 4px solid var(--ac, var(--green));
      border-radius: 18px;
      cursor: pointer;
      transition: border-color .2s, box-shadow .2s, transform .2s;
      overflow: hidden;
      animation: fadeUp .4s ease both;
    }
    .article-card:hover {
      border-color: var(--ac, var(--green));
      box-shadow: 0 6px 28px rgba(0,0,0,.22);
      transform: translateY(-2px);
    }
    .article-card.open {
      border-color: var(--ac, var(--green));
      box-shadow: 0 8px 32px rgba(0,0,0,.28);
    }
    .article-grid .article-card:nth-child(1) { animation-delay: .05s; }
    .article-grid .article-card:nth-child(2) { animation-delay: .10s; }
    .article-grid .article-card:nth-child(3) { animation-delay: .15s; }
    .article-grid .article-card:nth-child(4) { animation-delay: .20s; }
    .article-grid .article-card:nth-child(5) { animation-delay: .25s; }
    .article-grid .article-card:nth-child(6) { animation-delay: .30s; }

    /* ── Card Top ───────────────────────────────────────── */
    .ac-top {
      display: flex;
      align-items: flex-start;
      gap: .9rem;
      padding: 1.2rem 1.15rem;
    }
    .ac-icon {
      font-size: 1.65rem;
      flex-shrink: 0;
      line-height: 1;
      margin-top: .05rem;
    }
    .ac-head { flex: 1; min-width: 0; }
    .ac-title {
      font-size: .96rem;
      font-weight: 800;
      color: var(--text);
      margin-bottom: .25rem;
      line-height: 1.25;
    }
    .ac-summary {
      font-size: .79rem;
      color: var(--soft);
      line-height: 1.45;
    }
    .ac-chevron {
      flex-shrink: 0;
      font-size: 1.3rem;
      color: var(--soft);
      transition: transform .28s;
      line-height: 1;
      margin-top: .12rem;
      user-select: none;
    }
    .article-card.open .ac-chevron {
      transform: rotate(90deg);
      color: var(--ac, var(--green));
    }

    /* ── Accordion Body ─────────────────────────────────── */
    .ac-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height .38s ease;
    }
    .article-card.open .ac-body { max-height: 1400px; }
    .ac-content {
      border-top: 1px solid var(--border);
      padding: 1rem 1.2rem 1.4rem;
    }
    .ac-content p {
      font-size: .865rem;
      line-height: 1.75;
      color: var(--text);
      margin-bottom: .55rem;
    }
    .ac-content p:last-child { margin-bottom: 0; }

    /* ── Mobile ─────────────────────────────────────────── */
    @media (max-width: 900px) {
      .learn-hero { padding: 1.5rem 1rem 1.25rem; }
      .tab-bar-wrap { padding: 0 1rem; }
      .learn-content { padding: 1.25rem 1rem 5rem; }
    }
  </style>
</head>
<body>

<DashNav
  userId={user.id}
  userName={userName}
  tierLabel={tierLabel}
  planType={planType}
  activePage="learn"
/>

<!-- Page Hero -->
<div class="learn-hero">
  <div class="learn-hero-inner">
    <div class="lh-row">
      <div>
        <div class="lh-eyebrow"><Map size={13} /> Help &amp; Learn</div>
        <h1 class="learn-title">Your Keto Journey<br/><em>Guide &amp; Hub</em></h1>
        <p class="learn-sub">
          Master the app, understand the science, and get answers — all in one place.
        </p>
      </div>
      <a href="/dashboard?tour=1" class="tour-launch-btn">
        <Play size={14} />
        Take the Tour
      </a>
    </div>
  </div>
</div>

<!-- Sticky Tab Bar -->
<div class="tab-bar-wrap">
  <div class="tab-bar">
    {tabs.map((tab, i) => (
      <button
        class={i === 0 ? 'tab-btn active' : 'tab-btn'}
        data-tab={tab.key}
        style={`--tc: ${tab.color}`}
        onclick={`window.showLearnTab('${tab.key}')`}
      >
        {tab.label}
      </button>
    ))}
  </div>
</div>

<!-- Tab Panels -->
<div class="learn-content">

  <!-- ══ APP GUIDE PANEL ═════════════════════════════════════ -->
  <div class="tab-panel active" data-panel="guide">

    <!-- Quick Start Checklist -->
    <div class="guide-section">
      <h2 class="guide-section-title">
        <Target size={18} style="color:var(--green)" />
        Quick Start Checklist
      </h2>

      <!-- Progress bar -->
      <div class="qs-progress">
        <div class="qs-prog-bar">
          <div class="qs-prog-fill" id="qsProgFill" style={`width:${Math.round((doneCount / quickStart.length) * 100)}%`}></div>
        </div>
        <span class="qs-prog-count" id="qsDoneCount">{doneCount}</span>
        <span class="qs-prog-label">/ {quickStart.length} completed</span>
      </div>

      <div class="qs-list">
        {quickStart.map((item, idx) => (
          <div
            class={item.done ? 'qs-item done' : 'qs-item'}
            id={item.clientId ? `qs-item-${item.clientId}` : undefined}
            style={`animation-delay:${idx * .06}s`}
          >
            <div class="qs-check">
              {item.done && <CheckCircle size={14} color="#fff" />}
            </div>
            <div class="qs-body">
              <div class="qs-label">{item.label}</div>
              <div class="qs-desc">{item.desc}</div>
            </div>
            {!item.done && (
              <a href={item.href} class="qs-cta">
                Go <ChevronRight size={12} />
              </a>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Feature Guide Cards -->
    <div class="guide-section">
      <h2 class="guide-section-title">
        <HelpCircle size={18} style="color:var(--blue)" />
        Feature Guide
      </h2>
      <div class="feat-grid">

        <!-- Daily Check-In -->
        <div class="feat-card" style="--fc:#10b981;--fi-bg:rgba(16,185,129,.1)" onclick="toggleFeat('fc-checkin')">
          <div class="fc-top">
            <div class="fc-icon"><ClipboardCheck size={18} /></div>
            <div class="fc-info">
              <div class="fc-title">Daily Check-In</div>
              <div class="fc-desc">Log your vitals, mood, energy, and water intake every morning.</div>
            </div>
            <ChevronRight size={15} class="fc-caret" />
          </div>
          <div class="fc-body" id="fc-checkin">
            <div class="fc-steps">
              <div class="fc-step"><span class="fc-step-num">1</span>Open Check-In every morning before breakfast</div>
              <div class="fc-step"><span class="fc-step-num">2</span>Rate energy (1–5), mood, hunger, brain fog, and sleep</div>
              <div class="fc-step"><span class="fc-step-num">3</span>Log water glasses and whether you followed your meal plan</div>
              <div class="fc-step"><span class="fc-step-num">4</span>Submit to earn 30 XP and keep your streak alive</div>
            </div>
            <a href="/dashboard/checkin" class="fc-goto">Open Check-In <ChevronRight size={12} /></a>
          </div>
        </div>

        <!-- Meal Planning -->
        <div class="feat-card" style="--fc:#f59e0b;--fi-bg:rgba(245,158,11,.1)" onclick="toggleFeat('fc-meals')">
          <div class="fc-top">
            <div class="fc-icon"><Utensils size={18} /></div>
            <div class="fc-info">
              <div class="fc-title">Meal Planning</div>
              <div class="fc-desc">Personalized keto meals and a full recipe library at your fingertips.</div>
            </div>
            <ChevronRight size={15} class="fc-caret" />
          </div>
          <div class="fc-body" id="fc-meals">
            <div class="fc-steps">
              <div class="fc-step"><span class="fc-step-num">1</span>Today's meals appear automatically on your dashboard</div>
              <div class="fc-step"><span class="fc-step-num">2</span>Tap any meal card to see the full recipe and nutrition</div>
              <div class="fc-step"><span class="fc-step-num">3</span>Use the Swap button if a meal doesn't suit you today</div>
              <div class="fc-step"><span class="fc-step-num">4</span>Browse the full recipe library for {planType === 'basic_30' ? '30+' : planType === 'pro_6' ? '87+' : '150+'} keto recipes</div>
            </div>
            <a href="/dashboard/recipes" class="fc-goto">Browse Recipes <ChevronRight size={12} /></a>
          </div>
        </div>

        <!-- Progress Tracking -->
        <div class="feat-card" style="--fc:#3b82f6;--fi-bg:rgba(59,130,246,.1)" onclick="toggleFeat('fc-progress')">
          <div class="fc-top">
            <div class="fc-icon"><BarChart3 size={18} /></div>
            <div class="fc-info">
              <div class="fc-title">Progress Tracking</div>
              <div class="fc-desc">Charts, weight log, body measurements, and achievement tracking.</div>
            </div>
            <ChevronRight size={15} class="fc-caret" />
          </div>
          <div class="fc-body" id="fc-progress">
            <div class="fc-steps">
              <div class="fc-step"><span class="fc-step-num">1</span>Log your weight regularly — aim for every 3–4 days</div>
              <div class="fc-step"><span class="fc-step-num">2</span>Add body measurements (waist, hips, arms) monthly</div>
              <div class="fc-step"><span class="fc-step-num">3</span>Review energy and compliance trends in the charts</div>
              <div class="fc-step"><span class="fc-step-num">4</span>Check achievements to see badges you've unlocked</div>
            </div>
            <a href="/dashboard/progress" class="fc-goto">View Progress <ChevronRight size={12} /></a>
          </div>
        </div>

        <!-- Fasting Timer -->
        <div class="feat-card" style="--fc:#8b5cf6;--fi-bg:rgba(139,92,246,.1)" onclick="toggleFeat('fc-fasting')">
          <div class="fc-top">
            <div class="fc-icon"><Timer size={18} /></div>
            <div class="fc-info">
              <div class="fc-title">Fasting Timer</div>
              <div class="fc-desc">Track intermittent fasting windows with a live countdown timer.</div>
            </div>
            <ChevronRight size={15} class="fc-caret" />
          </div>
          <div class="fc-body" id="fc-fasting">
            <div class="fc-steps">
              <div class="fc-step"><span class="fc-step-num">1</span>Choose your protocol: 12:12, 16:8, 18:6, or 20:4</div>
              <div class="fc-step"><span class="fc-step-num">2</span>Tap "Start Fast" when your eating window closes</div>
              <div class="fc-step"><span class="fc-step-num">3</span>The timer counts down — the app tracks your progress</div>
              <div class="fc-step"><span class="fc-step-num">4</span>End the fast when your window opens to earn XP</div>
            </div>
            <a href="/dashboard/fasting" class="fc-goto">Open Fasting <ChevronRight size={12} /></a>
          </div>
        </div>

        <!-- Habits & Streaks -->
        <div class="feat-card" style="--fc:#10b981;--fi-bg:rgba(16,185,129,.1)" onclick="toggleFeat('fc-habits')">
          <div class="fc-top">
            <div class="fc-icon"><Repeat size={18} /></div>
            <div class="fc-info">
              <div class="fc-title">Habits &amp; Streaks</div>
              <div class="fc-desc">Build powerful keto habits with daily tracking and streak rewards.</div>
            </div>
            <ChevronRight size={15} class="fc-caret" />
          </div>
          <div class="fc-body" id="fc-habits">
            <div class="fc-steps">
              <div class="fc-step"><span class="fc-step-num">1</span>Visit Habits to see your active daily habit list</div>
              <div class="fc-step"><span class="fc-step-num">2</span>Check off habits each day to earn XP and build streaks</div>
              <div class="fc-step"><span class="fc-step-num">3</span>Your overall streak is protected by daily check-ins</div>
              <div class="fc-step"><span class="fc-step-num">4</span>Milestone streaks (7, 14, 30 days) unlock achievements</div>
            </div>
            <a href="/dashboard/habits" class="fc-goto">Open Habits <ChevronRight size={12} /></a>
          </div>
        </div>

        <!-- XP & Leveling -->
        <div class="feat-card" style="--fc:#f59e0b;--fi-bg:rgba(245,158,11,.1)" onclick="toggleFeat('fc-xp')">
          <div class="fc-top">
            <div class="fc-icon"><Trophy size={18} /></div>
            <div class="fc-info">
              <div class="fc-title">XP &amp; Leveling System</div>
              <div class="fc-desc">Earn XP for every healthy action — level up and unlock achievements.</div>
            </div>
            <ChevronRight size={15} class="fc-caret" />
          </div>
          <div class="fc-body" id="fc-xp">
            <div class="fc-steps">
              <div class="fc-step"><span class="fc-step-num">1</span>Check-in = 30 XP · Task = 10–25 XP · Fasting = 50 XP</div>
              <div class="fc-step"><span class="fc-step-num">2</span>Every 500 XP = 1 level up (shown on your dashboard)</div>
              <div class="fc-step"><span class="fc-step-num">3</span>Streak bonuses multiply XP — never break the chain</div>
              <div class="fc-step"><span class="fc-step-num">4</span>View all earned achievements on your Profile page</div>
            </div>
            <a href="/dashboard/profile" class="fc-goto">View Profile <ChevronRight size={12} /></a>
          </div>
        </div>

        <!-- Shopping List -->
        <div class="feat-card" style="--fc:#3b82f6;--fi-bg:rgba(59,130,246,.1)" onclick="toggleFeat('fc-shopping')">
          <div class="fc-top">
            <div class="fc-icon"><ShoppingCart size={18} /></div>
            <div class="fc-info">
              <div class="fc-title">Shopping List</div>
              <div class="fc-desc">Week-by-week keto shopping lists tailored to your meal plan.</div>
            </div>
            <ChevronRight size={15} class="fc-caret" />
          </div>
          <div class="fc-body" id="fc-shopping">
            <div class="fc-steps">
              <div class="fc-step"><span class="fc-step-num">1</span>Open Shopping to see this week's ingredient list</div>
              <div class="fc-step"><span class="fc-step-num">2</span>Switch between weeks using the week tabs at the top</div>
              <div class="fc-step"><span class="fc-step-num">3</span>Check off items as you shop — the list updates instantly</div>
              <div class="fc-step"><span class="fc-step-num">4</span>Items are grouped by category for easy navigation</div>
            </div>
            <a href="/dashboard/shopping" class="fc-goto">View Shopping List <ChevronRight size={12} /></a>
          </div>
        </div>

        <!-- AI Coach -->
        <div class={`feat-card${planType !== 'elite_12' ? ' fc-locked' : ''}`} style="--fc:#f59e0b;--fi-bg:rgba(245,158,11,.1)" onclick={planType === 'elite_12' ? "toggleFeat('fc-ai')" : ''}>
          <div class="fc-top">
            <div class="fc-icon"><Sparkles size={18} /></div>
            <div class="fc-info">
              <div class="fc-title">
                AI Coach
                {planType === 'elite_12'
                  ? <span class="fc-badge elite">ELITE</span>
                  : <span class="fc-badge pro"><Lock size={10} /> Upgrade</span>}
              </div>
              <div class="fc-desc">Your personal keto AI coach — ask anything, get personalized advice.</div>
            </div>
            <ChevronRight size={15} class="fc-caret" />
          </div>
          {planType === 'elite_12' && (
            <div class="fc-body" id="fc-ai">
              <div class="fc-steps">
                <div class="fc-step"><span class="fc-step-num">1</span>Type any question about keto, your plan, or symptoms</div>
                <div class="fc-step"><span class="fc-step-num">2</span>The AI uses your personal data: weight, streak, checkins</div>
                <div class="fc-step"><span class="fc-step-num">3</span>Use quick suggestions for common topics</div>
                <div class="fc-step"><span class="fc-step-num">4</span>Chat history is saved so you can review past advice</div>
              </div>
              <a href="/dashboard/ai-coach" class="fc-goto">Open AI Coach <ChevronRight size={12} /></a>
            </div>
          )}
          {planType !== 'elite_12' && (
            <div style="padding:.6rem 0 .2rem;font-size:.77rem;color:var(--soft);">
              <a href="/dashboard/upgrade" style="color:var(--gold,#f59e0b);font-weight:700;text-decoration:none;">Upgrade to Elite</a> to unlock your personal AI keto coach.
            </div>
          )}
        </div>

      </div>
    </div>

  </div>
  <!-- ══ END APP GUIDE PANEL ══════════════════════════════════ -->

  <!-- ══ KETO SCIENCE PANELS ══════════════════════════════════ -->
  {tabs.filter(tab => tab.key !== 'guide').map((tab) => (
    <div class="tab-panel" data-panel={tab.key}>
      <div class="article-grid">
        {articles.filter(a => a.tab === tab.key).map(article => (
          <div
            class="article-card"
            data-id={article.id}
            style={`--ac: ${article.color}`}
            onclick={`window.toggleLearn('${article.id}')`}
          >
            <div class="ac-top">
              <span class="ac-icon">{article.icon}</span>
              <div class="ac-head">
                <h3 class="ac-title">{article.title}</h3>
                <p class="ac-summary">{article.summary}</p>
              </div>
              <span class="ac-chevron">&#x203A;</span>
            </div>
            <div class="ac-body" id={`body-${article.id}`}>
              <div class="ac-content">
                {article.body.map(line => (
                  <p>{line}</p>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}
</div>

<script is:inline>
  /* ── Tab switching ───────────────────────────────────── */
  window.showLearnTab = function(tabKey) {
    var panels = document.querySelectorAll('.tab-panel');
    var buttons = document.querySelectorAll('.tab-btn');
    for (var i = 0; i < panels.length; i++) {
      panels[i].classList.remove('active');
    }
    for (var j = 0; j < buttons.length; j++) {
      buttons[j].classList.remove('active');
    }
    var panel = document.querySelector('[data-panel="' + tabKey + '"]');
    var btn   = document.querySelector('[data-tab="' + tabKey + '"]');
    if (panel) panel.classList.add('active');
    if (btn)   btn.classList.add('active');
  };

  /* ── Article accordion ───────────────────────────────── */
  window.toggleLearn = function(id) {
    var card = document.querySelector('[data-id="' + id + '"]');
    if (!card) return;
    var isOpen = card.classList.contains('open');
    var grid = card.closest('.article-grid');
    if (grid) {
      var siblings = grid.querySelectorAll('.article-card.open');
      for (var k = 0; k < siblings.length; k++) {
        siblings[k].classList.remove('open');
      }
    }
    if (!isOpen) {
      card.classList.add('open');
      setTimeout(function() {
        card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 50);
    }
  };

  /* ── Feature card accordion ──────────────────────────── */
  function toggleFeat(bodyId) {
    var body = document.getElementById(bodyId);
    if (!body) return;
    var card = body.closest('.feat-card');
    if (!card) return;
    // Close all others in the same grid
    var grid = card.closest('.feat-grid');
    if (grid) {
      var others = grid.querySelectorAll('.feat-card.open');
      for (var i = 0; i < others.length; i++) {
        if (others[i] !== card) others[i].classList.remove('open');
      }
    }
    card.classList.toggle('open');
  }

  /* ── Client-side quickstart checklist updates ────────── */
  (function() {
    // qs6: recipe viewed
    var qs6Done = !!localStorage.getItem('keto-recipe-viewed');
    if (qs6Done) {
      var el = document.getElementById('qs-item-qs6');
      if (el) el.classList.add('done');
    }

    // qs7: tour completed
    var qs7Done = !!localStorage.getItem('keto-tour-v1');
    var qs7El = document.getElementById('qs-item-qs7');
    if (qs7Done && qs7El) qs7El.classList.add('done');

    // Recount and update progress bar
    var totalDone = document.querySelectorAll('.qs-item.done').length;
    var total = document.querySelectorAll('.qs-item').length;
    var fill = document.getElementById('qsProgFill');
    var count = document.getElementById('qsDoneCount');
    if (fill) fill.style.width = Math.round((totalDone / total) * 100) + '%';
    if (count) count.textContent = String(totalDone);
  })();
</script>

</body>
</html>
