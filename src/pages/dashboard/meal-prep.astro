---
// src/pages/dashboard/meal-prep.astro
// Weekly Meal Prep Planner — Mon–Sun, Breakfast/Lunch/Dinner per day
// Saves to meal_prep_plans via POST /api/meal-prep/save
// ──────────────────────────────────────────────────────────────────

import { requireAuth } from '../../lib/auth';
import { supabase } from '../../lib/supabase';
import DashNav from '../../components/DashNav.astro';
import UtensilsCrossed from 'lucide-astro/UtensilsCrossed';
import Clock from 'lucide-astro/Clock';
import Calendar from 'lucide-astro/Calendar';
import ShoppingCart from 'lucide-astro/ShoppingCart';
import CheckSquare from 'lucide-astro/CheckSquare';
import Flame from 'lucide-astro/Flame';
import Plus from 'lucide-astro/Plus';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile } = auth;

const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? '👑 Elite' : planType === 'pro_6' ? '⚡ Pro' : '🥑 Basic';
const userName  = profile.full_name?.split(' ')[0] || 'there';

// ── Load last saved plan ─────────────────────────────────────────
const { data: savedPlan, error: loadError } = await supabase
  .from('meal_prep_plans')
  .select('id, week_start_date, plan_data, created_at')
  .eq('user_id', user.id)
  .order('week_start_date', { ascending: false })
  .limit(1)
  .maybeSingle();

const planData = savedPlan?.plan_data || {};
const savedDate = savedPlan?.week_start_date || '';
const loadErrMsg = loadError ? loadError.message : '';

// ── Days & slots ─────────────────────────────────────────────────
const DAYS = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
const SLOTS = ['breakfast', 'lunch', 'dinner'];
const SLOT_LABELS = { breakfast: '🌅 Breakfast', lunch: '☀️ Lunch', dinner: '🌙 Dinner' };

// ── Common keto ingredient map per meal keyword ──────────────────
// Used to auto-generate a "Shopping Needs" summary from typed meal names
const KETO_INGREDIENT_HINTS = {
  eggs:         ['Eggs (1 doz)', 'Butter (2 tbsp)', 'Salt & pepper'],
  omelette:     ['Eggs (3)', 'Cheese (30g)', 'Spinach (handful)', 'Butter'],
  bacon:        ['Bacon (200g)', 'Parchment paper'],
  avocado:      ['Avocado (2)', 'Lemon (1)', 'Salt'],
  salad:        ['Lettuce/greens (1 bag)', 'Olive oil (2 tbsp)', 'Cucumber', 'Cherry tomatoes'],
  chicken:      ['Chicken breast/thighs (500g)', 'Olive oil', 'Garlic (3 cloves)', 'Herbs'],
  beef:         ['Ground beef / steak (400g)', 'Olive oil', 'Garlic', 'Salt & pepper'],
  salmon:       ['Salmon fillet (2×150g)', 'Lemon (1)', 'Butter (2 tbsp)', 'Dill'],
  steak:        ['Steak (300g)', 'Butter (30g)', 'Garlic (2 cloves)', 'Rosemary'],
  soup:         ['Bone broth / stock (500ml)', 'Cream (100ml)', 'Onion (1)', 'Garlic'],
  cauliflower:  ['Cauliflower (1 head)', 'Butter (2 tbsp)', 'Cream (50ml)'],
  zucchini:     ['Zucchini (2)', 'Olive oil', 'Parmesan (20g)'],
  shrimp:       ['Shrimp (250g)', 'Butter (2 tbsp)', 'Garlic (3 cloves)', 'Lemon (1)'],
  tuna:         ['Tuna (1 can)', 'Mayo (2 tbsp)', 'Celery (1 stalk)', 'Mustard'],
  burger:       ['Ground beef (400g)', 'Lettuce leaves', 'Cheese (40g)', 'Pickles', 'Mustard'],
  wrap:         ['Lettuce wraps (8 leaves)', 'Chicken (300g)', 'Avocado (1)', 'Cream cheese'],
  bowl:         ['Mixed greens (1 bag)', 'Protein of choice (200g)', 'Olive oil', 'Lemon'],
  stir:         ['Broccoli (1 head)', 'Soy sauce (3 tbsp)', 'Sesame oil (1 tbsp)', 'Garlic'],
  casserole:    ['Ground beef (400g)', 'Cream (200ml)', 'Cheese (100g)', 'Spinach'],
  smoothie:     ['Avocado (1)', 'Coconut milk (200ml)', 'Protein powder (1 scoop)', 'Ice'],
  pancakes:     ['Almond flour (120g)', 'Eggs (3)', 'Cream cheese (60g)', 'Butter'],
  muffins:      ['Almond flour (200g)', 'Eggs (3)', 'Butter (60g)', 'Baking powder'],
  coffee:       ['Coffee beans / grounds', 'Heavy cream (50ml)', 'Butter (1 tbsp)'],
  default:      ['Olive oil (general)', 'Salt & pepper', 'Garlic (bulb)', 'Butter (250g)'],
};

// Serialise saved plan for JS
const planDataJson = JSON.stringify(planData);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Meal Prep Planner · Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,700;1,700&family=DM+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>

<DashNav
  userId={user.id}
  userName={userName}
  tierLabel={tierLabel}
  planType={planType}
  activePage="meal-prep"
/>

<main class="mp-page">

  <!-- ── Header ─────────────────────────────────────────────── -->
  <header class="mp-hero">
    <div class="mp-hero-inner">
      <div>
        <h1 class="mp-title"><UtensilsCrossed size={26} style="vertical-align:middle;margin-right:.5rem;" /> Meal Prep Planner</h1>
        <p class="mp-sub">Plan your full week of keto meals — then save &amp; shop smarter.</p>
        {savedDate && (
          <p class="mp-saved-badge">Last saved: week of {savedDate}</p>
        )}
        {loadErrMsg && (
          <p class="mp-warn">Could not load saved plan: {loadErrMsg}</p>
        )}
      </div>
      <button class="mp-btn-save" onclick="window.savePlan()">
        <CheckSquare size={16} style="vertical-align:middle;margin-right:.3rem;" /> Save Plan
      </button>
    </div>
  </header>

  <!-- ── Status messages ────────────────────────────────────── -->
  <div id="mpStatus" class="mp-status" style="display:none"></div>

  <!-- ── Weekly Grid ────────────────────────────────────────── -->
  <section class="mp-grid-section">
    <div class="mp-grid" id="mpGrid">
      {DAYS.map((day, di) => (
        <div class="mp-day-card" data-day-index={di}>
          <div class="mp-day-header">
            <span class="mp-day-name">{day}</span>
            <span class="mp-day-num">Day {di + 1}</span>
          </div>

          {SLOTS.map((slot) => (
            <div class="mp-slot" data-slot={slot}>
              <div class="mp-slot-label">{SLOT_LABELS[slot]}</div>
              <input
                class="mp-input mp-input-name"
                type="text"
                placeholder="Meal name…"
                value={(planData[day]?.[slot])?.name || ''}
                data-day={day}
                data-field="name"
                data-slot={slot}
                oninput="window.onMealInput(this)"
              />
              <input
                class="mp-input mp-input-prep"
                type="text"
                placeholder="Prep time (e.g. 15 min)"
                value={(planData[day]?.[slot])?.prepTime || ''}
                data-day={day}
                data-field="prepTime"
                data-slot={slot}
                oninput="window.onMealInput(this)"
              />
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- ── Shopping Needs ─────────────────────────────────────── -->
  <section class="mp-shop-section">
    <div class="mp-shop-header">
      <h2 class="mp-shop-title"><ShoppingCart size={20} style="vertical-align:middle;margin-right:.4rem;" /> Shopping Needs</h2>
      <p class="mp-shop-sub">Auto-generated from your typed meal names. Fill in your plan above to see suggestions.</p>
    </div>
    <div id="mpShopList" class="mp-shop-grid">
      <p class="mp-shop-empty">Start filling in meals above — ingredient suggestions will appear here.</p>
    </div>
  </section>

</main>

<style>
/* ── Page layout ─────────────────────────────────────────────── */
.mp-page {
  min-height: calc(100vh - var(--nav-h));
  padding: 2rem 1.5rem 6rem;
  max-width: 1400px;
  margin: 0 auto;
}

/* ── Hero ────────────────────────────────────────────────────── */
.mp-hero {
  margin-bottom: 2rem;
  animation: fadeUp .5s ease both;
}
.mp-hero-inner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}
.mp-title {
  font-family: 'Fraunces', serif;
  font-size: clamp(1.6rem, 4vw, 2.2rem);
  font-weight: 700;
  color: var(--text);
  margin-bottom: .3rem;
}
.mp-sub {
  color: var(--soft);
  font-size: .92rem;
}
.mp-saved-badge {
  margin-top: .4rem;
  font-size: .78rem;
  color: var(--green);
  background: rgba(16,185,129,.08);
  border: 1px solid rgba(16,185,129,.18);
  display: inline-block;
  padding: .2rem .75rem;
  border-radius: 99px;
}
.mp-warn {
  margin-top: .4rem;
  font-size: .78rem;
  color: var(--red);
  background: rgba(239,68,68,.08);
  border: 1px solid rgba(239,68,68,.18);
  display: inline-block;
  padding: .2rem .75rem;
  border-radius: 99px;
}

/* ── Save button ─────────────────────────────────────────────── */
.mp-btn-save {
  padding: .75rem 1.6rem;
  background: var(--green);
  color: #fff;
  border: none;
  border-radius: 12px;
  font-weight: 800;
  font-size: .92rem;
  cursor: pointer;
  transition: transform .15s, box-shadow .15s, opacity .15s;
  white-space: nowrap;
  flex-shrink: 0;
}
.mp-btn-save:hover  { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(16,185,129,.3); }
.mp-btn-save:active { transform: translateY(0); opacity: .85; }
.mp-btn-save:disabled { opacity: .55; cursor: not-allowed; transform: none; }

/* ── Status bar ──────────────────────────────────────────────── */
.mp-status {
  padding: .85rem 1.25rem;
  border-radius: 12px;
  font-size: .88rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
  animation: fadeUp .3s ease both;
}
.mp-status.ok    { background: rgba(16,185,129,.12); border: 1px solid rgba(16,185,129,.25); color: var(--green2); }
.mp-status.error { background: rgba(239,68,68,.1);   border: 1px solid rgba(239,68,68,.2);   color: #f87171; }

/* ── Grid section ────────────────────────────────────────────── */
.mp-grid-section { animation: fadeUp .5s .1s ease both; }

.mp-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: .9rem;
  overflow-x: auto;
  padding-bottom: .5rem;
}
@media (max-width: 1100px) {
  .mp-grid { grid-template-columns: repeat(4, minmax(200px, 1fr)); }
}
@media (max-width: 700px) {
  .mp-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 450px) {
  .mp-grid { grid-template-columns: 1fr; }
}

/* ── Day card ────────────────────────────────────────────────── */
.mp-day-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 18px;
  overflow: hidden;
  transition: border-color .2s, transform .2s;
  min-width: 0;
}
.mp-day-card:hover {
  border-color: var(--border2);
  transform: translateY(-2px);
}

.mp-day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: .7rem 1rem;
  background: rgba(16,185,129,.06);
  border-bottom: 1px solid var(--border);
}
.mp-day-name {
  font-weight: 800;
  font-size: .85rem;
  color: var(--green);
}
.mp-day-num {
  font-size: .72rem;
  color: var(--soft);
  background: var(--muted);
  padding: .15rem .45rem;
  border-radius: 99px;
}

/* ── Slot ────────────────────────────────────────────────────── */
.mp-slot {
  padding: .75rem .85rem;
  border-bottom: 1px solid var(--border);
}
.mp-slot:last-child { border-bottom: none; }

.mp-slot-label {
  font-size: .72rem;
  font-weight: 700;
  color: var(--soft);
  margin-bottom: .42rem;
  text-transform: uppercase;
  letter-spacing: .04em;
}

.mp-input {
  width: 100%;
  background: var(--card2);
  border: 1px solid var(--border);
  border-radius: 9px;
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: .82rem;
  padding: .42rem .65rem;
  outline: none;
  transition: border-color .2s, background .2s;
  margin-bottom: .3rem;
  display: block;
}
.mp-input:last-child { margin-bottom: 0; }
.mp-input::placeholder { color: var(--soft); opacity: .7; }
.mp-input:focus { border-color: var(--green); background: rgba(16,185,129,.04); }
.mp-input-prep { font-size: .76rem; color: var(--soft); }

/* ── Shopping section ────────────────────────────────────────── */
.mp-shop-section {
  margin-top: 2.5rem;
  animation: fadeUp .5s .2s ease both;
}
.mp-shop-header { margin-bottom: 1.25rem; }
.mp-shop-title {
  font-family: 'Fraunces', serif;
  font-size: 1.35rem;
  font-weight: 700;
  margin-bottom: .25rem;
}
.mp-shop-sub {
  font-size: .85rem;
  color: var(--soft);
}

.mp-shop-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1rem;
}
.mp-shop-empty {
  color: var(--soft);
  font-size: .9rem;
  grid-column: 1 / -1;
  padding: 1.5rem;
  text-align: center;
  background: var(--card);
  border: 1px dashed var(--border2);
  border-radius: 14px;
}

/* Shopping category card */
.mp-shop-cat {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 1rem 1.1rem;
  transition: border-color .2s;
}
.mp-shop-cat:hover { border-color: var(--border2); }
.mp-shop-cat-title {
  font-weight: 800;
  font-size: .82rem;
  margin-bottom: .65rem;
  color: var(--green2);
  display: flex;
  align-items: center;
  gap: .35rem;
  text-transform: uppercase;
  letter-spacing: .05em;
}
.mp-shop-item {
  font-size: .84rem;
  color: var(--text);
  padding: .25rem 0;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: .4rem;
}
.mp-shop-item:last-child { border-bottom: none; }
.mp-shop-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--green);
  flex-shrink: 0;
}

/* ── Animation ───────────────────────────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>

<script is:inline define:vars={{ planDataJson, DAYS: JSON.stringify(['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday']) }}>
(function () {

  /* ── State: live plan in memory ──────────────────────────── */
  var plan = {};
  try { plan = JSON.parse(planDataJson) || {}; } catch(e) { plan = {}; }

  var days = JSON.parse(DAYS);

  /* ── Ingredient hints (mirrors server-side map) ─────────── */
  var hints = {
    eggs:         ['Eggs (1 doz)', 'Butter (2 tbsp)', 'Salt & pepper'],
    omelette:     ['Eggs (3)', 'Cheese (30g)', 'Spinach (handful)', 'Butter'],
    bacon:        ['Bacon (200g)', 'Parchment paper'],
    avocado:      ['Avocado (2)', 'Lemon (1)', 'Salt'],
    salad:        ['Lettuce/greens (1 bag)', 'Olive oil (2 tbsp)', 'Cucumber', 'Cherry tomatoes'],
    chicken:      ['Chicken breast/thighs (500g)', 'Olive oil', 'Garlic (3 cloves)', 'Herbs'],
    beef:         ['Ground beef / steak (400g)', 'Olive oil', 'Garlic', 'Salt & pepper'],
    salmon:       ['Salmon fillet (2×150g)', 'Lemon (1)', 'Butter (2 tbsp)', 'Dill'],
    steak:        ['Steak (300g)', 'Butter (30g)', 'Garlic (2 cloves)', 'Rosemary'],
    soup:         ['Bone broth / stock (500ml)', 'Cream (100ml)', 'Onion (1)', 'Garlic'],
    cauliflower:  ['Cauliflower (1 head)', 'Butter (2 tbsp)', 'Cream (50ml)'],
    zucchini:     ['Zucchini (2)', 'Olive oil', 'Parmesan (20g)'],
    shrimp:       ['Shrimp (250g)', 'Butter (2 tbsp)', 'Garlic (3 cloves)', 'Lemon (1)'],
    tuna:         ['Tuna (1 can)', 'Mayo (2 tbsp)', 'Celery (1 stalk)', 'Mustard'],
    burger:       ['Ground beef (400g)', 'Lettuce leaves', 'Cheese (40g)', 'Pickles', 'Mustard'],
    wrap:         ['Lettuce wraps (8 leaves)', 'Chicken (300g)', 'Avocado (1)', 'Cream cheese'],
    bowl:         ['Mixed greens (1 bag)', 'Protein of choice (200g)', 'Olive oil', 'Lemon'],
    stir:         ['Broccoli (1 head)', 'Soy sauce (3 tbsp)', 'Sesame oil (1 tbsp)', 'Garlic'],
    casserole:    ['Ground beef (400g)', 'Cream (200ml)', 'Cheese (100g)', 'Spinach'],
    smoothie:     ['Avocado (1)', 'Coconut milk (200ml)', 'Protein powder (1 scoop)', 'Ice'],
    pancakes:     ['Almond flour (120g)', 'Eggs (3)', 'Cream cheese (60g)', 'Butter'],
    muffins:      ['Almond flour (200g)', 'Eggs (3)', 'Butter (60g)', 'Baking powder'],
    coffee:       ['Coffee beans / grounds', 'Heavy cream (50ml)', 'Butter (1 tbsp)'],
  };

  /* ── Category definitions ───────────────────────────────── */
  var cats = {
    'Protein & Meat':   { icon: '🥩', kw: ['egg','chicken','beef','steak','bacon','salmon','tuna','shrimp','lamb','pork','turkey','fish'] },
    'Dairy & Cheese':   { icon: '🧀', kw: ['cheese','butter','cream','ghee','milk','parmesan','mozzarella','cheddar','ricotta','kefir'] },
    'Fresh Produce':    { icon: '🥬', kw: ['avocado','spinach','lettuce','broccoli','cauliflower','zucchini','cucumber','tomato','celery','lemon','onion'] },
    'Pantry & Oils':    { icon: '🏺', kw: ['olive oil','coconut','almond flour','soy sauce','mustard','mayo','broth','stock','vinegar','baking'] },
    'Herbs & Spices':   { icon: '🌿', kw: ['salt','pepper','garlic','dill','rosemary','herbs','paprika','thyme','basil','oregano','ginger'] },
  };

  /* ── Listen to inputs already rendered in the DOM ───────── */
  document.querySelectorAll('.mp-input').forEach(function(inp) {
    inp.addEventListener('input', function() { window.onMealInput(inp); });
  });

  /* ── onMealInput: update plan state + refresh shopping ──── */
  window.onMealInput = function(el) {
    var day   = el.getAttribute('data-day');
    var slot  = el.getAttribute('data-slot');
    var field = el.getAttribute('data-field');
    var val   = el.value.trim();

    if (!plan[day]) plan[day] = {};
    if (!plan[day][slot]) plan[day][slot] = { name: '', prepTime: '' };
    plan[day][slot][field] = val;

    refreshShopping();
  };

  /* ── Gather ingredient suggestions from typed meal names ── */
  function buildShoppingList() {
    var collected = {}; // category → Set of items

    Object.keys(plan).forEach(function(day) {
      Object.keys(plan[day]).forEach(function(slot) {
        var name = (plan[day][slot].name || '').toLowerCase();
        if (!name) return;

        var matched = false;
        Object.keys(hints).forEach(function(kw) {
          if (name.indexOf(kw) !== -1) {
            matched = true;
            var items = hints[kw];
            items.forEach(function(item) {
              var catKey = categorizItem(item);
              if (!collected[catKey]) collected[catKey] = {};
              collected[catKey][item] = true;
            });
          }
        });

        // Always add base keto pantry if any meal is typed
        if (matched) {
          var baseItems = ['Olive oil (general)', 'Salt & pepper', 'Garlic (bulb)'];
          baseItems.forEach(function(item) {
            var catKey = categorizItem(item);
            if (!collected[catKey]) collected[catKey] = {};
            collected[catKey][item] = true;
          });
        }
      });
    });

    return collected;
  }

  function categorizItem(item) {
    var lower = item.toLowerCase();
    var found = 'Other';
    Object.keys(cats).forEach(function(catName) {
      cats[catName].kw.forEach(function(kw) {
        if (lower.indexOf(kw) !== -1) { found = catName; }
      });
    });
    return found;
  }

  function refreshShopping() {
    var container = document.getElementById('mpShopList');
    if (!container) return;

    var list = buildShoppingList();
    var catKeys = Object.keys(list);

    if (catKeys.length === 0) {
      container.innerHTML = '<p class="mp-shop-empty">Start filling in meals above — ingredient suggestions will appear here.</p>';
      return;
    }

    var html = '';
    catKeys.forEach(function(cat) {
      var catDef = cats[cat] || { icon: '📦' };
      var items = Object.keys(list[cat]);
      if (!items.length) return;

      html += '<div class="mp-shop-cat">';
      html += '<div class="mp-shop-cat-title">' + catDef.icon + ' ' + cat + '</div>';
      items.forEach(function(itm) {
        html += '<div class="mp-shop-item"><span class="mp-shop-dot"></span>' + itm + '</div>';
      });
      html += '</div>';
    });

    container.innerHTML = html || '<p class="mp-shop-empty">No suggestions yet — type some meal names above.</p>';
  }

  /* ── savePlan: POST to /api/meal-prep/save ─────────────── */
  window.savePlan = function() {
    var btn = document.querySelector('.mp-btn-save');
    var statusEl = document.getElementById('mpStatus');

    // Collect current values directly from DOM inputs
    var freshPlan = {};
    document.querySelectorAll('.mp-input').forEach(function(inp) {
      var day   = inp.getAttribute('data-day');
      var slot  = inp.getAttribute('data-slot');
      var field = inp.getAttribute('data-field');
      var val   = inp.value.trim();
      if (!freshPlan[day]) freshPlan[day] = {};
      if (!freshPlan[day][slot]) freshPlan[day][slot] = { name: '', prepTime: '' };
      freshPlan[day][slot][field] = val;
    });

    // Derive this-week Monday
    var now = new Date();
    var dow = now.getDay();
    var diff = (dow === 0) ? -6 : 1 - dow;
    var mon = new Date(now);
    mon.setDate(now.getDate() + diff);
    var weekStart = mon.toISOString().split('T')[0];

    if (btn) { btn.disabled = true; btn.textContent = '⏳ Saving…'; }
    if (statusEl) { statusEl.style.display = 'none'; }

    fetch('/api/meal-prep/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ plan_data: freshPlan, week_start_date: weekStart }),
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (btn) { btn.disabled = false; btn.textContent = '💾 Save Plan'; }
      if (statusEl) {
        statusEl.style.display = 'block';
        if (data.success) {
          statusEl.className = 'mp-status ok';
          statusEl.textContent = '✅ Meal prep plan saved for the week of ' + weekStart + '!';
          plan = freshPlan;
        } else {
          statusEl.className = 'mp-status error';
          statusEl.textContent = '❌ Save failed: ' + (data.error || 'Unknown error');
        }
        // Auto-hide after 4s
        setTimeout(function() { statusEl.style.display = 'none'; }, 4000);
      }
    })
    .catch(function(err) {
      if (btn) { btn.disabled = false; btn.textContent = '💾 Save Plan'; }
      if (statusEl) {
        statusEl.style.display = 'block';
        statusEl.className = 'mp-status error';
        statusEl.textContent = '❌ Network error: ' + err.message;
        setTimeout(function() { statusEl.style.display = 'none'; }, 4000);
      }
    });
  };

  /* ── Initial shopping render from saved plan ────────────── */
  refreshShopping();

})();
</script>

</body>
</html>
