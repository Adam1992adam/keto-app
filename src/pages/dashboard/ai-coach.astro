---
import { getUserJourney, getMealCycleDays } from '../../lib/supabase';
import { requireAuth } from '../../lib/auth';
import Sidebar from '../../components/Sidebar.astro';
import { getTranslator, normaliseLang } from '../../lib/i18n';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;

if (profile.subscription_tier !== 'elite_12') return Astro.redirect('/dashboard/upgrade');

const planType  = profile.subscription_tier;
const tierLabel = 'Elite';
const userName  = profile.full_name?.split(' ')[0] || 'there';
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);
const today     = new Date().toISOString().split('T')[0];
const nowHour   = new Date().getHours();

const journey    = await getUserJourney(user.id, db);
const currentDay = journey?.current_day || 1;
const streak     = journey?.streak_days || 0;
const totalXp    = journey?.total_xp || 0;
const level      = journey?.level || 1;
const weekNum    = Math.ceil(currentDay / 7);
const cycledDay  = ((currentDay - 1) % getMealCycleDays(planType)) + 1;

// Parallel data fetch
const results = await Promise.all([
  db.from('onboarding_data').select('current_weight,target_weight,dietary_restrictions,fasting_protocol').eq('user_id', user.id).maybeSingle(),
  db.from('daily_checkins').select('energy_level,water_glasses,had_headache,had_fatigue').eq('user_id', user.id).eq('checkin_date', today).maybeSingle(),
  db.from('daily_tasks').select('task_title,completed').eq('user_id', user.id).eq('day_number', currentDay),
  db.from('weight_logs').select('weight,logged_date').eq('user_id', user.id).order('logged_date', { ascending: false }).limit(3),
  db.from('fasting_sessions').select('started_at,target_hours').eq('user_id', user.id).is('ended_at', null).order('started_at', { ascending: false }).limit(1).maybeSingle(),
  db.from('macro_goals').select('daily_calories,protein_g,fat_g,carbs_g').eq('user_id', user.id).maybeSingle(),
  db.from('meal_completions').select('meal_type').eq('user_id', user.id).eq('day_number', currentDay),
  db.from('chat_messages').select('role,content,created_at').eq('user_id', user.id).order('created_at', { ascending: false }).limit(40),
]);

const onboarding    = results[0].data;
const todayCheckin  = results[1].data;
const todayTasks    = results[2].data || [];
const weightLogs    = results[3].data || [];
const activeFast    = results[4].data;
const macroGoals    = results[5].data;
const mealComps     = results[6].data || [];
const chatHistory   = (results[7].data || []).reverse();

// Meal plan for today
const { data: mealPlanDirect } = await db
  .from('meal_plans')
  .select('meal_type, recipe:recipes(id,title,calories,protein,fat,net_carbs)')
  .eq('plan_type', planType)
  .eq('day_number', cycledDay)
  .order('meal_type');

const { data: mealPlanFallback } = mealPlanDirect?.length ? { data: null } : await db
  .from('meal_plans')
  .select('meal_type, recipe:recipes(id,title,calories,protein,fat,net_carbs)')
  .eq('plan_type', 'basic_30')
  .eq('day_number', cycledDay)
  .order('meal_type');

const mealPlan = (mealPlanDirect?.length ? mealPlanDirect : mealPlanFallback) || [];

// Group chat history by date for sidebar history panel
const historyByDate = chatHistory.reduce((acc, msg) => {
  const d = new Date((msg as any).created_at).toISOString().split('T')[0];
  if (!acc[d]) acc[d] = { date: d, msgs: [] };
  acc[d].msgs.push(msg);
  return acc;
}, {} as Record<string, { date: string; msgs: any[] }>);
const historyDates = Object.values(historyByDate).sort((a, b) => b.date.localeCompare(a.date));

// Derived stats
const startWeight   = onboarding?.current_weight || 0;
const goalWeight    = onboarding?.target_weight  || 0;
const latestWeight  = weightLogs[0]?.weight || startWeight;
const weightLost    = Math.max(0, startWeight - latestWeight);
const toGoal        = Math.max(0.1, startWeight - goalWeight);
const goalPct       = Math.min(100, Math.round((weightLost / toGoal) * 100));
const completedTasksCount = todayTasks.filter((t) => t.completed).length;
const eatenCount    = mealComps.length;
const totalMeals    = mealPlan.length || 4;
const taskPct       = todayTasks.length > 0 ? Math.round((completedTasksCount / todayTasks.length) * 100) : 0;
const mealPct       = Math.round((eatenCount / totalMeals) * 100);
const waterCount    = (todayCheckin as any)?.water_glasses || 0;
const waterPct      = Math.round((waterCount / 8) * 100);
const fastingActive = !!activeFast;
const fastHours     = activeFast ? Math.floor((Date.now() - new Date(activeFast.started_at).getTime()) / 3600000) : 0;

// Consumed macros
const eatenSet = new Set(mealComps.map((c) => (c as any).meal_type));
const consumed = mealPlan.filter((m) => eatenSet.has((m as any).meal_type) && (m as any).recipe)
  .reduce((acc, m) => {
    const r = (m as any).recipe;
    return { cal: acc.cal + (r.calories||0), prot: acc.prot + parseFloat(r.protein||0), fat: acc.fat + parseFloat(r.fat||0), carbs: acc.carbs + parseFloat(r.net_carbs||0) };
  }, { cal: 0, prot: 0, fat: 0, carbs: 0 });

const calPct  = macroGoals?.daily_calories ? Math.min(100, Math.round((consumed.cal  / macroGoals.daily_calories) * 100)) : 0;
const protPct = macroGoals?.protein_g      ? Math.min(100, Math.round((consumed.prot / macroGoals.protein_g)      * 100)) : 0;
const restrictions = onboarding?.dietary_restrictions || [];

// Pre-computed booleans for JSX conditionals — avoids `< NUMBER` inside {} JSX which Astro reads as a tag
const showLowWater   = !!todayCheckin && (waterCount < 4);
const showBreakfast  = nowHour < 11;
const showLunch      = nowHour >= 11 && nowHour < 15;
const showSnack      = nowHour >= 15 && nowHour < 19;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{t('coach.title')} — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet"/>
  <style>
    :root{--bg:#FAF6F1;--card:#FFFFFF;--card2:#F2EDE5;--border:rgba(255,90,122,.12);--border2:rgba(255,90,122,.28);--rv-accent:#FF5C7A;--surface:#F2EDE5;--text:#1A0A00;--soft:#7A6055;--muted:#E8DDD5;--green:#10b981;--green2:#34d399;--purple:#8b5cf6;--indigo:#6366f1;--gold:#f59e0b;--blue:#3b82f6;}
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Bricolage Grotesque',sans-serif;background:var(--bg);color:var(--text);height:100vh;overflow:hidden;display:flex;flex-direction:column;}

    /* ── Layout ── */
    .ai-layout{display:flex;position:fixed;top:0;bottom:0;left:232px;right:0;overflow:hidden;z-index:200;}

    /* ── Sidebar ── */
    .ai-sidebar{
      width:270px;flex-shrink:0;overflow-y:auto;
      border-right:1px solid var(--border);
      background:var(--card);
      display:flex;flex-direction:column;gap:0;
      scrollbar-width:thin;scrollbar-color:rgba(255,90,122,.15) transparent;
    }
    .ai-sidebar::-webkit-scrollbar{width:3px;}
    .ai-sidebar::-webkit-scrollbar-thumb{background:rgba(255,90,122,.15);border-radius:99px;}

    /* Coach card */
    .ai-coach-card{
      padding:1.25rem 1.1rem 1rem;
      background:linear-gradient(135deg,rgba(255,92,122,.08),rgba(255,92,122,.03));
      border-bottom:1px solid var(--border);
      flex-shrink:0;
    }
    .ai-coach-top{display:flex;align-items:center;gap:.75rem;margin-bottom:.75rem;}
    .ai-coach-avatar{
      width:44px;height:44px;border-radius:14px;flex-shrink:0;
      background:linear-gradient(135deg,#6366f1,#8b5cf6);
      display:flex;align-items:center;justify-content:center;font-size:1.3rem;
      box-shadow:0 6px 20px rgba(99,102,241,.4);position:relative;
    }
    .ai-coach-dot{position:absolute;bottom:-2px;right:-2px;width:11px;height:11px;border-radius:50%;background:#10b981;border:2px solid var(--card);}
    .ai-coach-name{font-size:.95rem;font-weight:800;line-height:1.2;}
    .ai-coach-sub{font-size:.67rem;color:var(--rv-accent);font-weight:700;letter-spacing:.04em;text-transform:uppercase;}
    .ai-user-chip{
      display:flex;align-items:center;gap:.5rem;
      background:rgba(255,92,122,.06);border:1px solid rgba(255,92,122,.15);
      border-radius:10px;padding:.45rem .7rem;
    }
    .ai-user-avatar{width:26px;height:26px;border-radius:8px;background:linear-gradient(135deg,var(--green),#059669);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:.7rem;color:#fff;flex-shrink:0;}
    .ai-user-info{flex:1;min-width:0;}
    .ai-user-name{font-size:.78rem;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .ai-user-meta{font-size:.63rem;color:var(--soft);}

    /* Stats block */
    .ai-stats-block{padding:.9rem 1.1rem;border-bottom:1px solid var(--border);}
    .ai-stats-title{font-size:.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--soft);margin-bottom:.65rem;}
    .ai-stat-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:.55rem;}
    .ai-stat-row:last-child{margin-bottom:0;}
    .ai-stat-label{font-size:.72rem;color:var(--soft);display:flex;align-items:center;gap:.3rem;}
    .ai-stat-val{font-size:.78rem;font-weight:800;}
    .ai-mini-bar{height:4px;border-radius:99px;background:rgba(0,0,0,.07);margin-top:.2rem;overflow:hidden;}
    .ai-mini-fill{height:100%;border-radius:99px;transition:width .4s;}

    /* Today block */
    .ai-today-block{padding:.9rem 1.1rem;border-bottom:1px solid var(--border);}
    .ai-meal-chip{
      display:flex;align-items:center;gap:.4rem;padding:.3rem .6rem;
      border-radius:8px;font-size:.7rem;margin-bottom:.3rem;
    }
    .ai-meal-chip.eaten{background:rgba(16,185,129,.1);color:var(--green);}
    .ai-meal-chip.pending{background:var(--card2);color:var(--soft);}

    /* Suggestions */
    .ai-sug-block{padding:.9rem 1.1rem;flex:1;}
    .ai-sug-title{font-size:.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--soft);margin-bottom:.6rem;}
    .ai-sug-btn{
      display:block;width:100%;text-align:left;
      padding:.55rem .75rem;border-radius:11px;margin-bottom:.35rem;
      background:rgba(255,92,122,.06);border:1px solid rgba(255,92,122,.15);
      color:var(--text);font-size:.73rem;font-weight:600;cursor:pointer;
      transition:all .18s;font-family:inherit;
    }
    .ai-sug-btn:hover{background:rgba(255,92,122,.12);border-color:rgba(255,92,122,.3);transform:translateX(3px);}
    .ai-sug-btn:last-child{margin-bottom:0;}

    /* ── Chat main ── */
    .ai-main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;}

    /* Chat header */
    .ai-chat-header{
      padding:.8rem 1.25rem;border-bottom:1px solid var(--border);
      display:flex;align-items:center;justify-content:space-between;
      background:var(--card);flex-shrink:0;
    }
    .ai-chat-header-left{display:flex;align-items:center;gap:.6rem;}
    .ai-chat-title{font-size:.95rem;font-weight:800;}
    .ai-chat-sub{font-size:.68rem;color:var(--soft);}
    .ai-hbtn{
      padding:.3rem .7rem;border-radius:9px;font-size:.68rem;font-weight:700;
      background:var(--card2);border:1px solid var(--border);
      color:var(--soft);cursor:pointer;transition:all .18s;font-family:inherit;
    }
    .ai-hbtn:hover{border-color:var(--green);color:var(--green);}
    .ai-hbtn.danger:hover{border-color:#ef4444;color:#f87171;}

    /* Messages */
    .ai-messages{
      flex:1;overflow-y:auto;padding:1.25rem;
      display:flex;flex-direction:column;gap:.875rem;
      scroll-behavior:smooth;
    }
    .ai-messages::-webkit-scrollbar{width:4px;}
    .ai-messages::-webkit-scrollbar-track{background:transparent;}
    .ai-messages::-webkit-scrollbar-thumb{background:rgba(0,0,0,.1);border-radius:99px;}

    .ai-msg{display:flex;gap:.6rem;align-items:flex-end;animation:msgIn .2s ease;}
    @keyframes msgIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
    .ai-msg.user{flex-direction:row-reverse;}

    .ai-msg-avatar{
      width:30px;height:30px;border-radius:9px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;font-size:.9rem;
      background:linear-gradient(135deg,#6366f1,#8b5cf6);
    }
    .ai-msg.user .ai-msg-avatar{background:linear-gradient(135deg,var(--green),#059669);}

    .ai-msg-bubble{
      max-width:78%;padding:.7rem .95rem;
      border-radius:18px;font-size:.82rem;line-height:1.65;word-break:break-word;
    }
    .ai-msg.bot .ai-msg-bubble{
      background:var(--card2);border:1px solid var(--border);
      color:var(--text);border-radius:4px 18px 18px 18px;
    }
    .ai-msg.user .ai-msg-bubble{
      background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;
      border-radius:18px 4px 18px 18px;
    }
    .ai-msg.bot .ai-msg-bubble img{max-width:100%;border-radius:10px;margin-top:.5rem;display:block;}

    /* Markdown styles inside bot bubbles */
    .ai-msg.bot .ai-msg-bubble strong{color:var(--green2);font-weight:800;}
    .ai-msg.bot .ai-msg-bubble em{color:var(--gold);font-style:italic;}
    .ai-msg.bot .ai-msg-bubble .ai-h2{font-size:.92rem;font-weight:800;color:var(--text);margin:.6rem 0 .3rem;padding-bottom:.2rem;border-bottom:1px solid var(--border);}
    .ai-msg.bot .ai-msg-bubble .ai-h3{font-size:.82rem;font-weight:800;color:var(--green);margin:.5rem 0 .2rem;}
    .ai-msg.bot .ai-msg-bubble .ai-li{padding:.15rem 0 .15rem .5rem;border-left:2px solid rgba(16,185,129,.3);margin:.15rem 0;color:var(--text);}
    .ai-msg.bot .ai-msg-bubble .ai-li-num{padding:.15rem 0;color:var(--text);}
    .ai-msg.bot .ai-msg-bubble .ai-li-num .ai-num{display:inline-block;min-width:1.4rem;font-weight:800;color:var(--purple);}
    .ai-msg.bot .ai-msg-bubble code{background:rgba(99,102,241,.15);border:1px solid rgba(99,102,241,.2);border-radius:5px;padding:.1rem .35rem;font-family:monospace;font-size:.78rem;color:#a5b4fc;}
    .ai-msg.bot .ai-msg-bubble pre{background:rgba(0,0,0,.05);border:1px solid var(--border);border-radius:10px;padding:.75rem;margin:.5rem 0;overflow-x:auto;}
    .ai-msg.bot .ai-msg-bubble pre code{background:none;border:none;padding:0;font-size:.75rem;}
    .ai-avocado{display:inline-block;letter-spacing:-.05em;}

    /* Typing dots */
    .ai-typing{display:flex;gap:4px;align-items:center;padding:.15rem 0;}
    .ai-typing span{width:6px;height:6px;border-radius:50%;background:var(--soft);animation:tdot 1s infinite;}
    .ai-typing span:nth-child(2){animation-delay:.15s;}
    .ai-typing span:nth-child(3){animation-delay:.3s;}
    @keyframes tdot{0%,60%,100%{transform:translateY(0);opacity:.4;}30%{transform:translateY(-5px);opacity:1;}}

    /* Welcome */
    .ai-welcome .ai-msg-bubble{background:rgba(99,102,241,.08);border-color:rgba(99,102,241,.2);}

    /* Image preview */
    .ai-img-preview{
      margin:.5rem 1.25rem 0;display:none;
      background:var(--card2);border:1px solid var(--border);border-radius:14px;
      padding:.6rem .75rem;align-items:center;gap:.75rem;
    }
    .ai-img-preview.show{display:flex;}
    .ai-img-preview img{width:56px;height:56px;object-fit:cover;border-radius:9px;border:1px solid rgba(99,102,241,.3);}
    .ai-img-preview-info{flex:1;font-size:.72rem;color:var(--soft);}
    .ai-img-remove{width:24px;height:24px;border-radius:6px;background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.2);color:#f87171;font-size:.8rem;cursor:pointer;display:flex;align-items:center;justify-content:center;}

    /* Input area */
    .ai-input-area{
      padding:.875rem 1.25rem 1rem;border-top:1px solid var(--border);
      background:var(--card);flex-shrink:0;
    }
    .ai-input-row{display:flex;align-items:center;gap:.5rem;}
    .ai-img-btn{
      width:38px;height:38px;border-radius:11px;flex-shrink:0;
      background:var(--card2);border:1px solid var(--border);
      display:flex;align-items:center;justify-content:center;font-size:1.05rem;cursor:pointer;transition:all .18s;
    }
    .ai-img-btn:hover{border-color:var(--rv-accent);background:rgba(255,92,122,.1);}
    .ai-input{
      flex:1;padding:.65rem 1rem;border-radius:13px;
      background:var(--card2);border:1px solid var(--border);
      color:var(--text);font-size:.82rem;font-family:inherit;outline:none;
      transition:border-color .18s;resize:none;height:40px;max-height:120px;overflow-y:auto;
    }
    .ai-input:focus{border-color:rgba(255,92,122,.45);}
    .ai-input::placeholder{color:var(--soft);}
    .ai-send{
      width:38px;height:38px;border-radius:11px;flex-shrink:0;
      background:linear-gradient(135deg,var(--rv-accent),#ff8fa3);border:none;color:#fff;
      cursor:pointer;transition:all .18s;display:flex;align-items:center;justify-content:center;
    }
    .ai-send:hover{transform:scale(1.08);box-shadow:0 6px 18px rgba(255,92,122,.35);}
    .ai-send:disabled{opacity:.45;cursor:not-allowed;transform:none;box-shadow:none;}
    .ai-input-hint{font-size:.62rem;color:var(--soft);margin-top:.4rem;text-align:center;}

    /* Mobile */
    @media(max-width:900px){
      .ai-sidebar{display:none;}
      .ai-layout{left:0;bottom:72px;}
      .ai-messages{padding:.875rem;}
      .ai-input-area{padding:.75rem;}
      .ai-msg-bubble{max-width:88%;}
    }
    @media(max-width:400px){
      .ai-msg-bubble{max-width:94%;font-size:.82rem;padding:.6rem .8rem;}
      .ai-messages{padding:.625rem;}
    }
  </style>
</head>
<body>
<Sidebar userName={userName} planType={planType} tierLabel={tierLabel} currentDay={currentDay} activePage="ai-coach" />

<div class="ai-layout">

  <!-- ── SIDEBAR ── -->
  <aside class="ai-sidebar">

    <!-- Coach info -->
    <div class="ai-coach-card">
      <div class="ai-coach-top">
        <div class="ai-coach-avatar">
          🤖
          <div class="ai-coach-dot"></div>
        </div>
        <div>
          <div class="ai-coach-name">Keto AI Coach</div>
          <div class="ai-coach-sub">✦ Elite Exclusive</div>
        </div>
      </div>
      <div class="ai-user-chip">
        <div class="ai-user-avatar">{userName.charAt(0).toUpperCase()}</div>
        <div class="ai-user-info">
          <div class="ai-user-name">{profile.full_name || userName}</div>
          <div class="ai-user-meta">Day {currentDay} · Week {weekNum} · Lv.{level}</div>
        </div>
      </div>
    </div>

    <!-- Journey stats -->
    <div class="ai-stats-block">
      <div class="ai-stats-title">📊 Journey Stats</div>

      <div class="ai-stat-row">
        <span class="ai-stat-label">🔥 Streak</span>
        <span class="ai-stat-val" style="color:var(--gold)">{streak} days</span>
      </div>
      <div class="ai-stat-row">
        <span class="ai-stat-label">⭐ XP</span>
        <span class="ai-stat-val" style="color:var(--purple)">{totalXp}</span>
      </div>
      {weightLost > 0 && (
        <div class="ai-stat-row">
          <span class="ai-stat-label">📉 Lost</span>
          <span class="ai-stat-val" style="color:var(--green)">-{weightLost.toFixed(1)}kg</span>
        </div>
      )}
      {latestWeight > 0 && (
        <div class="ai-stat-row">
          <span class="ai-stat-label">🎯 Current</span>
          <span class="ai-stat-val">{latestWeight}kg</span>
        </div>
      )}
      {goalPct > 0 && (
        <div style="margin-top:.5rem;">
          <div style="display:flex;justify-content:space-between;font-size:.67rem;color:var(--soft);margin-bottom:.25rem;">
            <span>Goal progress</span>
            <span style="color:var(--green);font-weight:800;">{goalPct}%</span>
          </div>
          <div class="ai-mini-bar">
            <div class="ai-mini-fill" style={`width:${goalPct}%;background:linear-gradient(90deg,var(--green),var(--green2));`}></div>
          </div>
        </div>
      )}
    </div>

    <!-- Today's status -->
    <div class="ai-today-block">
      <div class="ai-stats-title">📅 Today</div>

      <div class="ai-stat-row">
        <span class="ai-stat-label">✅ Tasks</span>
        <span class="ai-stat-val">{completedTasksCount}/{todayTasks.length}</span>
      </div>
      <div class="ai-mini-bar" style="margin-bottom:.55rem;">
        <div class="ai-mini-fill" style={`width:${taskPct}%;background:linear-gradient(90deg,#3b82f6,#60a5fa);`}></div>
      </div>

      <div class="ai-stat-row">
        <span class="ai-stat-label">🍽️ Meals</span>
        <span class="ai-stat-val">{eatenCount}/{totalMeals}</span>
      </div>
      <div class="ai-mini-bar" style="margin-bottom:.55rem;">
        <div class="ai-mini-fill" style={`width:${mealPct}%;background:linear-gradient(90deg,var(--green),var(--green2));`}></div>
      </div>

      <div class="ai-stat-row">
        <span class="ai-stat-label">💧 Water</span>
        <span class="ai-stat-val">{waterCount}/8 gl</span>
      </div>
      <div class="ai-mini-bar" style="margin-bottom:.55rem;">
        <div class="ai-mini-fill" style={`width:${waterPct}%;background:linear-gradient(90deg,#06b6d4,#22d3ee);`}></div>
      </div>

      {macroGoals && (
        <div>
          <div class="ai-stat-row">
            <span class="ai-stat-label">🔥 Calories</span>
            <span class="ai-stat-val">{Math.round(consumed.cal)}/{macroGoals.daily_calories}</span>
          </div>
          <div class="ai-mini-bar" style="margin-bottom:.3rem;">
            <div class="ai-mini-fill" style={`width:${calPct}%;background:linear-gradient(90deg,var(--gold),#fbbf24);`}></div>
          </div>
          <div class="ai-stat-row">
            <span class="ai-stat-label">⚡ Protein</span>
            <span class="ai-stat-val">{Math.round(consumed.prot)}g/{macroGoals.protein_g}g</span>
          </div>
          <div class="ai-mini-bar">
            <div class="ai-mini-fill" style={`width:${protPct}%;background:linear-gradient(90deg,var(--purple),#a78bfa);`}></div>
          </div>
        </div>
      )}

      {fastingActive && (
        <div style="margin-top:.65rem;padding:.5rem .65rem;border-radius:10px;background:rgba(139,92,246,.1);border:1px solid rgba(139,92,246,.2);font-size:.72rem;color:#a78bfa;font-weight:700;">
          ⏱️ Fasting: {fastHours}h active
        </div>
      )}
    </div>

    <!-- Chat History panel -->
    {historyDates.length > 0 && (
      <div class="ai-stats-block">
        <div class="ai-stats-title" style="display:flex;align-items:center;justify-content:space-between;">
          💬 Chat History
          <span style="color:var(--soft);font-size:.6rem;font-weight:600;">{chatHistory.length} messages</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:.25rem;">
          {historyDates.map(d => {
            const label = new Date(d.date + 'T12:00:00').toLocaleDateString('en', { month: 'short', day: 'numeric' });
            const firstUser = d.msgs.find((m) => (m as any).role === 'user');
            const preview = firstUser ? (firstUser as any).content.slice(0, 40) + ((firstUser as any).content.length > 40 ? '…' : '') : '';
            const userCount = d.msgs.filter((m) => (m as any).role === 'user').length;
            return (
              <button
                onclick={`window.scrollToDate('${d.date}')`}
                style="text-align:left;background:var(--card2);border:1px solid var(--border);border-radius:9px;padding:.45rem .65rem;cursor:pointer;transition:all .18s;width:100%;"
                onmouseover="this.style.borderColor='rgba(16,185,129,.3)'"
                onmouseout="this.style.borderColor='var(--border)'">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.12rem;">
                  <span style="font-size:.72rem;font-weight:800;color:var(--green);">{label}</span>
                  <span style="font-size:.6rem;color:var(--soft);">{userCount} msg{userCount !== 1 ? 's' : ''}</span>
                </div>
                {preview && <div style="font-size:.65rem;color:var(--soft);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{preview}</div>}
              </button>
            );
          })}
        </div>
      </div>
    )}

    <!-- Dynamic suggestions -->
    <div class="ai-sug-block">
      <div class="ai-sug-title">🧠 Ask me</div>
      {!todayCheckin && (
        <button class="ai-sug-btn" data-msg="I haven't done my check-in yet. What should I focus on today based on my journey?">✅ Today's priorities</button>
      )}
      {fastingActive && (
        <button class="ai-sug-btn" data-msg={`I've been fasting for ${fastHours} hours. Any tips to stay strong and break my fast correctly?`}>⏱️ Fasting {fastHours}h — tips</button>
      )}
      {(todayCheckin as any)?.energy_level <= 2 && (
        <button class="ai-sug-btn" data-msg="My energy is very low today. What can I do to boost it on keto?">⚡ Low energy fix</button>
      )}
      {showLowWater && (
        <button class="ai-sug-btn" data-msg="I've only had a few glasses of water today. How important is hydration on keto and how do I drink more?">💧 Hydration help</button>
      )}
      {(todayCheckin as any)?.had_headache && (
        <button class="ai-sug-btn" data-msg="I have a keto headache today. What are the best immediate remedies?">🧠 Keto headache fix</button>
      )}
      {showBreakfast && (
        <button class="ai-sug-btn" data-msg="What's a quick high-protein keto breakfast I can make in under 10 minutes?">🍽️ Quick keto breakfast</button>
      )}
      {showLunch && (
        <button class="ai-sug-btn" data-msg="Suggest a keto lunch that's filling, easy to make, and keeps me in ketosis.">🍽️ Keto lunch ideas</button>
      )}
      {showSnack && (
        <button class="ai-sug-btn" data-msg="What keto snacks can I have right now to avoid afternoon cravings?">✨ Afternoon snack ideas</button>
      )}
      {nowHour >= 19 && (
        <button class="ai-sug-btn" data-msg="What's a satisfying and easy keto dinner I can cook tonight?">🍽️ Tonight's keto dinner</button>
      )}
      <button class="ai-sug-btn" data-msg={`I'm on Day ${currentDay} of my keto journey. Give me an honest assessment of how I'm doing and what to improve.`}>📊 Full progress review</button>
      <button class="ai-sug-btn" data-msg="What are the best keto foods to improve fat burning and stay in deep ketosis?">🔥 Maximize fat burn</button>
      <button class="ai-sug-btn" data-msg={`I have ${Math.max(0, (macroGoals?.protein_g || 130) - Math.round(consumed.prot))}g protein left to hit my goal today. What foods should I eat?`}>🎯 Hit protein goal</button>
      {restrictions.includes('no_pork') && (
        <button class="ai-sug-btn" data-msg="Give me a high-protein keto meal with no pork — chicken or beef based.">🍽️ No-pork keto meal</button>
      )}
      <button class="ai-sug-btn" data-msg={`Give me the best single keto tip specifically for someone on Day ${currentDay} of their journey.`}>✨ Day {currentDay} tip</button>
    </div>

  </aside>

  <!-- ── MAIN CHAT ── -->
  <main class="ai-main">

    <!-- Chat header -->
    <div class="ai-chat-header">
      <div class="ai-chat-header-left">
        <div style="width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);flex-shrink:0;"></div>
        <div>
          <div class="ai-chat-title">Chat with your AI Coach</div>
          <div class="ai-chat-sub">Day {currentDay} · {streak}-day streak · {totalXp} XP · Level {level}</div>
        </div>
      </div>
      <div style="display:flex;gap:.4rem;">
        <button class="ai-hbtn" id="clearBtn">🗑️ Clear chat</button>
      </div>
    </div>

    <!-- Messages -->
    <div class="ai-messages" id="aiMessages">
      <!-- Welcome -->
      <div class="ai-msg bot ai-welcome">
        <div class="ai-msg-avatar">🤖</div>
        <div class="ai-msg-bubble">
          Hey <strong>{userName}</strong>! I'm your personal Keto AI Coach — I have full access to your journey data.<br/><br/>
          You're on <strong>Day {currentDay}</strong> with a <strong>{streak}-day streak</strong> and <strong>{totalXp} XP</strong> at <strong>Level {level}</strong>.
          {weightLost > 0 && <> You've lost <strong>{weightLost.toFixed(1)}kg</strong> — keep going! 🔥</>}
          <br/><br/>
          <span style="opacity:.7;font-size:.75rem;">📷 Send a food photo for instant macro analysis · Send a fridge photo for recipe ideas · Ask me anything about keto!</span>
        </div>
      </div>

      <!-- Pre-rendered history -->
      {chatHistory.map((msg) => (
        <div class={`ai-msg ${(msg as any).role === 'user' ? 'user' : 'bot'}`} data-date={(msg as any).created_at ? (msg as any).created_at.split('T')[0] : ''}>
          <div class="ai-msg-avatar">{(msg as any).role === 'user' ? '👤' : '🤖'}</div>
          <div class="ai-msg-bubble" data-raw={(msg as any).role === 'assistant' ? (msg as any).content : undefined}>
            {(msg as any).role === 'user' ? (msg as any).content : ''}
          </div>
        </div>
      ))}
    </div>

    <!-- Image preview -->
    <div class="ai-img-preview" id="aiImgPreview">
      <img id="aiImgThumb" src="" alt=""/>
      <div class="ai-img-preview-info">Image ready to send<br/><span style="font-size:.65rem;opacity:.6;">Tap send or add a message</span></div>
      <button class="ai-img-remove" id="aiImgRemove">×</button>
    </div>

    <!-- Input -->
    <div class="ai-input-area">
      <div class="ai-input-row">
        <label class="ai-img-btn" for="aiImgInput" title="Send a food photo">
          📷
          <input type="file" id="aiImgInput" accept="image/*" style="display:none;"/>
        </label>
        <textarea
          class="ai-input"
          id="aiInput"
          placeholder="Ask me anything — recipes, progress, symptoms, meal ideas…"
          rows="1"
        ></textarea>
        <button class="ai-send" id="aiSend">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </div>
      <div class="ai-input-hint">Enter to send · Shift+Enter for new line · Powered by Hy3 AI</div>
    </div>

  </main>
</div>

<script is:inline>
// ── Markdown renderer ───────────────────────────────────────
function md(raw) {
  if (!raw) return '';
  var s = raw;
  // Preserve code blocks
  var codeBlocks = [];
  s = s.replace(/```[\w]*\n?([\s\S]*?)```/g, function(_, code) {
    var i = codeBlocks.length;
    codeBlocks.push(code.trim().replace(/</g,'&lt;').replace(/>/g,'&gt;'));
    return '\x00CB'+i+'\x00';
  });
  // Inline code
  var inlineCodes = [];
  s = s.replace(/`([^`\n]+)`/g, function(_, code) {
    var i = inlineCodes.length;
    inlineCodes.push(code.replace(/</g,'&lt;').replace(/>/g,'&gt;'));
    return '\x00IC'+i+'\x00';
  });
  // Bold italic
  s = s.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
  // Bold
  s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  // Italic
  s = s.replace(/\*([^\*\n]+?)\*/g, '<em>$1</em>');
  // Headings
  s = s.replace(/^### (.+)$/gm, '<div class="ai-h3">$1</div>');
  s = s.replace(/^## (.+)$/gm,  '<div class="ai-h2">$1</div>');
  // Numbered list
  s = s.replace(/^(\d+)\. (.+)$/gm, '<div class="ai-li-num"><span class="ai-num">$1.</span> $2</div>');
  // Bullet list
  s = s.replace(/^[-*•] (.+)$/gm, '<div class="ai-li">$1</div>');
  // Avocado rating
  s = s.replace(/(🥑+)\/5/g, '<span class="ai-avocado">$1</span>/5');
  // Line breaks
  s = s.replace(/\n\n/g, '<br/><br/>');
  s = s.replace(/\n/g, '<br/>');
  // Restore code blocks
  codeBlocks.forEach(function(code, i) {
    s = s.replace('\x00CB'+i+'\x00', '<pre><code>'+code+'</code></pre>');
  });
  inlineCodes.forEach(function(code, i) {
    s = s.replace('\x00IC'+i+'\x00', '<code>'+code+'</code>');
  });
  return s;
}

// Render pre-rendered history bot messages
document.querySelectorAll('.ai-msg.bot .ai-msg-bubble[data-raw]').forEach(function(el) {
  var raw = el.getAttribute('data-raw');
  if (raw) el.innerHTML = md(raw);
  el.removeAttribute('data-raw');
});

// ── Elements ────────────────────────────────────────────────
var messages = document.getElementById('aiMessages');
var input    = document.getElementById('aiInput');
var sendBtn  = document.getElementById('aiSend');
var imgInput = document.getElementById('aiImgInput');
var imgPrev  = document.getElementById('aiImgPreview');
var imgThumb = document.getElementById('aiImgThumb');
var imgRem   = document.getElementById('aiImgRemove');
var clearBtn = document.getElementById('clearBtn');

var pendingImg = null;
var isLoading  = false;

// Auto-scroll to bottom on load
scrollBottom();

// ── Suggestions ─────────────────────────────────────────────
document.querySelectorAll('.ai-sug-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var msg = btn.getAttribute('data-msg');
    if (msg && input) {
      input.value = msg;
      autoResize();
      sendMsg();
    }
  });
});

// ── Image handling ───────────────────────────────────────────
imgInput.addEventListener('change', function() {
  var file = this.files && this.files[0];
  if (!file) return;
  if (file.size > 4 * 1024 * 1024) { alert('Max image size: 4MB'); return; }
  var reader = new FileReader();
  reader.onload = function(ev) {
    var result = ev.target.result;
    var base64 = result.split(',')[1];
    pendingImg = { base64: base64, type: file.type };
    imgThumb.src = result;
    imgPrev.classList.add('show');
  };
  reader.readAsDataURL(file);
});

imgRem.addEventListener('click', clearImage);
function clearImage() {
  pendingImg = null;
  imgInput.value = '';
  imgPrev.classList.remove('show');
  imgThumb.src = '';
}

// ── Clear chat ───────────────────────────────────────────────
clearBtn.addEventListener('click', function() {
  if (!confirm('Clear all chat history?')) return;
  fetch('/api/chat/history', { method: 'DELETE' }).then(function() {
    messages.innerHTML = '';
    addWelcome();
  });
});

function addWelcome() {
  var w = document.createElement('div');
  w.className = 'ai-msg bot ai-welcome';
  w.innerHTML = '<div class="ai-msg-avatar">🤖</div><div class="ai-msg-bubble"><strong>Chat cleared!</strong> Ready for a fresh start. Ask me anything 💪</div>';
  messages.appendChild(w);
  scrollBottom();
}

// ── Send ─────────────────────────────────────────────────────
sendBtn.addEventListener('click', sendMsg);
input.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMsg(); }
});

// Auto-resize textarea
input.addEventListener('input', autoResize);
function autoResize() {
  input.style.height = '40px';
  input.style.height = Math.min(input.scrollHeight, 120) + 'px';
}

async function sendMsg() {
  var text = input.value.trim();
  if ((!text && !pendingImg) || isLoading) return;

  isLoading = true;
  sendBtn.disabled = true;

  // User bubble
  if (pendingImg) {
    addBubble('<img src="data:' + pendingImg.type + ';base64,' + pendingImg.base64 + '" style="max-width:200px;border-radius:10px;margin-bottom:.3rem;display:block;"/>' + (text ? escHtml(text) : '📸 Image sent'), 'user', true);
  } else {
    addBubble(escHtml(text), 'user', true);
  }

  input.value = '';
  input.style.height = '40px';

  var typing = addTyping();

  try {
    var res = await fetch('/api/chat/gemini', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ message: text || '', imageBase64: pendingImg ? pendingImg.base64 : null, imageType: pendingImg ? pendingImg.type : null }),
    });

    typing.remove();

    var data = await res.json();
    if (!res.ok || data.error) {
      addBubble('❌ ' + (data.error || 'Something went wrong. Please try again.'), 'bot', true);
    } else {
      var bubble = addBubble('', 'bot', true);
      bubble.querySelector('.ai-msg-bubble').innerHTML = md(data.reply);
    }
  } catch (e) {
    typing.remove();
    addBubble('❌ Connection error. Please check your network and try again.', 'bot', true);
  }

  clearImage();
  isLoading = false;
  sendBtn.disabled = false;
  input.focus();
}

// ── Helpers ──────────────────────────────────────────────────
function addBubble(htmlContent, role, scroll) {
  var wrap   = document.createElement('div');
  wrap.className = 'ai-msg ' + role;
  var avatar = document.createElement('div');
  avatar.className = 'ai-msg-avatar';
  avatar.textContent = role === 'user' ? '👤' : '🤖';
  var bubble = document.createElement('div');
  bubble.className = 'ai-msg-bubble';
  bubble.innerHTML = htmlContent;
  wrap.appendChild(avatar);
  wrap.appendChild(bubble);
  messages.appendChild(wrap);
  if (scroll) scrollBottom();
  return wrap;
}

function addTyping() {
  var wrap = document.createElement('div');
  wrap.className = 'ai-msg bot';
  wrap.innerHTML = '<div class="ai-msg-avatar">🤖</div><div class="ai-msg-bubble"><div class="ai-typing"><span></span><span></span><span></span></div></div>';
  messages.appendChild(wrap);
  scrollBottom();
  return wrap;
}

function scrollBottom() {
  if (messages) messages.scrollTop = messages.scrollHeight;
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── History scroll ───────────────────────────────────────────
window.scrollToDate = function(date) {
  var msgs = messages.querySelectorAll('.ai-msg[data-date]');
  for (var i = 0; i < msgs.length; i++) {
    if (msgs[i].getAttribute('data-date') === date) {
      msgs[i].scrollIntoView({ behavior: 'smooth', block: 'start' });
      return;
    }
  }
};
</script>
</body>
</html>
