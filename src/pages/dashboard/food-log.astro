---
// src/pages/dashboard/food-log.astro
import { requireAuth } from '../../lib/auth';
import Sidebar from '../../components/Sidebar.astro';
import { getUserJourney, updateCurrentDay } from '../../lib/supabase';
import { getTranslator, normaliseLang } from '../../lib/i18n';

const auth = await requireAuth(Astro);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { user, profile, db } = auth;
const planType  = profile.subscription_tier || 'basic_30';
const tierLabel = planType === 'elite_12' ? 'Elite' : planType === 'pro_6' ? 'Pro' : 'Basic';
const userName  = profile.full_name?.split(' ')[0] || 'there';
const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);

await updateCurrentDay(user.id).catch(() => null);
const journey    = await getUserJourney(user.id, db).catch(() => null);
const currentDay = journey?.current_day || 1;

const today     = new Date().toISOString().split('T')[0];
const dateParam = Astro.url.searchParams.get('date') || today;
const viewDate  = dateParam <= today ? dateParam : today;

const d       = new Date(viewDate + 'T12:00:00Z');
const prevDay = new Date(d.getTime() - 86400000).toISOString().split('T')[0];
const nextDay = new Date(d.getTime() + 86400000).toISOString().split('T')[0];
const isToday = viewDate === today;

const { data: foodLogs } = await db
  .from('food_logs').select('*').eq('user_id', user.id).eq('logged_date', viewDate)
  .order('created_at', { ascending: true });
const logs = foodLogs || [];

const { data: macroGoals } = await db
  .from('macro_goals').select('*').eq('user_id', user.id).maybeSingle();
const goalCal  = macroGoals?.daily_calories || 1800;
const goalProt = macroGoals?.protein_g      || 120;
const goalFat  = macroGoals?.fat_g          || 120;
const goalCarb = macroGoals?.carbs_g        || 25;

const totals = logs.reduce((a, f) => ({
  cal:  a.cal  + (f.calories  || 0),
  prot: a.prot + parseFloat(f.protein_g || 0),
  fat:  a.fat  + parseFloat(f.fat_g     || 0),
  carb: a.carb + parseFloat(f.carbs_g   || 0),
}), { cal:0, prot:0, fat:0, carb:0 });

const calPct  = Math.min(100, Math.round((totals.cal  / goalCal)  * 100));
const protPct = Math.min(100, Math.round((totals.prot / goalProt) * 100));
const fatPct  = Math.min(100, Math.round((totals.fat  / goalFat)  * 100));
const carbPct = Math.min(100, Math.round((totals.carb / goalCarb) * 100));

// SVG ring helpers
const R = 42;
const CIRC = Math.round(2 * Math.PI * R);
const calDash  = Math.round((calPct  / 100) * CIRC);
const protDash = Math.round((protPct / 100) * CIRC);
const fatDash  = Math.round((fatPct  / 100) * CIRC);
const carbDash = Math.round((carbPct / 100) * CIRC);

const mealOrder = ['breakfast','lunch','dinner','snack','other'];
const byMeal: Record<string, typeof logs> = {};
for (const f of logs) {
  const mt = f.meal_type || 'other';
  if (!byMeal[mt]) byMeal[mt] = [];
  byMeal[mt].push(f);
}
const sortedMeals = mealOrder.filter(m => byMeal[m]);

const displayDate = new Date(viewDate + 'T12:00:00Z').toLocaleDateString('en', {
  weekday:'long', month:'long', day:'numeric'
});

const sevenDaysAgo = new Date(Date.now() - 6 * 86400000).toISOString().split('T')[0];
const { data: weekLogs } = await db
  .from('food_logs').select('logged_date, calories').eq('user_id', user.id)
  .gte('logged_date', sevenDaysAgo).lte('logged_date', today);

const weekByDay: Record<string, number> = {};
for (const l of (weekLogs || [])) {
  weekByDay[l.logged_date] = (weekByDay[l.logged_date] || 0) + (l.calories || 0);
}
const last7 = Array.from({ length: 7 }, (_, i) => {
  const dd = new Date(Date.now() - (6 - i) * 86400000).toISOString().split('T')[0];
  return { date: dd, cal: weekByDay[dd] || 0, day: new Date(dd + 'T12:00:00').toLocaleDateString('en',{weekday:'short'}).slice(0,2) };
});
const maxWeekCal = Math.max(...last7.map(x => x.cal), goalCal, 1);

const mealMeta: Record<string, { label: string; icon: string }> = {
  breakfast: { label: 'Breakfast', icon: 'M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z' },
  lunch:     { label: 'Lunch',     icon: 'M12 2v8l4 4-4 4v2M6 6l6 6-6 6' },
  dinner:    { label: 'Dinner',    icon: 'M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z' },
  snack:     { label: 'Snack',     icon: 'M17 8h1a4 4 0 1 1 0 8h-1M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V8zM6 2v6M10 2v6' },
  other:     { label: 'Other',     icon: 'M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM12 12h.01' },
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Meals — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
  <script is:inline>(function(){var t=localStorage.getItem('keto-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
  <style>
    /* ── Rose Vital tokens ───────────────────────────────── */
    :root {
      --rv-bg:      #FAF6F1;
      --rv-card:    #FFFFFF;
      --rv-bg-alt:  #F2EDE5;
      --rv-ink:     #16110F;
      --rv-ink-soft:#4A4340;
      --rv-muted:   #8A8077;
      --rv-line:    #E5DED2;
      --rv-accent:  #FF5C7A;
      --rv-accent-2:#B6FF3C;
      --rv-accent-3:#FF914D;
      --rv-blue:    #4E80EE;
    }
    [data-theme="dark"] {
      --rv-bg:      #0F0B09;
      --rv-card:    #1A1410;
      --rv-bg-alt:  #221C18;
      --rv-ink:     #F5F0EA;
      --rv-ink-soft:#B8AFA6;
      --rv-muted:   #6B6260;
      --rv-line:    #2E2520;
    }

    *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Geist', system-ui, sans-serif;
      background: var(--rv-bg);
      color: var(--rv-ink);
      min-height: 100vh;
    }

    /* ── Shell ───────────────────────────────────────────── */
    .rv-fl-shell {
      display: grid;
      grid-template-columns: 232px 1fr;
      min-height: 100vh;
    }
    .rv-fl-main {
      min-width: 0;
      overflow-x: hidden;
    }
    @media (max-width: 900px) {
      .rv-fl-shell { grid-template-columns: 1fr; }
      .rv-fl-main  { padding-bottom: 5.5rem; }
    }

    /* ── Page layout ─────────────────────────────────────── */
    .rv-fl-inner {
      max-width: 780px;
      margin: 0 auto;
      padding: 2.5rem 2rem 4rem;
    }
    @media (max-width: 640px) {
      .rv-fl-inner { padding: 1.25rem 1rem 3rem; }
    }

    @keyframes fadeUp { from{opacity:0;transform:translateY(10px);} to{opacity:1;transform:translateY(0);} }
    @keyframes spin   { to{transform:rotate(360deg);} }

    /* ── Page header ─────────────────────────────────────── */
    .rv-fl-hd {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 2rem;
      animation: fadeUp .35s ease both;
    }
    .rv-fl-title {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 1.6rem;
      font-weight: 800;
      color: var(--rv-ink);
      line-height: 1.1;
    }
    .rv-fl-subtitle {
      font-size: .78rem;
      color: var(--rv-muted);
      margin-top: .2rem;
      font-family: 'Geist Mono', monospace;
    }

    /* ── Date navigator ──────────────────────────────────── */
    .rv-fl-datebar {
      display: flex;
      align-items: center;
      gap: 1rem;
      background: var(--rv-card);
      border: 1px solid var(--rv-line);
      border-radius: 14px;
      padding: .75rem 1rem;
      margin-bottom: 1.5rem;
      animation: fadeUp .3s .04s ease both;
    }
    .rv-fl-dnarr {
      display: flex; align-items: center; justify-content: center;
      width: 34px; height: 34px; border-radius: 9px;
      background: var(--rv-bg-alt); border: 1px solid var(--rv-line);
      color: var(--rv-ink-soft); text-decoration: none;
      font-size: .9rem; font-weight: 700;
      transition: all .15s; flex-shrink: 0;
    }
    .rv-fl-dnarr:hover { background: var(--rv-ink); color: var(--rv-bg); }
    .rv-fl-dnarr.disabled { opacity: .3; pointer-events: none; }
    .rv-fl-dncenter { flex: 1; text-align: center; }
    .rv-fl-dndate {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 1rem; font-weight: 700;
      color: var(--rv-ink);
    }
    .rv-fl-dnsub {
      font-size: .68rem; color: var(--rv-muted);
      font-family: 'Geist Mono', monospace;
      margin-top: .1rem;
    }
    .rv-today-chip {
      display: inline-block; padding: .15rem .55rem;
      border-radius: 99px;
      background: var(--rv-accent-2);
      color: var(--rv-ink);
      font-family: 'Geist Mono', monospace;
      font-size: .58rem; font-weight: 700;
      letter-spacing: .05em;
      margin-left: .4rem;
      vertical-align: middle;
    }

    /* ── Macro summary card ──────────────────────────────── */
    .rv-macro-card {
      background: var(--rv-card);
      border: 1px solid var(--rv-line);
      border-radius: 18px;
      padding: 1.5rem;
      margin-bottom: 1.25rem;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 1.5rem;
      align-items: center;
      animation: fadeUp .35s .06s ease both;
    }
    @media (max-width: 500px) {
      .rv-macro-card { grid-template-columns: 1fr; }
    }

    /* calorie ring */
    .rv-cal-ring { position: relative; width: 110px; height: 110px; flex-shrink: 0; }
    .rv-cal-ring svg { transform: rotate(-90deg); }
    .rv-cal-center {
      position: absolute; inset: 0;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
    }
    .rv-cal-num {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 1.5rem; font-weight: 800;
      color: var(--rv-ink); line-height: 1;
    }
    .rv-cal-lbl {
      font-family: 'Geist Mono', monospace;
      font-size: .55rem; font-weight: 600;
      color: var(--rv-muted);
      letter-spacing: .05em;
      margin-top: .15rem;
    }

    /* macro bars */
    .rv-macro-bars { display: flex; flex-direction: column; gap: .75rem; }
    .rv-mb {
      display: grid;
      grid-template-columns: 60px 1fr 52px;
      align-items: center;
      gap: .6rem;
    }
    .rv-mb-lbl {
      font-family: 'Geist Mono', monospace;
      font-size: .65rem; font-weight: 600;
      color: var(--rv-muted);
      letter-spacing: .04em;
    }
    .rv-mb-track {
      height: 6px; border-radius: 99px;
      background: var(--rv-bg-alt); overflow: hidden;
    }
    .rv-mb-fill { height: 100%; border-radius: 99px; transition: width .6s ease; }
    .rv-mb-val {
      font-family: 'Geist Mono', monospace;
      font-size: .7rem; font-weight: 700;
      color: var(--rv-ink-soft);
      text-align: right;
    }

    /* ── Week sparkline ──────────────────────────────────── */
    .rv-sparkline {
      background: var(--rv-card);
      border: 1px solid var(--rv-line);
      border-radius: 18px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 1.5rem;
      animation: fadeUp .35s .08s ease both;
    }
    .rv-sp-head {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 1rem;
    }
    .rv-sp-title {
      font-family: 'Geist Mono', monospace;
      font-size: .65rem; font-weight: 600;
      color: var(--rv-muted); letter-spacing: .08em; text-transform: uppercase;
    }
    .rv-sp-total {
      font-family: 'Geist Mono', monospace;
      font-size: .72rem; font-weight: 700;
      color: var(--rv-ink-soft);
    }
    .rv-sp-bars {
      display: flex; align-items: flex-end;
      gap: .35rem; height: 56px;
    }
    .rv-sp-col {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; gap: .35rem;
      text-decoration: none;
    }
    .rv-sp-bar {
      width: 100%; border-radius: 4px 4px 2px 2px;
      min-height: 4px; transition: all .25s;
    }
    .rv-sp-day {
      font-family: 'Geist Mono', monospace;
      font-size: .58rem; font-weight: 600;
      color: var(--rv-muted);
    }

    /* ── Section label ───────────────────────────────────── */
    .rv-section-lbl {
      font-family: 'Geist Mono', monospace;
      font-size: .65rem; font-weight: 700;
      color: var(--rv-muted);
      letter-spacing: .1em; text-transform: uppercase;
      margin-bottom: .75rem;
      margin-top: .25rem;
    }

    /* ── Meal group ──────────────────────────────────────── */
    .rv-meal-group {
      background: var(--rv-card);
      border: 1px solid var(--rv-line);
      border-radius: 16px;
      margin-bottom: .85rem;
      overflow: hidden;
      animation: fadeUp .35s ease both;
    }
    .rv-mg-head {
      display: flex; align-items: center; gap: .65rem;
      padding: .85rem 1.25rem;
      border-bottom: 1px solid var(--rv-line);
    }
    .rv-mg-icon {
      width: 32px; height: 32px; border-radius: 8px;
      background: var(--rv-bg-alt);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .rv-mg-icon svg { color: var(--rv-ink-soft); }
    .rv-mg-name {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-weight: 700; font-size: .88rem; flex: 1;
      color: var(--rv-ink);
    }
    .rv-mg-cal {
      font-family: 'Geist Mono', monospace;
      font-size: .7rem; font-weight: 600;
      color: var(--rv-muted);
    }

    /* food row */
    .rv-fl-row {
      display: flex; align-items: center; gap: .6rem;
      padding: .75rem 1.25rem;
      border-bottom: 1px solid var(--rv-line);
      transition: background .15s;
    }
    .rv-fl-row:last-child { border-bottom: none; }
    .rv-fl-row:hover { background: var(--rv-bg-alt); }
    .rv-fl-fname {
      flex: 1; min-width: 0;
      font-size: .84rem; font-weight: 600;
      color: var(--rv-ink);
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .rv-fl-pills {
      display: flex; gap: .3rem; flex-shrink: 0; flex-wrap: wrap;
    }
    .rv-pill {
      font-family: 'Geist Mono', monospace;
      font-size: .6rem; font-weight: 600;
      padding: .2rem .45rem; border-radius: 6px;
    }
    .rv-pill-cal { background: rgba(255,92,122,.1); color: var(--rv-accent); }
    .rv-pill-p   { background: rgba(78,128,238,.1); color: var(--rv-blue); }
    .rv-pill-f   { background: rgba(255,145,77,.1); color: var(--rv-accent-3); }
    .rv-pill-c   { background: rgba(239,68,68,.1);  color: #e05252; }
    .rv-fl-actions { display: flex; gap: .2rem; flex-shrink: 0; }
    .rv-fl-act-btn {
      background: none; border: none; cursor: pointer;
      width: 30px; height: 30px; border-radius: 7px;
      display: flex; align-items: center; justify-content: center;
      color: var(--rv-muted); font-size: .78rem;
      transition: all .15s;
    }
    .rv-fl-act-btn:hover.edit  { background: rgba(78,128,238,.1); color: var(--rv-blue); }
    .rv-fl-act-btn:hover.swap  { background: rgba(182,255,60,.15); color: #5c8a00; }
    .rv-fl-act-btn:hover.del   { background: rgba(239,68,68,.1); color: #e05252; }
    @media (max-width: 640px) {
      .rv-fl-act-btn { width: 38px; height: 38px; }
      .rv-fl-pills { display: none; }
    }

    /* ── Empty state ─────────────────────────────────────── */
    .rv-empty {
      text-align: center;
      padding: 3.5rem 2rem;
      background: var(--rv-card);
      border: 1px solid var(--rv-line);
      border-radius: 18px;
      animation: fadeUp .35s ease both;
    }
    .rv-empty-icon {
      width: 64px; height: 64px; border-radius: 16px;
      background: var(--rv-bg-alt);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1rem;
    }
    .rv-empty-title {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 1.1rem; font-weight: 700;
      color: var(--rv-ink); margin-bottom: .4rem;
    }
    .rv-empty-sub {
      font-size: .82rem; color: var(--rv-muted);
      line-height: 1.6; max-width: 300px; margin: 0 auto 1.5rem;
    }
    .rv-btn-primary {
      display: inline-flex; align-items: center; gap: .5rem;
      padding: .65rem 1.4rem; border-radius: 10px;
      background: var(--rv-ink); color: var(--rv-bg);
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: .84rem; font-weight: 700;
      text-decoration: none; border: none; cursor: pointer;
      transition: opacity .15s;
    }
    .rv-btn-primary:hover { opacity: .85; }

    /* ── FAB ─────────────────────────────────────────────── */
    .rv-fab {
      position: fixed; bottom: 5.5rem; right: 1.25rem; z-index: 200;
      width: 52px; height: 52px; border-radius: 50%;
      background: var(--rv-ink); color: var(--rv-accent-2);
      border: none; font-size: 1.5rem; cursor: pointer;
      box-shadow: 0 6px 20px rgba(22,17,15,.25);
      display: flex; align-items: center; justify-content: center;
      transition: transform .2s, box-shadow .2s;
    }
    .rv-fab:hover { transform: scale(1.08); box-shadow: 0 8px 28px rgba(22,17,15,.35); }
    @media (min-width: 900px) { .rv-fab { bottom: 2rem; right: 2rem; } }

    /* ── Toast ───────────────────────────────────────────── */
    .rv-toast {
      position: fixed; top: 1.25rem; right: 1.5rem; z-index: 9999;
      padding: .7rem 1.1rem; border-radius: 10px;
      font-family: 'Geist Mono', monospace;
      font-weight: 600; font-size: .75rem;
      background: var(--rv-ink); color: var(--rv-bg);
      box-shadow: 0 8px 24px rgba(0,0,0,.18);
      transform: translateX(120px); opacity: 0;
      pointer-events: none; transition: all .3s;
    }
    .rv-toast.show { transform: translateX(0); opacity: 1; }

    /* ── Modals — shared ─────────────────────────────────── */
    .rv-backdrop {
      display: none; position: fixed; inset: 0; z-index: 1000;
      background: rgba(22,17,15,.55);
      backdrop-filter: blur(6px);
      align-items: flex-end; justify-content: center;
    }
    .rv-backdrop.open { display: flex; }
    @media (min-width: 640px) {
      .rv-backdrop { align-items: center; padding: 1.25rem; }
    }
    .rv-modal {
      background: var(--rv-card);
      border: 1px solid var(--rv-line);
      border-radius: 20px 20px 0 0;
      padding: 1.5rem 1.25rem 2rem;
      width: 100%; max-width: 480px;
      max-height: 92vh; overflow-y: auto;
      display: flex; flex-direction: column; gap: .9rem;
    }
    @media (min-width: 640px) {
      .rv-modal { border-radius: 20px; max-height: 88vh; }
    }
    .rv-modal-handle {
      width: 36px; height: 4px; border-radius: 99px;
      background: var(--rv-line); margin: 0 auto .25rem;
    }
    .rv-modal-title {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 1.1rem; font-weight: 800; color: var(--rv-ink);
    }

    /* search row */
    .rv-search-row { display: flex; gap: .5rem; }
    .rv-search-wrap { flex: 1; position: relative; }
    .rv-search-ico {
      position: absolute; left: .7rem; top: 50%;
      transform: translateY(-50%);
      color: var(--rv-muted); pointer-events: none;
    }
    .rv-input {
      width: 100%;
      background: var(--rv-bg-alt);
      border: 1.5px solid var(--rv-line);
      border-radius: 10px;
      padding: .62rem .8rem;
      color: var(--rv-ink);
      font-family: 'Geist', system-ui, sans-serif;
      font-size: .86rem; outline: none;
      transition: border-color .2s;
    }
    .rv-input:focus { border-color: var(--rv-ink); }
    .rv-search-input { padding-left: 2.2rem; }
    .rv-btn-scan {
      flex-shrink: 0; display: flex; align-items: center; gap: .4rem;
      padding: .62rem .9rem; border-radius: 10px;
      background: var(--rv-bg-alt); border: 1.5px solid var(--rv-line);
      color: var(--rv-ink-soft);
      font-family: 'Geist Mono', monospace;
      font-size: .72rem; font-weight: 600; cursor: pointer;
      transition: all .2s; white-space: nowrap;
    }
    .rv-btn-scan:hover { background: var(--rv-ink); color: var(--rv-bg); border-color: var(--rv-ink); }

    /* search results */
    .rv-sr-box {
      display: none; flex-direction: column;
      border: 1.5px solid var(--rv-line); border-radius: 12px;
      overflow: hidden; max-height: 230px; overflow-y: auto;
    }
    .rv-sr-box.visible { display: flex; }
    .rv-sr-item {
      padding: .7rem 1rem; border-bottom: 1px solid var(--rv-line);
      cursor: pointer; transition: background .15s;
    }
    .rv-sr-item:last-child { border-bottom: none; }
    .rv-sr-item:hover { background: var(--rv-bg-alt); }
    .rv-sr-name { font-weight: 600; font-size: .82rem; color: var(--rv-ink); line-height: 1.3; }
    .rv-sr-brand { font-size: .66rem; color: var(--rv-muted); margin-top: .1rem; }
    .rv-sr-pills { display: flex; gap: .3rem; margin-top: .3rem; flex-wrap: wrap; }
    .rv-sr-spin {
      display: flex; align-items: center; justify-content: center;
      padding: 1.5rem; gap: .5rem;
      font-family: 'Geist Mono', monospace;
      font-size: .72rem; color: var(--rv-muted);
    }
    .rv-spinner {
      width: 16px; height: 16px;
      border: 2px solid var(--rv-line);
      border-top-color: var(--rv-ink);
      border-radius: 50%;
      animation: spin .7s linear infinite;
    }
    .rv-sr-empty {
      padding: 1rem; text-align: center;
      font-size: .78rem; color: var(--rv-muted);
    }

    /* serving row */
    .rv-serving-row {
      display: flex; align-items: center; gap: .65rem;
    }
    .rv-serving-lbl {
      font-family: 'Geist Mono', monospace;
      font-size: .66rem; font-weight: 600; color: var(--rv-muted);
      white-space: nowrap;
    }
    .rv-serving-input {
      width: 72px; text-align: center;
      background: var(--rv-bg-alt); border: 1.5px solid var(--rv-line);
      border-radius: 9px; padding: .5rem .6rem;
      color: var(--rv-ink); font-family: 'Geist', system-ui; font-size: .85rem;
      outline: none; transition: border-color .2s;
    }
    .rv-serving-input:focus { border-color: var(--rv-ink); }
    .rv-serving-unit {
      font-family: 'Geist Mono', monospace;
      font-size: .66rem; color: var(--rv-muted);
    }

    /* divider */
    .rv-divider {
      display: flex; align-items: center; gap: .5rem;
      font-family: 'Geist Mono', monospace;
      font-size: .63rem; font-weight: 600; color: var(--rv-muted);
    }
    .rv-divider::before,.rv-divider::after { content:''; flex:1; height:1px; background:var(--rv-line); }

    /* form fields */
    .rv-label {
      font-family: 'Geist Mono', monospace;
      font-size: .65rem; font-weight: 600;
      color: var(--rv-muted); letter-spacing: .04em;
      display: block; margin-bottom: .3rem;
    }
    .rv-fm-row  { display: grid; grid-template-columns: 1fr 1fr; gap: .55rem; }
    .rv-fm-row4 { display: grid; grid-template-columns: repeat(4,1fr); gap: .5rem; }
    @media (max-width: 480px) { .rv-fm-row4 { grid-template-columns: repeat(2,1fr); } }

    .rv-fm-actions { display: flex; gap: .55rem; margin-top: .25rem; }
    .rv-btn-cancel {
      flex: 1; padding: .7rem; border-radius: 10px;
      background: var(--rv-bg-alt); border: 1px solid var(--rv-line);
      color: var(--rv-ink-soft);
      font-family: 'Bricolage Grotesque', system-ui; font-weight: 700;
      font-size: .82rem; cursor: pointer; transition: all .2s;
    }
    .rv-btn-cancel:hover { border-color: var(--rv-ink-soft); }
    .rv-btn-save {
      flex: 2; padding: .7rem; border-radius: 10px;
      background: var(--rv-ink); color: var(--rv-bg);
      border: none;
      font-family: 'Bricolage Grotesque', system-ui; font-weight: 800;
      font-size: .84rem; cursor: pointer; transition: opacity .2s;
    }
    .rv-btn-save:disabled { opacity: .5; cursor: not-allowed; }
    .rv-btn-save.edit-mode { background: var(--rv-blue); }

    /* iOS zoom fix */
    @media (max-width: 640px) {
      .rv-input, .rv-search-input, .rv-serving-input { font-size: 16px !important; }
    }

    /* ── Scanner overlay ─────────────────────────────────── */
    .rv-scanner-ov {
      display: none; position: fixed; inset: 0; z-index: 2000;
      background: #000;
      flex-direction: column; align-items: center; justify-content: center;
    }
    .rv-scanner-ov.open { display: flex; }
    .rv-scanner-guide {
      position: absolute; width: 220px; height: 140px;
      border: 2.5px solid var(--rv-accent-2); border-radius: 12px;
      box-shadow: 0 0 0 4000px rgba(0,0,0,.65);
    }
    .rv-scanner-hint {
      color: #fff; font-family: 'Geist', system-ui;
      font-size: .84rem; margin-top: 1.5rem; text-align: center;
      opacity: .8; max-width: 260px;
    }
    .rv-scanner-close {
      margin-top: 1.5rem; padding: .6rem 1.75rem; border-radius: 10px;
      background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
      color: #fff; font-family: 'Geist', system-ui; font-weight: 600;
      font-size: .84rem; cursor: pointer;
    }
    .rv-scanner-fallback { color: #fff; font-family: 'Geist', system-ui; font-size: .82rem; text-align: center; max-width: 300px; }
    .rv-scanner-fallback input { width: 100%; margin: .75rem 0; padding: .65rem 1rem; border-radius: 10px; border: 1.5px solid rgba(182,255,60,.4); background: rgba(255,255,255,.08); color: #fff; font-size: .9rem; text-align: center; outline: none; }
    .rv-scanner-fallback input::placeholder { color: rgba(255,255,255,.35); }
    .rv-scanner-lookup { padding: .58rem 1.5rem; border-radius: 9px; background: var(--rv-accent-2); border: none; color: var(--rv-ink); font-weight: 700; font-size: .84rem; cursor: pointer; }

    /* ── Swap modal ──────────────────────────────────────── */
    .rv-swap-modal {
      background: var(--rv-card); border: 1px solid var(--rv-line);
      border-radius: 20px 20px 0 0;
      padding: 1.25rem 1.25rem 2rem;
      width: 100%; max-width: 520px;
      max-height: 88vh; overflow-y: auto;
      display: flex; flex-direction: column; gap: .75rem;
    }
    @media (min-width: 640px) { .rv-swap-modal { border-radius: 20px; max-height: 85vh; } }
    .rv-swap-current {
      background: var(--rv-bg-alt); border: 1px solid var(--rv-line);
      border-radius: 11px; padding: .65rem .9rem; font-size: .78rem;
    }
    .rv-swap-cname { font-weight: 700; color: var(--rv-ink); margin-bottom: .2rem; }
    .rv-swap-cmacros {
      font-family: 'Geist Mono', monospace;
      font-size: .66rem; color: var(--rv-muted);
    }
    .rv-swap-list { display: flex; flex-direction: column; gap: .5rem; }
    .rv-swap-card {
      background: var(--rv-bg-alt); border: 1px solid var(--rv-line);
      border-radius: 12px; padding: .75rem 1rem;
      display: flex; align-items: center; gap: .85rem;
      transition: border-color .15s;
    }
    .rv-swap-card:hover { border-color: var(--rv-ink-soft); }
    .rv-swap-img {
      width: 44px; height: 44px; border-radius: 9px;
      object-fit: cover; flex-shrink: 0;
      background: var(--rv-line);
    }
    .rv-swap-img-ph {
      width: 44px; height: 44px; border-radius: 9px; flex-shrink: 0;
      background: var(--rv-line);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem;
    }
    .rv-swap-info { flex: 1; min-width: 0; }
    .rv-swap-name {
      font-weight: 700; font-size: .82rem; color: var(--rv-ink);
      line-height: 1.3; margin-bottom: .25rem;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .rv-swap-pills { display: flex; gap: .3rem; flex-wrap: wrap; }
    .rv-swap-use {
      flex-shrink: 0; padding: .4rem .8rem; border-radius: 8px;
      background: var(--rv-ink); color: var(--rv-bg);
      border: none; font-weight: 700; font-size: .74rem;
      cursor: pointer; transition: opacity .2s;
    }
    .rv-swap-use:hover { opacity: .8; }
    .rv-swap-use:disabled { opacity: .45; cursor: not-allowed; }
    .rv-swap-spin { text-align: center; padding: 2rem; color: var(--rv-muted); font-size: .84rem; }
    .rv-swap-empty { text-align: center; padding: 1.5rem; color: var(--rv-muted); font-size: .8rem; }
  </style>
</head>
<body>

<div class="rv-fl-shell">
  <Sidebar userName={userName} planType={planType} tierLabel={tierLabel} currentDay={currentDay} activePage="food-log" />

  <div class="rv-fl-main">
    <div class="rv-fl-inner">

      <!-- PAGE HEADER -->
      <div class="rv-fl-hd">
        <div>
          <div class="rv-fl-title">Meal Log</div>
          <div class="rv-fl-subtitle">{logs.length} item{logs.length !== 1 ? 's' : ''} · {Math.round(totals.cal)} kcal consumed</div>
        </div>
      </div>

      <!-- DATE NAVIGATOR -->
      <div class="rv-fl-datebar">
        <a href={`/dashboard/food-log?date=${prevDay}`} class="rv-fl-dnarr">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <div class="rv-fl-dncenter">
          <div class="rv-fl-dndate">
            {displayDate}
            {isToday && <span class="rv-today-chip">TODAY</span>}
          </div>
          <div class="rv-fl-dnsub">Tap ← → to browse history</div>
        </div>
        <a href={`/dashboard/food-log?date=${nextDay}`} class={`rv-fl-dnarr${isToday ? ' disabled' : ''}`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>

      <!-- MACRO SUMMARY -->
      <div class="rv-macro-card">
        <!-- Calorie ring -->
        <div class="rv-cal-ring">
          <svg width="110" height="110" viewBox="0 0 96 96">
            <circle cx="48" cy="48" r={R} fill="none" stroke="var(--rv-line)" stroke-width="8"/>
            <circle cx="48" cy="48" r={R} fill="none"
              stroke="var(--rv-accent)"
              stroke-width="8"
              stroke-linecap="round"
              stroke-dasharray={`${calDash} ${CIRC}`}
              stroke-dashoffset="0"/>
          </svg>
          <div class="rv-cal-center">
            <div class="rv-cal-num">{Math.round(totals.cal)}</div>
            <div class="rv-cal-lbl">/ {goalCal} KCAL</div>
          </div>
        </div>

        <!-- Macro bars -->
        <div class="rv-macro-bars">
          <div class="rv-mb">
            <div class="rv-mb-lbl">PROTEIN</div>
            <div class="rv-mb-track">
              <div class="rv-mb-fill" style={`width:${protPct}%;background:var(--rv-blue);`}></div>
            </div>
            <div class="rv-mb-val" style="color:var(--rv-blue);">{Math.round(totals.prot)}g</div>
          </div>
          <div class="rv-mb">
            <div class="rv-mb-lbl">FAT</div>
            <div class="rv-mb-track">
              <div class="rv-mb-fill" style={`width:${fatPct}%;background:var(--rv-accent-3);`}></div>
            </div>
            <div class="rv-mb-val" style="color:var(--rv-accent-3);">{Math.round(totals.fat)}g</div>
          </div>
          <div class="rv-mb">
            <div class="rv-mb-lbl">NET CARBS</div>
            <div class="rv-mb-track">
              <div class="rv-mb-fill" style={`width:${carbPct}%;background:#e05252;`}></div>
            </div>
            <div class="rv-mb-val" style="color:#e05252;">{Math.round(totals.carb)}g</div>
          </div>
          <div class="rv-mb">
            <div class="rv-mb-lbl">GOAL</div>
            <div class="rv-mb-track">
              <div class="rv-mb-fill" style={`width:${calPct}%;background:var(--rv-accent);`}></div>
            </div>
            <div class="rv-mb-val">{calPct}%</div>
          </div>
        </div>
      </div>

      <!-- 7-DAY SPARKLINE -->
      <div class="rv-sparkline">
        <div class="rv-sp-head">
          <div class="rv-sp-title">Calories — Last 7 Days</div>
          <div class="rv-sp-total">{Math.round(last7.reduce((s,x) => s+x.cal, 0) / 7)} avg/day</div>
        </div>
        <div class="rv-sp-bars">
          {last7.map(item => {
            const h = Math.max(4, Math.round((item.cal / maxWeekCal) * 100));
            const isActive = item.date === viewDate;
            return (
              <a href={`/dashboard/food-log?date=${item.date}`} class="rv-sp-col" style="text-decoration:none;">
                <div class="rv-sp-bar" style={`height:${h}%;background:${isActive ? 'var(--rv-accent)' : item.cal > 0 ? 'var(--rv-line)' : 'var(--rv-bg-alt)'};${isActive ? 'box-shadow:0 0 8px rgba(255,92,122,.35);' : ''}`} title={`${item.cal} kcal`}></div>
                <div class="rv-sp-day" style={isActive ? 'color:var(--rv-accent);font-weight:700;' : ''}>{item.day}</div>
              </a>
            );
          })}
        </div>
      </div>

      <!-- FOOD ENTRIES -->
      {logs.length > 0 ? (
        <div>
          <div class="rv-section-lbl">Logged Meals</div>
          {sortedMeals.map((mt, idx) => {
            const items = byMeal[mt];
            const mealCal = items.reduce((s, f) => s + (f.calories || 0), 0);
            const meta = mealMeta[mt] || mealMeta['other'];
            return (
              <div class="rv-meal-group" style={`animation-delay:${0.05 + idx * 0.04}s;`}>
                <div class="rv-mg-head">
                  <div class="rv-mg-icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d={meta.icon}/>
                    </svg>
                  </div>
                  <div class="rv-mg-name">{meta.label}</div>
                  <div class="rv-mg-cal">{Math.round(mealCal)} kcal</div>
                </div>
                {items.map(f => (
                  <div class="rv-fl-row" data-id={f.id}>
                    <div class="rv-fl-fname">{f.food_name}</div>
                    <div class="rv-fl-pills">
                      <span class="rv-pill rv-pill-cal">{f.calories} cal</span>
                      <span class="rv-pill rv-pill-p">{f.protein_g}P</span>
                      <span class="rv-pill rv-pill-f">{f.fat_g}F</span>
                      <span class="rv-pill rv-pill-c">{f.carbs_g}C</span>
                    </div>
                    <div class="rv-fl-actions">
                      <button class="rv-fl-act-btn edit"
                        data-id={f.id}
                        data-name={f.food_name}
                        data-cal={f.calories}
                        data-prot={f.protein_g}
                        data-fat={f.fat_g}
                        data-carb={f.carbs_g}
                        data-meal={f.meal_type || 'other'}
                        onclick="window.editEntry(this)"
                        title="Edit">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      </button>
                      <button class="rv-fl-act-btn swap"
                        data-id={f.id}
                        data-name={f.food_name}
                        data-cal={f.calories}
                        data-prot={f.protein_g}
                        data-fat={f.fat_g}
                        data-carb={f.carbs_g}
                        data-meal={f.meal_type || 'other'}
                        onclick="window.openSwap(this)"
                        title="Suggest alternatives">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 3 4 4-4 4"/><path d="M20 7H4"/><path d="m8 21-4-4 4-4"/><path d="M4 17h16"/></svg>
                      </button>
                      <button class="rv-fl-act-btn del"
                        data-id={f.id}
                        onclick="window.deleteEntry(this)"
                        title="Remove">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                      </button>
                    </div>
                  </div>
                ))}
              </div>
            );
          })}
        </div>
      ) : (
        <div class="rv-empty">
          <div class="rv-empty-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--rv-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
          </div>
          <div class="rv-empty-title">Nothing logged {isToday ? 'today' : 'on this day'}</div>
          <div class="rv-empty-sub">{isToday ? 'Search any food, scan a barcode, or tap the + button to log manually.' : 'No entries were recorded for this date.'}</div>
          {isToday && (
            <a href="/dashboard/recipes" class="rv-btn-primary">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              Browse Recipes
            </a>
          )}
        </div>
      )}

    </div>
  </div>
</div>

<!-- FAB (today only) -->
{isToday && (
  <button class="rv-fab" onclick="window.openAdd()" title="Log food" aria-label="Log food">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
  </button>
)}

<!-- ── ADD / EDIT MODAL ──────────────────────────────────────── -->
<div class="rv-backdrop" id="addModal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
  <div class="rv-modal">
    <div class="rv-modal-handle"></div>
    <div class="rv-modal-title" id="modalTitle">Log Food</div>

    <div class="rv-search-row">
      <div class="rv-search-wrap">
        <span class="rv-search-ico">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </span>
        <input class="rv-input rv-search-input" id="flSearch" placeholder='Search food (e.g. "chicken breast")' autocomplete="off" oninput="window.onSearchInput(this.value)"/>
      </div>
      <button class="rv-btn-scan" id="scanBtn" onclick="window.openScanner()" title="Scan barcode">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><rect x="7" y="7" width="3" height="10"/><rect x="14" y="7" width="3" height="10"/></svg>
        Scan
      </button>
    </div>

    <div class="rv-sr-box" id="searchResults"></div>

    <div id="servingRow" class="rv-serving-row" style="display:none;">
      <span class="rv-serving-lbl">Serving:</span>
      <input class="rv-serving-input" id="flServing" type="number" min="1" max="2000" value="100" oninput="window.recalcServing()"/>
      <span class="rv-serving-unit">g / ml</span>
    </div>

    <div class="rv-divider">or enter manually</div>

    <div>
      <label class="rv-label">Food name *</label>
      <input class="rv-input" id="flName" placeholder="e.g. Scrambled eggs" autocomplete="off" maxlength="200"/>
    </div>
    <div class="rv-fm-row">
      <div>
        <label class="rv-label">Meal type</label>
        <select class="rv-input" id="flMeal">
          <option value="breakfast">Breakfast</option>
          <option value="lunch">Lunch</option>
          <option value="dinner">Dinner</option>
          <option value="snack">Snack</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label class="rv-label">Calories</label>
        <input class="rv-input" id="flCal" type="number" min="0" max="9999" placeholder="0"/>
      </div>
    </div>
    <div>
      <label class="rv-label">Macros (grams)</label>
      <div class="rv-fm-row4">
        <input class="rv-input" id="flProt"  type="number" min="0" max="500" step="0.1" placeholder="Prot"/>
        <input class="rv-input" id="flFat"   type="number" min="0" max="500" step="0.1" placeholder="Fat"/>
        <input class="rv-input" id="flCarb"  type="number" min="0" max="500" step="0.1" placeholder="Carbs"/>
        <input class="rv-input" id="flFiber" type="number" min="0" max="500" step="0.1" placeholder="Fiber"/>
      </div>
    </div>

    <div class="rv-fm-actions">
      <button class="rv-btn-cancel" onclick="window.closeAdd()">Cancel</button>
      <button class="rv-btn-save" id="flSaveBtn" onclick="window.saveEntry()">Log Food</button>
      <button class="rv-btn-save edit-mode" id="flUpdateBtn" onclick="window.updateEntry()" style="display:none;">Save Changes</button>
    </div>
  </div>
</div>

<!-- ── BARCODE SCANNER ─────────────────────────────────────────── -->
<div class="rv-scanner-ov" id="scannerOverlay">
  <div id="scannerContent" style="display:flex;flex-direction:column;align-items:center;width:100%;padding:1.5rem;"></div>
</div>

<!-- ── SWAP MODAL ─────────────────────────────────────────────── -->
<div class="rv-backdrop" id="swapModal" role="dialog" aria-modal="true">
  <div class="rv-swap-modal">
    <div class="rv-modal-handle"></div>
    <div class="rv-modal-title">Suggest Alternatives</div>
    <div class="rv-swap-current" id="swapCurrentInfo"></div>
    <div id="swapList" class="rv-swap-list">
      <div class="rv-swap-spin">Loading suggestions…</div>
    </div>
    <button class="rv-btn-cancel" onclick="window.closeSwap()">Cancel</button>
  </div>
</div>

<div class="rv-toast" id="toast"></div>

<script is:inline define:vars={{ viewDate }}>
var __selectedPer100 = null;
var __editId = null;
var __swapLogId = null;
var __swapLogMeal = 'other';
var __searchTimer = null;

// ── Toast ─────────────────────────────────────────────────────
function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(function(){ t.classList.remove('show'); }, 2800);
}

// ── Add modal ─────────────────────────────────────────────────
window.openAdd = function() {
  document.getElementById('addModal').classList.add('open');
  setTimeout(function(){ document.getElementById('flSearch').focus(); }, 80);
};
window.closeAdd = function() {
  document.getElementById('addModal').classList.remove('open');
  resetModal();
};

function resetModal() {
  document.getElementById('flSearch').value = '';
  var sr = document.getElementById('searchResults');
  sr.className = 'rv-sr-box'; sr.innerHTML = '';
  document.getElementById('servingRow').style.display = 'none';
  __selectedPer100 = null; __editId = null;
  ['flName','flCal','flProt','flFat','flCarb','flFiber'].forEach(function(id){
    var el = document.getElementById(id); if (el) el.value = '';
  });
  document.getElementById('modalTitle').textContent = 'Log Food';
  document.getElementById('flSaveBtn').style.display = '';
  document.getElementById('flUpdateBtn').style.display = 'none';
  var sr2 = document.querySelector('.rv-search-row');
  if (sr2) sr2.style.display = '';
  var dv = document.querySelector('.rv-divider');
  if (dv) dv.style.display = '';
}

// ── Edit entry ────────────────────────────────────────────────
window.editEntry = function(btn) {
  __editId = btn.getAttribute('data-id');
  var name = btn.getAttribute('data-name') || '';
  var cal  = btn.getAttribute('data-cal')  || '0';
  var prot = btn.getAttribute('data-prot') || '0';
  var fat  = btn.getAttribute('data-fat')  || '0';
  var carb = btn.getAttribute('data-carb') || '0';
  var meal = btn.getAttribute('data-meal') || 'other';
  document.getElementById('modalTitle').textContent = 'Edit Entry';
  document.getElementById('flSaveBtn').style.display = 'none';
  document.getElementById('flUpdateBtn').style.display = '';
  var sr = document.querySelector('.rv-search-row');
  if (sr) sr.style.display = 'none';
  var dv = document.querySelector('.rv-divider');
  if (dv) dv.style.display = 'none';
  document.getElementById('servingRow').style.display = 'none';
  document.getElementById('flName').value = name;
  document.getElementById('flCal').value  = cal;
  document.getElementById('flProt').value = prot;
  document.getElementById('flFat').value  = fat;
  document.getElementById('flCarb').value = carb;
  var mealEl = document.getElementById('flMeal');
  if (mealEl) mealEl.value = meal;
  document.getElementById('addModal').classList.add('open');
  setTimeout(function(){ document.getElementById('flName').focus(); }, 80);
};

window.updateEntry = function() {
  if (!__editId) return;
  var name = document.getElementById('flName').value.trim();
  if (!name) { document.getElementById('flName').focus(); return; }
  var cal   = parseFloat(document.getElementById('flCal').value)   || 0;
  var prot  = parseFloat(document.getElementById('flProt').value)  || 0;
  var fat   = parseFloat(document.getElementById('flFat').value)   || 0;
  var carb  = parseFloat(document.getElementById('flCarb').value)  || 0;
  var fiber = parseFloat(document.getElementById('flFiber').value) || 0;
  var meal  = document.getElementById('flMeal').value || 'other';
  var netCarb = Math.max(0, carb - fiber);
  var btn = document.getElementById('flUpdateBtn');
  btn.disabled = true; btn.textContent = 'Saving…';
  fetch('/api/food-log/update', {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: __editId, food_name: name, calories: cal, protein_g: prot, fat_g: fat, carbs_g: netCarb, meal_type: meal }),
  })
  .then(function(r){ return r.json(); })
  .then(function(d){
    if (d.success) { showToast('Entry updated'); window.closeAdd(); setTimeout(function(){ window.location.reload(); }, 400); }
    else { btn.disabled = false; btn.textContent = 'Save Changes'; showToast('Failed: ' + (d.error || 'error')); }
  })
  .catch(function(){ btn.disabled = false; btn.textContent = 'Save Changes'; showToast('Connection error'); });
};

// ── Search ────────────────────────────────────────────────────
window.onSearchInput = function(val) {
  clearTimeout(__searchTimer);
  var q = val.trim();
  if (!q) { var b = document.getElementById('searchResults'); b.className = 'rv-sr-box'; b.innerHTML = ''; return; }
  __searchTimer = setTimeout(function(){ doSearch(q); }, 420);
};

function doSearch(q) {
  var box = document.getElementById('searchResults');
  box.className = 'rv-sr-box visible';
  box.innerHTML = '<div class="rv-sr-spin"><div class="rv-spinner"></div> Searching…</div>';
  var url = 'https://world.openfoodfacts.org/cgi/search.pl?search_terms='
    + encodeURIComponent(q)
    + '&json=1&page_size=8&fields=product_name,brands,nutriments,serving_quantity&action=process&search_simple=1';
  fetch(url)
    .then(function(r){ return r.json(); })
    .then(function(data) {
      var products = (data.products || []).filter(function(p){ return p.product_name && p.nutriments; });
      if (!products.length) { box.innerHTML = '<div class="rv-sr-empty">No results — fill in manually below.</div>'; return; }
      box.innerHTML = '';
      products.forEach(function(p) {
        var n    = p.nutriments;
        var cal  = Math.round(n['energy-kcal_100g'] || n['energy_100g'] / 4.184 || 0);
        var prot = roundMacro(n['proteins_100g']);
        var fat  = roundMacro(n['fat_100g']);
        var carb = roundMacro(n['carbohydrates_100g']);
        var fiber= roundMacro(n['fiber_100g']);
        var name = p.product_name || 'Unknown';
        var brand= p.brands ? '· ' + p.brands.split(',')[0].trim() : '';
        var item = document.createElement('div');
        item.className = 'rv-sr-item';
        item.innerHTML =
          '<div class="rv-sr-name">' + escHtml(name) + '</div>' +
          '<div class="rv-sr-brand">per 100g ' + escHtml(brand) + '</div>' +
          '<div class="rv-sr-pills">' +
          '<span class="rv-pill rv-pill-cal">' + cal + ' kcal</span>' +
          '<span class="rv-pill rv-pill-p">' + prot + 'g P</span>' +
          '<span class="rv-pill rv-pill-f">' + fat  + 'g F</span>' +
          '<span class="rv-pill rv-pill-c">' + carb + 'g C</span>' +
          '</div>';
        item.addEventListener('click', function(){ selectProduct(name, { cal:cal, prot:prot, fat:fat, carb:carb, fiber:fiber }); });
        box.appendChild(item);
      });
    })
    .catch(function(){ box.innerHTML = '<div class="rv-sr-empty">Search unavailable — fill in manually.</div>'; });
}

function selectProduct(name, per100) {
  __selectedPer100 = per100;
  var box = document.getElementById('searchResults');
  box.className = 'rv-sr-box'; box.innerHTML = '';
  document.getElementById('flSearch').value = name;
  document.getElementById('flName').value = name;
  document.getElementById('servingRow').style.display = 'flex';
  document.getElementById('flServing').value = 100;
  applyServing(100, per100);
}

window.recalcServing = function() {
  if (!__selectedPer100) return;
  var g = parseFloat(document.getElementById('flServing').value) || 100;
  applyServing(g, __selectedPer100);
};

function applyServing(g, per100) {
  var r = g / 100;
  document.getElementById('flCal').value   = Math.round(per100.cal  * r);
  document.getElementById('flProt').value  = roundMacro(per100.prot * r);
  document.getElementById('flFat').value   = roundMacro(per100.fat  * r);
  document.getElementById('flCarb').value  = roundMacro(per100.carb * r);
  document.getElementById('flFiber').value = roundMacro(per100.fiber* r);
}

// ── Scanner ───────────────────────────────────────────────────
window.openScanner = function() {
  var overlay = document.getElementById('scannerOverlay');
  var content = document.getElementById('scannerContent');
  if (typeof BarcodeDetector !== 'undefined') {
    overlay.classList.add('open');
    content.innerHTML =
      '<div style="position:relative;display:flex;align-items:center;justify-content:center;width:100%;max-width:360px;">' +
      '<video id="scanVideo" autoplay playsinline muted style="width:100%;border-radius:14px;max-height:60vh;object-fit:cover;"></video>' +
      '<div class="rv-scanner-guide"></div></div>' +
      '<p class="rv-scanner-hint">Point camera at a product barcode</p>' +
      '<button class="rv-scanner-close" onclick="window.closeScanner()">Cancel</button>';
    navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
      .then(function(stream) {
        var video = document.getElementById('scanVideo');
        if (!video) return;
        video.srcObject = stream; window.__scanStream = stream;
        var detector = new BarcodeDetector({ formats: ['ean_13','ean_8','upc_a','upc_e','code_128','code_39','itf','qr_code'] });
        var found = false;
        function tick() {
          if (found || !document.getElementById('scanVideo')) return;
          detector.detect(video).then(function(codes) {
            if (codes.length && !found) { found = true; window.closeScanner(); lookupBarcode(codes[0].rawValue); }
            else requestAnimationFrame(tick);
          }).catch(function(){ requestAnimationFrame(tick); });
        }
        video.addEventListener('play', function(){ requestAnimationFrame(tick); });
      })
      .catch(function(){ showFallbackScanner(content); });
  } else {
    overlay.classList.add('open'); showFallbackScanner(content);
  }
};

function showFallbackScanner(content) {
  content.innerHTML =
    '<div class="rv-scanner-fallback">' +
    '<p style="font-size:1.5rem;margin-bottom:.5rem;">📷</p>' +
    '<p>Enter the barcode number from the product</p>' +
    '<input id="manualBarcode" type="text" inputmode="numeric" placeholder="e.g. 3017620422003"/>' +
    '<br/><button class="rv-scanner-lookup" onclick="window.lookupManualBarcode()">Look Up</button>' +
    '</div>' +
    '<button class="rv-scanner-close" style="margin-top:1.5rem;" onclick="window.closeScanner()">Cancel</button>';
  setTimeout(function(){ var el = document.getElementById('manualBarcode'); if (el) el.focus(); }, 100);
}

window.closeScanner = function() {
  if (window.__scanStream) { window.__scanStream.getTracks().forEach(function(t){ t.stop(); }); window.__scanStream = null; }
  document.getElementById('scannerOverlay').classList.remove('open');
  document.getElementById('scannerContent').innerHTML = '';
};

window.lookupManualBarcode = function() {
  var val = (document.getElementById('manualBarcode')?.value || '').trim();
  if (!val) return;
  window.closeScanner(); lookupBarcode(val);
};

function lookupBarcode(code) {
  showToast('Looking up barcode…');
  fetch('https://world.openfoodfacts.org/api/v0/product/' + encodeURIComponent(code) + '.json?fields=product_name,brands,nutriments,serving_quantity')
    .then(function(r){ return r.json(); })
    .then(function(data) {
      if (data.status !== 1 || !data.product) { showToast('Product not found'); return; }
      var p = data.product; var n = p.nutriments || {};
      var cal  = Math.round(n['energy-kcal_100g'] || n['energy_100g'] / 4.184 || 0);
      var prot = roundMacro(n['proteins_100g']);
      var fat  = roundMacro(n['fat_100g']);
      var carb = roundMacro(n['carbohydrates_100g']);
      var fiber= roundMacro(n['fiber_100g']);
      var name = p.product_name || 'Product ' + code;
      window.openAdd(); selectProduct(name, { cal:cal, prot:prot, fat:fat, carb:carb, fiber:fiber });
      showToast(name + ' found');
    })
    .catch(function(){ showToast('Barcode lookup failed'); });
}

// ── Save entry ────────────────────────────────────────────────
window.saveEntry = function() {
  var name = document.getElementById('flName').value.trim();
  if (!name) { document.getElementById('flName').focus(); return; }
  var cal   = parseFloat(document.getElementById('flCal').value)   || 0;
  var prot  = parseFloat(document.getElementById('flProt').value)  || 0;
  var fat   = parseFloat(document.getElementById('flFat').value)   || 0;
  var carb  = parseFloat(document.getElementById('flCarb').value)  || 0;
  var fiber = parseFloat(document.getElementById('flFiber').value) || 0;
  var meal  = document.getElementById('flMeal').value || 'other';
  var netCarb = Math.max(0, carb - fiber);
  var btn = document.getElementById('flSaveBtn');
  btn.disabled = true; btn.textContent = 'Logging…';
  fetch('/api/food-log/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ food_name: name, calories: cal, protein_g: prot, fat_g: fat, carbs_g: netCarb, meal_type: meal, client_date: new Date().toLocaleDateString('en-CA') }),
  })
  .then(function(r){ return r.json(); })
  .then(function(d){
    if (d.success) { showToast('Logged!'); window.closeAdd(); setTimeout(function(){ window.location.reload(); }, 500); }
    else { btn.disabled = false; btn.textContent = 'Log Food'; showToast(d.error || 'Failed'); }
  })
  .catch(function(){ btn.disabled = false; btn.textContent = 'Log Food'; showToast('Connection error'); });
};

// ── Delete entry ──────────────────────────────────────────────
window.deleteEntry = function(btn) {
  var id  = btn.getAttribute('data-id');
  var row = btn.closest('.rv-fl-row');
  fetch('/api/food-log/delete', {
    method: 'DELETE',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: id }),
  })
  .then(function(r){ return r.json(); })
  .then(function(d){
    if (d.success) {
      if (row) { row.style.opacity='0'; row.style.transform='translateX(10px)'; row.style.transition='all .25s'; }
      setTimeout(function(){ window.location.reload(); }, 300);
    } else { showToast('Could not delete'); }
  })
  .catch(function(){ showToast('Error'); });
};

// ── Swap suggestions ──────────────────────────────────────────
window.openSwap = function(btn) {
  __swapLogId   = btn.getAttribute('data-id');
  __swapLogMeal = btn.getAttribute('data-meal') || 'other';
  var name = btn.getAttribute('data-name') || '';
  var cal  = btn.getAttribute('data-cal')  || '0';
  var prot = btn.getAttribute('data-prot') || '0';
  var fat  = btn.getAttribute('data-fat')  || '0';
  var carb = btn.getAttribute('data-carb') || '0';
  document.getElementById('swapCurrentInfo').innerHTML =
    '<div class="rv-swap-cname">' + escHtml(name) + '</div>' +
    '<div class="rv-swap-cmacros">' + cal + ' kcal · ' + prot + 'g P · ' + fat + 'g F · ' + carb + 'g C</div>';
  document.getElementById('swapList').innerHTML = '<div class="rv-swap-spin"><div class="rv-spinner" style="display:inline-block;"></div> Loading…</div>';
  document.getElementById('swapModal').classList.add('open');
  var params = new URLSearchParams({ calories: cal, protein_g: prot, fat_g: fat, carbs_g: carb });
  fetch('/api/food/suggest-swaps?' + params.toString())
    .then(function(r){ return r.json(); })
    .then(function(d){ renderSwaps(d.suggestions || []); })
    .catch(function(){ renderSwaps([]); });
};

function renderSwaps(suggestions) {
  var list = document.getElementById('swapList');
  if (!suggestions.length) {
    list.innerHTML = '<div class="rv-swap-empty">No similar recipes found. Try a different food.</div>';
    return;
  }
  list.innerHTML = '';
  suggestions.forEach(function(r) {
    var card = document.createElement('div');
    card.className = 'rv-swap-card';
    var imgHtml = r.image_url
      ? '<img class="rv-swap-img" src="' + escHtml(r.image_url) + '" alt="" loading="lazy">'
      : '<div class="rv-swap-img-ph">🥗</div>';
    var cal   = Math.round(r.calories  || 0);
    var prot  = Math.round(r.protein   || 0);
    var fat   = Math.round(r.fat       || 0);
    var carbs = Math.round(r.net_carbs || 0);
    var time  = (r.prep_time || 0) + (r.cook_time || 0);
    card.innerHTML =
      imgHtml +
      '<div class="rv-swap-info">' +
        '<div class="rv-swap-name">' + escHtml(r.title) + (time ? ' <span style="color:var(--rv-muted);font-size:.68rem;">· ' + time + 'min</span>' : '') + '</div>' +
        '<div class="rv-swap-pills">' +
          '<span class="rv-pill rv-pill-cal">' + cal + ' cal</span>' +
          '<span class="rv-pill rv-pill-p">' + prot + 'P</span>' +
          '<span class="rv-pill rv-pill-f">' + fat + 'F</span>' +
          '<span class="rv-pill rv-pill-c">' + carbs + 'C</span>' +
        '</div>' +
      '</div>' +
      '<button class="rv-swap-use" onclick="window.applySwap(this,' +
        JSON.stringify(r.title) + ',' + cal + ',' + prot + ',' + fat + ',' + carbs + ')">Use</button>';
    list.appendChild(card);
  });
}

window.applySwap = function(btn, recipeName, cal, prot, fat, carbs) {
  if (!__swapLogId) return;
  btn.disabled = true; btn.textContent = '…';
  var logId = __swapLogId; var mealType = __swapLogMeal;
  fetch('/api/food-log/delete', { method:'DELETE', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ id: logId }) })
  .then(function(r){ return r.json(); })
  .then(function(d){
    if (!d.success) throw new Error('Delete failed');
    return fetch('/api/food-log/add', { method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ food_name: recipeName, calories: cal, protein_g: prot, fat_g: fat, carbs_g: carbs, meal_type: mealType, client_date: new Date().toLocaleDateString('en-CA') }) });
  })
  .then(function(r){ return r.json(); })
  .then(function(d){
    if (d.success) { showToast('Swapped to ' + recipeName); window.closeSwap(); setTimeout(function(){ window.location.reload(); }, 500); }
    else { btn.disabled = false; btn.textContent = 'Use'; showToast('Swap failed'); }
  })
  .catch(function(){ btn.disabled = false; btn.textContent = 'Use'; showToast('Error during swap'); });
};

window.closeSwap = function() {
  document.getElementById('swapModal').classList.remove('open');
  __swapLogId = null;
};

// ── Helpers ───────────────────────────────────────────────────
function roundMacro(v) { return Math.round((v || 0) * 10) / 10; }
function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// ── Backdrop / keyboard ───────────────────────────────────────
document.getElementById('addModal').addEventListener('click', function(e){ if (e.target === this) window.closeAdd(); });
document.getElementById('swapModal').addEventListener('click', function(e){ if (e.target === this) window.closeSwap(); });
document.addEventListener('keydown', function(e){
  if (e.key === 'Enter' && document.getElementById('addModal').classList.contains('open')) window.saveEntry();
  if (e.key === 'Escape') { window.closeAdd(); window.closeScanner(); window.closeSwap(); }
});
</script>
</body>
</html>
