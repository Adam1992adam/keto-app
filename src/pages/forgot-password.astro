---
const sent  = Astro.url.searchParams.get('sent');
const error = Astro.url.searchParams.get('error');
const SITE_URL = (import.meta.env.PUBLIC_APP_URL || 'https://ketojourney.fun').replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reset Password — KetoJourney</title>
  <meta name="robots" content="noindex, nofollow"/>
  <link rel="canonical" href={SITE_URL + '/forgot-password'}/>
  <link rel="icon" type="image/png" sizes="32x32" href="/icon-72.png"/>
  <meta name="theme-color" content="#FF5C7A"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:#FAF6F1; --bg-alt:#F2EDE5; --ink:#16110F; --ink-soft:#4A4340;
      --muted:#8A8077; --line:#E5DED2; --accent:#FF5C7A; --card:#FFFFFF;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; -webkit-font-smoothing: antialiased; }
    body {
      font-family: 'Geist', sans-serif; background: var(--bg); color: var(--ink);
      min-height: 100vh; display: flex; flex-direction: column;
    }
    a { color: inherit; text-decoration: none; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; }

    /* NAV */
    .nav {
      padding: .9rem 1.75rem; display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid var(--line);
    }
    .nav-logo {
      display: inline-flex; align-items: center; gap: 10px;
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 18px; font-weight: 700; letter-spacing: -0.03em; color: var(--ink);
    }
    .nav-logo .dot {
      width: 26px; height: 26px; border-radius: 50%;
      background: var(--accent); display: grid; place-items: center;
      font-family: 'Instrument Serif', serif; font-style: italic;
      font-size: 15px; color: #fff; font-weight: 400; flex-shrink: 0;
    }
    .nav-logo em { font-family: 'Instrument Serif', serif; font-style: italic; font-weight: 400; color: var(--accent); }
    .nav-back {
      font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 500;
      letter-spacing: 0.08em; color: var(--muted); transition: color .2s;
      display: inline-flex; align-items: center; gap: 5px;
    }
    .nav-back:hover { color: var(--ink); }

    /* MAIN */
    .main {
      flex: 1; display: flex; align-items: center; justify-content: center;
      padding: 3rem 1.5rem;
    }
    .card {
      width: 100%; max-width: 440px;
      background: var(--card); border: 1px solid var(--line);
      border-radius: 24px; padding: 2.5rem 2.25rem;
      animation: fadeUp .4s ease both;
    }

    /* ICON */
    .icon-wrap {
      width: 52px; height: 52px; border-radius: 14px;
      background: rgba(255,92,122,.1); display: flex;
      align-items: center; justify-content: center; margin-bottom: 1.5rem;
    }
    .icon-wrap svg { display: block; }

    /* HEADING */
    .card-eyebrow {
      font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--accent); margin-bottom: 10px;
      display: inline-flex; align-items: center; gap: 7px;
    }
    .card-eyebrow::before {
      content: ''; width: 5px; height: 5px; border-radius: 50%;
      background: var(--accent); box-shadow: 0 0 0 3px rgba(255,92,122,.2);
    }
    .card-h {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 1.85rem; font-weight: 700; letter-spacing: -0.04em;
      line-height: 1.05; margin-bottom: .45rem;
    }
    .card-h em { font-family: 'Instrument Serif', serif; font-style: italic; font-weight: 400; color: var(--accent); }
    .card-sub { font-size: .85rem; color: var(--ink-soft); line-height: 1.6; margin-bottom: 1.75rem; }

    /* ALERT */
    .alert {
      display: flex; align-items: flex-start; gap: .7rem;
      padding: .85rem 1rem; border-radius: 12px; font-size: .8rem;
      margin-bottom: 1.25rem; line-height: 1.5;
    }
    .alert svg { flex-shrink: 0; margin-top: 1px; }
    .alert-error   { background: rgba(239,68,68,.07); border: 1px solid rgba(239,68,68,.2); color: #b91c1c; }
    .alert-success { background: rgba(16,185,129,.07); border: 1px solid rgba(16,185,129,.25); color: #065f46; }

    /* FIELD */
    .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 1.1rem; }
    .field-l {
      font-family: 'Geist Mono', monospace; font-size: 10px;
      letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted);
    }
    .field-wrap { position: relative; }
    .field-icon {
      position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
      display: flex; align-items: center; pointer-events: none;
    }
    .field input {
      width: 100%; padding: 12px 14px 12px 38px;
      background: var(--bg); border: 1px solid var(--line);
      border-radius: 12px; font-family: 'Geist', sans-serif;
      font-size: 15px; color: var(--ink); outline: none;
      transition: border-color .15s, box-shadow .15s;
    }
    .field input:focus { border-color: var(--accent); box-shadow: 0 0 0 4px rgba(255,92,122,.12); }
    .field input::placeholder { color: var(--muted); }

    /* BUTTON */
    .btn {
      width: 100%; margin-top: 4px; padding: 14px;
      background: var(--ink); color: var(--bg); border-radius: 13px;
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 15px; font-weight: 600; letter-spacing: -0.01em;
      display: inline-flex; justify-content: center; align-items: center; gap: 8px;
      transition: background .15s, transform .1s; cursor: pointer;
    }
    .btn:hover { background: var(--accent); }
    .btn:active { transform: scale(.98); }
    .btn:disabled { opacity: .5; cursor: not-allowed; transform: none; }
    .spin {
      display: none; width: 15px; height: 15px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,.3); border-top-color: #fff;
      animation: spin .7s linear infinite; flex-shrink: 0;
    }

    /* BACK LINK */
    .back-row {
      margin-top: 1.25rem; text-align: center;
      font-family: 'Geist Mono', monospace; font-size: 11px;
      letter-spacing: 0.08em; color: var(--muted);
    }
    .back-row a { color: var(--ink); font-weight: 500; margin-left: 4px; }
    .back-row a:hover { color: var(--accent); }

    /* SUCCESS */
    .success-icon-wrap {
      width: 60px; height: 60px; border-radius: 50%;
      background: rgba(16,185,129,.1); border: 1px solid rgba(16,185,129,.25);
      display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;
    }
    .success-h {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 1.6rem; font-weight: 700; letter-spacing: -0.04em; margin-bottom: .4rem;
    }
    .success-h em { font-family: 'Instrument Serif', serif; font-style: italic; font-weight: 400; color: var(--accent); }
    .success-body { font-size: .85rem; color: var(--ink-soft); line-height: 1.65; margin-bottom: 1.25rem; }
    .success-note {
      background: var(--bg); border: 1px solid var(--line);
      border-radius: 12px; padding: .85rem 1rem;
      font-size: .78rem; color: var(--ink-soft); line-height: 1.6;
    }
    .success-note a { color: var(--accent); font-weight: 600; }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes spin   { to { transform: rotate(360deg); } }
  </style>
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo">
    <span class="dot">k</span>keto<em>journey</em>
  </a>
  <a href="/login" class="nav-back">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
    Back to login
  </a>
</nav>

<main class="main">
  <div class="card">

    {sent ? (
      <div>
        <div class="success-icon-wrap">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="success-h">Check your <em>inbox</em></div>
        <p class="success-body">
          We sent a password reset link to your email address.<br/>
          Click the link to set a new password — it expires in 1 hour.
        </p>
        <div class="success-note">
          Didn't receive it? Check your spam folder, or
          <a href="/forgot-password">try again</a> with the correct address.
        </div>
        <div class="back-row">
          Remember your password? <a href="/login">Sign in</a>
        </div>
      </div>
    ) : (
      <div>
        <div class="card-eyebrow">Account recovery</div>
        <h1 class="card-h">Reset your <em>password</em></h1>
        <p class="card-sub">Enter your email and we'll send you a link to get back in. Takes about 2 minutes.</p>

        {error && (
          <div class="alert alert-error">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span>
              {error === 'ratelimited'
                ? 'Too many attempts. Please wait a few minutes and try again.'
                : 'Something went wrong. Please try again.'}
            </span>
          </div>
        )}

        <form id="fpForm" action="/api/auth/forgot-password" method="POST">
          <div class="field">
            <label class="field-l" for="email">Email address</label>
            <div class="field-wrap">
              <span class="field-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email"/>
            </div>
          </div>

          <button type="submit" class="btn" id="btn">
            <div class="spin" id="spin"></div>
            <span id="btnText">Send reset link</span>
            <span style="font-family:'Instrument Serif',serif;font-size:17px;">→</span>
          </button>
        </form>

        <div class="back-row">
          Remember your password? <a href="/login">Sign in</a>
        </div>
      </div>
    )}

  </div>
</main>

<script is:inline>
  var form = document.getElementById('fpForm');
  var btn  = document.getElementById('btn');
  var spin = document.getElementById('spin');
  var txt  = document.getElementById('btnText');
  if (form) {
    form.addEventListener('submit', function() {
      btn.disabled = true;
      spin.style.display = 'block';
      txt.textContent = 'Sending…';
    });
  }
</script>
</body>
</html>
