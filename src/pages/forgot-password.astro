---
const sent = Astro.url.searchParams.get('sent');
const error = Astro.url.searchParams.get('error');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reset Password — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,900;1,9..144,700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --dark:#0a0f0a; --dark2:#0f1710; --card:#141f14;
      --border:rgba(16,185,129,.14); --border2:rgba(16,185,129,.28);
      --text:#e8f0e8; --soft:#6a8a6a; --muted:#3a4e3a;
      --green:#10b981; --green2:#34d399; --red:#ef4444;
    }
    *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
    html,body { height:100%; font-family:'DM Sans',sans-serif; background:var(--dark); color:var(--text); }
    body { display:flex; align-items:center; justify-content:center; min-height:100vh; padding:2rem; }

    .card {
      background:var(--dark2); border:1px solid var(--border);
      border-radius:24px; padding:2.5rem 2.25rem;
      width:100%; max-width:420px;
      animation:fadeUp .45s ease both;
    }
    .back-link {
      display:inline-flex; align-items:center; gap:.4rem;
      color:var(--soft); font-size:.8rem; font-weight:600;
      text-decoration:none; margin-bottom:2rem;
      transition:color .2s;
    }
    .back-link:hover { color:var(--green); }
    .icon-wrap {
      width:56px; height:56px; border-radius:16px;
      background:rgba(16,185,129,.1); border:1px solid var(--border2);
      display:flex; align-items:center; justify-content:center;
      margin-bottom:1.5rem;
    }
    .icon-wrap svg { width:26px; height:26px; stroke:var(--green); stroke-width:2; fill:none; }
    h1 {
      font-family:'Fraunces',serif; font-size:1.9rem; font-weight:900;
      line-height:1.1; margin-bottom:.5rem;
    }
    h1 em { font-style:italic; color:var(--green); }
    .sub { font-size:.875rem; color:var(--soft); line-height:1.6; margin-bottom:1.75rem; }

    .alert {
      display:flex; align-items:flex-start; gap:.75rem;
      padding:.9rem 1.1rem; border-radius:12px; font-size:.82rem; font-weight:600;
      margin-bottom:1.5rem;
    }
    .alert-error   { background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.25); color:#fca5a5; }
    .alert-success { background:rgba(16,185,129,.08); border:1px solid var(--border2); color:var(--green2); }

    .field { margin-bottom:1.25rem; }
    .field-label {
      display:block; font-size:.75rem; font-weight:800;
      color:var(--soft); text-transform:uppercase; letter-spacing:.07em; margin-bottom:.5rem;
    }
    .field-wrap { position:relative; }
    .field-icon { position:absolute; left:1rem; top:50%; transform:translateY(-50%); pointer-events:none; }
    .field-icon svg { width:16px; height:16px; stroke:var(--soft); stroke-width:2; fill:none; }
    .field-input {
      width:100%; padding:.875rem 1.1rem .875rem 2.75rem;
      background:var(--card); border:1.5px solid var(--border);
      border-radius:13px; color:var(--text);
      font-family:'DM Sans',sans-serif; font-size:.875rem; font-weight:500;
      transition:all .22s; outline:none;
    }
    .field-input::placeholder { color:var(--muted); }
    .field-input:focus { border-color:var(--green); background:rgba(16,185,129,.04); box-shadow:0 0 0 4px rgba(16,185,129,.1); }

    .btn {
      width:100%; padding:.975rem;
      background:linear-gradient(135deg,var(--green),var(--green2));
      border:none; border-radius:13px; color:#fff;
      font-family:'DM Sans',sans-serif; font-weight:800; font-size:.95rem;
      cursor:pointer; transition:all .25s;
      display:flex; align-items:center; justify-content:center; gap:.5rem;
    }
    .btn:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(16,185,129,.4); }
    .btn:disabled { opacity:.5; cursor:not-allowed; transform:none; }
    .spinner {
      display:none; width:18px; height:18px; border-radius:50%;
      border:2.5px solid rgba(255,255,255,.3); border-top-color:#fff;
      animation:spin .7s linear infinite;
    }

    .success-state { text-align:center; }
    .success-icon {
      width:72px; height:72px; border-radius:50%;
      background:rgba(16,185,129,.1); border:2px solid var(--border2);
      display:flex; align-items:center; justify-content:center;
      margin:0 auto 1.5rem;
    }
    .success-icon svg { width:32px; height:32px; stroke:var(--green); stroke-width:2.5; fill:none; }
    .success-title { font-family:'Fraunces',serif; font-size:1.6rem; font-weight:900; margin-bottom:.75rem; }
    .success-body { color:var(--soft); font-size:.875rem; line-height:1.7; margin-bottom:1.5rem; }
    .success-note {
      background:rgba(16,185,129,.06); border:1px solid var(--border);
      border-radius:12px; padding:.9rem 1.1rem;
      font-size:.78rem; color:var(--soft); line-height:1.6;
    }

    @keyframes fadeUp { from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);} }
    @keyframes spin   { to{transform:rotate(360deg);} }
  </style>
</head>
<body>
<div class="card">
  <a href="/login" class="back-link">
    <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;stroke-width:2.5;fill:none"><polyline points="15 18 9 12 15 6"/></svg>
    Back to login
  </a>

  {sent ? (
    <div class="success-state">
      <div class="success-icon">
        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="success-title">Check your inbox</div>
      <p class="success-body">
        We sent a password reset link to your email.<br/>
        Click the link in the email to set a new password.
      </p>
      <div class="success-note">
        Didn't receive it? Check your spam folder, or <a href="/forgot-password" style="color:var(--green);font-weight:700;">try again</a> with the correct email address. The link expires in 1 hour.
      </div>
    </div>
  ) : (
    <>
      <div class="icon-wrap">
        <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      </div>
      <h1>Forgot your<br/><em>password?</em></h1>
      <p class="sub">Enter your email and we'll send you a link to reset it. Back in your account in 2 minutes.</p>

      {error && (
        <div class="alert alert-error">
          <span>⚠️</span>
          <span>{error === 'notfound' ? 'No account found with that email address.' : error === 'ratelimited' ? 'Too many attempts. Please wait a few minutes and try again.' : 'Something went wrong. Please try again.'}</span>
        </div>
      )}

      <form id="fpForm" action="/api/auth/forgot-password" method="POST">
        <div class="field">
          <label class="field-label" for="email">Email Address</label>
          <div class="field-wrap">
            <span class="field-icon">
              <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </span>
            <input type="email" id="email" name="email" required
              class="field-input" placeholder="your@email.com"/>
          </div>
        </div>
        <button type="submit" class="btn" id="btn">
          <div class="spinner" id="spinner"></div>
          <span id="btnText">Send Reset Link</span>
        </button>
      </form>
    </>
  )}
</div>

<script is:inline>
  var form = document.getElementById('fpForm');
  var btn  = document.getElementById('btn');
  var spinner = document.getElementById('spinner');
  var btnText = document.getElementById('btnText');
  if (form) {
    form.addEventListener('submit', function() {
      btn.disabled = true;
      spinner.style.display = 'block';
      btnText.textContent = 'Sending…';
    });
  }
</script>
</body>
</html>
