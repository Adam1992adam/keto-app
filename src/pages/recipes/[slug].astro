---
import { createClient } from '@supabase/supabase-js';

const supabaseUrl  = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnon = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const db = createClient(supabaseUrl, supabaseAnon);

const { slug } = Astro.params;
const SITE_URL  = (import.meta.env.PUBLIC_APP_URL || 'https://ketojourney.fun').replace(/\/$/, '');

const { data: recipe } = await db
  .from('blog_recipes')
  .select('*')
  .eq('slug', slug)
  .eq('published', true)
  .single();

if (!recipe) return Astro.redirect('/recipes');

// Related recipes (same difficulty, excluding current)
const { data: relatedRaw } = await db
  .from('blog_recipes')
  .select('id, title, slug, cover_image_url, difficulty, calories, net_carbs, prep_time, cook_time')
  .eq('published', true)
  .eq('difficulty', recipe.difficulty)
  .neq('id', recipe.id)
  .limit(3);
const related = relatedRaw || [];

// Parse ingredients and instructions (one per line)
const ingredients  = (recipe.ingredients || '').split('\n').map((l: string) => l.trim()).filter(Boolean);
const instructions = (recipe.instructions || '').split('\n').map((l: string) => l.trim()).filter(Boolean);
const totalTime    = (recipe.prep_time || 0) + (recipe.cook_time || 0);

const pageTitle = recipe.seo_title || recipe.title;
const pageDesc  = recipe.seo_description || recipe.description || '';
const ogImage   = recipe.cover_image_url || `${SITE_URL}/og-image.png`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{pageTitle} — Keto Recipe | KetoJourney</title>
  <meta name="description" content={pageDesc}/>
  <link rel="canonical" href={`${SITE_URL}/recipes/${recipe.slug}`}/>
  <meta property="og:type"        content="article"/>
  <meta property="og:title"       content={pageTitle}/>
  <meta property="og:description" content={pageDesc}/>
  <meta property="og:url"         content={`${SITE_URL}/recipes/${recipe.slug}`}/>
  <meta property="og:image"       content={ogImage}/>
  <meta name="twitter:card"       content="summary_large_image"/>
  <meta name="twitter:title"      content={pageTitle}/>
  <meta name="twitter:description"content={pageDesc}/>
  <meta name="twitter:image"      content={ogImage}/>
  <link rel="icon" type="image/png" sizes="32x32" href="/icon-72.png"/>
  <meta name="theme-color" content="#FF5C7A"/>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Serif:ital@0;1&family=Geist:wght@400;500;600&display=swap" rel="stylesheet"/>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org","@type":"Recipe",
    "name": recipe.title,
    "description": pageDesc,
    "image": ogImage,
    "prepTime": `PT${recipe.prep_time || 0}M`,
    "cookTime": `PT${recipe.cook_time || 0}M`,
    "totalTime": `PT${totalTime}M`,
    "recipeYield": `${recipe.servings} servings`,
    "recipeCategory": "Keto",
    "keywords": recipe.tags?.join(', ') || 'keto, low-carb',
    "nutrition": {
      "@type":"NutritionInformation",
      "calories": `${recipe.calories} calories`,
      "carbohydrateContent": `${recipe.carbs}g`,
      "fiberContent": `${recipe.fiber}g`,
      "proteinContent": `${recipe.protein}g`,
      "fatContent": `${recipe.fat}g`
    },
    "recipeIngredient": ingredients,
    "recipeInstructions": instructions.map((step: string, i: number) => ({
      "@type":"HowToStep", "position": i+1, "text": step
    })),
    "author":{"@type":"Organization","name":"KetoJourney","url":SITE_URL},
    "publisher":{"@type":"Organization","name":"KetoJourney","url":SITE_URL}
  })}/>
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    a { color:inherit; text-decoration:none; }
    img { display:block; max-width:100%; }
    :root {
      --bg:#FAF6F1; --bg-alt:#F2EDE5; --ink:#16110F; --ink-soft:#4A4340;
      --muted:#8A8077; --line:#E5DED2; --accent:#FF5C7A; --accent-2:#B6FF3C;
      --card:#FFFFFF;
      --display:'Bricolage Grotesque',system-ui,sans-serif;
      --serif:'Instrument Serif',serif;
      --body:'Geist',system-ui,sans-serif;
    }
    body { font-family:var(--body); background:var(--bg); color:var(--ink); overflow-x:hidden; }
    .nav { position:sticky; top:0; z-index:100; background:rgba(250,246,241,.92); backdrop-filter:blur(12px); border-bottom:1px solid var(--line); padding:16px 32px; display:flex; align-items:center; justify-content:space-between; }
    .nav-logo { display:flex; align-items:center; gap:10px; }
    .nav-logo-mark { width:34px; height:34px; background:var(--ink); border-radius:8px; display:flex; align-items:center; justify-content:center; font-family:var(--display); font-weight:800; font-size:.9rem; color:var(--accent-2); }
    .nav-logo-text { font-family:var(--display); font-weight:800; font-size:1rem; }
    .nav-links { display:flex; align-items:center; gap:8px; }
    .nav-link { font-size:.85rem; font-weight:500; color:var(--ink-soft); padding:6px 12px; border-radius:8px; transition:all .15s; }
    .nav-link:hover { color:var(--ink); background:var(--bg-alt); }
    .nav-cta { background:var(--accent); color:#fff; padding:8px 18px; border-radius:999px; font-size:.85rem; font-weight:700; font-family:var(--display); transition:opacity .15s; }
    .nav-cta:hover { opacity:.88; }
    @media(max-width:640px){ .nav-links{display:none;} .nav{padding:14px 18px;} }

    /* LAYOUT */
    .page { max-width:1100px; margin:0 auto; padding:40px 32px 80px; display:grid; grid-template-columns:1fr 300px; gap:48px; align-items:start; }
    @media(max-width:900px){ .page{grid-template-columns:1fr; padding:28px 18px 64px;} .sidebar{display:none;} }

    /* HERO */
    .recipe-hero { margin-bottom:32px; }
    .breadcrumb { display:flex; align-items:center; gap:6px; font-size:.78rem; color:var(--muted); margin-bottom:18px; }
    .breadcrumb a:hover { color:var(--ink); }
    .recipe-diff { display:inline-flex; padding:4px 12px; border-radius:999px; font-size:.72rem; font-weight:700; margin-bottom:14px; }
    .diff-easy { background:rgba(16,185,129,.1); color:#059669; }
    .diff-medium { background:rgba(245,158,11,.1); color:#d97706; }
    .diff-hard { background:rgba(239,68,68,.1); color:#dc2626; }
    .recipe-title { font-family:var(--display); font-size:clamp(1.7rem,4vw,2.6rem); font-weight:800; line-height:1.15; color:var(--ink); margin-bottom:14px; }
    .recipe-desc-text { font-size:1.05rem; color:var(--ink-soft); line-height:1.7; margin-bottom:24px; }
    .recipe-cover { width:100%; border-radius:20px; aspect-ratio:16/9; object-fit:cover; margin-bottom:0; }

    /* TIME + SERVINGS STRIP */
    .info-strip { display:flex; gap:0; background:var(--card); border:1px solid var(--line); border-radius:16px; overflow:hidden; margin:28px 0; }
    .info-item { flex:1; padding:16px 12px; text-align:center; border-right:1px solid var(--line); }
    .info-item:last-child { border-right:none; }
    .info-icon { font-size:1.3rem; margin-bottom:5px; }
    .info-val { font-family:var(--display); font-size:1.1rem; font-weight:800; color:var(--ink); }
    .info-label { font-size:.7rem; color:var(--muted); text-transform:uppercase; letter-spacing:.06em; margin-top:2px; }

    /* NUTRITION */
    .nutrition-bar { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:32px; }
    .nutr { background:var(--card); border:1px solid var(--line); border-radius:14px; padding:14px 10px; text-align:center; }
    .nutr-val { font-family:var(--display); font-size:1.4rem; font-weight:800; color:var(--ink); }
    .nutr-unit { font-size:.75rem; color:var(--muted); }
    .nutr-label { font-size:.68rem; color:var(--muted); text-transform:uppercase; letter-spacing:.06em; margin-top:3px; }
    .nutr.highlight { background:var(--accent); border-color:var(--accent); }
    .nutr.highlight .nutr-val, .nutr.highlight .nutr-unit, .nutr.highlight .nutr-label { color:#fff; }

    /* SECTIONS */
    .section-title { font-family:var(--display); font-size:1.25rem; font-weight:800; color:var(--ink); margin-bottom:16px; display:flex; align-items:center; gap:8px; }
    .ingredients-list { list-style:none; display:flex; flex-direction:column; gap:10px; margin-bottom:36px; }
    .ingredient-item { display:flex; align-items:flex-start; gap:12px; padding:12px 14px; background:var(--card); border:1px solid var(--line); border-radius:12px; font-size:.92rem; color:var(--ink-soft); }
    .ingredient-check { width:20px; height:20px; border-radius:6px; border:2px solid var(--line); flex-shrink:0; cursor:pointer; transition:all .15s; display:flex; align-items:center; justify-content:center; margin-top:1px; }
    .ingredient-check.done { background:var(--accent); border-color:var(--accent); }
    .ingredient-check.done::after { content:'✓'; color:#fff; font-size:.7rem; font-weight:800; }
    .ingredient-item.done { opacity:.5; text-decoration:line-through; }

    .steps-list { display:flex; flex-direction:column; gap:16px; margin-bottom:36px; }
    .step { display:flex; gap:16px; align-items:flex-start; }
    .step-num { width:36px; height:36px; border-radius:50%; background:var(--ink); color:var(--bg); display:flex; align-items:center; justify-content:center; font-family:var(--display); font-size:.88rem; font-weight:800; flex-shrink:0; cursor:pointer; transition:background .15s; }
    .step.done .step-num { background:var(--accent); }
    .step-text { font-size:.95rem; color:var(--ink-soft); line-height:1.65; padding-top:6px; }
    .step.done .step-text { opacity:.55; text-decoration:line-through; }

    /* TAGS */
    .tags { display:flex; gap:8px; flex-wrap:wrap; margin-top:20px; }
    .tag { padding:5px 14px; border-radius:999px; font-size:.78rem; font-weight:600; background:var(--bg-alt); color:var(--ink-soft); border:1px solid var(--line); }

    /* SIDEBAR */
    .sidebar { display:flex; flex-direction:column; gap:20px; position:sticky; top:90px; }
    .sidebar-card { background:var(--card); border:1px solid var(--line); border-radius:20px; padding:22px; }
    .sidebar-title { font-family:var(--display); font-size:1rem; font-weight:800; color:var(--ink); margin-bottom:12px; }
    .sidebar-cta { background:linear-gradient(135deg,var(--ink) 0%,#2D1F1A 100%); color:#fff; }
    .sidebar-cta .sidebar-title { color:#fff; }
    .cta-eyebrow { font-size:.68rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:var(--accent-2); margin-bottom:8px; }
    .cta-sub { font-size:.84rem; color:rgba(255,255,255,.65); line-height:1.55; margin-bottom:16px; }
    .cta-btn { display:block; text-align:center; padding:11px 20px; border-radius:999px; font-size:.85rem; font-weight:700; font-family:var(--display); margin-bottom:8px; transition:opacity .15s; }
    .cta-btn-primary { background:var(--accent); color:#fff; }
    .cta-btn-primary:hover { opacity:.88; }
    .cta-btn-outline { background:rgba(255,255,255,.1); color:#fff; border:1px solid rgba(255,255,255,.2); }
    .cta-btn-outline:hover { background:rgba(255,255,255,.18); }
    .nutr-full { display:flex; flex-direction:column; gap:8px; }
    .nutr-row { display:flex; align-items:center; justify-content:space-between; font-size:.84rem; }
    .nutr-row-label { color:var(--ink-soft); }
    .nutr-row-val { font-weight:700; color:var(--ink); }
    .nutr-row.sub { padding-left:14px; }
    .nutr-row.sub .nutr-row-label { color:var(--muted); font-size:.8rem; }
    .nutr-divider { height:1px; background:var(--line); }

    /* RELATED */
    .related { margin-top:52px; }
    .related-title-h { font-family:var(--display); font-size:1.25rem; font-weight:800; color:var(--ink); margin-bottom:20px; }
    .related-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:18px; }
    .related-card { background:var(--card); border:1px solid var(--line); border-radius:16px; overflow:hidden; display:flex; flex-direction:column; transition:transform .2s, box-shadow .2s; }
    .related-card:hover { transform:translateY(-3px); box-shadow:0 10px 30px rgba(22,17,15,.07); }
    .related-img { width:100%; aspect-ratio:4/3; object-fit:cover; background:var(--bg-alt); }
    .related-img-ph { width:100%; aspect-ratio:4/3; background:linear-gradient(135deg,var(--bg-alt),var(--line)); display:flex; align-items:center; justify-content:center; font-size:2rem; }
    .related-body { padding:16px; }
    .related-name { font-family:var(--display); font-size:.96rem; font-weight:700; color:var(--ink); line-height:1.3; margin-bottom:6px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
    .related-meta { font-size:.76rem; color:var(--muted); }

    /* BOTTOM CTA */
    .bottom-cta { background:var(--ink); border-radius:24px; margin:40px 0 0; padding:44px 40px; display:flex; align-items:center; justify-content:space-between; gap:24px; }
    .bottom-cta h2 { font-family:var(--display); font-size:1.5rem; font-weight:800; color:#fff; margin-bottom:8px; }
    .bottom-cta p { font-size:.88rem; color:rgba(255,255,255,.6); max-width:400px; line-height:1.6; }
    .bottom-cta-btns { display:flex; gap:10px; flex-shrink:0; flex-wrap:wrap; }
    .bcta-p { background:var(--accent); color:#fff; padding:12px 24px; border-radius:999px; font-size:.88rem; font-weight:700; font-family:var(--display); white-space:nowrap; transition:opacity .15s; }
    .bcta-p:hover { opacity:.88; }
    .bcta-g { background:rgba(255,255,255,.1); color:#fff; padding:12px 24px; border-radius:999px; font-size:.88rem; font-weight:600; border:1px solid rgba(255,255,255,.2); white-space:nowrap; transition:background .15s; }
    .bcta-g:hover { background:rgba(255,255,255,.18); }
    @media(max-width:640px){ .bottom-cta{flex-direction:column;padding:28px 22px;} .nutrition-bar{grid-template-columns:repeat(2,1fr);} }

    .footer { border-top:1px solid var(--line); padding:28px 32px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
    .footer-copy { font-size:.8rem; color:var(--muted); }
    .footer-links { display:flex; gap:20px; }
    .footer-links a { font-size:.8rem; color:var(--muted); transition:color .15s; }
    .footer-links a:hover { color:var(--ink); }
  </style>
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo">
    <div class="nav-logo-mark">K</div>
    <span class="nav-logo-text">KetoJourney</span>
  </a>
  <div class="nav-links">
    <a href="/" class="nav-link">Home</a>
    <a href="/blog" class="nav-link">Blog</a>
    <a href="/recipes" class="nav-link">Recipes</a>
  </div>
  <a href="/signup" class="nav-cta">Start Free Trial</a>
</nav>

<div class="page">

  <!-- ── Main recipe ── -->
  <main>
    <div class="recipe-hero">
      <div class="breadcrumb">
        <a href="/">Home</a><span>/</span>
        <a href="/recipes">Recipes</a><span>/</span>
        <span>{recipe.title}</span>
      </div>

      <span class={`recipe-diff ${recipe.difficulty === 'Easy' ? 'diff-easy' : recipe.difficulty === 'Medium' ? 'diff-medium' : 'diff-hard'}`}>
        {recipe.difficulty}
      </span>
      <h1 class="recipe-title">{recipe.title}</h1>
      {recipe.description && <p class="recipe-desc-text">{recipe.description}</p>}

      {recipe.cover_image_url && (
        <img src={recipe.cover_image_url} alt={recipe.title} class="recipe-cover" loading="eager"/>
      )}
    </div>

    <!-- Info strip -->
    <div class="info-strip">
      {recipe.prep_time > 0 && (
        <div class="info-item">
          <div class="info-icon">🔪</div>
          <div class="info-val">{recipe.prep_time} min</div>
          <div class="info-label">Prep</div>
        </div>
      )}
      {recipe.cook_time > 0 && (
        <div class="info-item">
          <div class="info-icon">🔥</div>
          <div class="info-val">{recipe.cook_time} min</div>
          <div class="info-label">Cook</div>
        </div>
      )}
      {totalTime > 0 && (
        <div class="info-item">
          <div class="info-icon">⏱</div>
          <div class="info-val">{totalTime} min</div>
          <div class="info-label">Total</div>
        </div>
      )}
      <div class="info-item">
        <div class="info-icon">👤</div>
        <div class="info-val">{recipe.servings}</div>
        <div class="info-label">Servings</div>
      </div>
    </div>

    <!-- Nutrition highlights -->
    <div class="nutrition-bar">
      <div class="nutr highlight">
        <div class="nutr-val">{recipe.calories}<span class="nutr-unit"> kcal</span></div>
        <div class="nutr-label">Calories</div>
      </div>
      <div class="nutr">
        <div class="nutr-val">{recipe.net_carbs}<span class="nutr-unit">g</span></div>
        <div class="nutr-label">Net Carbs</div>
      </div>
      <div class="nutr">
        <div class="nutr-val">{recipe.protein}<span class="nutr-unit">g</span></div>
        <div class="nutr-label">Protein</div>
      </div>
      <div class="nutr">
        <div class="nutr-val">{recipe.fat}<span class="nutr-unit">g</span></div>
        <div class="nutr-label">Fat</div>
      </div>
    </div>

    <!-- Ingredients -->
    {ingredients.length > 0 && (
      <>
        <h2 class="section-title">🥄 Ingredients</h2>
        <ul class="ingredients-list" id="ingredientsList">
          {ingredients.map((ing: string, i: number) => (
            <li class="ingredient-item" id={`ing-${i}`} onclick={`toggleIngredient(${i})`} style="cursor:pointer">
              <div class="ingredient-check" id={`chk-${i}`}></div>
              <span>{ing}</span>
            </li>
          ))}
        </ul>
      </>
    )}

    <!-- Instructions -->
    {instructions.length > 0 && (
      <>
        <h2 class="section-title">📋 Instructions</h2>
        <ol class="steps-list" id="stepsList">
          {instructions.map((step: string, i: number) => (
            <li class="step" id={`step-${i}`}>
              <div class="step-num" onclick={`toggleStep(${i})`}>{i + 1}</div>
              <div class="step-text">{step}</div>
            </li>
          ))}
        </ol>
      </>
    )}

    <!-- Tags -->
    {recipe.tags && recipe.tags.length > 0 && (
      <div class="tags">
        {recipe.tags.map((tag: string) => <span class="tag">#{tag}</span>)}
      </div>
    )}

    <!-- Bottom CTA -->
    <div class="bottom-cta">
      <div>
        <h2>Want 500+ more keto recipes?</h2>
        <p>Access the full recipe library, personalized meal plans, and progress tracking — free for 7 days.</p>
      </div>
      <div class="bottom-cta-btns">
        <a href="/signup" class="bcta-p">Start Free Trial</a>
        <a href="/recipes" class="bcta-g">More Recipes</a>
      </div>
    </div>

    <!-- Related -->
    {related.length > 0 && (
      <div class="related">
        <h2 class="related-title-h">You might also like</h2>
        <div class="related-grid">
          {related.map(r => (
            <a href={`/recipes/${r.slug}`} class="related-card">
              {r.cover_image_url
                ? <img src={r.cover_image_url} alt={r.title} class="related-img" loading="lazy"/>
                : <div class="related-img-ph">🥘</div>
              }
              <div class="related-body">
                <div class="related-name">{r.title}</div>
                <div class="related-meta">{(r.prep_time||0)+(r.cook_time||0)} min · {r.calories} kcal</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </main>

  <!-- ── Sidebar ── -->
  <aside class="sidebar">

    <!-- CTA -->
    <div class="sidebar-card sidebar-cta">
      <p class="cta-eyebrow">Free 7-Day Trial</p>
      <div class="sidebar-title">Get this recipe in your meal plan</div>
      <p class="cta-sub">Personalized keto meal plans with shopping lists — tailored to your goals.</p>
      <a href="/signup" class="cta-btn cta-btn-primary">Start Free Trial</a>
      <a href="/signup" class="cta-btn cta-btn-outline">Get Free Guide</a>
    </div>

    <!-- Full nutrition -->
    <div class="sidebar-card">
      <div class="sidebar-title">Nutrition per serving</div>
      <div class="nutr-full">
        <div class="nutr-row"><span class="nutr-row-label">Calories</span><span class="nutr-row-val">{recipe.calories} kcal</span></div>
        <div class="nutr-divider"></div>
        <div class="nutr-row"><span class="nutr-row-label">Total Carbs</span><span class="nutr-row-val">{recipe.carbs}g</span></div>
        <div class="nutr-row sub"><span class="nutr-row-label">— Fiber</span><span class="nutr-row-val">{recipe.fiber}g</span></div>
        <div class="nutr-row sub"><span class="nutr-row-label">— Net Carbs</span><span class="nutr-row-val" style="color:var(--accent);font-weight:800">{recipe.net_carbs}g</span></div>
        <div class="nutr-divider"></div>
        <div class="nutr-row"><span class="nutr-row-label">Protein</span><span class="nutr-row-val">{recipe.protein}g</span></div>
        <div class="nutr-row"><span class="nutr-row-label">Fat</span><span class="nutr-row-val">{recipe.fat}g</span></div>
      </div>
    </div>

  </aside>
</div>

<footer class="footer">
  <span class="footer-copy">© {new Date().getFullYear()} KetoJourney. All rights reserved.</span>
  <div class="footer-links">
    <a href="/privacy-policy">Privacy</a>
    <a href="/terms">Terms</a>
    <a href="/recipes">Recipes</a>
  </div>
</footer>

<script is:inline>
/* Interactive ingredient checklist */
function toggleIngredient(i) {
  var item = document.getElementById('ing-' + i);
  var chk  = document.getElementById('chk-' + i);
  if (!item || !chk) return;
  var done = item.classList.toggle('done');
  chk.classList.toggle('done', done);
}

/* Interactive step completion */
function toggleStep(i) {
  var step = document.getElementById('step-' + i);
  if (step) step.classList.toggle('done');
}
</script>
</body>
</html>
