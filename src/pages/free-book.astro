---
export const prerender = true;
const SITE_URL = (import.meta.env.PUBLIC_APP_URL || 'https://ketojourney.fun').replace(/\/$/, '');
const PAGE_TITLE = 'Free Keto Recipe Book — 7 Recipes Under 5g Net Carbs | Keto Journey';
const PAGE_DESC  = 'Get 7 delicious keto recipes with full macros delivered to your inbox — free. No credit card. No spam.';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESC}/>
  <meta property="og:title" content={PAGE_TITLE}/>
  <meta property="og:description" content={PAGE_DESC}/>
  <meta property="og:type" content="website"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/icon-72.png"/>
  <meta name="theme-color" content="#FF5C7A"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Serif:ital@0;1&family=Geist:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    :root {
      --bg:      #FAF6F1;
      --bg-alt:  #F2EDE5;
      --ink:     #16110F;
      --ink-soft:#4A4340;
      --muted:   #8A8077;
      --line:    #E5DED2;
      --accent:  #FF5C7A;
      --accent-2:#B6FF3C;
      --card:    #FFFFFF;
      --display: 'Bricolage Grotesque', system-ui, sans-serif;
      --serif:   'Instrument Serif', serif;
      --body:    'Geist', system-ui, sans-serif;
    }
    body { font-family: var(--body); background: var(--bg); color: var(--ink); overflow-x: hidden; }

    /* NAV */
    .nav { position: sticky; top: 0; z-index: 100; background: rgba(250,246,241,.92); backdrop-filter: blur(12px); border-bottom: 1px solid var(--line); padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { display: flex; align-items: center; gap: 10px; }
    .nav-logo-mark { width: 34px; height: 34px; background: var(--ink); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: var(--display); font-weight: 800; font-size: .9rem; color: var(--accent-2); }
    .nav-logo-text { font-family: var(--display); font-weight: 800; font-size: 1rem; }
    .nav-links { display: flex; align-items: center; gap: 8px; }
    .nav-link { font-size: .85rem; font-weight: 500; color: var(--ink-soft); padding: 6px 12px; border-radius: 8px; transition: all .15s; }
    .nav-link:hover { color: var(--ink); background: var(--bg-alt); }
    .nav-cta { background: var(--accent); color: #fff; padding: 8px 18px; border-radius: 999px; font-size: .85rem; font-weight: 700; font-family: var(--display); transition: opacity .15s; }
    .nav-cta:hover { opacity: .88; }
    @media(max-width:640px){ .nav-links{ display: none; } .nav{ padding: 14px 18px; } }

    /* HERO */
    .hero { text-align: center; padding: 72px 24px 56px; max-width: 700px; margin: 0 auto; }
    .hero-badge {
      display: inline-block; padding: 5px 16px;
      background: rgba(255,92,122,.08); border: 1px solid rgba(255,92,122,.2);
      border-radius: 999px; font-size: .78rem; font-weight: 700;
      color: var(--accent); letter-spacing: .05em; text-transform: uppercase;
      margin-bottom: 24px;
    }
    h1 { font-family: var(--display); font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; line-height: 1.1; color: var(--ink); margin-bottom: 20px; }
    h1 em { font-family: var(--serif); font-style: italic; color: var(--accent); }
    .hero-sub { font-size: 1.05rem; color: var(--ink-soft); line-height: 1.75; margin-bottom: 40px; max-width: 560px; margin-left: auto; margin-right: auto; }

    /* FORM */
    .form-wrap { background: var(--card); border: 1px solid var(--line); border-radius: 20px; padding: 28px 32px; max-width: 500px; margin: 0 auto; box-shadow: 0 4px 24px rgba(22,17,15,.06); }
    .form-row { display: flex; gap: 10px; }
    .form-input { flex: 1; padding: 13px 16px; background: var(--bg-alt); border: 1px solid var(--line); border-radius: 12px; color: var(--ink); font-size: .95rem; font-family: var(--body); outline: none; transition: border-color .2s; }
    .form-input:focus { border-color: var(--accent); }
    .form-input::placeholder { color: var(--muted); }
    .form-btn { padding: 13px 22px; background: var(--accent); border: none; border-radius: 12px; color: #fff; font-size: .92rem; font-weight: 700; font-family: var(--display); cursor: pointer; white-space: nowrap; transition: opacity .2s, transform .15s; }
    .form-btn:hover { opacity: .88; transform: translateY(-1px); }
    .form-btn:disabled { opacity: .6; cursor: not-allowed; transform: none; }
    .form-note { font-size: .75rem; color: var(--muted); text-align: center; margin-top: 12px; }
    .form-msg { margin-top: 14px; padding: 11px 14px; border-radius: 10px; font-size: .85rem; font-weight: 600; display: none; }
    .form-msg.success { display: block; background: rgba(16,185,129,.08); border: 1px solid rgba(16,185,129,.2); color: #059669; }
    .form-msg.error { display: block; background: rgba(239,68,68,.07); border: 1px solid rgba(239,68,68,.18); color: #dc2626; }
    @media(max-width:540px){ .form-row{ flex-direction: column; } .form-wrap{ padding: 22px 18px; } }

    /* PROOF BAR */
    .proof { display: flex; justify-content: center; gap: 28px; flex-wrap: wrap; padding: 24px 24px 52px; border-bottom: 1px solid var(--line); }
    .proof-item { display: flex; align-items: center; gap: 7px; font-size: .85rem; color: var(--muted); }
    .proof-item strong { color: var(--ink); font-weight: 700; }

    /* RECIPE SECTION */
    .section { max-width: 760px; margin: 0 auto; padding: 64px 24px; }
    .section-eyebrow { text-align: center; font-size: .72rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; }
    h2 { font-family: var(--display); font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 800; text-align: center; color: var(--ink); line-height: 1.2; margin-bottom: 40px; }
    .recipes-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 14px; }
    .recipe-card { background: var(--card); border: 1px solid var(--line); border-radius: 16px; padding: 18px; display: flex; gap: 14px; align-items: flex-start; transition: transform .2s, box-shadow .2s; }
    .recipe-card:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(22,17,15,.07); }
    .recipe-icon { font-size: 30px; flex-shrink: 0; }
    .recipe-name { font-family: var(--display); font-size: .96rem; font-weight: 700; color: var(--ink); margin-bottom: 3px; }
    .recipe-meta { font-size: .76rem; color: var(--muted); margin-bottom: 5px; }
    .recipe-desc { font-size: .82rem; color: var(--ink-soft); line-height: 1.55; }
    .recipe-tag { display: inline-block; margin-top: 8px; padding: 3px 10px; background: rgba(255,92,122,.07); border: 1px solid rgba(255,92,122,.18); border-radius: 999px; font-size: .72rem; font-weight: 700; color: var(--accent); }

    /* WHAT'S INCLUDED */
    .features-section { background: var(--bg-alt); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 64px 24px; }
    .features-inner { max-width: 760px; margin: 0 auto; }
    .features-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 16px; margin-top: 40px; }
    .feature-item { background: var(--card); border: 1px solid var(--line); border-radius: 16px; padding: 22px 16px; text-align: center; }
    .feature-icon { font-size: 28px; margin-bottom: 10px; }
    .feature-title { font-family: var(--display); font-size: .92rem; font-weight: 700; color: var(--ink); margin-bottom: 6px; }
    .feature-desc { font-size: .8rem; color: var(--muted); line-height: 1.5; }

    /* BOTTOM CTA */
    .bottom-cta-wrap { max-width: 760px; margin: 0 auto; padding: 56px 24px; }
    .bottom-cta { background: var(--ink); border-radius: 24px; padding: 48px 40px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
    .bottom-cta h2 { font-family: var(--display); font-size: 1.6rem; font-weight: 800; color: #fff; margin-bottom: 10px; text-align: left; }
    .bottom-cta p { font-size: .88rem; color: rgba(255,255,255,.6); line-height: 1.65; max-width: 380px; }
    .bottom-cta-btn { display: inline-block; padding: 14px 28px; background: var(--accent); color: #fff; font-family: var(--display); font-weight: 700; font-size: .92rem; border-radius: 999px; white-space: nowrap; transition: opacity .15s; flex-shrink: 0; }
    .bottom-cta-btn:hover { opacity: .88; }
    @media(max-width:640px){ .bottom-cta{ flex-direction: column; padding: 28px 22px; } .bottom-cta h2{ font-size: 1.3rem; } }

    /* FOOTER */
    .footer { border-top: 1px solid var(--line); padding: 24px 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .footer-copy { font-size: .8rem; color: var(--muted); }
    .footer-links { display: flex; gap: 20px; }
    .footer-links a { font-size: .8rem; color: var(--muted); transition: color .15s; }
    .footer-links a:hover { color: var(--ink); }
  </style>
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo">
    <div class="nav-logo-mark">K</div>
    <span class="nav-logo-text">KetoJourney</span>
  </a>
  <div class="nav-links">
    <a href="/" class="nav-link">Home</a>
    <a href="/blog" class="nav-link">Blog</a>
    <a href="/recipes" class="nav-link">Recipes</a>
  </div>
  <a href="/start" class="nav-cta">Start Free Trial</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-badge">📖 Free Recipe Book</div>
  <h1>7 Keto Recipes Under <em>5g Net Carbs</em> — Delivered Free</h1>
  <p class="hero-sub">No fluff. No filler. Just 7 proven keto recipes with full macros, ready in 30 minutes or less. Enter your email and we'll send it instantly.</p>

  <div class="form-wrap">
    <div class="form-row">
      <input type="email" class="form-input" id="emailInput" placeholder="Enter your email address" autocomplete="email"/>
      <button class="form-btn" id="submitBtn" type="button">Send It Free →</button>
    </div>
    <p class="form-note">🔒 No spam, ever. Unsubscribe anytime.</p>
    <div class="form-msg" id="formMsg"></div>
  </div>
</section>

<!-- PROOF BAR -->
<div class="proof">
  <div class="proof-item">✅ <strong>100% Free</strong> — no credit card</div>
  <div class="proof-item">⚡ <strong>Instant delivery</strong> to your inbox</div>
  <div class="proof-item">🍽️ <strong>Full macros</strong> for every recipe</div>
  <div class="proof-item">⏱️ <strong>30 min or less</strong> — all recipes</div>
</div>

<!-- RECIPE PREVIEWS -->
<section class="section">
  <p class="section-eyebrow">Inside the free book</p>
  <h2>7 Recipes You'll Actually Want to Make</h2>
  <div class="recipes-grid">
    <div class="recipe-card">
      <div class="recipe-icon">🥚</div>
      <div>
        <div class="recipe-name">Bacon &amp; Egg Cups</div>
        <div class="recipe-meta">⏱ 15 min · 280 cal</div>
        <div class="recipe-desc">Crispy bacon-lined cups with a baked egg inside. Zero carbs, zero effort.</div>
        <span class="recipe-tag">1g net carbs</span>
      </div>
    </div>
    <div class="recipe-card">
      <div class="recipe-icon">🥑</div>
      <div>
        <div class="recipe-name">Avocado Tuna Boats</div>
        <div class="recipe-meta">⏱ 10 min · 320 cal</div>
        <div class="recipe-desc">Avocado halves stuffed with tuna, mayo, and lemon. Perfect weekday lunch.</div>
        <span class="recipe-tag">2g net carbs</span>
      </div>
    </div>
    <div class="recipe-card">
      <div class="recipe-icon">🍗</div>
      <div>
        <div class="recipe-name">Garlic Butter Chicken</div>
        <div class="recipe-meta">⏱ 25 min · 490 cal</div>
        <div class="recipe-desc">Pan-seared thighs in a rich parmesan cream sauce. Restaurant-quality, keto-approved.</div>
        <span class="recipe-tag">3g net carbs</span>
      </div>
    </div>
    <div class="recipe-card">
      <div class="recipe-icon">🍚</div>
      <div>
        <div class="recipe-name">Cauliflower Fried Rice</div>
        <div class="recipe-meta">⏱ 20 min · 210 cal</div>
        <div class="recipe-desc">Riced cauliflower stir-fried with eggs and sesame oil. Satisfying without the carbs.</div>
        <span class="recipe-tag">5g net carbs</span>
      </div>
    </div>
    <div class="recipe-card">
      <div class="recipe-icon">🥬</div>
      <div>
        <div class="recipe-name">BLT Lettuce Wraps</div>
        <div class="recipe-meta">⏱ 10 min · 240 cal</div>
        <div class="recipe-desc">Crispy bacon, tomato, and mayo in romaine leaves. Better than the sandwich.</div>
        <span class="recipe-tag">2g net carbs</span>
      </div>
    </div>
    <div class="recipe-card">
      <div class="recipe-icon">🍝</div>
      <div>
        <div class="recipe-name">Zucchini Noodles &amp; Pesto</div>
        <div class="recipe-meta">⏱ 15 min · 310 cal</div>
        <div class="recipe-desc">Spiralized zucchini tossed with basil pesto and toasted pine nuts.</div>
        <span class="recipe-tag">4g net carbs</span>
      </div>
    </div>
    <div class="recipe-card">
      <div class="recipe-icon">🍰</div>
      <div>
        <div class="recipe-name">No-Bake Cheesecake Bites</div>
        <div class="recipe-meta">⏱ 30 min + chill · 180 cal</div>
        <div class="recipe-desc">Cream cheese bites on an almond flour crust, sweetened with erythritol.</div>
        <span class="recipe-tag">3g net carbs</span>
      </div>
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED -->
<section class="features-section">
  <div class="features-inner">
    <p class="section-eyebrow">What's included</p>
    <h2>Everything in Your Free Book</h2>
    <div class="features-grid">
      <div class="feature-item">
        <div class="feature-icon">🍽️</div>
        <div class="feature-title">7 Full Recipes</div>
        <div class="feature-desc">Breakfast, lunch, dinner, and dessert — all under 5g net carbs.</div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">📊</div>
        <div class="feature-title">Full Macros</div>
        <div class="feature-desc">Calories, protein, fat, and net carbs for every recipe.</div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">⏱️</div>
        <div class="feature-title">30 Min or Less</div>
        <div class="feature-desc">No complex techniques — just fast, flavourful keto cooking.</div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">🛒</div>
        <div class="feature-title">Beginner Friendly</div>
        <div class="feature-desc">Common ingredients, simple steps — no keto knowledge needed.</div>
      </div>
    </div>
  </div>
</section>

<!-- BOTTOM CTA -->
<div class="bottom-cta-wrap">
  <div class="bottom-cta">
    <div>
      <h2>Ready to start your keto journey?</h2>
      <p>These 7 recipes are just the beginning. Get 500+ recipes, a 30-day meal plan, daily coaching, and AI-powered tracking — free for 7 days.</p>
    </div>
    <a href="/start" class="bottom-cta-btn">Start Free 7-Day Trial →</a>
  </div>
</div>

<footer class="footer">
  <span class="footer-copy">© {new Date().getFullYear()} KetoJourney. All rights reserved.</span>
  <div class="footer-links">
    <a href="/privacy-policy">Privacy</a>
    <a href="/terms">Terms</a>
    <a href="/blog">Blog</a>
  </div>
</footer>

<script>
  const emailInput = document.getElementById('emailInput') as HTMLInputElement | null;
  const submitBtn  = document.getElementById('submitBtn')  as HTMLButtonElement | null;
  const formMsg    = document.getElementById('formMsg')    as HTMLElement | null;

  function showMsg(text: string, type: string) {
    if (!formMsg) return;
    formMsg.textContent = text;
    formMsg.className   = 'form-msg ' + type;
  }

  submitBtn?.addEventListener('click', async () => {
    if (!emailInput || !submitBtn || !formMsg) return;
    const email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      showMsg('Please enter a valid email address.', 'error');
      return;
    }
    submitBtn.disabled    = true;
    submitBtn.textContent = 'Sending…';
    formMsg.className     = 'form-msg';
    try {
      const res  = await fetch('/api/leads/collect', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ email }),
      });
      const data = await res.json();
      if (res.ok) {
        showMsg('✅ Check your inbox — the recipe book is on its way!', 'success');
        emailInput.value      = '';
        submitBtn.textContent = 'Sent! ✓';
      } else {
        showMsg(data.error || 'Something went wrong. Please try again.', 'error');
        submitBtn.disabled    = false;
        submitBtn.textContent = 'Send It Free →';
      }
    } catch {
      showMsg('Network error. Please try again.', 'error');
      submitBtn.disabled    = false;
      submitBtn.textContent = 'Send It Free →';
    }
  });

  emailInput?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') submitBtn?.click();
  });
</script>

</body>
</html>
