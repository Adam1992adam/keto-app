---
// Supabase sends the user here with #access_token=...&type=recovery in the URL hash.
// We read it client-side and call supabase.auth.updateUser({ password }).
const error = Astro.url.searchParams.get('error');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Set New Password — Keto Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,900;1,9..144,700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --dark:#0a0f0a; --dark2:#0f1710; --card:#141f14;
      --border:rgba(16,185,129,.14); --border2:rgba(16,185,129,.28);
      --text:#e8f0e8; --soft:#6a8a6a; --muted:#3a4e3a;
      --green:#10b981; --green2:#34d399; --red:#ef4444;
    }
    *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
    html,body { height:100%; font-family:'DM Sans',sans-serif; background:var(--dark); color:var(--text); }
    body { display:flex; align-items:center; justify-content:center; min-height:100vh; padding:2rem; }
    .card {
      background:var(--dark2); border:1px solid var(--border);
      border-radius:24px; padding:2.5rem 2.25rem;
      width:100%; max-width:420px; animation:fadeUp .45s ease both;
    }
    .icon-wrap {
      width:56px; height:56px; border-radius:16px;
      background:rgba(16,185,129,.1); border:1px solid var(--border2);
      display:flex; align-items:center; justify-content:center; margin-bottom:1.5rem;
    }
    .icon-wrap svg { width:26px; height:26px; stroke:var(--green); stroke-width:2; fill:none; }
    h1 { font-family:'Fraunces',serif; font-size:1.9rem; font-weight:900; line-height:1.1; margin-bottom:.5rem; }
    h1 em { font-style:italic; color:var(--green); }
    .sub { font-size:.875rem; color:var(--soft); line-height:1.6; margin-bottom:1.75rem; }
    .alert { display:flex; align-items:flex-start; gap:.75rem; padding:.9rem 1.1rem; border-radius:12px; font-size:.82rem; font-weight:600; margin-bottom:1.5rem; }
    .alert-error { background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.25); color:#fca5a5; }
    .field { margin-bottom:1.25rem; }
    .field-label { display:block; font-size:.75rem; font-weight:800; color:var(--soft); text-transform:uppercase; letter-spacing:.07em; margin-bottom:.5rem; }
    .field-wrap { position:relative; }
    .field-icon { position:absolute; left:1rem; top:50%; transform:translateY(-50%); pointer-events:none; }
    .field-icon svg { width:16px; height:16px; stroke:var(--soft); stroke-width:2; fill:none; }
    .field-input {
      width:100%; padding:.875rem 1.1rem .875rem 2.75rem;
      background:var(--card); border:1.5px solid var(--border);
      border-radius:13px; color:var(--text);
      font-family:'DM Sans',sans-serif; font-size:.875rem; font-weight:500;
      transition:all .22s; outline:none;
    }
    .field-input::placeholder { color:var(--muted); }
    .field-input:focus { border-color:var(--green); background:rgba(16,185,129,.04); box-shadow:0 0 0 4px rgba(16,185,129,.1); }
    .pw-toggle { position:absolute; right:1rem; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:var(--soft); font-size:1rem; transition:color .2s; }
    .pw-toggle:hover { color:var(--text); }
    .strength-bar { display:flex; gap:4px; margin-top:.5rem; }
    .strength-seg { flex:1; height:3px; border-radius:99px; background:var(--muted); transition:background .3s; }
    .strength-label { font-size:.7rem; color:var(--soft); margin-top:.35rem; }
    .btn {
      width:100%; padding:.975rem;
      background:linear-gradient(135deg,var(--green),var(--green2));
      border:none; border-radius:13px; color:#fff;
      font-family:'DM Sans',sans-serif; font-weight:800; font-size:.95rem;
      cursor:pointer; transition:all .25s;
      display:flex; align-items:center; justify-content:center; gap:.5rem;
    }
    .btn:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(16,185,129,.4); }
    .btn:disabled { opacity:.5; cursor:not-allowed; transform:none; }
    .spinner { display:none; width:18px; height:18px; border-radius:50%; border:2.5px solid rgba(255,255,255,.3); border-top-color:#fff; animation:spin .7s linear infinite; }
    /* invalid token state */
    .invalid-state { text-align:center; }
    .invalid-icon { width:64px; height:64px; border-radius:50%; background:rgba(239,68,68,.1); border:2px solid rgba(239,68,68,.25); display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem; }
    .invalid-icon svg { width:28px; height:28px; stroke:#ef4444; stroke-width:2; fill:none; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);} }
    @keyframes spin   { to{transform:rotate(360deg);} }
  </style>
</head>
<body>
<div class="card">
  <!-- shown while JS checks the token -->
  <div id="loadingState" style="text-align:center;padding:2rem 0;">
    <div style="width:36px;height:36px;border-radius:50%;border:3px solid var(--border2);border-top-color:var(--green);animation:spin .7s linear infinite;margin:0 auto 1rem;"></div>
    <p style="color:var(--soft);font-size:.875rem;">Verifying your reset link…</p>
  </div>

  <!-- shown when token is invalid / expired -->
  <div id="invalidState" style="display:none;" class="invalid-state">
    <div class="invalid-icon">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    </div>
    <h1 style="font-family:'Fraunces',serif;font-size:1.6rem;margin-bottom:.75rem;">Link expired</h1>
    <p style="color:var(--soft);font-size:.875rem;line-height:1.7;margin-bottom:1.5rem;">This password reset link has expired or already been used. Reset links are valid for 1 hour.</p>
    <a href="/forgot-password" style="display:inline-block;padding:.875rem 2rem;background:linear-gradient(135deg,var(--green),var(--green2));border-radius:13px;color:#fff;font-weight:800;font-size:.9rem;text-decoration:none;">Request a New Link</a>
  </div>

  <!-- the actual form -->
  <div id="formState" style="display:none;">
    <div class="icon-wrap">
      <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
    </div>
    <h1>Set your<br/><em>new password</em></h1>
    <p class="sub">Choose a strong password. You'll use it to log in from now on.</p>

    <div id="formError" class="alert alert-error" style="display:none;">
      <span>⚠️</span><span id="formErrorText">Something went wrong.</span>
    </div>

    <div class="field">
      <label class="field-label" for="password">New Password</label>
      <div class="field-wrap">
        <span class="field-icon"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg></span>
        <input type="password" id="password" class="field-input" placeholder="Min. 8 characters" minlength="8"/>
        <button type="button" class="pw-toggle" id="pwToggle1">👁️</button>
      </div>
      <div class="strength-bar">
        <div class="strength-seg" id="s1"></div>
        <div class="strength-seg" id="s2"></div>
        <div class="strength-seg" id="s3"></div>
        <div class="strength-seg" id="s4"></div>
      </div>
      <div class="strength-label" id="strengthLabel">Enter a password</div>
    </div>

    <div class="field">
      <label class="field-label" for="confirm">Confirm Password</label>
      <div class="field-wrap">
        <span class="field-icon"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg></span>
        <input type="password" id="confirm" class="field-input" placeholder="Repeat password"/>
        <button type="button" class="pw-toggle" id="pwToggle2">👁️</button>
      </div>
    </div>

    <button class="btn" id="submitBtn" onclick="submitReset()">
      <div class="spinner" id="spinner"></div>
      <span id="btnText">Set New Password</span>
    </button>
  </div>
</div>

<script is:inline>
  // Supabase public config — injected at runtime via meta tag approach
  var SUPABASE_URL = '';
  var SUPABASE_KEY = '';

  // Parse hash fragment for Supabase recovery tokens
  function getHashParams() {
    var hash = window.location.hash.substring(1);
    var params = {};
    hash.split('&').forEach(function(p) {
      var parts = p.split('=');
      if (parts.length === 2) params[parts[0]] = decodeURIComponent(parts[1]);
    });
    return params;
  }

  var hashParams = getHashParams();
  var accessToken = hashParams['access_token'];
  var tokenType   = hashParams['type'];

  // Show appropriate state
  if (!accessToken || tokenType !== 'recovery') {
    document.getElementById('loadingState').style.display = 'none';
    document.getElementById('invalidState').style.display = 'block';
  } else {
    document.getElementById('loadingState').style.display = 'none';
    document.getElementById('formState').style.display = 'block';
  }

  // Password strength
  var pwField = document.getElementById('password');
  if (pwField) {
    pwField.addEventListener('input', function() {
      var pw = pwField.value;
      var score = 0;
      if (pw.length >= 8)  score++;
      if (pw.length >= 12) score++;
      if (/[A-Z]/.test(pw) && /[0-9]/.test(pw)) score++;
      if (/[^A-Za-z0-9]/.test(pw)) score++;
      var colors = ['','#ef4444','#f59e0b','#10b981','#34d399'];
      var labels = ['','Weak','Fair','Strong','Very strong'];
      for (var i = 1; i <= 4; i++) {
        document.getElementById('s'+i).style.background = i <= score ? colors[score] : 'var(--muted)';
      }
      document.getElementById('strengthLabel').textContent = pw.length === 0 ? 'Enter a password' : labels[score] || 'Weak';
      document.getElementById('strengthLabel').style.color = colors[score] || 'var(--soft)';
    });
  }

  // Toggle visibility
  function togglePw(inputId, btnId) {
    var input = document.getElementById(inputId);
    var btn   = document.getElementById(btnId);
    if (input && btn) {
      btn.addEventListener('click', function() {
        var isText = input.type === 'text';
        input.type = isText ? 'password' : 'text';
        btn.textContent = isText ? '👁️' : '🙈';
      });
    }
  }
  togglePw('password', 'pwToggle1');
  togglePw('confirm',  'pwToggle2');

  async function submitReset() {
    var pw  = document.getElementById('password').value;
    var cfm = document.getElementById('confirm').value;
    var errDiv  = document.getElementById('formError');
    var errText = document.getElementById('formErrorText');
    var btn     = document.getElementById('submitBtn');
    var spinner = document.getElementById('spinner');
    var btnText = document.getElementById('btnText');

    errDiv.style.display = 'none';

    if (pw.length < 8) { errText.textContent = 'Password must be at least 8 characters.'; errDiv.style.display = 'flex'; return; }
    if (pw !== cfm)    { errText.textContent = 'Passwords do not match.'; errDiv.style.display = 'flex'; return; }

    btn.disabled = true;
    spinner.style.display = 'block';
    btnText.textContent = 'Saving…';

    try {
      var res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pw, access_token: accessToken }),
      });
      var data = await res.json();
      if (data.success) {
        window.location.href = '/login?message=Password+updated+successfully.+Please+log+in.';
      } else {
        errText.textContent = data.error || 'Failed to update password.';
        errDiv.style.display = 'flex';
        btn.disabled = false;
        spinner.style.display = 'none';
        btnText.textContent = 'Set New Password';
      }
    } catch(e) {
      errText.textContent = 'Network error. Please try again.';
      errDiv.style.display = 'flex';
      btn.disabled = false;
      spinner.style.display = 'none';
      btnText.textContent = 'Set New Password';
    }
  }
</script>
</body>
</html>
