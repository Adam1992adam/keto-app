---
const SITE_URL = (import.meta.env.PUBLIC_APP_URL || 'https://ketojourney.fun').replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Find Your Perfect Keto Plan — KetoJourney</title>
  <meta name="description" content="Answer 6 quick questions and get a personalized keto plan built around your goals, lifestyle and experience."/>
  <link rel="canonical" href={SITE_URL + '/start'}/>
  <meta property="og:title"       content="Find Your Perfect Keto Plan"/>
  <meta property="og:description" content="6 questions. Personalized plan. Start your free 7-day trial."/>
  <meta property="og:image"       content={SITE_URL + '/og-image.png'}/>
  <meta name="twitter:card"       content="summary_large_image"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/icon-72.png"/>
  <meta name="theme-color" content="#FF5C7A"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet"/>
  <style>
    :root{
      --bg:#FAF6F1;--card:#fff;--card2:#F2EDE5;
      --border:rgba(255,90,122,.13);--border2:rgba(255,90,122,.28);
      --text:#1A0A00;--soft:#7A6055;--muted:#C8B4AA;
      --accent:#FF5C7A;--accent2:#ff8fa3;--accent-bg:rgba(255,92,122,.07);
      --green:#10b981;--gold:#f59e0b;--blue:#3b82f6;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html,body{height:100%;overflow-x:hidden;}
    body{font-family:'Bricolage Grotesque',sans-serif;background:var(--bg);color:var(--text);}

    /* ── NAV ── */
    .qnav{
      position:fixed;top:0;left:0;right:0;z-index:100;
      padding:.85rem 1.5rem;display:flex;align-items:center;justify-content:space-between;
      background:rgba(250,246,241,.9);backdrop-filter:blur(12px);
      border-bottom:1px solid var(--border);
    }
    .qnav-logo{display:flex;align-items:center;gap:.4rem;font-weight:800;font-size:1rem;color:var(--text);text-decoration:none;}
    .qnav-logo span{color:var(--accent);}
    .qnav-login{font-size:.8rem;font-weight:700;color:var(--soft);text-decoration:none;transition:color .2s;}
    .qnav-login:hover{color:var(--accent);}

    /* ── PROGRESS ── */
    .prog-wrap{
      position:fixed;top:52px;left:0;right:0;z-index:99;
      padding:.5rem 1.5rem .4rem;background:rgba(250,246,241,.9);backdrop-filter:blur(8px);
    }
    .prog-bar{height:4px;background:var(--border);border-radius:4px;overflow:hidden;}
    .prog-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:4px;transition:width .45s ease;}
    .prog-label{font-size:.68rem;font-weight:700;color:var(--muted);text-align:right;margin-top:.3rem;}

    /* ── MAIN CONTAINER ── */
    .quiz-wrap{
      min-height:100vh;padding:6.5rem 1rem 3rem;
      display:flex;flex-direction:column;align-items:center;justify-content:flex-start;
    }

    /* ── STEP ── */
    .step{display:none;width:100%;max-width:600px;animation:fadeUp .35s ease both;}
    .step.active{display:block;}
    @keyframes fadeUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:translateY(0);}}

    .step-eyebrow{
      display:inline-flex;align-items:center;gap:.4rem;
      background:var(--accent-bg);border:1px solid var(--border);
      border-radius:99px;padding:.28rem .85rem;
      font-size:.67rem;font-weight:800;color:var(--accent);
      text-transform:uppercase;letter-spacing:.1em;margin-bottom:1rem;
    }
    .step-q{font-size:1.75rem;font-weight:800;line-height:1.15;margin-bottom:.55rem;}
    .step-q em{font-style:italic;color:var(--accent);}
    .step-hint{font-size:.82rem;color:var(--soft);margin-bottom:1.75rem;line-height:1.5;}

    /* ── OPTION CARDS ── */
    .options{display:flex;flex-direction:column;gap:.75rem;}
    .options.grid2{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;}
    .opt{
      display:flex;align-items:center;gap:.9rem;
      background:var(--card);border:2px solid var(--border);
      border-radius:16px;padding:1rem 1.15rem;
      cursor:pointer;transition:all .2s;user-select:none;
      position:relative;
    }
    .opt:hover{border-color:var(--border2);transform:translateY(-2px);box-shadow:0 6px 20px rgba(255,92,122,.1);}
    .opt.selected{
      border-color:var(--accent);background:var(--accent-bg);
      box-shadow:0 0 0 3px rgba(255,92,122,.12);
    }
    .opt-icon{
      width:44px;height:44px;border-radius:12px;
      display:flex;align-items:center;justify-content:center;
      font-size:1.3rem;flex-shrink:0;
      background:var(--card2);transition:background .2s;
    }
    .opt.selected .opt-icon{background:rgba(255,92,122,.14);}
    .opt-body{flex:1;}
    .opt-title{font-size:.92rem;font-weight:800;line-height:1.2;}
    .opt-sub{font-size:.72rem;color:var(--soft);margin-top:.18rem;}
    .opt-check{
      width:22px;height:22px;border-radius:50%;
      border:2px solid var(--muted);flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
      transition:all .2s;
    }
    .opt.selected .opt-check{background:var(--accent);border-color:var(--accent);}
    .opt-check svg{display:none;}
    .opt.selected .opt-check svg{display:block;}

    /* multi-select variant */
    .opt .opt-check.multi{border-radius:6px;}

    /* ── NEXT BUTTON ── */
    .next-btn{
      width:100%;margin-top:1.5rem;padding:1rem;
      background:linear-gradient(135deg,var(--accent),var(--accent2));
      border:none;border-radius:14px;color:#fff;
      font-family:'Bricolage Grotesque',sans-serif;font-size:.95rem;font-weight:800;
      cursor:pointer;transition:all .25s;
      display:flex;align-items:center;justify-content:center;gap:.5rem;
      position:relative;overflow:hidden;
    }
    .next-btn:disabled{opacity:.4;cursor:not-allowed;transform:none!important;}
    .next-btn:not(:disabled):hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(255,92,122,.35);}
    .next-btn::before{
      content:'';position:absolute;inset:0;
      background:linear-gradient(90deg,transparent,rgba(255,255,255,.12),transparent);
      transform:translateX(-100%);transition:transform .5s;
    }
    .next-btn:not(:disabled):hover::before{transform:translateX(100%);}

    .back-link{
      display:inline-flex;align-items:center;gap:.3rem;
      font-size:.78rem;font-weight:700;color:var(--muted);
      border:none;background:none;cursor:pointer;
      padding:.4rem 0;margin-bottom:.5rem;
      transition:color .2s;
    }
    .back-link:hover{color:var(--soft);}

    /* ── MULTI-SELECT COUNTER ── */
    .multi-counter{
      display:inline-flex;align-items:center;gap:.4rem;
      font-size:.72rem;color:var(--soft);margin-top:.75rem;
    }
    .multi-counter strong{color:var(--accent);}

    /* ── ANALYZING STEP ── */
    .analyze-wrap{text-align:center;padding:2.5rem 1rem;}
    .analyze-ring{
      width:80px;height:80px;border-radius:50%;
      border:4px solid var(--border);border-top-color:var(--accent);
      animation:spin .9s linear infinite;margin:0 auto 1.75rem;
    }
    @keyframes spin{to{transform:rotate(360deg);}}
    .analyze-title{font-size:1.5rem;font-weight:800;margin-bottom:.5rem;}
    .analyze-msg{font-size:.88rem;color:var(--soft);min-height:1.5rem;transition:opacity .3s;}
    .analyze-steps{
      margin-top:2rem;display:flex;flex-direction:column;gap:.6rem;
      max-width:320px;margin-left:auto;margin-right:auto;
    }
    .a-step{
      display:flex;align-items:center;gap:.6rem;
      font-size:.8rem;color:var(--muted);transition:color .4s;
    }
    .a-step.done{color:var(--text);}
    .a-dot{
      width:20px;height:20px;border-radius:50%;flex-shrink:0;
      border:2px solid var(--muted);display:flex;align-items:center;justify-content:center;
      font-size:.6rem;transition:all .4s;
    }
    .a-step.done .a-dot{background:var(--green);border-color:var(--green);color:#fff;}

    /* ── RESULT STEP ── */
    .result-hero{
      text-align:center;padding:1.25rem 0 1.5rem;
    }
    .result-badge{
      display:inline-flex;align-items:center;gap:.5rem;
      background:linear-gradient(135deg,rgba(255,92,122,.12),rgba(255,143,163,.06));
      border:1.5px solid var(--border2);border-radius:99px;
      padding:.4rem 1.1rem;font-size:.72rem;font-weight:800;
      color:var(--accent);margin-bottom:1rem;
    }
    .result-title{font-size:2rem;font-weight:800;line-height:1.1;margin-bottom:.5rem;}
    .result-title em{font-style:italic;color:var(--accent);}
    .result-sub{font-size:.88rem;color:var(--soft);line-height:1.6;}

    .plan-rec{
      background:linear-gradient(135deg,rgba(255,92,122,.08),rgba(255,143,163,.03));
      border:2px solid var(--border2);border-radius:20px;
      padding:1.25rem 1.4rem;margin:1.25rem 0;
      display:flex;align-items:center;gap:1rem;
    }
    .plan-rec-icon{font-size:2.2rem;flex-shrink:0;}
    .plan-rec-name{font-size:1.1rem;font-weight:800;}
    .plan-rec-desc{font-size:.78rem;color:var(--soft);margin-top:.18rem;line-height:1.5;}
    .plan-rec-tag{
      margin-left:auto;flex-shrink:0;
      padding:.3rem .85rem;border-radius:99px;
      background:var(--accent);color:#fff;
      font-size:.65rem;font-weight:800;letter-spacing:.06em;text-transform:uppercase;
    }

    .insights{display:flex;flex-direction:column;gap:.75rem;margin:1.25rem 0;}
    .insight{
      display:flex;align-items:flex-start;gap:.85rem;
      background:var(--card);border:1px solid var(--border);
      border-radius:14px;padding:.9rem 1rem;
    }
    .insight-icon{
      width:36px;height:36px;border-radius:10px;flex-shrink:0;
      background:var(--accent-bg);display:flex;align-items:center;justify-content:center;
      font-size:1rem;border:1px solid var(--border);
    }
    .insight-text{font-size:.82rem;line-height:1.55;}
    .insight-text strong{color:var(--text);}

    /* ── TRIAL SIGNUP FORM ── */
    .signup-section{
      background:var(--card);border:1.5px solid var(--border);
      border-radius:20px;padding:1.4rem 1.5rem;margin-top:1.5rem;
    }
    .signup-head{text-align:center;margin-bottom:1.25rem;}
    .signup-head h3{font-size:1.15rem;font-weight:800;margin-bottom:.3rem;}
    .signup-head p{font-size:.8rem;color:var(--soft);}
    .trial-badge{
      display:inline-flex;align-items:center;gap:.4rem;
      background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.25);
      border-radius:99px;padding:.28rem .85rem;
      font-size:.7rem;font-weight:800;color:var(--green);
      margin-bottom:.75rem;
    }
    .sf-field{margin-bottom:.9rem;}
    .sf-label{display:block;font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:var(--soft);margin-bottom:.4rem;}
    .sf-wrap{position:relative;}
    .sf-icon{position:absolute;left:.85rem;top:50%;transform:translateY(-50%);font-size:.85rem;pointer-events:none;}
    .sf-input{
      width:100%;padding:.8rem 1rem .8rem 2.5rem;
      background:var(--card2);border:1.5px solid var(--border);
      border-radius:11px;color:var(--text);
      font-family:'Bricolage Grotesque',sans-serif;font-size:.875rem;font-weight:500;
      outline:none;transition:all .2s;
    }
    .sf-input::placeholder{color:var(--muted);}
    .sf-input:focus{border-color:var(--accent);background:rgba(255,92,122,.04);box-shadow:0 0 0 3px rgba(255,92,122,.1);}
    .sf-input.err{border-color:#ef4444;}
    .sf-err{font-size:.72rem;color:#ef4444;margin-top:.3rem;display:none;}
    .sf-err.show{display:block;}

    .pw-bars{display:flex;gap:.3rem;margin:.5rem 0 .25rem;}
    .pw-bar{flex:1;height:3px;border-radius:2px;background:var(--muted);transition:background .3s;}
    .pw-bar.w{background:#ef4444;}
    .pw-bar.m{background:var(--gold);}
    .pw-bar.s{background:var(--green);}
    .pw-label{font-size:.67rem;color:var(--soft);}

    .pw-toggle{
      position:absolute;right:.85rem;top:50%;transform:translateY(-50%);
      background:none;border:none;cursor:pointer;color:var(--soft);
      font-size:.9rem;transition:color .2s;padding:.2rem;
    }
    .pw-toggle:hover{color:var(--text);}

    .signup-btn{
      width:100%;margin-top:.5rem;padding:.95rem;
      background:linear-gradient(135deg,var(--accent),var(--accent2));
      border:none;border-radius:12px;color:#fff;
      font-family:'Bricolage Grotesque',sans-serif;font-size:.92rem;font-weight:800;
      cursor:pointer;transition:all .25s;
      display:flex;align-items:center;justify-content:center;gap:.5rem;
    }
    .signup-btn:disabled{opacity:.5;cursor:not-allowed;}
    .signup-btn:not(:disabled):hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(255,92,122,.35);}
    .spin-sm{display:none;width:15px;height:15px;border-radius:50%;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;animation:spin .7s linear infinite;}
    .form-err{font-size:.78rem;color:#b91c1c;text-align:center;margin-top:.6rem;display:none;}
    .form-err.show{display:block;}

    .already-link{text-align:center;font-size:.8rem;color:var(--soft);margin-top:.75rem;}
    .already-link a{color:var(--accent);font-weight:800;text-decoration:none;}
    .already-link a:hover{text-decoration:underline;}

    .or-divider{display:flex;align-items:center;gap:.75rem;margin:1.1rem 0 .9rem;}
    .or-line{flex:1;height:1px;background:var(--border);}
    .or-text{font-size:.68rem;font-weight:700;color:var(--muted);}

    .ebook-btn{
      display:flex;align-items:center;justify-content:center;gap:.5rem;
      width:100%;padding:.8rem;border:1.5px solid var(--border);
      border-radius:12px;background:transparent;color:var(--soft);
      font-family:'Bricolage Grotesque',sans-serif;font-size:.85rem;font-weight:700;
      cursor:pointer;text-decoration:none;transition:all .2s;
    }
    .ebook-btn:hover{border-color:var(--border2);color:var(--accent);}

    .trust-row{
      display:flex;align-items:center;justify-content:center;
      flex-wrap:wrap;gap:.4rem .8rem;margin-top:1rem;
      font-size:.7rem;color:var(--muted);
    }
    .trust-item{display:flex;align-items:center;gap:.3rem;}
    .trust-sep{color:var(--border);}

    /* ── SUCCESS ── */
    .success-wrap{text-align:center;padding:2rem 1rem;}
    .success-icon{font-size:3.5rem;margin-bottom:.85rem;}
    .success-title{font-size:1.65rem;font-weight:800;color:var(--accent);margin-bottom:.5rem;}
    .success-sub{font-size:.85rem;color:var(--soft);line-height:1.65;margin-bottom:1.5rem;}
    .success-prog{height:4px;background:var(--border);border-radius:4px;overflow:hidden;}
    .success-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:4px;animation:grow 2.5s ease forwards;}
    @keyframes grow{from{width:0;}to{width:100%;}}

    @media(max-width:600px){
      .step-q{font-size:1.4rem;}
      .options.grid2{grid-template-columns:1fr;}
      .result-title{font-size:1.6rem;}
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav class="qnav">
  <a href="/" class="qnav-logo">🥑 Keto<span>Journey</span></a>
  <a href="/login" class="qnav-login">Already a member? Log in →</a>
</nav>

<!-- PROGRESS -->
<div class="prog-wrap">
  <div class="prog-bar"><div class="prog-fill" id="progFill" style="width:0%"></div></div>
  <div class="prog-label" id="progLabel">Step 1 of 6</div>
</div>

<div class="quiz-wrap">

  <!-- ══ STEP 1: GOAL ══ -->
  <div class="step active" id="step-1">
    <div class="step-eyebrow">✨ Quick quiz</div>
    <h1 class="step-q">What's your <em>main goal</em><br/>with keto?</h1>
    <p class="step-hint">This shapes every meal, every tip, every day of your plan.</p>
    <div class="options">
      <div class="opt" onclick="selectSingle(1,'weight_loss',this)">
        <div class="opt-icon">🔥</div>
        <div class="opt-body">
          <div class="opt-title">Lose weight</div>
          <div class="opt-sub">Burn fat, feel lighter, fit into your favourite clothes</div>
        </div>
        <div class="opt-check"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
      </div>
      <div class="opt" onclick="selectSingle(1,'muscle',this)">
        <div class="opt-icon">💪</div>
        <div class="opt-body">
          <div class="opt-title">Build lean muscle</div>
          <div class="opt-sub">Stay strong and toned while staying keto</div>
        </div>
        <div class="opt-check"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
      </div>
      <div class="opt" onclick="selectSingle(1,'energy',this)">
        <div class="opt-icon">⚡</div>
        <div class="opt-body">
          <div class="opt-title">Boost energy & focus</div>
          <div class="opt-sub">End brain fog, power through the day without crashes</div>
        </div>
        <div class="opt-check"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
      </div>
      <div class="opt" onclick="selectSingle(1,'health',this)">
        <div class="opt-icon">❤️</div>
        <div class="opt-body">
          <div class="opt-title">Improve overall health</div>
          <div class="opt-sub">Better blood sugar, cholesterol, and metabolic markers</div>
        </div>
        <div class="opt-check"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
      </div>
    </div>
    <button class="next-btn" id="next-1" disabled onclick="goNext(1)">Continue →</button>
  </div>

  <!-- ══ STEP 2: EXPERIENCE ══ -->
  <div class="step" id="step-2">
    <button class="back-link" onclick="goBack(2)">← Back</button>
    <div class="step-eyebrow">🥑 Experience</div>
    <h2 class="step-q">Have you tried<br/><em>keto before?</em></h2>
    <p class="step-hint">Honest answer helps us set the right pace for your plan.</p>
    <div class="options">
      <div class="opt" onclick="selectSingle(2,'new',this)">
        <div class="opt-icon">🆕</div>
        <div class="opt-body">
          <div class="opt-title">Never tried it</div>
          <div class="opt-sub">I'm completely new to the keto diet</div>
        </div>
        <div class="opt-check"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
      </div>
      <div class="opt" onclick="selectSingle(2,'tried',this)">
        <div class="opt-icon">🌱</div>
        <div class="opt-body">
          <div class="opt-title">Tried it briefly</div>
          <div class="opt-sub">Started but couldn't stick with it</div>
        </div>
        <div class="opt-check"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
      </div>
      <div class="opt" onclick="selectSingle(2,'months',this)">
        <div class="opt-icon">✅</div>
        <div class="opt-body">
          <div class="opt-title">Done it for months</div>
          <div class="opt-sub">I know the basics, ready to level up</div>
        </div>
        <div class="opt-check"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
      </div>
      <div class="opt" onclick="selectSingle(2,'current',this)">
        <div class="opt-icon">🏆</div>
        <div class="opt-body">
          <div class="opt-title">Currently eating keto</div>
          <div class="opt-sub">I want better results and structure</div>
        </div>
        <div class="opt-check"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
      </div>
    </div>
    <button class="next-btn" id="next-2" disabled onclick="goNext(2)">Continue →</button>
  </div>

  <!-- ══ STEP 3: CHALLENGES ══ -->
  <div class="step" id="step-3">
    <button class="back-link" onclick="goBack(3)">← Back</button>
    <div class="step-eyebrow">⚡ Challenges</div>
    <h2 class="step-q">What are your<br/><em>biggest challenges?</em></h2>
    <p class="step-hint">Pick up to 3 — we'll build solutions into your plan.</p>
    <div class="options">
      <div class="opt" onclick="selectMulti(3,'cravings',this,3)">
        <div class="opt-icon">🍫</div>
        <div class="opt-body">
          <div class="opt-title">Carb & sugar cravings</div>
          <div class="opt-sub">Hard to resist bread, pasta, sweets</div>
        </div>
        <div class="opt-check multi"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
      </div>
      <div class="opt" onclick="selectMulti(3,'meal_prep',this,3)">
        <div class="opt-icon">🍽️</div>
        <div class="opt-body">
          <div class="opt-title">Meal planning & prep</div>
          <div class="opt-sub">Don't know what to cook every day</div>
        </div>
