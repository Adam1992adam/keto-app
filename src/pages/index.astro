---
// index.astro — Landing Page (Rose Vital redesign 2026-04-27)
import { createClient } from '@supabase/supabase-js';
import CookieConsent from '../components/CookieConsent.astro';

const supabaseUrl    = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey= import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  const supabase = createClient(supabaseUrl, supabaseAnonKey, {
    global: { headers: { Authorization: `Bearer ${accessToken}` } },
  });
  const { data: { user } } = await supabase.auth.getUser(accessToken);
  if (user) return Astro.redirect('/dashboard');
}

const SITE_URL       = (import.meta.env.PUBLIC_APP_URL || 'https://ketojourney.fun').replace(/\/$/, '');
const accountDeleted = Astro.url.searchParams.get('deleted') === '1';

const SIGNUP_FALLBACK = '/signup';
const CHECKOUT_BASIC  = import.meta.env.LEMONSQUEEZY_BASIC_URL  || SIGNUP_FALLBACK;
const CHECKOUT_PRO    = import.meta.env.LEMONSQUEEZY_PRO_URL    || SIGNUP_FALLBACK;
const CHECKOUT_ELITE  = import.meta.env.LEMONSQUEEZY_ELITE_URL  || SIGNUP_FALLBACK;

const PAGE_TITLE       = 'Keto Journey — Transform Your Body With Intelligent Keto';
const PAGE_DESCRIPTION = 'AI-powered keto meal plans, daily coaching, and smart progress tracking — personalized to YOUR goals. Start your 30, 90, or 360-day keto journey today.';
const OG_IMAGE         = `${SITE_URL}/og-image.png`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESCRIPTION}/>
  <meta name="keywords" content="keto diet, keto meal plan, ketogenic diet app, keto coaching, keto recipes, weight loss, low carb diet, keto tracker"/>
  <meta name="author" content="KetoJourney"/>
  <link rel="canonical" href={SITE_URL + '/'}/>

  <meta property="og:type"        content="website"/>
  <meta property="og:url"         content={SITE_URL + '/'}/>
  <meta property="og:site_name"   content="KetoJourney"/>
  <meta property="og:title"       content={PAGE_TITLE}/>
  <meta property="og:description" content={PAGE_DESCRIPTION}/>
  <meta property="og:image"       content={OG_IMAGE}/>
  <meta property="og:image:width" content="1200"/>
  <meta property="og:image:height"content="630"/>
  <meta property="og:image:alt"   content="KetoJourney — AI-powered keto coaching app"/>
  <meta property="og:locale"      content="en_US"/>

  <meta name="twitter:card"        content="summary_large_image"/>
  <meta name="twitter:title"       content={PAGE_TITLE}/>
  <meta name="twitter:description" content={PAGE_DESCRIPTION}/>
  <meta name="twitter:image"       content={OG_IMAGE}/>
  <meta name="twitter:image:alt"   content="KetoJourney — AI-powered keto coaching app"/>

  <link rel="icon"             type="image/png" sizes="32x32" href="/icon-72.png"/>
  <link rel="icon"             type="image/png" sizes="192x192" href="/icon-192.png"/>
  <link rel="apple-touch-icon" sizes="192x192"  href="/icon-192.png"/>
  <link rel="manifest"         href="/manifest.webmanifest"/>
  <meta name="theme-color"     content="#FF5C7A"/>
  <meta name="mobile-web-app-capable"       content="yes"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="default"/>
  <meta name="apple-mobile-web-app-title"   content="KetoJourney"/>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "KetoJourney",
    "description": PAGE_DESCRIPTION,
    "url": SITE_URL,
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Web",
    "offers": [
      { "@type": "Offer", "name": "Basic",  "price": "29.99", "priceCurrency": "USD" },
      { "@type": "Offer", "name": "Pro",    "price": "69",    "priceCurrency": "USD" },
      { "@type": "Offer", "name": "Elite",  "price": "149",   "priceCurrency": "USD" }
    ],
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "2400" }
  })}></script>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet"/>

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-JRQ61VBZ4N"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-JRQ61VBZ4N');
  </script>

  <style>
    /* ── RESET ── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    a { color: inherit; text-decoration: none; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; }
    img { display: block; max-width: 100%; }
    ::selection { background: #FF5C7A; color: #fff; }

    /* ── DESIGN TOKENS (Rose Vital) ── */
    :root {
      --bg:       #FAF6F1;
      --bg-alt:   #F2EDE5;
      --ink:      #16110F;
      --ink-soft: #4A4340;
      --muted:    #8A8077;
      --line:     #E5DED2;
      --accent:   #FF5C7A;
      --accent-2: #B6FF3C;
      --accent-3: #FF914D;
      --card:     #FFFFFF;
      --display:  'Bricolage Grotesque', system-ui, sans-serif;
      --serif:    'Instrument Serif', serif;
      --body:     'Geist', system-ui, sans-serif;
      --mono:     'Geist Mono', monospace;
    }

    body {
      font-family: var(--body);
      background: var(--bg);
      color: var(--ink);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ── SHARED SECTION TYPOGRAPHY ── */
    .section-kicker {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .section-kicker::before {
      content: '';
      width: 28px;
      height: 1px;
      background: var(--accent);
    }
    .section-h2 {
      font-family: var(--display);
      font-size: clamp(38px, 5vw, 72px);
      line-height: 0.95;
      letter-spacing: -0.035em;
      font-weight: 700;
      margin-top: 16px;
      color: var(--ink);
      text-wrap: balance;
    }
    .section-h2 em {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 400;
      color: var(--accent);
    }
    .section-lede {
      font-size: 18px;
      line-height: 1.55;
      color: var(--ink-soft);
      max-width: 480px;
    }

    /* ── DELETED BANNER ── */
    .deleted-banner {
      background: #fee2e2;
      color: #991b1b;
      text-align: center;
      padding: 14px 20px;
      font-size: 14px;
      font-weight: 500;
    }

    /* ══════════════════════════════════════
       NAV
    ══════════════════════════════════════ */
    .nav {
      position: sticky;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 18px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background .35s ease, padding .35s ease, border-color .35s ease;
      border-bottom: 1px solid transparent;
    }
    .nav.scrolled {
      background: rgba(250,246,241,.88);
      backdrop-filter: blur(18px) saturate(1.2);
      -webkit-backdrop-filter: blur(18px) saturate(1.2);
      padding: 12px 32px;
      border-bottom-color: var(--line);
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: var(--display);
      font-weight: 700;
      font-size: 20px;
      letter-spacing: -0.02em;
      color: var(--ink);
    }
    .nav-logo-mark {
      width: 32px;
      height: 32px;
      border-radius: 10px;
      background: var(--ink);
      color: var(--accent-2);
      display: grid;
      place-items: center;
      font-weight: 800;
      font-size: 16px;
    }
    .nav-links {
      display: flex;
      gap: 28px;
      align-items: center;
    }
    .nav-link {
      font-size: 14px;
      font-weight: 500;
      color: var(--ink-soft);
      transition: color .2s;
    }
    .nav-link:hover { color: var(--ink); }
    .nav-cta { display: flex; gap: 10px; align-items: center; }
    .btn {
      font-family: var(--body);
      font-weight: 500;
      font-size: 14px;
      padding: 10px 18px;
      border-radius: 999px;
      transition: transform .15s, background .2s, color .2s;
      white-space: nowrap;
    }
    .btn:active { transform: scale(0.97); }
    .btn-ghost { color: var(--ink); }
    .btn-ghost:hover { background: var(--bg-alt); }
    .btn-dark { background: var(--ink); color: var(--bg); }
    .btn-dark:hover { background: var(--accent); color: #fff; }
    @media (max-width: 760px) {
      .nav { padding: 14px 18px; }
      .nav-links { display: none; }
      .nav.scrolled { padding: 10px 18px; }
    }

    /* ══════════════════════════════════════
       HERO
    ══════════════════════════════════════ */
    .hero {
      position: relative;
      min-height: 100vh;
      padding: 60px 32px 80px;
      overflow: hidden;
    }
    .hero-blob {
      position: absolute;
      width: 480px;
      height: 480px;
      border-radius: 50%;
      filter: blur(40px);
      z-index: 0;
      pointer-events: none;
    }
    .hero-blob-1 {
      background: radial-gradient(circle, rgba(255,92,122,.35), transparent 70%);
      top: -120px;
      right: -60px;
    }
    .hero-blob-2 {
      background: radial-gradient(circle, rgba(182,255,60,.4), transparent 70%);
      bottom: -160px;
      left: -120px;
    }
    .hero-grid {
      position: relative;
      z-index: 1;
      max-width: 1440px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 48px;
      align-items: center;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-soft);
      padding: 8px 14px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255,255,255,.6);
    }
    .hero-eyebrow-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 0 4px rgba(255,92,122,.25);
    }
    .hero-h1 {
      font-family: var(--display);
      font-size: clamp(48px, 7.5vw, 112px);
      line-height: 0.92;
      letter-spacing: -0.04em;
      font-weight: 700;
      margin-top: 28px;
      color: var(--ink);
      text-wrap: balance;
    }
    .hero-h1 em {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 400;
      color: var(--accent);
      letter-spacing: -0.02em;
    }
    .hero-h1 .accent-block {
      display: inline-block;
      background: var(--accent-2);
      padding: 0 14px;
      margin: 0 4px;
      border-radius: 8px;
      color: var(--ink);
      transform: rotate(-1.5deg);
    }
    .hero-sub {
      margin-top: 28px;
      max-width: 520px;
      font-size: 18px;
      line-height: 1.55;
      color: var(--ink-soft);
    }
    .hero-cta-row {
      margin-top: 36px;
      display: flex;
      gap: 14px;
      align-items: center;
      flex-wrap: wrap;
    }
    .btn-hero-primary {
      padding: 18px 30px;
      background: var(--ink);
      color: var(--bg);
      border-radius: 999px;
      font-weight: 600;
      font-size: 16px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: transform .2s, background .2s;
    }
    .btn-hero-primary:hover { background: var(--accent); color: #fff; transform: translateY(-2px); }
    .btn-hero-ghost {
      padding: 18px 24px;
      color: var(--ink);
      border-radius: 999px;
      font-weight: 500;
      font-size: 16px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border: 1px solid var(--line);
      transition: background .2s;
    }
    .btn-hero-ghost:hover { background: var(--card); }
    .hero-trust {
      margin-top: 36px;
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 13px;
      color: var(--muted);
    }
    .avatar-stack { display: flex; }
    .avatar-stack img {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 2px solid var(--bg);
      margin-left: -10px;
      object-fit: cover;
    }
    .avatar-stack img:first-child { margin-left: 0; }

    /* Hero visual column */
    .hero-visual {
      position: relative;
      aspect-ratio: 1 / 1.05;
      max-width: 580px;
      margin-left: auto;
      width: 100%;
    }
    .visual-photo {
      position: absolute;
      inset: 0;
      border-radius: 32px;
      overflow: hidden;
      background: var(--bg-alt);
    }
    .visual-photo img { width: 100%; height: 100%; object-fit: cover; filter: saturate(1.05); }
    .visual-photo::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,.3) 100%);
    }

    /* Activity rings card */
    .ring-card {
      position: absolute;
      background: var(--card);
      border-radius: 24px;
      padding: 18px;
      box-shadow: 0 30px 60px -20px rgba(0,0,0,.18), 0 1px 0 rgba(255,255,255,.6) inset;
      z-index: 3;
      top: 32px;
      left: -28px;
      width: 230px;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 14px;
      align-items: center;
    }
    .rings-svg { width: 70px; height: 70px; }
    .ring-track { fill: none; stroke: var(--line); stroke-width: 6; }
    .ring-fill  { fill: none; stroke-width: 6; stroke-linecap: round; }
    /* Ring animations - from 0 to target dasharray on load */
    .ring-coral  { stroke: var(--accent);   animation: rf-coral  1.8s cubic-bezier(0,.8,.2,1) .1s both; stroke-dasharray: 0 188.5; }
    .ring-lime   { stroke: var(--accent-2); animation: rf-lime   1.8s cubic-bezier(0,.8,.2,1) .3s both; stroke-dasharray: 0 138.2; }
    .ring-orange { stroke: var(--accent-3); animation: rf-orange 1.8s cubic-bezier(0,.8,.2,1) .5s both; stroke-dasharray: 0 88.0; }
    @keyframes rf-coral  { to { stroke-dasharray: 160.2 188.5; } }
    @keyframes rf-lime   { to { stroke-dasharray:  91.2 138.2; } }
    @keyframes rf-orange { to { stroke-dasharray:  36.9  88.0; } }
    .ring-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .ring-val {
      font-family: var(--display);
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--ink);
    }
    .ring-sub { font-size: 11px; color: var(--ink-soft); margin-top: 2px; }

    /* Stat chips */
    .stat-chip {
      position: absolute;
      background: var(--ink);
      color: var(--bg);
      padding: 14px 18px;
      border-radius: 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      z-index: 3;
    }
    .stat-chip-1 { top: 36%; right: -36px; }
    .stat-chip-2 { bottom: 24px; left: -20px; background: var(--accent); color: #fff; }
    .stat-chip .num {
      font-family: var(--display);
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .stat-chip .lbl {
      font-size: 11px;
      opacity: 0.75;
      font-family: var(--mono);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    /* Meal card */
    .meal-card {
      position: absolute;
      bottom: 90px;
      right: -10px;
      background: var(--card);
      border-radius: 20px;
      padding: 14px;
      width: 240px;
      box-shadow: 0 30px 60px -20px rgba(0,0,0,.18);
      z-index: 3;
    }
    .meal-card-head { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .meal-thumb { width: 48px; height: 48px; border-radius: 12px; object-fit: cover; flex-shrink: 0; }
    .meal-card-meta { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: 0.06em; }
    .meal-card-title { font-weight: 600; font-size: 13px; color: var(--ink); margin-top: 2px; }
    .macro-bars { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; }
    .macro-bar { display: flex; flex-direction: column; gap: 4px; }
    .macro-bar .ml { font-family: var(--mono); font-size: 9px; color: var(--muted); letter-spacing: 0.1em; }
    .macro-bar .mv { font-size: 11px; font-weight: 600; color: var(--ink); }
    .macro-bar .mtrack { height: 4px; border-radius: 2px; background: var(--line); overflow: hidden; }
    .macro-bar .mfill { height: 100%; border-radius: 2px; }

    @media (max-width: 980px) {
      .hero-grid { grid-template-columns: 1fr; gap: 60px; }
      .hero-visual { max-width: 100%; aspect-ratio: 4/5; margin-left: 0; }
      .hero { padding: 60px 18px 60px; }
      .meal-card { right: 10px; }
      .stat-chip-1 { right: 10px; }
      .stat-chip-2 { left: 10px; }
      .ring-card { left: 10px; }
    }

    /* ══════════════════════════════════════
       MARQUEE
    ══════════════════════════════════════ */
    .marquee {
      padding: 28px 0;
      background: var(--ink);
      color: var(--bg);
      overflow: hidden;
      position: relative;
      z-index: 2;
    }
    .marquee-track {
      display: flex;
      gap: 56px;
      animation: marquee-scroll 38s linear infinite;
      width: max-content;
    }
    .marquee-item {
      display: flex;
      align-items: baseline;
      gap: 14px;
      white-space: nowrap;
    }
    .marquee-num {
      font-family: var(--display);
      font-size: 38px;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--bg);
    }
    .marquee-num em {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 400;
      color: var(--accent);
    }
    .marquee-lbl {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(250,246,241,.7);
    }
    .marquee-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      align-self: center;
      flex-shrink: 0;
    }
    @keyframes marquee-scroll { to { transform: translateX(-33.333%); } }

    /* ══════════════════════════════════════
       FEATURES
    ══════════════════════════════════════ */
    .features {
      padding: 140px 32px 120px;
      background: var(--bg);
    }
    .features-inner { max-width: 1440px; margin: 0 auto; }
    .section-head {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 60px;
      align-items: end;
      margin-bottom: 72px;
    }
    .feat-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 20px;
    }
    .feat-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 28px;
      padding: 28px;
      display: flex;
      flex-direction: column;
      gap: 18px;
      transition: transform .3s, box-shadow .3s, border-color .3s;
      overflow: hidden;
      min-height: 380px;
      grid-column: span 2;
    }
    .feat-card.large {
      grid-column: span 4;
      flex-direction: row;
      min-height: 460px;
      align-items: stretch;
    }
    .feat-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255,92,122,.4);
      box-shadow: 0 30px 50px -25px rgba(0,0,0,.18);
    }
    .feat-card-head { display: flex; align-items: center; justify-content: space-between; }
    .feat-tag { font-family: var(--mono); font-size: 11px; letter-spacing: 0.16em; color: var(--muted); }
    .feat-kicker {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--bg-alt);
      color: var(--ink);
    }
    .feat-img {
      flex: 1;
      border-radius: 18px;
      overflow: hidden;
      background: var(--bg-alt);
      min-height: 180px;
    }
    .feat-img img { width: 100%; height: 100%; object-fit: cover; }
    .feat-card.large .feat-img { flex: 1.2; }
    .feat-card.large .feat-body {
      flex: 1;
      padding: 14px 14px 14px 0;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 30px;
    }
    .feat-body { display: flex; flex-direction: column; gap: 10px; }
    .feat-title {
      font-family: var(--display);
      font-size: 26px;
      line-height: 1.05;
      letter-spacing: -0.02em;
      font-weight: 600;
      color: var(--ink);
    }
    .feat-card.large .feat-title { font-size: 42px; line-height: 0.95; }
    .feat-desc { font-size: 14px; line-height: 1.55; color: var(--ink-soft); }
    .feat-card.large .feat-desc { font-size: 17px; }
    .feat-arrow {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: var(--ink);
      color: var(--bg);
      display: grid;
      place-items: center;
      font-size: 14px;
      transition: transform .25s, background .25s;
    }
    .feat-card:hover .feat-arrow { background: var(--accent); color: #fff; transform: rotate(-45deg); }
    @media (max-width: 980px) {
      .features { padding: 90px 18px; }
      .section-head { grid-template-columns: 1fr; gap: 24px; }
      .feat-grid { grid-template-columns: 1fr; }
      .feat-card, .feat-card.large { grid-column: span 1; flex-direction: column; min-height: 380px; }
      .feat-card.large .feat-body { padding: 0; }
    }

    /* ══════════════════════════════════════
       HOW IT WORKS
    ══════════════════════════════════════ */
    .how {
      padding: 140px 32px 120px;
      background: var(--bg-alt);
      overflow: hidden;
    }
    .how-inner { max-width: 1440px; margin: 0 auto; }
    .how-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 72px;
      gap: 40px;
    }
    .how-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .step {
      background: var(--card);
      border-radius: 28px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      position: relative;
      transition: transform .35s;
    }
    .step:hover { transform: translateY(-6px); }
    .step-img { aspect-ratio: 4/3; overflow: hidden; background: var(--bg-alt); }
    .step-img img { width: 100%; height: 100%; object-fit: cover; }
    .step-body { padding: 28px; display: flex; flex-direction: column; gap: 14px; }
    .step-num {
      font-family: var(--display);
      font-size: 80px;
      font-weight: 700;
      letter-spacing: -0.05em;
      line-height: 0.8;
      color: var(--accent);
    }
    .step-title {
      font-family: var(--display);
      font-size: 28px;
      line-height: 1.05;
      letter-spacing: -0.02em;
      font-weight: 600;
      color: var(--ink);
    }
    .step-desc { font-size: 15px; line-height: 1.55; color: var(--ink-soft); }
    @media (max-width: 980px) {
      .how { padding: 90px 18px; }
      .how-head { flex-direction: column; align-items: flex-start; }
      .how-grid { grid-template-columns: 1fr; }
    }

    /* ══════════════════════════════════════
       RECIPES
    ══════════════════════════════════════ */
    .recipes-sec {
      padding: 140px 32px 120px;
      background: var(--bg);
    }
    .recipes-inner { max-width: 1440px; margin: 0 auto; }
    .recipes-head {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 40px;
      align-items: flex-end;
      margin-bottom: 60px;
    }
    .recipes-cta-btn {
      padding: 16px 26px;
      background: var(--ink);
      color: var(--bg);
      border-radius: 999px;
      font-weight: 600;
      font-size: 15px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: background .2s, color .2s;
      white-space: nowrap;
    }
    .recipes-cta-btn:hover { background: var(--accent); color: #fff; }
    .recipes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .recipe-card {
      background: var(--card);
      border-radius: 24px;
      overflow: hidden;
      border: 1px solid var(--line);
      transition: transform .3s, box-shadow .3s;
    }
    .recipe-card:hover { transform: translateY(-6px); box-shadow: 0 30px 50px -25px rgba(0,0,0,.18); }
    .recipe-img {
      aspect-ratio: 4/3;
      background: var(--bg-alt);
      overflow: hidden;
      position: relative;
    }
    .recipe-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s; }
    .recipe-card:hover .recipe-img img { transform: scale(1.06); }
    .recipe-tag {
      position: absolute;
      top: 14px;
      left: 14px;
      background: var(--card);
      color: var(--ink);
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 7px 11px;
      border-radius: 999px;
    }
    .recipe-body { padding: 22px 22px 24px; }
    .recipe-name {
      font-family: var(--display);
      font-size: 22px;
      line-height: 1.15;
      letter-spacing: -0.02em;
      font-weight: 600;
      color: var(--ink);
    }
    .recipe-macros {
      margin-top: 16px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 6px;
      padding-top: 16px;
      border-top: 1px dashed var(--line);
    }
    .recipe-macro { display: flex; flex-direction: column; gap: 2px; }
    .recipe-macro .rl { font-family: var(--mono); font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); }
    .recipe-macro .rv { font-family: var(--display); font-size: 18px; font-weight: 600; letter-spacing: -0.02em; color: var(--ink); }
    @media (max-width: 980px) {
      .recipes-sec { padding: 90px 18px; }
      .recipes-head { grid-template-columns: 1fr; }
      .recipes-grid { grid-template-columns: 1fr; }
    }

    /* ══════════════════════════════════════
       RESULTS (dark)
    ══════════════════════════════════════ */
    .results {
      padding: 140px 32px 120px;
      background: var(--ink);
      color: var(--bg);
      position: relative;
      overflow: hidden;
    }
    .results-glow {
      position: absolute;
      width: 700px;
      height: 700px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,92,122,.45), transparent 65%);
      filter: blur(60px);
      top: -200px;
      right: -200px;
      z-index: 0;
    }
    .results-inner { max-width: 1440px; margin: 0 auto; position: relative; z-index: 2; }
    .results-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 72px;
      gap: 40px;
    }
    .results .section-kicker { color: var(--accent-2); }
    .results .section-kicker::before { background: var(--accent-2); }
    .results .section-h2 { color: var(--bg); }
    .results .section-h2 em { color: var(--accent); }
    .results-lede { font-size: 18px; line-height: 1.55; color: rgba(250,246,241,.7); max-width: 460px; }
    .stories-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }
    .story {
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(250,246,241,.1);
      border-radius: 28px;
      padding: 32px;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 24px;
      align-items: start;
      transition: background .3s, border-color .3s;
    }
    .story:hover {
      background: rgba(255,255,255,.1);
      border-color: rgba(255,92,122,.4);
    }
    .story-img { width: 92px; height: 110px; border-radius: 18px; object-fit: cover; }
    .story-stars { color: var(--accent); font-size: 14px; letter-spacing: 2px; margin-bottom: 12px; }
    .story-quote {
      font-family: var(--display);
      font-size: 20px;
      line-height: 1.3;
      letter-spacing: -0.01em;
      font-weight: 500;
      color: var(--bg);
      margin-bottom: 22px;
      text-wrap: balance;
    }
    .story-meta { display: flex; align-items: center; gap: 14px; }
    .story-meta .sname { font-weight: 600; font-size: 14px; color: var(--bg); }
    .story-meta .splan { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(250,246,241,.55); }
    .story-loss { margin-left: auto; font-family: var(--display); font-size: 22px; font-weight: 700; letter-spacing: -0.02em; color: var(--accent-2); }
    @media (max-width: 980px) {
      .results { padding: 90px 18px; }
      .results-head { flex-direction: column; align-items: flex-start; }
      .stories-grid { grid-template-columns: 1fr; }
      .story { grid-template-columns: 1fr; padding: 24px; }
      .story-img { width: 100%; height: 200px; }
    }

    /* ══════════════════════════════════════
       PRICING
    ══════════════════════════════════════ */
    .pricing {
      padding: 140px 32px 120px;
      background: var(--bg);
    }
    .pricing-inner { max-width: 1440px; margin: 0 auto; }
    .pricing-head { text-align: center; margin-bottom: 72px; }
    .pricing-head .section-kicker { justify-content: center; }
    .pricing-head .section-kicker::before { display: none; }
    .pricing-lede { font-size: 18px; line-height: 1.55; color: var(--ink-soft); max-width: 540px; margin: 18px auto 0; }
    .plans-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      align-items: stretch;
    }
    .plan {
      position: relative;
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 28px;
      padding: 36px 32px;
      display: flex;
      flex-direction: column;
      transition: transform .3s, box-shadow .3s;
    }
    .plan:hover { transform: translateY(-4px); box-shadow: 0 30px 50px -25px rgba(0,0,0,.18); }
    .plan.featured { background: var(--ink); color: var(--bg); border-color: var(--ink); transform: scale(1.02); }
    .plan.featured:hover { transform: scale(1.02) translateY(-4px); }
    .plan-badge {
      position: absolute;
      top: -14px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--accent);
      color: #fff;
      padding: 6px 14px;
      border-radius: 999px;
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .plan.featured .plan-badge { background: var(--accent-2); color: var(--ink); }
    .plan-name { font-family: var(--display); font-size: 22px; font-weight: 600; letter-spacing: -0.02em; }
    .plan-len {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 4px;
    }
    .plan.featured .plan-len { color: rgba(250,246,241,.6); }
    .plan-price { margin: 28px 0 24px; display: flex; align-items: baseline; gap: 8px; }
    .plan-currency { font-family: var(--display); font-size: 30px; font-weight: 600; color: var(--ink-soft); }
    .plan.featured .plan-currency { color: rgba(250,246,241,.7); }
    .plan-amount {
      font-family: var(--display);
      font-size: 80px;
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 0.9;
      color: var(--ink);
    }
    .plan.featured .plan-amount { color: var(--bg); }
    .plan-term { font-size: 14px; color: var(--muted); margin-left: 4px; }
    .plan-features {
      list-style: none;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 24px 0;
      border-top: 1px dashed var(--line);
    }
    .plan.featured .plan-features { border-color: rgba(250,246,241,.18); }
    .plan-features li { display: flex; gap: 12px; font-size: 14px; line-height: 1.4; color: var(--ink-soft); }
    .plan.featured .plan-features li { color: rgba(250,246,241,.8); }
    .plan-features li::before {
      content: '✓';
      flex-shrink: 0;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: rgba(255,92,122,.15);
      color: var(--accent);
      display: grid;
      place-items: center;
      font-size: 11px;
      font-weight: 700;
    }
    .plan.featured .plan-features li::before { background: var(--accent-2); color: var(--ink); }
    .plan-cta {
      margin-top: 20px;
      padding: 16px;
      border-radius: 999px;
      text-align: center;
      font-weight: 600;
      font-size: 15px;
      background: var(--ink);
      color: var(--bg);
      transition: background .2s, color .2s;
      display: block;
    }
    .plan-cta:hover { background: var(--accent); color: #fff; }
    .plan.featured .plan-cta { background: var(--accent-2); color: var(--ink); }
    .plan.featured .plan-cta:hover { background: var(--accent); color: #fff; }
    .pricing-foot {
      margin-top: 36px;
      text-align: center;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
    }
    @media (max-width: 980px) {
      .pricing { padding: 90px 18px; }
      .plans-grid { grid-template-columns: 1fr; }
      .plan.featured { transform: none; }
      .plan.featured:hover { transform: translateY(-4px); }
    }

    /* ══════════════════════════════════════
       FAQ
    ══════════════════════════════════════ */
    .faq-sec {
      padding: 140px 32px 120px;
      background: var(--bg-alt);
    }
    .faq-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 0.7fr 1fr;
      gap: 80px;
      align-items: start;
    }
    .faq-list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--line);
    }
    .faq-item { border-bottom: 1px solid var(--line); padding: 24px 0; }
    .faq-q {
      width: 100%;
      text-align: left;
      font-family: var(--display);
      font-size: 20px;
      line-height: 1.25;
      letter-spacing: -0.015em;
      font-weight: 500;
      color: var(--ink);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 30px;
      padding: 0;
      transition: color .2s;
    }
    .faq-q:hover { color: var(--accent); }
    .faq-icon {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--card);
      border: 1px solid var(--line);
      display: grid;
      place-items: center;
      transition: background .2s, transform .3s, color .2s;
      font-size: 18px;
      color: var(--ink);
    }
    .faq-item.open .faq-icon { background: var(--accent); color: #fff; transform: rotate(45deg); }
    .faq-a-wrap {
      overflow: hidden;
      max-height: 0;
      opacity: 0;
      transition: max-height .35s ease, opacity .25s ease, margin-top .35s ease;
    }
    .faq-item.open .faq-a-wrap { max-height: 300px; opacity: 1; margin-top: 14px; }
    .faq-a { font-size: 16px; line-height: 1.6; color: var(--ink-soft); max-width: 56ch; }
    @media (max-width: 980px) {
      .faq-sec { padding: 90px 18px; }
      .faq-inner { grid-template-columns: 1fr; gap: 40px; }
      .faq-q { font-size: 17px; }
    }

    /* ══════════════════════════════════════
       CTA BLOCK
    ══════════════════════════════════════ */
    .cta-sec {
      padding: 100px 32px;
      background: var(--bg);
    }
    .cta-inner {
      max-width: 1440px;
      margin: 0 auto;
      background: var(--accent);
      border-radius: 40px;
      padding: 90px 60px;
      position: relative;
      overflow: hidden;
      text-align: center;
    }
    .cta-glow {
      position: absolute;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      filter: blur(40px);
      top: -200px;
      left: -100px;
      z-index: 0;
      background: radial-gradient(circle, rgba(182,255,60,.55), transparent 65%);
    }
    .cta-glow.r {
      left: auto;
      right: -100px;
      background: radial-gradient(circle, rgba(255,145,77,.55), transparent 65%);
    }
    .cta-content { position: relative; z-index: 2; }
    .cta-eyebrow {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,.85);
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,.15);
    }
    .cta-dot { width: 8px; height: 8px; border-radius: 50%; background: #fff; box-shadow: 0 0 0 4px rgba(255,255,255,.3); }
    .cta-h2 {
      font-family: var(--display);
      font-size: clamp(48px, 7vw, 108px);
      line-height: 0.92;
      letter-spacing: -0.04em;
      font-weight: 700;
      margin-top: 24px;
      color: #fff;
      text-wrap: balance;
    }
    .cta-h2 em { font-family: var(--serif); font-style: italic; font-weight: 400; color: var(--accent-2); letter-spacing: -0.02em; }
    .cta-sub { margin: 24px auto 0; max-width: 540px; font-size: 18px; line-height: 1.55; color: rgba(255,255,255,.9); }
    .cta-btn {
      margin-top: 36px;
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 22px 36px;
      background: var(--ink);
      color: #fff;
      border-radius: 999px;
      font-weight: 600;
      font-size: 17px;
      transition: transform .2s, background .2s, color .2s;
    }
    .cta-btn:hover { background: var(--accent-2); color: var(--ink); transform: translateY(-2px); }
    .cta-foot {
      margin-top: 24px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(255,255,255,.75);
    }
    @media (max-width: 980px) {
      .cta-sec { padding: 60px 18px; }
      .cta-inner { padding: 60px 28px; border-radius: 28px; }
    }

    /* ══════════════════════════════════════
       FOOTER
    ══════════════════════════════════════ */
    .footer {
      background: var(--ink);
      color: var(--bg);
      padding: 80px 32px 40px;
    }
    .footer-inner { max-width: 1440px; margin: 0 auto; }
    .footer-top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 60px;
      padding-bottom: 60px;
      border-bottom: 1px solid rgba(250,246,241,.14);
    }
    .footer-brand .logo {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: var(--display);
      font-weight: 700;
      font-size: 20px;
    }
    .footer-brand .mark {
      width: 36px;
      height: 36px;
      border-radius: 12px;
      background: var(--accent);
      color: var(--ink);
      display: grid;
      place-items: center;
      font-weight: 800;
      font-size: 18px;
    }
    .footer-brand p {
      margin-top: 18px;
      max-width: 320px;
      font-size: 15px;
      line-height: 1.55;
      color: rgba(250,246,241,.6);
    }
    .footer-col h4 {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(250,246,241,.5);
      margin-bottom: 16px;
      font-weight: 500;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-col a { font-size: 14px; color: rgba(250,246,241,.8); transition: color .2s; }
    .footer-col a:hover { color: var(--accent); }
    .footer-bottom {
      margin-top: 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 20px;
    }
    .footer-copy {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(250,246,241,.5);
    }
    .footer-socials { display: flex; gap: 10px; }
    .social {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: rgba(250,246,241,.1);
      display: grid;
      place-items: center;
      font-size: 14px;
      transition: background .2s;
    }
    .social:hover { background: var(--accent); }
    .super-mark {
      margin-top: 56px;
      padding: 20px 0 0;
      font-family: var(--display);
      font-size: clamp(80px, 18vw, 280px);
      font-weight: 700;
      letter-spacing: -0.05em;
      line-height: 0.85;
      color: transparent;
      -webkit-text-stroke: 1px rgba(250,246,241,.14);
      text-align: center;
      user-select: none;
      overflow: hidden;
    }
    .super-mark em {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 400;
      -webkit-text-stroke: 1px var(--accent);
    }
    @media (max-width: 980px) {
      .footer { padding: 60px 18px 30px; }
      .footer-top { grid-template-columns: 1fr 1fr; gap: 40px; }
    }
  </style>
</head>
