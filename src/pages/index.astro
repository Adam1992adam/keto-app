    .cta-guarantee {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      font-size: .78rem;
      color: var(--soft);
      margin-top: 1.2rem;
    }
    .cta-guarantee .shield { color: var(--green2); }

    /* ══════════════════════════════════════
       FOOTER
    ══════════════════════════════════════ */
    .footer {
      position: relative;
      z-index: 1;
      background: rgba(0,0,0,.3);
      border-top: 1px solid var(--border);
      padding: 3rem 2rem 2rem;
    }
