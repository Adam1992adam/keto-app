    /* ══════════════════════════════════════
       SECTION 6 — FAQ
    ══════════════════════════════════════ */
    .faq-list { display: flex; flex-direction: column; gap: .85rem; max-width: 760px; margin: 0 auto; }
    .faq-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      transition: border-color .2s;
    }
