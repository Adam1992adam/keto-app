    /* ══════════════════════════════════════
       SECTION 4 — HOW IT WORKS
    ══════════════════════════════════════ */
    .steps-wrap {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      position: relative;
    }
    .steps-wrap::before {
      content: '';
      position: absolute;
      top: 38px; left: calc(16.5% + 20px); right: calc(16.5% + 20px);
      height: 2px;
      background: linear-gradient(90deg, var(--green), rgba(16,185,129,.2), var(--green));
    }
    @media (max-width: 700px) {
      .steps-wrap { grid-template-columns: 1fr; }
      .steps-wrap::before { display: none; }
    }

    .step-card {
      text-align: center;
      padding: 2rem 1.5rem;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      transition: all .3s;
    }
    .step-card:hover {
      transform: translateY(-4px);
      border-color: var(--border2);
      box-shadow: 0 16px 40px rgba(0,0,0,.3);
    }
    .step-num {
      width: 56px; height: 56px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--green), var(--green2));
      display: flex; align-items: center; justify-content: center;
      font-family: 'Fraunces', serif;
      font-size: 1.3rem;
      font-weight: 900;
      color: #fff;
      margin: 0 auto 1rem;
      box-shadow: 0 0 24px rgba(16,185,129,.35);
    }
    .step-icon { font-size: 1.2rem; margin-bottom: .8rem; }
    .step-title {
      font-family: 'Fraunces', serif;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: .6rem;
    }
    .step-desc {
      font-size: .85rem;
      color: var(--soft);
      line-height: 1.65;
    }

    /* ══════════════════════════════════════
       SECTION 5 — PRICING
    ══════════════════════════════════════ */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      align-items: start;
    }
    @media (max-width: 900px) { .pricing-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; } }

    .plan-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 2rem;
      transition: all .3s;
      position: relative;
    }
    .plan-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 50px rgba(0,0,0,.4);
    }
    .plan-card.featured {
      background: linear-gradient(160deg, #0d1f10 0%, #0a1a0c 100%);
      border: 1.5px solid rgba(16,185,129,.45);
      box-shadow:
        0 0 0 1px rgba(16,185,129,.08),
        0 20px 60px rgba(16,185,129,.12),
        0 0 80px rgba(16,185,129,.06);
      transform: scale(1.04);
    }
    .plan-card.featured:hover { transform: scale(1.04) translateY(-4px); }

    .plan-badge-top {
      display: inline-flex;
      align-items: center;
      gap: .35rem;
      padding: .3rem .75rem;
      border-radius: 99px;
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .04em;
      text-transform: uppercase;
      margin-bottom: 1.2rem;
