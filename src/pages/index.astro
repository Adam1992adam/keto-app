    .faq-arrow {
      width: 22px; height: 22px;
      border-radius: 50%;
      background: var(--muted);
      display: flex; align-items: center; justify-content: center;
      font-size: .65rem;
      color: var(--soft);
      flex-shrink: 0;
      transition: all .3s;
    }
    .faq-item.open .faq-arrow { background: var(--green); color: #fff; transform: rotate(180deg); }

    .faq-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height .35s ease;
    }
    .faq-body-inner {
      padding: 0 1.4rem 1.3rem;
      font-size: .88rem;
      color: var(--soft);
      line-height: 1.7;
    }

    /* ══════════════════════════════════════
       SECTION 7 — FINAL CTA
    ══════════════════════════════════════ */
    .cta-strip {
      position: relative;
      text-align: center;
      padding: 90px 2rem;
      overflow: hidden;
    }
    .cta-strip::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 50% 50%, rgba(16,185,129,.1), transparent),
        linear-gradient(180deg, transparent, rgba(16,185,129,.04), transparent);
    }
    .cta-strip-inner { position: relative; z-index: 1; }
    .cta-title {
      font-family: 'Fraunces', serif;
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 900;
      letter-spacing: -.03em;
      color: var(--text);
      margin-bottom: .8rem;
    }
    .cta-title em { font-style: italic; color: var(--green2); }
    .cta-sub {
      font-size: 1rem;
      color: var(--soft);
      margin-bottom: 2.2rem;
      max-width: 480px;
      margin-left: auto; margin-right: auto;
