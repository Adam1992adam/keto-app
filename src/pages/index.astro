    .plan-badge-top.value   { background: rgba(245,158,11,.12); color: var(--gold); border: 1px solid rgba(245,158,11,.25); }

    .plan-name {
      font-family: 'Fraunces', serif;
      font-size: 1.4rem;
      font-weight: 900;
      color: var(--text);
      margin-bottom: .25rem;
      letter-spacing: -.02em;
    }
    .plan-duration {
      font-size: .78rem;
      color: var(--soft);
      margin-bottom: 1.4rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .06em;
    }
    .plan-price {
      display: flex;
