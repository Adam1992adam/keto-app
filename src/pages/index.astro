---
// index.astro — Landing Page
import { createClient } from '@supabase/supabase-js';
import CookieConsent from '../components/CookieConsent.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  const supabase = createClient(supabaseUrl, supabaseAnonKey, {
    global: { headers: { Authorization: `Bearer ${accessToken}` } },
  });
  const { data: { user } } = await supabase.auth.getUser(accessToken);
  if (user) return Astro.redirect('/dashboard');
}

const SITE_URL = (import.meta.env.PUBLIC_APP_URL || 'https://ketojourney.fun').replace(/\/$/, '');
const accountDeleted = Astro.url.searchParams.get('deleted') === '1';

// LemonSqueezy checkout URLs — set these in Vercel env vars
// After payment, LemonSqueezy should redirect to: https://www.ketojourney.fun/signup
const SIGNUP_FALLBACK = '/signup';
const CHECKOUT_BASIC = import.meta.env.LEMONSQUEEZY_BASIC_URL || SIGNUP_FALLBACK;
const CHECKOUT_PRO   = import.meta.env.LEMONSQUEEZY_PRO_URL   || SIGNUP_FALLBACK;
const CHECKOUT_ELITE = import.meta.env.LEMONSQUEEZY_ELITE_URL || SIGNUP_FALLBACK;
const PAGE_TITLE       = 'Keto Journey — Transform Your Body With Intelligent Keto';
const PAGE_DESCRIPTION = 'AI-powered keto meal plans, daily coaching, and smart progress tracking — personalized to YOUR goals. Start your 30, 90, or 360-day keto journey today.';
const OG_IMAGE         = `${SITE_URL}/og-image.png`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <!-- ── PRIMARY SEO ── -->
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESCRIPTION}/>
  <meta name="keywords" content="keto diet, keto meal plan, ketogenic diet app, keto coaching, keto recipes, weight loss, low carb diet, keto tracker"/>
  <meta name="author" content="KetoJourney"/>
  <link rel="canonical" href={SITE_URL + '/'}/>

  <!-- ── OPEN GRAPH (Facebook, LinkedIn, WhatsApp, Discord) ── -->
  <meta property="og:type"        content="website"/>
  <meta property="og:url"         content={SITE_URL + '/'}/>
  <meta property="og:site_name"   content="KetoJourney"/>
  <meta property="og:title"       content={PAGE_TITLE}/>
  <meta property="og:description" content={PAGE_DESCRIPTION}/>
  <meta property="og:image"       content={OG_IMAGE}/>
  <meta property="og:image:width" content="1200"/>
  <meta property="og:image:height"content="630"/>
  <meta property="og:image:alt"   content="KetoJourney — AI-powered keto coaching app"/>
  <meta property="og:locale"      content="en_US"/>

  <!-- ── TWITTER / X CARD ── -->
  <meta name="twitter:card"        content="summary_large_image"/>
  <meta name="twitter:title"       content={PAGE_TITLE}/>
  <meta name="twitter:description" content={PAGE_DESCRIPTION}/>
  <meta name="twitter:image"       content={OG_IMAGE}/>
  <meta name="twitter:image:alt"   content="KetoJourney — AI-powered keto coaching app"/>

  <!-- ── FAVICON & PWA ── -->
  <link rel="icon"             type="image/png" sizes="32x32" href="/icon-72.png"/>
  <link rel="icon"             type="image/png" sizes="192x192" href="/icon-192.png"/>
  <link rel="apple-touch-icon" sizes="192x192"  href="/icon-192.png"/>
  <link rel="manifest"         href="/manifest.webmanifest"/>
  <meta name="theme-color"     content="#10b981"/>
  <meta name="mobile-web-app-capable"       content="yes"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
  <meta name="apple-mobile-web-app-title"   content="KetoJourney"/>

  <!-- ── STRUCTURED DATA (JSON-LD) ── -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "KetoJourney",
    "description": PAGE_DESCRIPTION,
    "url": SITE_URL,
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Web",
    "offers": [
      { "@type": "Offer", "name": "Basic",  "price": "29.99", "priceCurrency": "USD", "description": "30-day keto program" },
      { "@type": "Offer", "name": "Pro",    "price": "69",    "priceCurrency": "USD", "description": "90-day keto program" },
      { "@type": "Offer", "name": "Elite",  "price": "149",   "priceCurrency": "USD", "description": "360-day keto program" }
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "reviewCount": "10000"
    }
  })}></script>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;0,9..144,900;1,9..144,700;1,9..144,900&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet"/>

  <style>
    /* ── CSS RESET & TOKENS ── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    :root {
      --bg: #060d09;
      --card: #0d1a0f;
      --card2: #111f13;
      --border: rgba(16,185,129,.1);
      --border2: rgba(16,185,129,.28);
      --text: #dfeedd;
      --soft: #4d7055;
      --muted: #233328;
      --green: #10b981;
      --green2: #34d399;
      --gold: #f59e0b;
      --purple: #8b5cf6;
      --blue: #3b82f6;
      --red: #ef4444;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── ANIMATED BACKGROUND ORBS ── */
    .bg-orbs {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
    }
    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      animation: orbFloat 12s ease-in-out infinite;
    }
    .orb-1 {
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(16,185,129,.18) 0%, transparent 70%);
      top: -200px; left: -100px;
      animation-delay: 0s;
    }
    .orb-2 {
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(52,211,153,.12) 0%, transparent 70%);
      top: 20%; right: -150px;
      animation-delay: -4s;
    }
    .orb-3 {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(245,158,11,.08) 0%, transparent 70%);
      bottom: 10%; left: 20%;
      animation-delay: -8s;
    }
    .orb-4 {
      width: 350px; height: 350px;
      background: radial-gradient(circle, rgba(16,185,129,.1) 0%, transparent 70%);
      bottom: -100px; right: 10%;
      animation-delay: -2s;
    }
    @keyframes orbFloat {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33%       { transform: translate(30px, -40px) scale(1.05); }
      66%       { transform: translate(-20px, 20px) scale(0.95); }
    }

    /* ── LAYOUT HELPERS ── */
    .container {
      position: relative;
      z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }
    .section { padding: 100px 0; }
    .section-sm { padding: 60px 0; }

    /* ── FADE-UP ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp .7s ease both; }
    .delay-1 { animation-delay: .1s; }
    .delay-2 { animation-delay: .2s; }
    .delay-3 { animation-delay: .3s; }
    .delay-4 { animation-delay: .4s; }
    .delay-5 { animation-delay: .5s; }
    .delay-6 { animation-delay: .6s; }
    .delay-7 { animation-delay: .7s; }

    /* ── NAV ── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      padding: 1.1rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(6,13,9,.75);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: .55rem;
      font-family: 'Fraunces', serif;
      font-weight: 900;
      font-size: 1.2rem;
      color: var(--text);
      text-decoration: none;
      letter-spacing: -.02em;
    }
    .nav-logo .logo-icon {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--green), var(--green2));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem;
      box-shadow: 0 0 20px rgba(16,185,129,.35);
    }
    .nav-logo .logo-green { color: var(--green2); }
    .nav-links {
      display: flex;
      align-items: center;
      gap: .2rem;
    }
    .nav-link {
      padding: .45rem 1rem;
      border-radius: 99px;
      font-size: .82rem;
      font-weight: 600;
      color: var(--soft);
      text-decoration: none;
      transition: color .2s;
    }
    .nav-link:hover { color: var(--text); }
    .nav-cta {
      padding: .5rem 1.3rem;
      background: var(--green);
      color: #fff;
      border-radius: 99px;
      font-size: .82rem;
      font-weight: 700;
      text-decoration: none;
      transition: all .2s;
      box-shadow: 0 0 16px rgba(16,185,129,.3);
    }
    .nav-cta:hover {
      background: var(--green2);
      box-shadow: 0 0 24px rgba(52,211,153,.4);
      transform: translateY(-1px);
    }
    @media (max-width: 700px) {
      .nav-links { display: none; }
      .nav { padding: 1rem 1.25rem; }
    }

    /* ══════════════════════════════════════
       SECTION 1 — HERO
    ══════════════════════════════════════ */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding-top: 80px;
      position: relative;
    }
    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      width: 100%;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      padding: .35rem .9rem;
      background: rgba(16,185,129,.1);
      border: 1px solid rgba(16,185,129,.25);
      border-radius: 99px;
      font-size: .75rem;
      font-weight: 600;
      color: var(--green2);
      margin-bottom: 1.5rem;
      letter-spacing: .04em;
      text-transform: uppercase;
    }
    .hero-badge .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--green2);
      animation: pulse 2s ease infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: .5; transform: scale(.7); }
    }
    .hero-title {
      font-family: 'Fraunces', serif;
      font-size: clamp(2.6rem, 5vw, 4.2rem);
      font-weight: 900;
      line-height: 1.08;
      letter-spacing: -.03em;
      color: var(--text);
      margin-bottom: 1.4rem;
    }
    .hero-title em {
      font-style: italic;
      color: var(--green2);
    }
    .hero-subtitle {
      font-size: 1.1rem;
      line-height: 1.65;
      color: var(--soft);
      max-width: 480px;
      margin-bottom: 2.2rem;
    }
    .hero-ctas {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      padding: .85rem 2rem;
      background: linear-gradient(135deg, var(--green), var(--green2));
      color: #fff;
      border-radius: 14px;
      font-size: .95rem;
      font-weight: 700;
      text-decoration: none;
      transition: all .25s;
      box-shadow: 0 4px 30px rgba(16,185,129,.35);
    }
    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 40px rgba(16,185,129,.5);
    }
    .btn-outline {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      padding: .85rem 1.8rem;
      background: transparent;
      color: var(--text);
      border: 1px solid var(--border2);
      border-radius: 14px;
      font-size: .95rem;
      font-weight: 600;
      text-decoration: none;
      transition: all .25s;
    }
    .btn-outline:hover {
      background: rgba(16,185,129,.08);
      border-color: var(--green);
      transform: translateY(-2px);
    }

    /* ── CSS Phone Mockup ── */
    .hero-visual {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    .phone-wrap {
      position: relative;
    }
    .phone {
      width: 280px;
      height: 560px;
      background: linear-gradient(160deg, #0d1f10 0%, #060d09 100%);
      border-radius: 40px;
      border: 2px solid rgba(16,185,129,.3);
      box-shadow:
        0 0 0 8px rgba(16,185,129,.06),
        0 30px 80px rgba(0,0,0,.6),
        0 0 60px rgba(16,185,129,.12);
      padding: 20px 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      position: relative;
      overflow: hidden;
    }
    .phone::before {
      content: '';
      position: absolute;
      top: 0; left: 50%;
      transform: translateX(-50%);
      width: 100px; height: 28px;
      background: #060d09;
      border-radius: 0 0 20px 20px;
      z-index: 2;
    }
    /* Animated shimmer on phone */
    .phone::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, transparent 40%, rgba(16,185,129,.04) 50%, transparent 60%);
      animation: phoneShimmer 4s ease-in-out infinite;
    }
    @keyframes phoneShimmer {
      0%, 100% { opacity: 0; transform: translateX(-100%); }
      50%       { opacity: 1; transform: translateX(100%); }
    }

    /* Phone header bar */
    .phone-header {
      margin-top: 18px;
      padding: 10px 12px;
      background: rgba(16,185,129,.08);
      border: 1px solid var(--border);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .phone-header-left { font-size: .62rem; font-weight: 700; color: var(--green2); }
    .phone-header-right { font-size: .55rem; color: var(--soft); }

    /* Progress ring in phone */
    .phone-ring-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      background: var(--card2);
      border-radius: 14px;
      border: 1px solid var(--border);
    }
    .mini-ring {
      width: 46px; height: 46px;
      flex-shrink: 0;
    }
    .mini-ring circle {
      fill: none;
      stroke-width: 4;
      stroke-linecap: round;
    }
    .mini-ring .track { stroke: rgba(16,185,129,.12); }
    .mini-ring .fill  {
      stroke: var(--green);
      stroke-dasharray: 113;
      stroke-dashoffset: 35;
      animation: ringFill 2s ease-out both;
    }
    @keyframes ringFill {
      from { stroke-dashoffset: 113; }
      to   { stroke-dashoffset: 35; }
    }
    .ring-info { flex: 1; }
    .ring-label { font-size: .58rem; color: var(--soft); font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
    .ring-value { font-size: .9rem; font-weight: 700; color: var(--text); font-family: 'Fraunces', serif; }

    /* Meal cards in phone */
    .phone-meal {
      padding: 8px 12px;
      background: var(--card);
      border-radius: 12px;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .meal-dot {
      width: 28px; height: 28px;
      border-radius: 8px;
      flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: .75rem;
    }
    .meal-dot.breakfast { background: rgba(245,158,11,.15); }
    .meal-dot.lunch     { background: rgba(16,185,129,.15); }
    .meal-dot.dinner    { background: rgba(139,92,246,.15); }
    .meal-info { flex: 1; }
    .meal-name { font-size: .6rem; font-weight: 600; color: var(--text); }
    .meal-kcal { font-size: .52rem; color: var(--soft); }
    .meal-check {
      width: 16px; height: 16px;
      border-radius: 50%;
      background: rgba(16,185,129,.2);
      border: 1.5px solid var(--green);
      display: flex; align-items: center; justify-content: center;
      font-size: .5rem; color: var(--green);
    }

    /* Streak badge in phone */
    .phone-streak {
      padding: 8px 12px;
      background: rgba(245,158,11,.08);
      border: 1px solid rgba(245,158,11,.2);
      border-radius: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .phone-streak-icon { font-size: 1rem; }
    .phone-streak-info { flex: 1; }
    .phone-streak-label { font-size: .55rem; color: rgba(245,158,11,.7); font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
    .phone-streak-val { font-size: .85rem; font-weight: 700; color: var(--gold); font-family: 'Fraunces', serif; }

    /* Floating stat badges */
    .stat-badge {
      position: absolute;
      background: rgba(13,26,15,.95);
      border: 1px solid var(--border2);
      border-radius: 12px;
      padding: .55rem .9rem;
      display: flex;
      align-items: center;
      gap: .45rem;
      box-shadow: 0 8px 30px rgba(0,0,0,.4);
      white-space: nowrap;
      backdrop-filter: blur(10px);
      animation: badgeFloat 6s ease-in-out infinite;
    }
    .stat-badge:nth-child(2) { animation-delay: -2s; }
    .stat-badge:nth-child(3) { animation-delay: -4s; }
    @keyframes badgeFloat {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-8px); }
    }
    .stat-badge-icon { font-size: 1rem; }
    .stat-badge-text { font-size: .72rem; font-weight: 700; color: var(--text); }
    .stat-badge-sub  { font-size: .6rem; color: var(--soft); }

    .badge-streak { top: 60px; left: -80px; }
    .badge-xp     { top: 220px; right: -85px; }
    .badge-weight { bottom: 100px; left: -90px; }

    @media (max-width: 1000px) {
      .badge-streak { left: -50px; }
      .badge-xp     { right: -50px; }
      .badge-weight { left: -60px; }
    }

    @media (max-width: 768px) {
      .hero-inner {
        grid-template-columns: 1fr;
        gap: 3rem;
        text-align: center;
      }
      .hero-subtitle { max-width: 100%; margin-left: auto; margin-right: auto; }
      .hero-ctas { justify-content: center; }
      .hero-visual { margin-top: 2rem; }
      .badge-streak { left: -10px; top: 30px; }
      .badge-xp { right: -10px; top: 180px; }
      .badge-weight { left: -10px; bottom: 60px; }
    }

    /* ══════════════════════════════════════
       SECTION 2 — SOCIAL PROOF BAR
    ══════════════════════════════════════ */
    .proof-bar {
      position: relative;
      z-index: 1;
      background: rgba(16,185,129,.07);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 1.4rem 2rem;
      overflow: hidden;
    }
    .proof-bar-inner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 3rem;
      flex-wrap: wrap;
    }
    .proof-stat {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .15rem;
    }
    .proof-stat-num {
      font-family: 'Fraunces', serif;
      font-size: 1.4rem;
      font-weight: 900;
      color: var(--green2);
      letter-spacing: -.02em;
    }
    .proof-stat-label {
      font-size: .72rem;
      font-weight: 600;
      color: var(--soft);
      text-transform: uppercase;
      letter-spacing: .06em;
    }
    .proof-divider {
      width: 1px; height: 40px;
      background: var(--border2);
    }
    @media (max-width: 600px) {
      .proof-divider { display: none; }
      .proof-bar-inner { gap: 1.5rem; }
    }

    /* ══════════════════════════════════════
       SECTION 3 — FEATURES GRID
    ══════════════════════════════════════ */
    .section-label {
      display: inline-block;
      font-size: .7rem;
      font-weight: 700;
      color: var(--green2);
      text-transform: uppercase;
      letter-spacing: .1em;
      margin-bottom: .8rem;
      padding: .3rem .9rem;
      background: rgba(16,185,129,.08);
      border: 1px solid rgba(16,185,129,.2);
      border-radius: 99px;
    }
    .section-title {
      font-family: 'Fraunces', serif;
      font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 900;
      letter-spacing: -.03em;
      color: var(--text);
      margin-bottom: .75rem;
      line-height: 1.1;
    }
    .section-title em { font-style: italic; color: var(--green2); }
    .section-subtitle {
      font-size: 1rem;
      color: var(--soft);
      max-width: 540px;
      line-height: 1.6;
    }
    .section-header { margin-bottom: 3.5rem; }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    @media (max-width: 900px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .features-grid { grid-template-columns: 1fr; } }

    .feat-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 1.8rem;
      transition: all .3s;
      position: relative;
      overflow: hidden;
    }
    .feat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(16,185,129,.4), transparent);
      opacity: 0;
      transition: opacity .3s;
