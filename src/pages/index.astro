      gap: .3rem;
      margin-bottom: 1.6rem;
      padding-bottom: 1.6rem;
      border-bottom: 1px solid var(--border);
    }
    .plan-currency { font-size: 1.2rem; font-weight: 700; color: var(--soft); }
