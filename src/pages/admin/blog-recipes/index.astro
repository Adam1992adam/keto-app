---
import { createClient } from '@supabase/supabase-js';

const adminSession = Astro.cookies.get('admin-session')?.value;
if (adminSession !== 'authenticated') return Astro.redirect('/admin-login');

const env = (Astro.locals as any)?.runtime?.env || {};
const SUPABASE_URL = process.env.PUBLIC_SUPABASE_URL || env.PUBLIC_SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL;
const SERVICE_KEY  = process.env.SUPABASE_SERVICE_ROLE_KEY || env.SUPABASE_SERVICE_ROLE_KEY || import.meta.env.SUPABASE_SERVICE_ROLE_KEY;
const db = createClient(SUPABASE_URL, SERVICE_KEY);

const { data: recipes } = await db
  .from('blog_recipes')
  .select('id, title, slug, difficulty, calories, net_carbs, published, published_at, created_at')
  .order('created_at', { ascending: false });

const all = recipes || [];
const published = all.filter(r => r.published).length;
const drafts    = all.filter(r => !r.published).length;
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Blog Recipes · Admin</title>
  <meta name="robots" content="noindex,nofollow"/>
  <style>
    :root{--bg:#060d09;--card:#0d1a0f;--card2:#111f13;--border:rgba(16,185,129,.12);--border2:rgba(16,185,129,.25);--text:#dfeedd;--soft:#4d7055;--muted:#233328;--green:#10b981;--green2:#34d399;--gold:#f59e0b;--red:#ef4444;}
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);}
    a{color:var(--green);text-decoration:none;}
    .nav{background:var(--card);border-bottom:1px solid var(--border);padding:.85rem 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
    .nav-brand{font-size:1rem;font-weight:800;color:var(--text);display:flex;align-items:center;gap:.4rem;}
    .nav-links{display:flex;align-items:center;gap:.5rem;}
    .nav-link{font-size:.82rem;font-weight:600;color:var(--soft);padding:.4rem .8rem;border-radius:8px;transition:all .2s;}
    .nav-link:hover{color:var(--text);background:var(--muted);text-decoration:none;}
    .nav-link.active{color:var(--green2);background:rgba(16,185,129,.08);}
    .page{max-width:1200px;margin:0 auto;padding:2rem 1.5rem 5rem;}
    .top-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;}
    .page-title{font-size:1.6rem;font-weight:900;}
    .page-sub{font-size:.82rem;color:var(--soft);margin-top:.2rem;}
    .btn{display:inline-flex;align-items:center;gap:.4rem;padding:.55rem 1.1rem;border-radius:10px;font-size:.84rem;font-weight:700;cursor:pointer;border:none;text-decoration:none;transition:all .15s;}
    .btn-primary{background:var(--green);color:#fff;}
    .btn-primary:hover{background:var(--green2);color:#fff;text-decoration:none;}
    .btn-danger{background:rgba(239,68,68,.15);color:#ef9494;border:1px solid rgba(239,68,68,.25);}
    .btn-danger:hover{background:rgba(239,68,68,.25);}
    .btn-ghost{background:transparent;color:var(--soft);border:1px solid var(--border);}
    .btn-ghost:hover{border-color:var(--border2);color:var(--text);}
    .stats{display:flex;gap:1rem;margin-bottom:1.5rem;}
    .stat{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:.8rem 1.2rem;display:flex;align-items:center;gap:.6rem;}
    .stat-num{font-size:1.4rem;font-weight:900;}
    .stat-label{font-size:.75rem;color:var(--soft);}
    .card{background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;}
    .table{width:100%;border-collapse:collapse;}
    .table th{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--soft);padding:.75rem 1rem;text-align:left;border-bottom:1px solid var(--border);}
    .table td{padding:.85rem 1rem;border-bottom:1px solid rgba(16,185,129,.06);font-size:.84rem;vertical-align:middle;}
    .table tr:last-child td{border-bottom:none;}
    .table tr:hover td{background:rgba(16,185,129,.04);}
    .badge{display:inline-flex;align-items:center;padding:.25rem .65rem;border-radius:999px;font-size:.7rem;font-weight:700;}
    .badge-pub{background:rgba(16,185,129,.15);color:var(--green2);}
    .badge-draft{background:rgba(245,158,11,.1);color:#fbbf24;}
    .diff-easy{background:rgba(16,185,129,.1);color:var(--green2);}
    .diff-medium{background:rgba(245,158,11,.1);color:#fbbf24;}
    .diff-hard{background:rgba(239,68,68,.1);color:#ef9494;}
    .item-title{font-weight:600;color:var(--text);max-width:280px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .item-slug{font-size:.75rem;color:var(--soft);margin-top:.15rem;}
    .actions{display:flex;align-items:center;gap:.5rem;}
    .empty{text-align:center;padding:3rem;color:var(--soft);}
    .empty-icon{font-size:2.5rem;margin-bottom:.75rem;}
    .macro-chip{font-size:.75rem;color:var(--soft);background:var(--card2);border:1px solid var(--border);border-radius:6px;padding:.15rem .4rem;}
  </style>
</head>
<body>
<nav class="nav">
  <div class="nav-brand">⚙️ KetoJourney Admin</div>
  <div class="nav-links">
    <a href="/admin" class="nav-link">Dashboard</a>
    <a href="/admin/analytics" class="nav-link">Analytics</a>
    <a href="/admin/moderation" class="nav-link">Moderation</a>
    <a href="/admin/blog" class="nav-link">Articles</a>
    <a href="/admin/blog-recipes" class="nav-link active">Recipes</a>
    <a href="/" class="nav-link">← Site</a>
  </div>
</nav>

<div class="page">
  <div class="top-bar">
    <div>
      <h1 class="page-title">Blog Recipes</h1>
      <p class="page-sub">{all.length} total &nbsp;·&nbsp; {published} published &nbsp;·&nbsp; {drafts} drafts</p>
    </div>
    <a href="/admin/blog-recipes/editor" class="btn btn-primary">+ New Recipe</a>
  </div>

  <div class="stats">
    <div class="stat"><span class="stat-num" style="color:var(--green2)">{all.length}</span><span class="stat-label">Total</span></div>
    <div class="stat"><span class="stat-num" style="color:var(--green)">{published}</span><span class="stat-label">Published</span></div>
    <div class="stat"><span class="stat-num" style="color:var(--gold)">{drafts}</span><span class="stat-label">Drafts</span></div>
  </div>

  <div class="card">
    {all.length === 0 ? (
      <div class="empty">
        <div class="empty-icon">🥗</div>
        <p>No recipes yet. Add your first one!</p>
        <a href="/admin/blog-recipes/editor" class="btn btn-primary" style="margin-top:1rem">+ New Recipe</a>
      </div>
    ) : (
      <table class="table">
        <thead>
          <tr>
            <th>Recipe</th>
            <th>Difficulty</th>
            <th>Macros</th>
            <th>Status</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {all.map(recipe => (
            <tr>
              <td>
                <div class="item-title">{recipe.title}</div>
                <div class="item-slug">/{recipe.slug}</div>
              </td>
              <td>
                <span class={`badge ${recipe.difficulty === 'Easy' ? 'diff-easy' : recipe.difficulty === 'Medium' ? 'diff-medium' : 'diff-hard'}`}>
                  {recipe.difficulty}
                </span>
              </td>
              <td>
                <div style="display:flex;gap:.3rem;flex-wrap:wrap">
                  <span class="macro-chip">{recipe.calories} kcal</span>
                  <span class="macro-chip">{recipe.net_carbs}g net carbs</span>
                </div>
              </td>
              <td>
                <span class={`badge ${recipe.published ? 'badge-pub' : 'badge-draft'}`}>
                  {recipe.published ? '● Published' : '○ Draft'}
                </span>
              </td>
              <td style="color:var(--soft);font-size:.78rem;white-space:nowrap">
                {recipe.published && recipe.published_at
                  ? new Date(recipe.published_at).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})
                  : new Date(recipe.created_at).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})}
              </td>
              <td>
                <div class="actions">
                  <a href={`/admin/blog-recipes/editor?id=${recipe.id}`} class="btn btn-ghost" style="padding:.35rem .7rem;font-size:.78rem">Edit</a>
                  {recipe.published && (
                    <a href={`/recipes/${recipe.slug}`} target="_blank" class="btn btn-ghost" style="padding:.35rem .7rem;font-size:.78rem">View ↗</a>
                  )}
                  <button onclick={`deleteRecipe('${recipe.id}','${recipe.title.replace(/'/g,"\\'")}' )`} class="btn btn-danger" style="padding:.35rem .7rem;font-size:.78rem">Delete</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</div>

<script is:inline>
function deleteRecipe(id, title) {
  if (!confirm('Delete "' + title + '"? This cannot be undone.')) return;
  fetch('/api/admin/blog-recipe-delete', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id }),
  }).then(function(r) { return r.json(); }).then(function(d) {
    if (d.success) window.location.reload();
    else alert('Error: ' + d.error);
  });
}
</script>
</body>
</html>
