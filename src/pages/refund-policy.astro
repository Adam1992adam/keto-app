---
// src/pages/refund-policy.astro
export const prerender = true;
import CookieConsent from '../components/CookieConsent.astro';
const lastUpdated = 'April 9, 2026';
const SITE_URL = (import.meta.env.PUBLIC_APP_URL || 'https://ketojourney.fun').replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Refund Policy · KetoJourney</title>
  <meta name="description" content="KetoJourney Refund Policy — 30-day money-back guarantee. No questions asked."/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href={SITE_URL + '/refund-policy'}/>
  <meta property="og:type"        content="website"/>
  <meta property="og:url"         content={SITE_URL + '/refund-policy'}/>
  <meta property="og:site_name"   content="KetoJourney"/>
  <meta property="og:title"       content="Refund Policy · KetoJourney"/>
  <meta property="og:description" content="KetoJourney Refund Policy — 30-day money-back guarantee. No questions asked."/>
  <meta property="og:image"       content={SITE_URL + '/og-image.png'}/>
  <meta name="twitter:card"       content="summary"/>
  <meta name="twitter:title"      content="Refund Policy · KetoJourney"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/icon-72.png"/>
  <meta name="theme-color" content="#10b981"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;1,9..144,900&family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #060d09; --card: #0d1a0f; --border: rgba(16,185,129,.12);
      --text: #dfeedd; --soft: #4d7055; --green: #10b981; --green2: #34d399;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); line-height:1.7; }
    a { color:var(--green); text-decoration:none; }
    a:hover { text-decoration:underline; }

    .nav { display:flex; align-items:center; justify-content:space-between; padding:1rem 2rem; border-bottom:1px solid var(--border); }
    .nav-logo { font-family:'Fraunces',serif; font-weight:900; font-size:1.2rem; color:var(--green2); display:flex; align-items:center; gap:.5rem; }
    .nav-back { font-size:.83rem; font-weight:700; color:var(--soft); border:1px solid var(--border); padding:.4rem .9rem; border-radius:8px; transition:all .2s; }
    .nav-back:hover { color:var(--text); border-color:var(--green); text-decoration:none; }

    .page { max-width:760px; margin:0 auto; padding:3rem 1.5rem 5rem; }
    .page-label { font-size:.7rem; font-weight:800; letter-spacing:.12em; text-transform:uppercase; color:var(--green); margin-bottom:.75rem; }
    h1 { font-family:'Fraunces',serif; font-weight:900; font-size:clamp(2rem,4vw,2.8rem); line-height:1.1; margin-bottom:.5rem; }
    .meta { font-size:.78rem; color:var(--soft); margin-bottom:2.5rem; }

    .guarantee-banner {
      background: linear-gradient(135deg, rgba(16,185,129,.15), rgba(52,211,153,.08));
      border: 1.5px solid rgba(16,185,129,.35);
      border-radius: 20px;
      padding: 2rem;
      margin-bottom: 2rem;
      text-align: center;
    }
    .guarantee-banner .badge {
      font-size: 3rem;
      margin-bottom: .75rem;
    }
    .guarantee-banner h2 {
      font-family: 'Fraunces', serif;
      font-size: 1.5rem;
      font-weight: 900;
      color: var(--green2);
      margin-bottom: .5rem;
    }
    .guarantee-banner p {
      font-size: .95rem;
      color: rgba(223,238,221,.85);
      max-width: 480px;
      margin: 0 auto;
    }

    .section { margin-bottom:1.5rem; padding:1.5rem; background:var(--card); border:1px solid var(--border); border-radius:16px; }
    h2 { font-family:'Fraunces',serif; font-size:1.1rem; font-weight:700; color:var(--green2); margin-bottom:.75rem; }
    p { font-size:.9rem; color:rgba(223,238,221,.8); margin-bottom:.75rem; }
    p:last-child { margin-bottom:0; }
    ol, ul { padding-left:1.25rem; margin:.5rem 0; }
    li { font-size:.9rem; color:rgba(223,238,221,.8); margin-bottom:.4rem; }
    strong { color: var(--text); }

    .steps {
      display: flex;
      flex-direction: column;
      gap: .75rem;
      margin: 1rem 0;
    }
    .step {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: .875rem 1rem;
      background: rgba(16,185,129,.06);
      border: 1px solid rgba(16,185,129,.12);
      border-radius: 12px;
    }
    .step-num {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--green), var(--green2));
      color: #fff;
      font-size: .78rem;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .step-text { font-size: .88rem; color: rgba(223,238,221,.85); line-height: 1.55; }
    .step-text strong { color: var(--text); }

    .warning {
      background: rgba(245,158,11,.08);
      border: 1px solid rgba(245,158,11,.25);
      border-radius: 10px;
      padding: .875rem 1rem;
      font-size: .85rem;
      color: rgba(245,158,11,.9);
      margin-top: .75rem;
    }

    .contact-box {
      background: rgba(16,185,129,.06);
      border: 1px solid rgba(16,185,129,.2);
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      text-align: center;
      margin-top: 1rem;
    }
    .contact-box p { font-size: .88rem; margin-bottom: .5rem; }
    .contact-box a {
      display: inline-block;
      background: var(--green);
      color: #fff;
      padding: .55rem 1.5rem;
      border-radius: 10px;
      font-weight: 700;
      font-size: .88rem;
      text-decoration: none;
      transition: opacity .15s;
    }
    .contact-box a:hover { opacity: .88; text-decoration: none; }

    .footer { text-align:center; padding:2rem; border-top:1px solid var(--border); font-size:.78rem; color:var(--soft); }
    .footer a { color: var(--soft); margin: 0 .5rem; }
    .footer a:hover { color: var(--text); }
  </style>
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo">🥑 KetoJourney</a>
  <a href="/" class="nav-back">← Back to Home</a>
</nav>

<div class="page">
  <div class="page-label">Legal</div>
  <h1>Refund Policy</h1>
  <p class="meta">Last updated: {lastUpdated}</p>

  <!-- Guarantee Banner -->
  <div class="guarantee-banner">
    <div class="badge">🛡️</div>
    <h2>30-Day Money-Back Guarantee</h2>
    <p>We believe in KetoJourney. If you're not satisfied for any reason within 30 days of purchase, we'll refund you in full — no questions asked.</p>
  </div>

  <!-- Eligibility -->
  <div class="section">
    <h2>1. Eligibility</h2>
    <p>You are eligible for a full refund if:</p>
    <ul>
      <li>Your refund request is submitted <strong>within 30 days</strong> of your original purchase date</li>
      <li>You purchased directly through <strong>ketojourney.fun</strong></li>
      <li>You have not previously received a refund for the same account</li>
    </ul>
    <p>All three plans — Basic (30 days), Pro (90 days), and Elite (360 days) — are covered by this guarantee.</p>
  </div>

  <!-- How to Request -->
  <div class="section">
    <h2>2. How to Request a Refund</h2>
    <p>The process takes less than 5 minutes:</p>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-text">Email us at <strong>support@ketojourney.fun</strong> with the subject line: <strong>"Refund Request"</strong></div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-text">Include your <strong>registered email address</strong> and <strong>order confirmation number</strong> (found in your LemonSqueezy receipt email)</div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-text">We will confirm receipt within <strong>1 business day</strong> and process the refund within <strong>5–10 business days</strong></div>
      </div>
    </div>
    <div class="warning">
      ⚠️ Refund requests submitted after 30 days of purchase are not eligible, unless required by applicable consumer protection law in your jurisdiction (e.g., EU Consumer Rights Directive).
    </div>
  </div>

  <!-- Processing -->
  <div class="section">
    <h2>3. Processing & Timeline</h2>
    <p>Once approved, refunds are issued to your <strong>original payment method</strong> (credit/debit card or PayPal, depending on how you paid).</p>
    <ul>
      <li><strong>Processing time:</strong> 5–10 business days after approval</li>
      <li><strong>Bank processing:</strong> An additional 3–5 business days may be required by your bank</li>
      <li><strong>Currency:</strong> Refunds are issued in USD at the original transaction amount</li>
    </ul>
    <p>We do not offer partial refunds or store credit. Refunds are always in full.</p>
  </div>

  <!-- After Refund -->
  <div class="section">
    <h2>4. Account Access After Refund</h2>
    <p>Once a refund is processed:</p>
    <ul>
      <li>Your account will be downgraded to inactive status immediately</li>
      <li>Your progress data, meal logs, and measurements are retained for 30 days, then permanently deleted</li>
      <li>You may create a new account and purchase again at any time</li>
    </ul>
  </div>

  <!-- Exceptions -->
  <div class="section">
    <h2>5. Exceptions & Special Circumstances</h2>
    <p>We will always work with you if something went wrong. Contact us if:</p>
    <ul>
      <li>You were charged twice for the same order</li>
      <li>Your account was not activated after payment</li>
      <li>You experienced a technical issue that prevented you from using the service</li>
    </ul>
    <p>In these cases, we will resolve the issue immediately — refund, credit, or account fix, whichever you prefer.</p>
  </div>

  <!-- Contact -->
  <div class="section">
    <h2>6. Contact Us</h2>
    <p>Questions about this policy or need help with a refund?</p>
    <div class="contact-box">
      <p>Our support team typically responds within 1–2 business days.</p>
      <a href="mailto:support@ketojourney.fun?subject=Refund Request">Email Support →</a>
    </div>
    <p style="margin-top:1rem;">You can also review our full <a href="/terms">Terms of Service</a> and <a href="/privacy-policy">Privacy Policy</a>.</p>
  </div>

</div>

<footer class="footer">
  <p>© 2026 KetoJourney · <a href="/privacy-policy">Privacy Policy</a> · <a href="/terms">Terms of Service</a> · <a href="/refund-policy">Refund Policy</a></p>
</footer>

<CookieConsent />
</body>
</html>
