---
// src/components/Sidebar.astro

interface Props {
  userName:   string;
  planType:   string;
  tierLabel:  string;   // accepted from pages; not used in template
  currentDay: number;
  activePage?: string;
}

const { userName, planType, currentDay, activePage = '' } = Astro.props;
const isElite  = planType === 'elite_12';
const initial  = (userName[0] || 'U').toUpperCase();
const tierMono = planType === 'elite_12' ? 'ELITE' : planType === 'pro_6' ? 'PRO' : 'BASIC';

const nav = [
  { href: '/dashboard',          id: 'dashboard', label: 'Today',    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>' },
  { href: '/dashboard/food-log', id: 'food-log',  label: 'Meals',    icon: '<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>' },
  { href: '/dashboard/fasting',  id: 'fasting',   label: 'Fasting',  icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
  { href: '/dashboard/progress', id: 'progress',  label: 'Progress', icon: '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>' },
  { href: '/dashboard/recipes',  id: 'recipes',   label: 'Recipes',  icon: '<path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>' },
  { href: '/dashboard/habits',   id: 'habits',    label: 'Habits',   icon: '<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>' },
  { href: '/dashboard/shopping', id: 'shopping',  label: 'Shopping', icon: '<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>' },
];

const activeMap: Record<string, string> = {
  'food-photo': 'food-log', 'food-log': 'food-log',
  'recipe': 'recipes', 'recipes': 'recipes', 'favorites': 'recipes', 'collections': 'recipes',
  'meal-planner': 'recipes', 'scanner': 'recipes',
  'checkin': 'progress', 'photos': 'progress', 'ketones': 'progress', 'steps': 'progress',
  'reflections': 'progress', 'share': 'progress',
  'weekly': 'shopping', 'meal-prep': 'shopping',
  'billing': 'billing', 'notification-preferences': 'notification-preferences',
  'notifications': 'notifications',
};
const activeId = activeMap[activePage] || activePage;
---

<!-- Apply saved theme before first paint (no flash) -->
<script is:inline>
(function () {
  try {
    if (localStorage.getItem('rv-theme') === 'dark')
      document.documentElement.setAttribute('data-theme', 'dark');
  } catch (e) {}
})();
</script>

<style is:global>
  /* ── Dark mode: warm dark palette ───────────────────────────
     Single override covers all dashboard pages via CSS vars.   */
  html[data-theme="dark"] {
    --rv-bg:       #0F0A08;
    --rv-bg-alt:   #1E1410;
    --rv-card:     #1A1210;
    --rv-card2:    #221814;
    --rv-line:     rgba(255, 90, 122, .13);
    --rv-ink:      #F2E8E0;
    --rv-ink-soft: #BCA090;
    --rv-muted:    #6A5248;
    --rv-accent:   #FF5C7A;
    --rv-accent-2: #B6FF3C;
    /* Legacy vars used on some pages */
    --bg:     #0F0A08;
    --card:   #1A1210;
    --card2:  #221814;
    --border: rgba(255, 90, 122, .13);
    --border2: rgba(255, 90, 122, .26);
    --text:   #F2E8E0;
    --soft:   #BCA090;
    --muted:  #6A5248;
  }
  html { transition: background-color .2s; }
</style>

<style>
  /* ── Sidebar shell ─────────────────────────────────────────── */
  .rv-sb {
    width: 232px; position: sticky; top: 0; height: 100vh;
    background: var(--rv-card, #fff);
    border-right: 1px solid var(--rv-line, #E5DED2);
    display: flex; flex-direction: column;
    padding: 20px 14px; overflow-y: auto; gap: 4px;
    z-index: 50; flex-shrink: 0;
  }

  /* ── Header row: logo + bell ──────────────────────────────── */
  .rv-sb-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px; padding: 0 4px; flex-shrink: 0;
  }
  .rv-sb-logo {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none;
  }
  .rv-logo-mark {
    width: 30px; height: 30px; border-radius: 7px; flex-shrink: 0;
    background: var(--rv-ink, #16110F);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bricolage Grotesque', system-ui, sans-serif;
    font-weight: 800; font-size: .92rem; color: var(--rv-accent-2, #B6FF3C);
  }
  .rv-logo-word {
    font-family: 'Bricolage Grotesque', system-ui, sans-serif;
    font-size: .74rem; font-weight: 500; letter-spacing: .07em;
    color: var(--rv-ink-soft, #4A4340);
  }
  .rv-logo-word strong { font-weight: 800; color: var(--rv-ink, #16110F); }

  /* ── Bell button ──────────────────────────────────────────── */
  .rv-bell-btn {
    position: relative; width: 32px; height: 32px; border-radius: 8px;
    background: transparent; border: 1px solid var(--rv-line, #E5DED2);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; text-decoration: none; flex-shrink: 0;
    color: var(--rv-ink-soft, #4A4340);
    transition: border-color .15s, background .15s;
  }
  .rv-bell-btn:hover { border-color: var(--rv-accent, #FF5C7A); background: var(--rv-bg-alt, #F2EDE5); }
  .rv-bell-ic { width: 15px; height: 15px; }
  .rv-bell-badge {
    display: none; position: absolute; top: -5px; right: -5px;
    min-width: 16px; height: 16px; border-radius: 8px;
    background: var(--rv-accent, #FF5C7A); color: #fff;
    font-size: .58rem; font-weight: 700; padding: 0 3px;
    align-items: center; justify-content: center;
    font-family: 'Bricolage Grotesque', system-ui, sans-serif; line-height: 1;
  }
  .rv-bell-badge.visible { display: flex; }

  /* ── Nav items ─────────────────────────────────────────────── */
  .rv-sb-nav { display: flex; flex-direction: column; gap: 2px; }
  .rv-ni {
    display: flex; align-items: center; gap: 11px;
    padding: 9px 12px; border-radius: 10px; text-decoration: none;
    font-family: 'Bricolage Grotesque', system-ui, sans-serif;
    font-size: .84rem; font-weight: 500;
    color: var(--rv-ink-soft, #4A4340); transition: all .15s;
  }
  .rv-ni:hover { background: var(--rv-bg-alt, #F2EDE5); color: var(--rv-ink, #16110F); }
  .rv-ni--active { background: var(--rv-ink, #16110F); color: var(--rv-bg, #FAF6F1) !important; }
  .rv-ni--active .rv-ni-ic { color: var(--rv-accent-2, #B6FF3C); }
  .rv-ni--elite .rv-ni-ic { color: var(--rv-accent, #FF5C7A); }
  .rv-ni-ic { width: 17px; height: 17px; flex-shrink: 0; }

  /* ── Section divider ───────────────────────────────────────── */
  .rv-sb-section {
    font-family: 'Bricolage Grotesque', system-ui, sans-serif;
    font-size: .62rem; font-weight: 700; letter-spacing: .1em;
    color: var(--rv-muted, #8A8077); text-transform: uppercase;
    padding: 12px 12px 4px; margin-top: 4px;
  }

  /* ── Bottom: dark-mode toggle + user chip ─────────────────── */
  .rv-sb-fill { flex: 1; min-height: 16px; }
  .rv-sb-bottom { display: flex; flex-direction: column; gap: 8px; flex-shrink: 0; }

  .rv-theme-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 6px 12px;
  }
  .rv-theme-lbl {
    font-family: 'Bricolage Grotesque', system-ui, sans-serif;
    font-size: .78rem; font-weight: 500; color: var(--rv-ink-soft, #4A4340);
  }
  .rv-theme-pill {
    position: relative; width: 40px; height: 22px;
    background: var(--rv-line, #E5DED2); border-radius: 11px;
    border: none; cursor: pointer; padding: 0; transition: background .2s; flex-shrink: 0;
  }
  .rv-theme-pill.on { background: var(--rv-accent, #FF5C7A); }
  .rv-theme-pill::after {
    content: ''; position: absolute; top: 3px; left: 3px;
    width: 16px; height: 16px; border-radius: 50%; background: #fff;
    transition: transform .2s; box-shadow: 0 1px 3px rgba(0,0,0,.2);
  }
  .rv-theme-pill.on::after { transform: translateX(18px); }

  .rv-sb-user {
    display: flex; align-items: center; gap: 10px; padding: 10px 12px;
    border-radius: 10px; text-decoration: none;
    border: 1px solid var(--rv-line, #E5DED2); transition: border-color .15s;
  }
  .rv-sb-user:hover { border-color: var(--rv-accent, #FF5C7A); }
  .rv-sb-avatar {
    width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
    background: var(--rv-accent, #FF5C7A); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bricolage Grotesque', system-ui, sans-serif;
    font-weight: 700; font-size: .88rem;
  }
  .rv-sb-info { display: flex; flex-direction: column; min-width: 0; }
  .rv-sb-name { font-family: 'Bricolage Grotesque', system-ui, sans-serif; font-size: .82rem; font-weight: 600; color: var(--rv-ink, #16110F); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .rv-sb-plan { font-size: .67rem; letter-spacing: .07em; color: var(--rv-muted, #8A8077); font-family: 'Geist Mono', monospace; margin-top: 1px; }

  /* ── Mobile bottom nav ─────────────────────────────────────── */
  .rv-mobnav {
    display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
    background: var(--rv-card, #fff); border-top: 1px solid var(--rv-line, #E5DED2);
    padding: 6px 0 max(6px, env(safe-area-inset-bottom));
  }
  .rv-mobnav-inner { display: flex; justify-content: space-around; }
  .rv-mn {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    padding: 4px 12px; text-decoration: none;
    font-family: 'Bricolage Grotesque', system-ui, sans-serif;
    font-size: .6rem; font-weight: 500; letter-spacing: .03em;
    color: var(--rv-ink-soft, #4A4340); transition: color .15s;
  }
  .rv-mn:hover, .rv-mn.active { color: var(--rv-accent, #FF5C7A); }
  .rv-mn-ic { width: 20px; height: 20px; }

  @media (max-width: 900px) {
    .rv-sb { display: none; }
    .rv-mobnav { display: block; }
  }
</style>

<!-- Desktop sidebar -->
<aside class="rv-sb">

  <!-- Header: logo + notifications bell -->
  <div class="rv-sb-head">
    <a href="/dashboard" class="rv-sb-logo">
      <span class="rv-logo-mark">K</span>
      <span class="rv-logo-word">KETO<strong>JOURNEY</strong></span>
    </a>
    <a href="/dashboard/notifications" class="rv-bell-btn" aria-label="Notifications">
      <svg class="rv-bell-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 01-3.46 0"/>
      </svg>
      <span class="rv-bell-badge" id="rvNotifBadge"></span>
    </a>
  </div>

  <!-- Main navigation -->
  <nav class="rv-sb-nav">
    {nav.map(item => (
      <a href={item.href} class={`rv-ni${activeId === item.id ? ' rv-ni--active' : ''}`}>
        <svg class="rv-ni-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon}></svg>
        <span>{item.label}</span>
      </a>
    ))}
    {isElite && (
      <a href="/dashboard/ai-coach" class={`rv-ni rv-ni--elite${activePage === 'ai-coach' ? ' rv-ni--active' : ''}`}>
        <svg class="rv-ni-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span>AI Coach</span>
      </a>
    )}
    <a href="/dashboard/profile" class={`rv-ni${activePage === 'profile' ? ' rv-ni--active' : ''}`}>
      <svg class="rv-ni-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <span>Profile</span>
    </a>
  </nav>

  <!-- Settings section -->
  <div class="rv-sb-section">Settings</div>
  <nav class="rv-sb-nav">
    <!-- Language -->
    <a href="/dashboard/profile#language" class={`rv-ni${activePage === 'profile' && false ? ' rv-ni--active' : ''}`}>
      <svg class="rv-ni-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
      <span>Language</span>
    </a>
    <!-- Notification preferences -->
    <a href="/dashboard/notification-preferences" class={`rv-ni${activePage === 'notification-preferences' ? ' rv-ni--active' : ''}`}>
      <svg class="rv-ni-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      <span>Alerts</span>
    </a>
    <!-- Billing -->
    <a href="/dashboard/billing" class={`rv-ni${activePage === 'billing' ? ' rv-ni--active' : ''}`}>
      <svg class="rv-ni-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
      <span>Billing</span>
    </a>
  </nav>

  <div class="rv-sb-fill"></div>

  <div class="rv-sb-bottom">
    <!-- Dark mode toggle -->
    <div class="rv-theme-row">
      <span class="rv-theme-lbl" id="rvThemeLbl">Light mode</span>
      <button class="rv-theme-pill" id="rvThemePill" aria-label="Toggle dark mode"></button>
    </div>
    <!-- User chip -->
    <a href="/dashboard/profile" class="rv-sb-user">
      <div class="rv-sb-avatar">{initial}</div>
      <div class="rv-sb-info">
        <span class="rv-sb-name">{userName}</span>
        <span class="rv-sb-plan">{tierMono} · DAY {currentDay}</span>
      </div>
    </a>
  </div>
</aside>

<script is:inline>
(function () {
  /* ── Dark mode toggle ─────────────────────────────────────── */
  var pill = document.getElementById('rvThemePill');
  var lbl  = document.getElementById('rvThemeLbl');
  var dark = document.documentElement.getAttribute('data-theme') === 'dark';

  function applyTheme(d) {
    dark = d;
    if (d) {
      document.documentElement.setAttribute('data-theme', 'dark');
      if (pill) pill.classList.add('on');
      if (lbl)  lbl.textContent = 'Dark mode';
    } else {
      document.documentElement.removeAttribute('data-theme');
      if (pill) pill.classList.remove('on');
      if (lbl)  lbl.textContent = 'Light mode';
    }
    try { localStorage.setItem('rv-theme', d ? 'dark' : 'light'); } catch (e) {}
  }

  applyTheme(dark); // sync pill state on load
  if (pill) pill.addEventListener('click', function () { applyTheme(!dark); });

  /* ── Notification badge ───────────────────────────────────── */
  var CACHE_KEY = 'rv_notif_count';
  var CACHE_TTL = 30000;
  function updateBadge(n) {
    var b = document.getElementById('rvNotifBadge');
    if (!b) return;
    if (n > 0) { b.textContent = n > 99 ? '99+' : n; b.classList.add('visible'); }
    else { b.classList.remove('visible'); }
  }
  try {
    var c = JSON.parse(sessionStorage.getItem(CACHE_KEY) || 'null');
    if (c && Date.now() - c.ts < CACHE_TTL) { updateBadge(c.count); return; }
  } catch (e) {}
  fetch('/api/notifications?limit=1', { credentials: 'same-origin' })
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (d) {
      if (!d) return;
      updateBadge(d.unreadCount || 0);
      try { sessionStorage.setItem(CACHE_KEY, JSON.stringify({ count: d.unreadCount || 0, ts: Date.now() })); } catch (e) {}
    }).catch(function () {});
})();
</script>

<!-- Mobile bottom nav -->
<nav class="rv-mobnav">
  <div class="rv-mobnav-inner">
    <a href="/dashboard" class={`rv-mn${activeId === 'dashboard' ? ' active' : ''}`}>
      <svg class="rv-mn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span>Today</span>
    </a>
    <a href="/dashboard/progress" class={`rv-mn${activeId === 'progress' ? ' active' : ''}`}>
      <svg class="rv-mn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
      <span>Progress</span>
    </a>
    <a href="/dashboard/food-log" class={`rv-mn${activeId === 'food-log' ? ' active' : ''}`}>
      <svg class="rv-mn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
      <span>Meals</span>
    </a>
    <a href="/dashboard/recipes" class={`rv-mn${activeId === 'recipes' ? ' active' : ''}`}>
      <svg class="rv-mn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
      <span>Recipes</span>
    </a>
    <a href="/dashboard/profile" class={`rv-mn${activePage === 'profile' ? ' active' : ''}`}>
      <svg class="rv-mn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <span>Profile</span>
    </a>
  </div>
</nav>
