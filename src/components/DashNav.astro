---
// src/components/DashNav.astro — Rose Vital redesign 2026-04-27
// Shared navigation + global design tokens for ALL dashboard pages.

import NotificationsBell from './NotificationsBell.astro';
import CookieConsent from './CookieConsent.astro';
import { getTranslator, normaliseLang } from '../lib/i18n';
import Home         from 'lucide-astro/Home';
import ChevronDown  from 'lucide-astro/ChevronDown';
import Sparkles     from 'lucide-astro/Sparkles';
import Users        from 'lucide-astro/Users';
import Zap          from 'lucide-astro/Zap';
import Moon         from 'lucide-astro/Moon';
import Sun          from 'lucide-astro/Sun';
import Activity     from 'lucide-astro/Activity';
import Utensils     from 'lucide-astro/Utensils';
import ClipboardList from 'lucide-astro/ClipboardList';
import User         from 'lucide-astro/User';
import HelpCircle   from 'lucide-astro/HelpCircle';
import Crown        from 'lucide-astro/Crown';
import Leaf         from 'lucide-astro/Leaf';

interface Props {
  userId:    string;
  userName:  string;
  tierLabel: string;
  planType:  string;
  activePage?: string;
}

const { userId, userName, tierLabel, planType, activePage = '' } = Astro.props;

const lang = normaliseLang(Astro.cookies.get('keto-lang')?.value);
const t    = getTranslator(lang);

const initials  = (userName[0] || 'U').toUpperCase();
const tierCss   = planType === 'elite_12' ? 'dn-tier dn-tier--elite' : planType === 'pro_6' ? 'dn-tier dn-tier--pro' : 'dn-tier dn-tier--basic';

const progressPages = ['progress', 'photos', 'checkin', 'reflections', 'ketones', 'share', 'steps'];
const mealPages     = ['recipes', 'food-log', 'food-photo', 'favorites', 'collections', 'meal-prep', 'scanner'];
const planPages     = ['shopping', 'habits', 'weekly', 'fasting', 'keto-calculator', 'meal-planner'];
const morePages     = ['learn', 'notifications', 'export', 'referrals', 'guide', 'billing'];

const activeGroup =
  activePage === 'dashboard'          ? 'today'     :
  progressPages.includes(activePage)  ? 'progress'  :
  mealPages.includes(activePage)      ? 'meals'     :
  planPages.includes(activePage)      ? 'plan'      :
  morePages.includes(activePage)      ? 'more'      :
  activePage === 'profile'            ? 'profile'   :
  activePage === 'ai-coach'           ? 'ai-coach'  :
  activePage === 'community'          ? 'community' :
  '';

const groups = [
  {
    key: 'progress', label: t('nav.progress'),
    links: [
      { href: '/dashboard/progress',    key: 'progress',    label: t('nav.progress_page') },
      { href: '/dashboard/photos',      key: 'photos',      label: t('nav.photos')        },
      { href: '/dashboard/checkin',     key: 'checkin',     label: t('nav.checkin')       },
      { href: '/dashboard/reflections', key: 'reflections', label: t('nav.reflections')   },
      { href: '/dashboard/ketones',     key: 'ketones',     label: t('nav.ketones')       },
      { href: '/dashboard/share',       key: 'share',       label: t('nav.share')         },
      { href: '/dashboard/steps',       key: 'steps',       label: t('nav.steps')         },
    ],
  },
  {
    key: 'meals', label: t('nav.meals'),
    links: [
      { href: '/dashboard/recipes',   key: 'recipes',   label: t('nav.recipes')   },
      { href: '/dashboard/food-log',   key: 'food-log',   label: t('nav.food_log')    },
      { href: '/dashboard/food-photo', key: 'food-photo', label: t('nav.food_photo')  },
      { href: '/dashboard/favorites',    key: 'favorites',    label: t('nav.favorites')     },
      { href: '/dashboard/collections',  key: 'collections',  label: 'Collections'          },
      { href: '/dashboard/meal-prep',    key: 'meal-prep',    label: t('nav.meal_prep')     },
      { href: '/dashboard/scanner',   key: 'scanner',   label: t('nav.scanner')   },
    ],
  },
  {
    key: 'plan', label: t('nav.plan'),
    links: [
      { href: '/dashboard/meal-planner',     key: 'meal-planner',    label: 'Meal Planner'      },
      { href: '/dashboard/shopping',        key: 'shopping',        label: t('nav.shopping')   },
      { href: '/dashboard/habits',          key: 'habits',          label: t('nav.habits')     },
      { href: '/dashboard/weekly',          key: 'weekly',          label: t('nav.weekly')     },
      { href: '/dashboard/fasting',         key: 'fasting',         label: t('nav.fasting')    },
      { href: '/dashboard/keto-calculator', key: 'keto-calculator', label: t('nav.calculator') },
    ],
  },
  {
    key: 'more', label: t('nav.more'),
    links: [
      { href: '/dashboard/guide',          key: 'guide',          label: t('nav.guide')          },
      { href: '/dashboard/learn',          key: 'learn',          label: t('nav.learn')          },
      { href: '/dashboard/notifications',  key: 'notifications',  label: t('nav.notifications')  },
      { href: '/dashboard/export',         key: 'export',         label: t('nav.export')         },
      { href: '/dashboard/referrals',      key: 'referrals',      label: t('nav.referrals')      },
      { href: '/dashboard/billing',        key: 'billing',        label: t('nav.billing')        },
    ],
  },
];
---

<!-- ══ ANTI-FLASH: apply stored theme before first paint ══ -->
<script is:inline>
(function(){
  var t = localStorage.getItem('keto-theme') || 'light';
  document.documentElement.setAttribute('data-theme', t);
})();
</script>

<!-- ══ GOOGLE ANALYTICS ════════════════════════════════════ -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-JRQ61VBZ4N"></script>
<script is:inline>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', 'G-JRQ61VBZ4N');
</script>

<!-- ══ TOP NAV ═══════════════════════════════════════════════ -->
<nav class="dash-nav">

  <!-- Logo -->
  <a href="/dashboard" class="dn-logo">
    <div class="dn-logo-mark">
      <span class="dn-logo-k">K</span>
    </div>
    <span class="dn-logo-text">KETO<strong>JOURNEY</strong></span>
  </a>

  <!-- ── Desktop pill tabs ───────────────────────────────── -->
  <ul class="dn-tabs" id="dnLinks">

    <!-- Today (direct link) -->
    <li>
      <a href="/dashboard" class={`dn-tab${activeGroup === 'today' ? ' active' : ''}`}>
        <Home size={13} />
        {t('nav.today')}
      </a>
    </li>

    <!-- Dropdown groups -->
    {groups.map(group => (
      <li class="dn-group" data-group={group.key}>
        <button
          class={`dn-tab${activeGroup === group.key ? ' active' : ''}`}
          onclick={`window.dnToggle('${group.key}', this)`}
          aria-expanded="false"
          aria-haspopup="true"
        >
          {group.label}
          <ChevronDown size={12} class="dn-caret" />
        </button>
        <div class="dn-drop" id={`dn-drop-${group.key}`} role="menu">
          {group.links.map(link => (
            <a
              href={link.href}
              class={`dn-drop-link${activePage === link.key ? ' active' : ''}`}
              role="menuitem"
            >
              {link.label}
            </a>
          ))}
        </div>
      </li>
    ))}

    <!-- AI Coach + Community (Elite only; locked buttons for others) -->
    {planType === 'elite_12' && (
      <li>
        <a href="/dashboard/ai-coach"
          class={`dn-tab dn-elite${activePage === 'ai-coach' ? ' active' : ''}`}>
          <Sparkles size={13} />
          {t('nav.ai_coach')}
        </a>
      </li>
    )}
    {planType !== 'elite_12' && (
      <li>
        <button
          class="dn-tab dn-locked"
          onclick="window.showFeatureUpsell && window.showFeatureUpsell('ai-coach')"
          title="Elite only">
          <Sparkles size={13} />
          {t('nav.ai_coach')} 🔒
        </button>
      </li>
    )}
    {(planType === 'elite_12' || planType === 'pro_6') && (
      <li>
        <a href="/dashboard/community"
          class={`dn-tab dn-elite${activePage === 'community' ? ' active' : ''}`}>
          <Users size={13} />
          {t('nav.community')}
        </a>
      </li>
    )}
    {planType === 'basic_30' && (
      <li>
        <button
          class="dn-tab dn-locked"
          onclick="window.showFeatureUpsell && window.showFeatureUpsell('community')"
          title="Pro & Elite only">
          <Users size={13} />
          {t('nav.community')} 🔒
        </button>
      </li>
    )}

    <!-- Upgrade (non-Elite) -->
    {planType === 'basic_30' && (
      <li>
        <a href="/dashboard/upgrade"
          class={`dn-tab dn-upgrade${activePage === 'upgrade' ? ' active' : ''}`}>
          <Zap size={13} />
          {t('nav.upgrade')}
        </a>
      </li>
    )}
    {planType === 'pro_6' && (
      <li>
        <a href="/dashboard/upgrade"
          class={`dn-tab dn-upgrade dn-upgrade--elite${activePage === 'upgrade' ? ' active' : ''}`}>
          <Zap size={13} />
          {t('nav.upgrade_elite')}
        </a>
      </li>
    )}
  </ul>

  <div class="dn-sp"></div>

  <!-- ── Right controls ─────────────────────────────────── -->
  <div class="dn-right">

    <a href="/dashboard/food-log" class="dn-quick-log">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Quick log
    </a>

    <span class={tierCss}>
      {planType === 'elite_12' && <Crown size={10} />}
      {planType === 'pro_6'    && <Zap   size={10} />}
      {planType === 'basic_30' && <Leaf  size={10} />}
      {planType === 'elite_12' ? 'Elite' : planType === 'pro_6' ? 'Pro' : 'Basic'}
    </span>

    <button class="dn-icon-btn" id="dnThemeBtn" title="Toggle theme" aria-label="Toggle theme">
      <Moon size={15} class="icon-moon" />
      <Sun  size={15} class="icon-sun"  />
    </button>

    <NotificationsBell userId={userId} />

    <a href="/dashboard/profile" class="dn-avatar" title={userName}>
      {initials}
    </a>
  </div>
</nav>

<!-- ══ MOBILE BOTTOM NAV ══════════════════════════════════ -->
<nav class="dn-bottom" aria-label="Mobile navigation">
  <a href="/dashboard" class={`dn-bn${activeGroup === 'today' ? ' active' : ''}`}>
    <Home size={20} /><span>{t('nav.today')}</span>
  </a>
  <a href="/dashboard/progress" class={`dn-bn${activeGroup === 'progress' ? ' active' : ''}`}>
    <Activity size={20} /><span>{t('nav.progress')}</span>
  </a>
  <a href="/dashboard/recipes" class={`dn-bn${activeGroup === 'meals' ? ' active' : ''}`}>
    <Utensils size={20} /><span>{t('nav.meals')}</span>
  </a>
  <a href="/dashboard/shopping" class={`dn-bn${activeGroup === 'plan' ? ' active' : ''}`}>
    <ClipboardList size={20} /><span>{t('nav.plan')}</span>
  </a>
  <a href="/dashboard/profile" class={`dn-bn${activeGroup === 'profile' ? ' active' : ''}`}>
    <User size={20} /><span>{t('nav.profile')}</span>
  </a>
</nav>

<CookieConsent />

<!-- ══ STYLES ════════════════════════════════════════════════ -->
<style>
/* ═══════════════════════════════════════════════════════════════
   ROSE VITAL — GLOBAL DESIGN TOKEN SYSTEM
   Strategy: html:not([data-theme="dark"]) = specificity [0,1,1]
   beats any page's :root [0,1,0], so light values always win.
   ═══════════════════════════════════════════════════════════════ */

/* ── Shape / spacing tokens (theme-independent) ── */
:root {
  --nav-h:     60px;
  --r-xs:      6px;
  --r-sm:      10px;
  --r:         16px;
  --r-lg:      22px;
  --r-xl:      28px;
  --r-full:    9999px;

  /* Rose Vital brand tokens — always available */
  --rv-ink:        #16110F;
  --rv-ink-soft:   #4A4340;
  --rv-ink-muted:  #9B9390;
  --rv-bg:         #FAF6F1;
  --rv-bg-alt:     #F2EDE5;
  --rv-card:       #FFFFFF;
  --rv-border:     rgba(22,17,15,.08);
  --rv-border-2:   rgba(22,17,15,.16);
  --rv-accent:     #FF5C7A;
  --rv-accent-2:   #B6FF3C;
  --rv-accent-3:   #FF914D;
}

/* ── LIGHT theme (Rose Vital) ─────────────────────────────── */
html:not([data-theme="dark"]) {
  --bg:          #FAF6F1;
  --bg2:         #F2EDE5;
  --card:        #FFFFFF;
  --card2:       #F8F4EF;
  --border:      rgba(22,17,15,.08);
  --border2:     rgba(255,92,122,.25);
  --text:        #16110F;
  --soft:        #4A4340;
  --muted:       #E5DDD5;
  --green:       #16a34a;
  --green2:      #22c55e;
  --green3:      #4ade80;
  --green-bg:    #f0fdf4;
  --green-ring:  rgba(22,163,74,.15);
  --amber:       #f59e0b;
  --amber2:      #fbbf24;
  --amber-bg:    #fffbeb;
  --gold:        #f59e0b;
  --red:         #ef4444;
  --red-bg:      #fef2f2;
  --purple:      #8b5cf6;
  --purple2:     #a78bfa;
  --purple-bg:   #faf5ff;
  --blue:        #3b82f6;
  --blue2:       #60a5fa;
  --blue-bg:     #eff6ff;
  --cyan:        #06b6d4;
  --cyan-bg:     #ecfeff;
  --shadow-xs:   0 1px 2px rgba(0,0,0,.04);
  --shadow-sm:   0 1px 4px rgba(0,0,0,.06), 0 2px 8px rgba(0,0,0,.03);
  --shadow:      0 4px 20px rgba(0,0,0,.06), 0 2px 6px rgba(0,0,0,.03);
  --shadow-lg:   0 8px 32px rgba(0,0,0,.08), 0 4px 12px rgba(0,0,0,.04);
  --shadow-xl:   0 20px 60px rgba(0,0,0,.09), 0 8px 20px rgba(0,0,0,.05);
}

/* ── DARK theme override ──────────────────────────────────── */
[data-theme="dark"] {
  --bg:          #130E0C;
  --bg2:         #1C1613;
  --card:        #1F1916;
  --card2:       #261E1A;
  --border:      rgba(255,255,255,.07);
  --border2:     rgba(255,92,122,.25);
  --text:        #F5EDE4;
  --soft:        #7A6D68;
  --muted:       #352B27;
  --green:       #10b981;
  --green2:      #34d399;
  --green3:      #6ee7b7;
  --green-bg:    rgba(16,185,129,.1);
  --green-ring:  rgba(16,185,129,.15);
  --amber:       #f59e0b;
  --amber2:      #fbbf24;
  --amber-bg:    rgba(245,158,11,.1);
  --gold:        #f59e0b;
  --red:         #ef4444;
  --red-bg:      rgba(239,68,68,.1);
  --purple:      #8b5cf6;
  --purple2:     #a78bfa;
  --purple-bg:   rgba(139,92,246,.1);
  --blue:        #3b82f6;
  --blue2:       #60a5fa;
  --blue-bg:     rgba(59,130,246,.1);
  --cyan:        #06b6d4;
  --cyan-bg:     rgba(6,182,212,.1);
  --shadow-xs:   0 1px 2px rgba(0,0,0,.3);
  --shadow-sm:   0 1px 4px rgba(0,0,0,.3);
  --shadow:      0 4px 16px rgba(0,0,0,.35);
  --shadow-lg:   0 8px 32px rgba(0,0,0,.4);
  --shadow-xl:   0 20px 60px rgba(0,0,0,.5);
}
[data-theme="dark"] { --rv-ink: #F5EDE4; --rv-ink-soft: #A09089; --rv-bg: #130E0C; --rv-bg-alt: #1C1613; --rv-card: #1F1916; --rv-border: rgba(255,255,255,.07); }

/* ── Hide top nav globally (sidebar replaces it) ─────────── */
.dash-nav { display: none !important; }
#dn-footer { display: none !important; }

/* ── Base reset ──────────────────────────────────────────── */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: 'Bricolage Grotesque', 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  transition: background .25s, color .25s;
}

/* ═══════════════════════════════════════════════════════════
   TOP NAV — Rose Vital
   ═══════════════════════════════════════════════════════════ */
.dash-nav {
  position: sticky; top: 0; z-index: 200;
  height: var(--nav-h);
  background: var(--card);
  border-bottom: 1px solid var(--border);
  box-shadow: 0 1px 0 var(--border);
  display: flex; align-items: center;
  padding: 0 1.25rem; gap: .75rem;
  backdrop-filter: blur(16px) saturate(1.2);
}

/* ── Logo ────────────────────────────────────────────────── */
.dn-logo {
  display: flex; align-items: center; gap: .55rem;
  text-decoration: none; flex-shrink: 0; user-select: none;
}
.dn-logo-mark {
  width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
  background: var(--rv-ink);
  display: flex; align-items: center; justify-content: center;
}
[data-theme="dark"] .dn-logo-mark { background: #FFFFFF; }
.dn-logo-k {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-size: .95rem; font-weight: 800; line-height: 1;
  color: var(--rv-accent-2);
}
[data-theme="dark"] .dn-logo-k { color: var(--rv-ink); }
.dn-logo-text {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-size: .72rem; font-weight: 500; letter-spacing: .08em;
  color: var(--soft);
}
.dn-logo-text strong { font-weight: 800; color: var(--text); letter-spacing: .06em; }

/* ── Pill tabs ───────────────────────────────────────────── */
.dn-tabs {
  display: flex; align-items: center; gap: .1rem;
  list-style: none; margin-left: .5rem;
}
@media (max-width: 900px) { .dn-tabs { display: none; } }

.dn-group { position: relative; }

.dn-tab {
  display: inline-flex; align-items: center; gap: .3rem;
  font-family: 'Bricolage Grotesque', sans-serif;
  font-size: .775rem; font-weight: 600; letter-spacing: -.01em;
  padding: .4rem .8rem; border-radius: var(--r-full);
  color: var(--soft); background: transparent;
  border: none; cursor: pointer;
  text-decoration: none; white-space: nowrap;
  transition: color .15s, background .15s;
  line-height: 1;
}
.dn-tab:hover { color: var(--text); background: var(--bg2); }

/* Active pill — ink bg + white text in light; accent in dark */
.dn-tab.active {
  background: var(--rv-ink);
  color: #FFFFFF;
}
[data-theme="dark"] .dn-tab.active {
  background: var(--rv-accent);
  color: #FFFFFF;
}

/* Elite tabs */
.dn-tab.dn-elite { color: var(--amber); }
.dn-tab.dn-elite:hover { color: var(--amber); background: var(--amber-bg); }
.dn-tab.dn-elite.active { background: var(--amber); color: #fff; }

/* Locked feature tab */
.dn-tab.dn-locked { color: var(--soft); opacity: .6; cursor: pointer; }
.dn-tab.dn-locked:hover { color: var(--rv-accent); background: rgba(255,92,122,.07); opacity: 1; }

/* Upgrade tab */
.dn-tab.dn-upgrade {
  color: var(--rv-accent);
  border: 1.5px solid rgba(255,92,122,.3);
  background: rgba(255,92,122,.05);
}
.dn-tab.dn-upgrade:hover { background: rgba(255,92,122,.1); border-color: var(--rv-accent); }
.dn-tab.dn-upgrade.active { background: var(--rv-accent); color: #fff; border-color: var(--rv-accent); }
.dn-tab.dn-upgrade--elite {
  color: #fbbf24;
  border-color: rgba(245,158,11,.4);
  background: rgba(245,158,11,.06);
}
.dn-tab.dn-upgrade--elite:hover {
  background: rgba(245,158,11,.12);
  box-shadow: 0 0 12px rgba(245,158,11,.15);
}

/* Caret */
.dn-caret { flex-shrink: 0; transition: transform .2s; }
.dn-group.open .dn-caret { transform: rotate(180deg); }
.dn-tab svg.dn-caret { flex-shrink: 0; }
.dn-tab svg:not(.dn-caret) { flex-shrink: 0; }

/* ── Dropdown ────────────────────────────────────────────── */
.dn-drop {
  position: absolute; top: calc(100% + 6px); left: 50%;
  transform: translateX(-50%) translateY(-4px);
  min-width: 164px;
  background: #FFFFFF;
  border: 1px solid rgba(22,17,15,.09);
  border-radius: var(--r-lg);
  padding: .4rem;
  box-shadow: 0 12px 40px rgba(0,0,0,.10), 0 2px 8px rgba(0,0,0,.06);
  opacity: 0; pointer-events: none;
  transition: opacity .15s ease, transform .15s ease;
  z-index: 300;
}
:global([data-theme="dark"]) .dn-drop {
  background: #1F1916;
  border: 1px solid rgba(255,255,255,.09);
  box-shadow: 0 12px 40px rgba(0,0,0,.5), 0 2px 8px rgba(0,0,0,.3);
}
.dn-group.open .dn-drop {
  opacity: 1; pointer-events: auto;
  transform: translateX(-50%) translateY(0);
}
.dn-drop-link {
  display: flex; align-items: center;
  padding: .48rem .8rem; border-radius: var(--r-sm);
  font-family: 'Bricolage Grotesque', sans-serif;
  font-size: .775rem; font-weight: 600;
  color: var(--soft); text-decoration: none; white-space: nowrap;
  transition: color .13s, background .13s;
}
.dn-drop-link:hover { color: var(--text); background: var(--bg2); }
:global([data-theme="dark"]) .dn-drop-link:hover { color: #F5EDE4; background: rgba(255,255,255,.05); }
.dn-drop-link.active { color: var(--rv-accent); background: rgba(255,92,122,.07); }
:global([data-theme="dark"]) .dn-drop-link.active { color: var(--rv-accent); background: rgba(255,92,122,.12); }

/* ── Spacer ──────────────────────────────────────────────── */
.dn-sp { flex: 1; min-width: 0; }

/* ── Right controls ──────────────────────────────────────── */
.dn-right {
  display: flex; align-items: center; gap: .4rem; flex-shrink: 0;
}

/* Quick-log pill CTA */
.dn-quick-log {
  display: inline-flex; align-items: center; gap: .3rem;
  font-family: 'Bricolage Grotesque', sans-serif;
  font-size: .72rem; font-weight: 700; letter-spacing: -.005em;
  padding: .38rem .85rem; border-radius: var(--r-full);
