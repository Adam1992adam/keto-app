    var s = document.createElement('style');
    s.id = 'dn-footer-styles';
    s.textContent = [
      '#dn-footer{margin-top:5rem;padding:2.5rem 2rem 2rem;border-top:1px solid var(--border);background:var(--card);position:relative;overflow:hidden;}',
      '#dn-footer::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse 70% 90% at 50% 120%,var(--green-ring),transparent);pointer-events:none;}',
      '#dn-footer a{text-decoration:none;}',
      '.dnf-inner{max-width:1280px;margin:0 auto;position:relative;}',
      '.dnf-top{display:flex;align-items:flex-start;justify-content:space-between;gap:2rem;flex-wrap:wrap;padding-bottom:2rem;margin-bottom:2rem;border-bottom:1px solid var(--border);}',

      /* Brand */
      '.dnf-brand{display:flex;flex-direction:column;gap:.8rem;max-width:270px;}',
      '.dnf-logo{display:flex;align-items:center;gap:.6rem;}',
      '.dnf-logo-mark{width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,var(--green),#15803d);display:flex;align-items:center;justify-content:center;font-size:1rem;box-shadow:0 2px 10px var(--green-ring);flex-shrink:0;}',
      '.dnf-logo-name{font-family:"DM Sans",sans-serif;font-size:.95rem;font-weight:800;color:var(--text);letter-spacing:-.01em;}',
      '.dnf-tagline{font-size:.79rem;color:var(--soft);line-height:1.6;}',

      /* Trust pills */
      '.dnf-pills{display:flex;gap:.5rem;flex-wrap:wrap;}',
      '.dnf-pill{display:inline-flex;align-items:center;gap:.3rem;padding:.22rem .7rem;border-radius:999px;background:var(--green-bg);border:1px solid var(--border2);font-size:.68rem;font-weight:700;color:var(--green);}',

      /* Columns */
      '.dnf-cols{display:flex;gap:3rem;flex-wrap:wrap;}',
      '.dnf-col-title{font-size:.67rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--green);margin-bottom:.9rem;}',
      '.dnf-col-links{display:flex;flex-direction:column;gap:.6rem;}',
      '.dnf-col-links a{font-size:.8rem;font-weight:500;color:var(--soft);display:inline-flex;align-items:center;gap:.4rem;transition:color .18s,transform .18s;}',
      '.dnf-col-links a:hover{color:var(--green);transform:translateX(3px);}',

      /* Bottom bar */
      '.dnf-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;}',
      '.dnf-copy{font-size:.73rem;color:var(--soft);font-weight:500;}',
