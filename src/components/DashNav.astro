<!-- ══ SCRIPT ════════════════════════════════════════════════ -->
<script is:inline>
(function () {

  /* ── Theme toggle ─────────────────────────────────────── */
  function applyTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    localStorage.setItem('keto-theme', t);
  }

  var themeBtn = document.getElementById('dnThemeBtn');
  if (themeBtn) {
    // Ensure current theme is applied
    var stored = localStorage.getItem('keto-theme') || 'light';
    applyTheme(stored);

    themeBtn.addEventListener('click', function () {
      var cur = document.documentElement.getAttribute('data-theme') || 'light';
      applyTheme(cur === 'dark' ? 'light' : 'dark');
    });
  }

  /* ── Dropdown toggle ──────────────────────────────────── */
  window.dnToggle = function (groupKey, btn) {
    var allGroups   = document.querySelectorAll('.dn-group');
    var clickedGrp  = btn ? btn.closest('.dn-group') : null;

    allGroups.forEach(function (g) {
      if (g !== clickedGrp) {
        g.classList.remove('open');
        var b = g.querySelector('.dn-tab');
        if (b) b.setAttribute('aria-expanded', 'false');
      }
    });

    if (!clickedGrp) return;
    var isOpen = clickedGrp.classList.contains('open');
    if (isOpen) {
      clickedGrp.classList.remove('open');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    } else {
      clickedGrp.classList.add('open');
      if (btn) btn.setAttribute('aria-expanded', 'true');
    }
  };

  /* ── Close on click outside ───────────────────────────── */
  document.addEventListener('click', function (e) {
    var el = e.target, inside = false;
    while (el) {
      if (el.classList && el.classList.contains('dn-group')) { inside = true; break; }
      el = el.parentElement;
    }
    if (!inside) {
      document.querySelectorAll('.dn-group').forEach(function (g) {
        g.classList.remove('open');
        var b = g.querySelector('.dn-tab');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
    }
  });

  /* ── Close on Escape ──────────────────────────────────── */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.dn-group').forEach(function (g) {
        g.classList.remove('open');
        var b = g.querySelector('.dn-tab');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
    }
  });

  /* ── Global fetch interceptor — auto-refresh expired tokens */
  (function () {
    var _fetch = window.fetch.bind(window);
    var _refreshing = false;

    window.fetch = function (input, init) {
      var url = typeof input === 'string' ? input
        : (input instanceof Request ? input.url : '');
      if (url.indexOf('/api/auth/') !== -1) return _fetch(input, init);

      return _fetch(input, init).then(function (res) {
        if (res.status !== 401) return res;
        if (_refreshing) { window.location.href = '/login'; return res; }
        _refreshing = true;
        return _fetch('/api/auth/refresh', { method: 'POST' })
          .then(function (ref) {
            _refreshing = false;
            if (!ref.ok) { window.location.href = '/login'; return res; }
            return _fetch(input, init);
          })
          .catch(function () {
            _refreshing = false;
            window.location.href = '/login';
            return res;
          });
      });
    };
  })();

  /* ── Service Worker + PWA ────────────────────────────── */
  (function () {
    if (!('serviceWorker' in navigator)) return;

    /* Inject manifest link if not already present */
    if (!document.querySelector('link[rel="manifest"]')) {
      var ml = document.createElement('link');
      ml.rel  = 'manifest';
      ml.href = '/manifest.webmanifest';
      document.head.appendChild(ml);
    }

    /* Register SW */
    navigator.serviceWorker.register('/sw.js').then(function (reg) {
      /* Check for SW update on page focus */
      document.addEventListener('visibilitychange', function () {
        if (document.visibilityState === 'visible') reg.update();
      });

      /* Notify user when new SW is waiting */
      reg.addEventListener('updatefound', function () {
        var newWorker = reg.installing;
        if (!newWorker) return;
        newWorker.addEventListener('statechange', function () {
          if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
            showUpdateToast(newWorker);
          }
        });
      });
    }).catch(function (err) {
      console.warn('SW registration failed:', err);
    });

    /* Listen for sync-complete messages from SW */
    navigator.serviceWorker.addEventListener('message', function (e) {
      if (e.data && e.data.type === 'SYNC_COMPLETE' && e.data.replayed > 0) {
        showToast('✓ ' + e.data.replayed + ' offline action(s) synced', 'green');
      }
    });

    /* Online/offline indicator */
    function updateOnlineStatus() {
      var bar = document.getElementById('offlineBar');
      if (!bar) {
        bar = document.createElement('div');
        bar.id = 'offlineBar';
        bar.style.cssText = [
          'position:fixed;top:0;left:0;right:0;z-index:9999',
          'padding:.45rem 1rem;text-align:center',
          'font-size:.78rem;font-weight:700;letter-spacing:.02em',
          'transition:transform .25s ease',
        ].join(';');
        document.body.appendChild(bar);
      }
      if (navigator.onLine) {
        bar.style.background = '#10b981';
        bar.style.color      = '#fff';
        bar.textContent      = '✓ Back online';
        bar.style.transform  = 'translateY(0)';
        setTimeout(function () { bar.style.transform = 'translateY(-100%)'; }, 2500);
      } else {
        bar.style.background = '#ef4444';
        bar.style.color      = '#fff';
        bar.textContent      = '⚠ You\'re offline — some features may be unavailable';
        bar.style.transform  = 'translateY(0)';
      }
    }
    window.addEventListener('online',  updateOnlineStatus);
    window.addEventListener('offline', updateOnlineStatus);
    if (!navigator.onLine) updateOnlineStatus();
  })();

  /* ── Update toast ─────────────────────────────────────── */
  function showUpdateToast(worker) {
    var t = document.createElement('div');
    t.style.cssText = [
      'position:fixed;bottom:80px;left:50%;transform:translateX(-50%)',
      'background:#16110F;border:1px solid rgba(255,92,122,.25)',
      'color:#F5EDE4;border-radius:14px;padding:.75rem 1.25rem',
      'font-family:"Bricolage Grotesque",sans-serif;font-size:.82rem;font-weight:600;z-index:9999',
      'display:flex;align-items:center;gap:.75rem;box-shadow:0 8px 32px rgba(0,0,0,.35)',
    ].join(';');
    t.innerHTML = '<span>↻ App updated — reload to get the latest</span>'
      + '<button onclick="this.closest(\'div\').remove()" '
      + 'style="background:#FF5C7A;color:#fff;border:none;border-radius:8px;'
      + 'padding:.3rem .75rem;cursor:pointer;font-weight:700;font-size:.78rem">Reload</button>';
    t.querySelector('button').addEventListener('click', function () {
      worker.postMessage({ type: 'SKIP_WAITING' });
      window.location.reload();
    });
    document.body.appendChild(t);
  }

  /* ── Generic toast ────────────────────────────────────── */
  function showToast(msg, color) {
    var t = document.createElement('div');
    var bg = color === 'green' ? '#FF5C7A' : '#3b82f6';
    t.style.cssText = [
      'position:fixed;bottom:80px;left:50%;transform:translateX(-50%)',
      'background:' + bg + ';color:#fff;border-radius:12px',
      'padding:.65rem 1.25rem;font-family:"Bricolage Grotesque",sans-serif;font-size:.82rem;font-weight:700',
      'z-index:9999;box-shadow:0 4px 20px rgba(0,0,0,.25)',
    ].join(';');
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(function () { t.remove(); }, 3500);
  }

  /* ── Footer injection (styles injected inline to bypass Astro scoping) ── */
  document.addEventListener('DOMContentLoaded', function() {
    if (document.getElementById('dn-footer')) return;

    /* ── Styles ── */
    var s = document.createElement('style');
    s.id = 'dn-footer-styles';
    s.textContent = [
      '#dn-footer{margin-top:5rem;padding:2.5rem 2rem 2rem;border-top:1px solid var(--border);background:var(--bg2);position:relative;overflow:hidden;}',
      '#dn-footer a{text-decoration:none;}',
      '.dnf-inner{max-width:1280px;margin:0 auto;position:relative;}',
      '.dnf-top{display:flex;align-items:flex-start;justify-content:space-between;gap:2rem;flex-wrap:wrap;padding-bottom:2rem;margin-bottom:2rem;border-bottom:1px solid var(--border);}',

      /* Brand */
      '.dnf-brand{display:flex;flex-direction:column;gap:.8rem;max-width:270px;}',
      '.dnf-logo{display:flex;align-items:center;gap:.55rem;}',
      '.dnf-logo-mark{width:32px;height:32px;border-radius:8px;background:var(--rv-ink);display:flex;align-items:center;justify-content:center;font-family:"Bricolage Grotesque",sans-serif;font-size:.9rem;font-weight:800;color:#B6FF3C;flex-shrink:0;}',
      '.dnf-logo-name{font-family:"Bricolage Grotesque",sans-serif;font-size:.85rem;font-weight:800;color:var(--text);letter-spacing:.04em;}',
      '.dnf-tagline{font-size:.79rem;color:var(--soft);line-height:1.65;}',

      /* Trust pills */
      '.dnf-pills{display:flex;gap:.5rem;flex-wrap:wrap;}',
      '.dnf-pill{display:inline-flex;align-items:center;gap:.3rem;padding:.22rem .7rem;border-radius:999px;background:rgba(255,92,122,.07);border:1px solid rgba(255,92,122,.2);font-family:"Bricolage Grotesque",sans-serif;font-size:.67rem;font-weight:700;color:var(--rv-accent);}',

      /* Columns */
      '.dnf-cols{display:flex;gap:3rem;flex-wrap:wrap;}',
      '.dnf-col-title{font-family:"Bricolage Grotesque",sans-serif;font-size:.62rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--soft);margin-bottom:.9rem;}',
      '.dnf-col-links{display:flex;flex-direction:column;gap:.6rem;}',
      '.dnf-col-links a{font-family:"Bricolage Grotesque",sans-serif;font-size:.78rem;font-weight:500;color:var(--soft);display:inline-flex;align-items:center;gap:.4rem;transition:color .16s,transform .16s;}',
      '.dnf-col-links a:hover{color:var(--rv-accent);transform:translateX(3px);}',

      /* Bottom bar */
      '.dnf-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;}',
      '.dnf-copy{font-family:"Bricolage Grotesque",sans-serif;font-size:.72rem;color:var(--soft);font-weight:500;}',
      '.dnf-copy strong{color:var(--text);}',
      '.dnf-legal{display:flex;align-items:center;gap:.5rem;}',
      '.dnf-legal a{font-family:"Bricolage Grotesque",sans-serif;font-size:.7rem;font-weight:600;color:var(--soft);transition:color .16s;}',
      '.dnf-legal a:hover{color:var(--rv-accent);}',
      '.dnf-legal-sep{font-size:.65rem;color:var(--muted);}',

      /* Mobile */
      '@media(max-width:900px){',
        '#dn-footer{margin-bottom:72px;padding:2rem 1.25rem 1.5rem;}',
        '.dnf-top{flex-direction:column;}',
        '.dnf-brand{max-width:100%;}',
        '.dnf-bottom{justify-content:center;text-align:center;}',
      '}',
    ].join('');
    document.head.appendChild(s);

    /* ── HTML ── */
    var f = document.createElement('footer');
    f.id = 'dn-footer';
    f.innerHTML = [
      '<div class="dnf-inner">',

        '<div class="dnf-top">',
          /* Brand + tagline + trust pills */
          '<div class="dnf-brand">',
            '<div class="dnf-logo">',
              '<div class="dnf-logo-mark">K</div>',
              '<span class="dnf-logo-name">KetoJourney</span>',
            '</div>',
            '<p class="dnf-tagline">Your structured keto coaching app — daily meal plans, smart tracking, and personalised guidance for a lasting transformation.</p>',
            '<div class="dnf-pills">',
              '<span class="dnf-pill">🔒 Secure Payments</span>',
