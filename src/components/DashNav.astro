<!-- ══ SCRIPT ════════════════════════════════════════════════ -->
<script is:inline>
(function () {

  /* ── Theme toggle ─────────────────────────────────────── */
  function applyTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    localStorage.setItem('keto-theme', t);
  }

  var themeBtn = document.getElementById('dnThemeBtn');
  if (themeBtn) {
    // Ensure current theme is applied
    var stored = localStorage.getItem('keto-theme') || 'light';
    applyTheme(stored);

    themeBtn.addEventListener('click', function () {
      var cur = document.documentElement.getAttribute('data-theme') || 'light';
      applyTheme(cur === 'dark' ? 'light' : 'dark');
    });
  }

  /* ── Dropdown toggle ──────────────────────────────────── */
  window.dnToggle = function (groupKey, btn) {
    var allGroups   = document.querySelectorAll('.dn-group');
    var clickedGrp  = btn ? btn.closest('.dn-group') : null;

    allGroups.forEach(function (g) {
      if (g !== clickedGrp) {
        g.classList.remove('open');
        var b = g.querySelector('.dn-tab');
        if (b) b.setAttribute('aria-expanded', 'false');
      }
    });

    if (!clickedGrp) return;
    var isOpen = clickedGrp.classList.contains('open');
    if (isOpen) {
      clickedGrp.classList.remove('open');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    } else {
      clickedGrp.classList.add('open');
      if (btn) btn.setAttribute('aria-expanded', 'true');
    }
  };

  /* ── Close on click outside ───────────────────────────── */
  document.addEventListener('click', function (e) {
    var el = e.target, inside = false;
    while (el) {
      if (el.classList && el.classList.contains('dn-group')) { inside = true; break; }
      el = el.parentElement;
    }
    if (!inside) {
      document.querySelectorAll('.dn-group').forEach(function (g) {
        g.classList.remove('open');
        var b = g.querySelector('.dn-tab');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
    }
  });

  /* ── Close on Escape ──────────────────────────────────── */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.dn-group').forEach(function (g) {
        g.classList.remove('open');
        var b = g.querySelector('.dn-tab');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
    }
  });

  /* ── Global fetch interceptor — auto-refresh expired tokens */
  (function () {
    var _fetch = window.fetch.bind(window);
    var _refreshing = false;

    window.fetch = function (input, init) {
      var url = typeof input === 'string' ? input
        : (input instanceof Request ? input.url : '');
      if (url.indexOf('/api/auth/') !== -1) return _fetch(input, init);

      return _fetch(input, init).then(function (res) {
        if (res.status !== 401) return res;
        if (_refreshing) { window.location.href = '/login'; return res; }
        _refreshing = true;
        return _fetch('/api/auth/refresh', { method: 'POST' })
          .then(function (ref) {
            _refreshing = false;
            if (!ref.ok) { window.location.href = '/login'; return res; }
            return _fetch(input, init);
          })
          .catch(function () {
            _refreshing = false;
            window.location.href = '/login';
            return res;
          });
      });
    };
  })();

  /* ── Service Worker + PWA ────────────────────────────── */
  (function () {
    if (!('serviceWorker' in navigator)) return;

    /* Inject manifest link if not already present */
    if (!document.querySelector('link[rel="manifest"]')) {
      var ml = document.createElement('link');
      ml.rel  = 'manifest';
      ml.href = '/manifest.webmanifest';
      document.head.appendChild(ml);
    }

    /* Register SW */
    navigator.serviceWorker.register('/sw.js').then(function (reg) {
      /* Check for SW update on page focus */
      document.addEventListener('visibilitychange', function () {
        if (document.visibilityState === 'visible') reg.update();
      });

      /* Notify user when new SW is waiting */
      reg.addEventListener('updatefound', function () {
        var newWorker = reg.installing;
        if (!newWorker) return;
        newWorker.addEventListener('statechange', function () {
          if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
            showUpdateToast(newWorker);
          }
        });
      });
    }).catch(function (err) {
      console.warn('SW registration failed:', err);
    });

    /* Listen for sync-complete messages from SW */
    navigator.serviceWorker.addEventListener('message', function (e) {
      if (e.data && e.data.type === 'SYNC_COMPLETE' && e.data.replayed > 0) {
        showToast('✓ ' + e.data.replayed + ' offline action(s) synced', 'green');
      }
    });

    /* Online/offline indicator */
    function updateOnlineStatus() {
      var bar = document.getElementById('offlineBar');
      if (!bar) {
        bar = document.createElement('div');
        bar.id = 'offlineBar';
        bar.style.cssText = [
          'position:fixed;top:0;left:0;right:0;z-index:9999',
          'padding:.45rem 1rem;text-align:center',
          'font-size:.78rem;font-weight:700;letter-spacing:.02em',
          'transition:transform .25s ease',
        ].join(';');
        document.body.appendChild(bar);
      }
      if (navigator.onLine) {
        bar.style.background = '#10b981';
        bar.style.color      = '#fff';
        bar.textContent      = '✓ Back online';
        bar.style.transform  = 'translateY(0)';
        setTimeout(function () { bar.style.transform = 'translateY(-100%)'; }, 2500);
      } else {
        bar.style.background = '#ef4444';
        bar.style.color      = '#fff';
        bar.textContent      = '⚠ You\'re offline — some features may be unavailable';
        bar.style.transform  = 'translateY(0)';
      }
    }
    window.addEventListener('online',  updateOnlineStatus);
    window.addEventListener('offline', updateOnlineStatus);
    if (!navigator.onLine) updateOnlineStatus();
  })();

  /* ── Update toast ─────────────────────────────────────── */
  function showUpdateToast(worker) {
    var t = document.createElement('div');
    t.style.cssText = [
      'position:fixed;bottom:80px;left:50%;transform:translateX(-50%)',
      'background:#0d1a0f;border:1px solid rgba(16,185,129,.3)',
      'color:#dfeedd;border-radius:12px;padding:.75rem 1.25rem',
      'font-size:.82rem;font-weight:600;z-index:9999',
      'display:flex;align-items:center;gap:.75rem;box-shadow:0 8px 32px rgba(0,0,0,.4)',
    ].join(';');
    t.innerHTML = '<span>🔄 App updated — reload to get the latest</span>'
      + '<button onclick="this.closest(\'div\').remove()" '
      + 'style="background:#10b981;color:#fff;border:none;border-radius:6px;'
      + 'padding:.3rem .75rem;cursor:pointer;font-weight:700;font-size:.78rem">Reload</button>';
    t.querySelector('button').addEventListener('click', function () {
      worker.postMessage({ type: 'SKIP_WAITING' });
      window.location.reload();
    });
    document.body.appendChild(t);
  }

  /* ── Generic toast ────────────────────────────────────── */
  function showToast(msg, color) {
    var t = document.createElement('div');
    var bg = color === 'green' ? '#10b981' : '#3b82f6';
    t.style.cssText = [
      'position:fixed;bottom:80px;left:50%;transform:translateX(-50%)',
      'background:' + bg + ';color:#fff;border-radius:10px',
      'padding:.65rem 1.25rem;font-size:.82rem;font-weight:700',
      'z-index:9999;box-shadow:0 4px 20px rgba(0,0,0,.3)',
    ].join(';');
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(function () { t.remove(); }, 3500);
  }

  /* ── Footer injection (after DOM ready — styles injected inline to bypass Astro scoping) ── */
  document.addEventListener('DOMContentLoaded', function() {
    if (document.getElementById('dn-footer')) return;

