            '</div>',
          '</div>',

          /* Link columns */
          '<div class="dnf-cols">',
            '<div>',
              '<div class="dnf-col-title">App</div>',
              '<div class="dnf-col-links">',
                '<a href="/dashboard">Dashboard</a>',
